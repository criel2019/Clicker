// 백호 스토리 데이터 (메타데이터 자동 삽입)
// 총 10장, 4645개 노드

Story.chapters.baekho = [
  {
    title: '1장 — 귀족 저택의 하녀',
    nodes: [
      { type: 'text', speaker: '', text: '윤 씨 가문 저택의 아침은 언제나 같은 순서로 시작됐다.' },
      { type: 'text', speaker: '', text: '닭이 울기 전에 하녀들이 일어난다. 부엌에 불을 지핀다. 물을 길어 온다. 마당을 쓴다. 주인 마님 방 앞에 세숫물을 올린다. 그리고.' },
      { type: 'text', speaker: '', text: '"호."' },
      { type: 'text', speaker: '', text: '하녀 수장의 목소리가 마당을 가로질렀다.' },
      { type: 'text', speaker: '', text: '"저 불렀어요?"' },
      { type: 'text', speaker: '', text: '뒤꼍에서 소녀가 걸어 나왔다. 천천히. 서두르지 않는 걸음이었다. 눈이 반쯤 감겨 있어도 표정에는 졸음 대신 어딘가 고요한 것이 있었다.' },
      { type: 'text', speaker: '', text: '도도함.' },
      { type: 'text', speaker: '', text: '그게 첫인상이었다.' },
      { type: 'text', speaker: '', text: '아홉 살짜리 하녀가 지을 법한 표정이 아니었다. 아홉 살이건 스물아홉이건. 이 저택에서 하녀가 지을 법한 표정이 아니었다.' },
      { type: 'text', speaker: '', text: '눈을 들고 있었다.' },
      { type: 'text', speaker: '', text: '고개가 곧았다.' },
      { type: 'text', speaker: '', text: '어깨가 처지지 않았다.' },
      { type: 'text', speaker: '', text: '명령받은 자리로 걸어오는 걸음이. 명령받지 않은 자의 걸음 같았다.' },
      { type: 'text', speaker: '', text: '"어제 마님 도자기를 깨뜨렸다며."' },
      { type: 'text', speaker: '', text: '하녀 수장의 목소리는 차가웠다.' },
      { type: 'text', speaker: '', text: '하녀 수장은 이 저택에서 20년을 일한 사람이었다. 등이 굽었다. 입가에 주름이 깊었다. 눈이 깊었다. 그 눈은 하녀들을 볼 때 두 가지만 봤다. 일을 잘 하는지. 말을 잘 듣는지.' },
      { type: 'text', speaker: '', text: '호는 두 가지 중 하나만 통과했다.' },
      { type: 'text', speaker: '', text: '일을 잘 하는지. 통과. 말을 잘 듣는지. 탈락.' },
      { type: 'text', speaker: '', text: '그것이 두 해 동안 쌓인 평가였다.' },
      { type: 'text', speaker: '', text: '"예."' },
      { type: 'text', speaker: '', text: '호가 대답했다. 부정하지 않았다.' },
      { type: 'text', speaker: '백호', text: '"실수였어? 아니면 일부러?"' },
      { type: 'text', speaker: '', text: '잠시 침묵이 있었다.' },
      { type: 'text', speaker: '', text: '아주 잠깐의 침묵이었다. 생각하는 침묵이 아니었다. 말할 순서를 정하는 침묵이었다.' },
      { type: 'text', speaker: '', text: '"실수예요. 하지만 처음 균열은 제가 만든 게 아니에요."' },
      { type: 'text', speaker: '', text: '"무슨 소리야."' },
      { type: 'text', speaker: '', text: '"그 도자기, 선반에 올릴 때부터 기울어져 있었어요. 제가 말씀드렸는데 아무도 안 들으셨고요. 결국 제가 청소하다 건드렸을 때 떨어진 거예요. 원인이 하나가 아닌데 책임을 하나한테만 돌리는 건 옳지 않아요."' },
      { type: 'text', speaker: '', text: '하녀 수장의 눈이 가늘어졌다.' },
      { type: 'text', speaker: '', text: '"지금 변명하는 거야?"' },
      { type: 'text', speaker: '', text: '"이유를 말하는 거예요."' },
      { type: 'text', speaker: '', text: '저택 구석에서 지켜보던 다른 하녀들이 숨을 죽였다.' },
      { type: 'text', speaker: '', text: '이 애는 또 시작이다.' },
      { type: 'text', speaker: '', text: '그 눈빛들이 말했다.' },
      { type: 'text', speaker: '', text: '하녀는 다섯 명이었다. 열여섯과 열여덟, 스물둘, 스물다섯. 그리고 열세 살짜리 호. 나이로만 따지면 가장 어렸다. 하지만 저택 안에서 가장 조용한 존재는 아니었다. 오히려 정반대였다.' },
      { type: 'text', speaker: '', text: '부엌 아주머니가 눈을 내리깔았다. 이번에도 저 애가 혼나겠구나 싶은 얼굴이었다.' },
      { type: 'text', speaker: '', text: '호는 하녀 수장을 봤다.' },
      { type: 'text', speaker: '', text: '하녀 수장이 걸음을 옮겼다. 호 앞에 딱 섰다. 내려다봤다. 호는 고개를 들었다. 눈을 맞췄다. 내려다보는 눈과 올려다보는 눈이 마주쳤는데.' },
      { type: 'text', speaker: '', text: '기묘하게도.' },
      { type: 'text', speaker: '', text: '압도된 쪽은 내려다보는 쪽이었다.' },
      { type: 'text', speaker: '', text: '"무릎 꿇어."' },
      { type: 'text', speaker: '', text: '"꿇을 이유가 없어요."' },
      { type: 'text', speaker: '', text: '순간 마당이 얼어붙었다.' },
      { type: 'text', speaker: '', text: '"......뭐?"' },
      { type: 'text', speaker: '', text: '"제가 잘못한 게 있으면 사과할게요. 하지만 잘못하지 않은 것에 무릎 꿇는 건 다른 문제예요."' },
      { type: 'text', speaker: '', text: '하녀 수장의 손이 올라갔다.' },
      { type: 'text', speaker: '', text: '뺨을 가로질렀다.' },
      { type: 'text', speaker: '', text: '탁.' },
      { type: 'text', speaker: '', text: '소리가 났다.' },
      { type: 'text', speaker: '', text: '다른 하녀들이 짧게 숨을 들이켰다.' },
      { type: 'text', speaker: '', text: '호의 고개가 옆으로 돌아갔다. 머리카락이 흩어졌다. 작은 몸이 한 발짝 밀렸다.' },
      { type: 'text', speaker: '', text: '호의 발이 마당 돌바닥을 눌렀다. 밀리지 않았다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '천천히.' },
      { type: 'text', speaker: '', text: '고개가 돌아왔다.' },
      { type: 'text', speaker: '', text: '뺨이 붉었다. 눈에 눈물이 고였다. 넘칠 것 같았다. 그러나.' },
      { type: 'text', speaker: '', text: '흘리지 않았다.' },
      { type: 'text', speaker: '', text: '고개를 숙이지 않았다.' },
      { type: 'text', speaker: '', text: '"맞는다고 고개를 숙이면, 처음부터 고개를 숙였어야 맞는 거잖아요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '목소리가 조금 떨렸다. 뺨이 아파서인지 눈물이 차서인지. 하지만 말은 끊기지 않았다.' },
      { type: 'text', speaker: '', text: '"저는 제가 틀렸다고 생각하지 않아요."' },
      { type: 'text', speaker: '', text: '하녀 수장의 얼굴이 굳었다. 무슨 말을 더 할 수가 없었다. 이 아이한테는. 때려도, 혼내도, 명령해도. 무너지지 않았다. 그냥.' },
      { type: 'text', speaker: '', text: '서 있었다.' },
      { type: 'text', speaker: '', text: '열세 살짜리가 아니었다. 스무 해를 세운 것 같은 등이었다. 호가 서 있는 마당 돌바닥에 갈라지는 소리가 났다. 금이 하나가 아니라 셋이었다. 호의 발 아래에서 거미줄처럼 갈라져 나간 것이었다. 누구도 보지 못했다. 호도.' },
      { type: 'text', speaker: '백호', text: '"일이나 해."' },
      { type: 'text', speaker: '', text: '결국 그 말만 하고 돌아섰다.' },
      { type: 'text', speaker: '', text: '호는 그 뒷모습을 봤다. 조용히.' },
      { type: 'text', speaker: '', text: '그리고 제 뺨에 손을 가져갔다.' },
      { type: 'text', speaker: '', text: '뜨거웠다.' },
      { type: 'text', speaker: '', text: '눈물이 눈꺼풀 안쪽에 차 있었다. 한 방울만 더 차면 흘렀을 것이다. 호는 눈을 꼭 감았다가 떴다.' },
      { type: 'text', speaker: '', text: '흘리지 않았다.' },
      { type: 'text', speaker: '', text: '절대로 울지 않는다.' },
      { type: 'text', speaker: '', text: '그 규칙이 뼈처럼 박혀 있었다.' },
      { type: 'text', speaker: '', text: '——고개를 숙이면 그들이 맞는 게 된다.' },
      { type: 'text', speaker: '', text: '그 생각이 훨씬 더 깊이.' },
      { type: 'text', speaker: '', text: '뼈 안쪽에.' },
      { type: 'text', speaker: '', text: '박혀 있었다.' },
      { type: 'text', speaker: '', text: '호에게는 세 가지 규칙이 있었다.' },
      { type: 'text', speaker: '', text: '절대로 먼저 고개를 숙이지 않는다. 절대로 먼저 사과하지 않는다. 절대로 울지 않는다.' },
      { type: 'text', speaker: '', text: '이 세 가지가 생긴 건 이 저택에 들어온 직후였다.' },
      { type: 'text', speaker: '', text: '정확히는.' },
      { type: 'text', speaker: '', text: '저택에 들어온 지 사흘째 되던 날.' },
      { type: 'text', speaker: '', text: '주인 마님이 불렀다.' },
      { type: 'text', speaker: '', text: '처음으로. 호를 직접.' },
      { type: 'text', speaker: '', text: '방 안에서 마님이 앉아 있었다. 화려한 옷을 입고. 화려한 것들에 둘러싸여.' },
      { type: 'text', speaker: '', text: '"네가 호라는 아이냐."' },
      { type: 'text', speaker: '', text: '"예."' },
      { type: 'text', speaker: '', text: '"어디서 왔냐."' },
      { type: 'text', speaker: '', text: '"갈 데가 없어서 왔어요."' },
      { type: 'text', speaker: '', text: '마님의 눈이 가늘어졌다.' },
      { type: 'text', speaker: '', text: '"하녀가 갈 데가 없어서 왔다고?"' },
      { type: 'text', speaker: '', text: '"사실이에요."' },
      { type: 'text', speaker: '', text: '"......건방지구나."' },
      { type: 'text', speaker: '', text: '"사실을 말한 거예요."' },
      { type: 'text', speaker: '', text: '그것이 시작이었다.' },
      { type: 'text', speaker: '', text: '마님이 그 자리에서 하녀 수장을 불렀다. 버릇을 가르치라고 했다. 버릇이 없는 아이라고 했다.' },
      { type: 'text', speaker: '', text: '호는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '——버릇이 없는 게 아니라.' },
      { type: 'text', speaker: '', text: '내가 틀렸다고 생각하지 않는 거예요.' },
      { type: 'text', speaker: '', text: '그 말을 하고 싶었다.' },
      { type: 'text', speaker: '', text: '하지 않았다.' },
      { type: 'text', speaker: '', text: '아직.' },
      { type: 'text', speaker: '', text: '이 저택이 어떤 곳인지 다 알기 전에는.' },
      { type: 'text', speaker: '', text: '섣불리 움직이면 안 됐다.' },
      { type: 'text', speaker: '', text: '그래서 그날 밤에 결심을 했다.' },
      { type: 'text', speaker: '', text: '세 가지 규칙.' },
      { type: 'text', speaker: '', text: '그 규칙들이.' },
      { type: 'text', speaker: '', text: '이 저택에서 호를 지켰다.' },
      { type: 'text', speaker: '', text: '무릎 꿇지 않을 수 있게.' },
      { type: 'text', speaker: '', text: '울지 않을 수 있게.' },
      { type: 'text', speaker: '', text: '——그리고.' },
      { type: 'text', speaker: '', text: '두 해 동안.' },
      { type: 'text', speaker: '', text: '한 번도 꺾이지 않았다.' },
      { type: 'text', speaker: '', text: '저택에 들어온 건 두 해 전이었다. 부모가 없었다. 갈 곳이 없었다. 먹여주고 재워준다는 말에 따라왔다. 그게 전부였다.' },
      { type: 'text', speaker: '', text: '따라오고 나서 알았다.' },
      { type: 'text', speaker: '', text: '먹여주고 재워주는 대신 원하는 건 어마어마했다.' },
      { type: 'text', speaker: '', text: '몸을 낮춰라. 말을 줄여라. 눈을 내려라. 주인 앞에서는 그림자처럼 존재해라. 주인이 부르면 즉시 달려와라. 주인이 화내면 즉시 사과해라.' },
      { type: 'text', speaker: '', text: '하지만 주인이 잘못해도 주인은 잘못하지 않았다.' },
      { type: 'text', speaker: '', text: '그걸 알았을 때.' },
      { type: 'text', speaker: '', text: '호는 이상하다고 생각했다.' },
      { type: 'text', speaker: '', text: '두 번째로 알았을 때.' },
      { type: 'text', speaker: '', text: '호는 틀렸다고 생각했다.' },
      { type: 'text', speaker: '', text: '세 번째로 알았을 때.' },
      { type: 'text', speaker: '', text: '호는 결심했다.' },
      { type: 'text', speaker: '', text: '고개를 숙이지 않겠다.' },
      { type: 'text', speaker: '', text: '한 번도.' },
      { type: 'text', speaker: '', text: '그 결심이 두 해 동안 지켜졌다.' },
      { type: 'text', speaker: '', text: '덕분에 호는 저택에서 유명했다. 좋은 쪽으로는 아니었다.' },
      { type: 'text', speaker: '', text: '"그 하녀 애, 버릇이 없어."' },
      { type: 'text', speaker: '', text: '"주인 마님 눈을 똑바로 쳐다본다니까."' },
      { type: 'text', speaker: '', text: '"맞아도 안 울어. 소름 돋지 않아?"' },
      { type: 'text', speaker: '', text: '호는 그 말들을 다 들었다.' },
      { type: 'text', speaker: '', text: '다 들으면서.' },
      { type: 'text', speaker: '', text: '——자기가 뭔 줄 안다.' },
      { type: 'text', speaker: '', text: '고개를 숙이면 그들이 맞는 게 된다.' },
      { type: 'text', speaker: '', text: '그 생각이 있는 한.' },
      { type: 'text', speaker: '', text: '고개를 숙일 수 없었다.' },
      { type: 'text', speaker: '', text: '저택의 하루는 길었다.' },
      { type: 'text', speaker: '', text: '새벽부터 저녁까지. 마당을 쓸고, 물을 긷고, 빨래를 하고, 식사를 나르고. 어깨가 아팠다. 손이 텄다.' },
      { type: 'text', speaker: '', text: '하지만 그것보다.' },
      { type: 'text', speaker: '', text: '외로운 게 더 아팠다.' },
      { type: 'text', speaker: '', text: '비교할 대상이 없었다. 혼자가 아닌 것이 어떤 것인지 몰랐다. 저택 안에서 다른 하녀들과 함께 일했지만, 함께라는 느낌이 없었다.' },
      { type: 'text', speaker: '', text: '저녁이 되면 다른 하녀들이 모여 앉아 떠들었다. 처음에 호도 끼었다. 하지만 호의 말이 너무 직선이었다. 좋으면 좋다고 했다. 싫으면 싫다고 했다. 점점 불러주지 않게 됐다.' },
      { type: 'text', speaker: '', text: '매일 저녁마다 혼자 뒤꼍에 앉았다. 하늘이 보이는 곳. 담장이 가려도 담장 너머로 별이 보였다.' },
      { type: 'text', speaker: '', text: '가려도 보이는 것.' },
      { type: 'text', speaker: '', text: '막혀도 있는 것.' },
      { type: 'text', speaker: '', text: '별이 그랬다.' },
      { type: 'text', speaker: '', text: '호는 그게 좋았다.' },
      { type: 'text', speaker: '', text: '가끔 달빛이 유난히 밝은 밤이면, 손끝에 뭔가 스치는 것 같았다. 차갑고 선명한 것이. 마치 손끝에서 바늘처럼 가느다란 빛이 잠깐 번졌다가 사라지는 것 같은. 그럴 때면 뒤꼍의 돌바닥이 차가워졌다. 한여름인데도. 호가 앉아 있는 자리를 중심으로 서리가 원을 그리며 퍼졌다. 반경 세 걸음 너비. 다음 날 아침이면 사라져 있었다.' },
      { type: 'text', speaker: '', text: '——그리고 그런 밤이면, 어딘가에서 뭔가가 다가오는 감각이 있었다. 아직 먼 곳에서. 하지만 분명히.' },
      { type: 'text', speaker: '', text: '계절이 지났다. 겨울, 봄, 여름. 그리고 가을이 왔다.' },
      { type: 'text', speaker: '', text: '윤 씨 가문의 추수 잔치가 열렸다.' },
      { type: 'text', speaker: '', text: '저택 전체가 바빠졌다. 외부 손님들이 들어왔다. 악사들이 들어왔다. 음식이 넘쳤다. 웃음소리가 넘쳤다.' },
      { type: 'text', speaker: '', text: '호는 뒤꼍 우물 청소를 맡았다.' },
      { type: 'text', speaker: '', text: '잔치 소리가 담장을 넘어왔다.' },
      { type: 'text', speaker: '', text: '웃음소리.' },
      { type: 'text', speaker: '', text: '악기 소리.' },
      { type: 'text', speaker: '', text: '노래하는 소리가 섞이고, 그 위로 잔 부딪히는 소리가 났다. 화려한 소리들이었다.' },
      { type: 'text', speaker: '', text: '호는 우물 바닥을 박박 문질렀다. 그 소리들이 자신이 있는 곳에는 닿지 않는 것처럼. 닿아도 스며들지 않는 것처럼.' },
      { type: 'text', speaker: '', text: '하지만 사실은.' },
      { type: 'text', speaker: '', text: '닿았다.' },
      { type: 'text', speaker: '', text: '소리가 닿을 때마다.' },
      { type: 'text', speaker: '', text: '뭔가 이상한 것이 흔들렸다.' },
      { type: 'text', speaker: '', text: '호는 더 세게 문질렀다. 수세미가 닳아서 손바닥으로 문지르는 꼴이었는데, 돌 표면에 금이 사방으로 갈렸다. 하나가 아니라 여러 줄이, 손이 닿는 점을 중심으로 방사형으로 퍼져나갔다. 우물 벽에 붙어 있던 이끼가 손이 닿지 않은 곳까지 벗겨졌다. 벗겨진 자리에 얇은 서리가 피어올랐다. 마치 열기가 아니라 냉기가 번진 것처럼.' },
      { type: 'text', speaker: '', text: '우물 밖에서 발소리가 들렸다. 경비였다. 순찰 경로가 뒤꼍을 지나는 시간이었다. 발소리가 우물 옆에서 멈췄다. 서리가 우물 입구까지 기어올라 있었다. 경비가 우물 안을 들여다보려는 듯 그림자가 기울었다.' },
      { type: 'text', speaker: '', text: '호가 고개를 들었다. 숨을 멈췄다.' },
      { type: 'text', speaker: '', text: '그리고 서리가 녹았다. 경비가 고개를 돌리기 전에. 물기만 남았다. 경비가 중얼거렸다. "우물물이 넘쳤나." 발소리가 멀어졌다.' },
      { type: 'text', speaker: '', text: '호는 그게 뭔지 몰랐다.' },
      { type: 'text', speaker: '', text: '그때.' },
      { type: 'text', speaker: '', text: '다른 발소리가 들렸다.' },
      { type: 'text', speaker: '', text: '혼자 이쪽으로 오는 발소리.' },
      { type: 'text', speaker: '', text: '호가 고개를 들었다.' },
      { type: 'text', speaker: '', text: '악사 복장을 한 사람이 걸어오고 있었다. 악기는 들고 있지 않았다. 빈손이었다. 뭔가를 찾는 눈이었다.' },
      { type: 'text', speaker: '', text: '그 눈이 뭔가를 찾다가.' },
      { type: 'text', speaker: '', text: '호에게 멈췄다.' },
      { type: 'text', speaker: '', text: '호는 그 눈을 봤다.' },
      { type: 'text', speaker: '', text: '모르는 사람인데.' },
      { type: 'text', speaker: '', text: '처음 보는 눈인데.' },
      { type: 'text', speaker: '', text: '낯선 느낌이 없었다.' },
      { type: 'text', speaker: '', text: '그 사람 뒤로, 아주 조그마한 아이가 따라왔다. 어린아이였다. 보통 아이들처럼 호기심에 두리번거리지 않았다. 눈이 조용했다. 그 아이의 눈이 먼저 호를 봤다.' },
      { type: 'text', speaker: '', text: '따뜻한 눈이었다.' },
      { type: 'text', speaker: '', text: '왜인지 눈을 못 떼게 만드는 눈.' },
      { type: 'text', speaker: '', text: '단순히 따뜻한 게 아니었다. 오래 알고 있는 것 같은 눈이었다. 처음 보는데 처음이 아닌 것 같은.' },
      { type: 'text', speaker: '', text: '"이름이 뭐예요?"' },
      { type: 'text', speaker: '', text: '악사 복장의 사람이 물었다.' },
      { type: 'text', speaker: '', text: '호는 우물 바닥 닦는 걸 멈추지 않았다.' },
      { type: 'text', speaker: '', text: '"왜요."' },
      { type: 'text', speaker: '', text: '"알고 싶어서요."' },
      { type: 'text', speaker: '', text: '"이유가 약해요."' },
      { type: 'text', speaker: '', text: '그 사람이 잠시 생각하는 것 같았다.' },
      { type: 'text', speaker: '', text: '"당신을 찾고 있었어요."' },
      { type: 'text', speaker: '', text: '호가 고개를 들었다.' },
      { type: 'text', speaker: '백호', text: '"저를요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"당신이 여기 있으면 안 될 것 같아서요."' },
      { type: 'text', speaker: '', text: '호는 그 사람을 위아래로 봤다. 천천히.' },
      { type: 'text', speaker: '', text: '악사 복장. 손에 흙이 없다. 악사치고 손이 너무 깨끗하다. 거짓말을 하는 사람의 눈이 아니다.' },
      { type: 'text', speaker: '', text: '하지만 전부 말하는 눈도 아니다.' },
      { type: 'text', speaker: '', text: '뭔가 알고 있는데 다 말하지 않는다.' },
      { type: 'text', speaker: '', text: '그리고 뒤에 따라오는 작은 아이. 그 아이가 저렇게 편하게 따라오는 한, 이 사람은 위험하지 않다.' },
      { type: 'text', speaker: '', text: '"......호예요."' },
      { type: 'text', speaker: '', text: '"나랑 같이 나갈 생각 있어요?"' },
      { type: 'text', speaker: '', text: '"있어요."' },
      { type: 'text', speaker: '', text: '빠른 대답이었다.' },
      { type: 'text', speaker: '', text: '그 사람이 놀란 것 같았다.' },
      { type: 'text', speaker: '', text: '"......바로요?"' },
      { type: 'text', speaker: '', text: '"당신이 올 줄 알고 있었어요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '혼자 뒤꼍에 앉아 별을 보며 기다리던 것들이. 그 기다림이 이 사람인지는 몰랐지만.' },
      { type: 'text', speaker: '', text: '뭔가가 온다는 감각은.' },
      { type: 'text', speaker: '', text: '틀리지 않았다.' },
      { type: 'text', speaker: '', text: '"오래전부터요."' },
      { type: 'text', speaker: '', text: '그 사람이 호를 봤다.' },
      { type: 'text', speaker: '', text: '작은 아이가 우물 옆으로 걸어왔다. 호 옆에 섰다. 그 작은 몸에서 뭔가 따뜻한 것이 났다. 온도가 있는 것이.' },
      { type: 'text', speaker: '', text: '호는 그 아이를 봤다.' },
      { type: 'text', speaker: '', text: '"이 아이는 누구예요?"' },
      { type: 'text', speaker: '', text: '"같이 다니는 아이예요."' },
      { type: 'text', speaker: '', text: '"가족이에요?"' },
      { type: 'text', speaker: '', text: '"그런 것 같기도 해요."' },
      { type: 'text', speaker: '', text: '"확실하지 않아요?"' },
      { type: 'text', speaker: '', text: '"어려운 관계예요."' },
      { type: 'text', speaker: '', text: '호는 그 대답을 한참 생각했다.' },
      { type: 'text', speaker: '', text: '그리고 결론을 냈다.' },
      { type: 'text', speaker: '', text: '이 사람은 이상하다.' },
      { type: 'text', speaker: '', text: '하지만 이상한 게.' },
      { type: 'text', speaker: '', text: '지금 당장은 나쁘지 않다.' },
      { type: 'text', speaker: '', text: '위험한 냄새가 나지 않는다.' },
      { type: 'text', speaker: '', text: '거짓말하는 냄새도 나지 않는다.' },
      { type: 'text', speaker: '', text: '"언제 나가요?"' },
      { type: 'text', speaker: '', text: '"오늘이요."' },
      { type: 'text', speaker: '', text: '"방법은요?"' },
      { type: 'text', speaker: '', text: '"악사들이 퇴장할 때 같이요."' },
      { type: 'text', speaker: '', text: '호가 손에 묻은 우물 때를 닦았다.' },
      { type: 'text', speaker: '백호', text: '"알겠어요."' },
      { type: 'text', speaker: '', text: '잔치 소리가 줄어들기 시작했다.' },
      { type: 'text', speaker: '', text: '손님들이 빠져나가기 시작한다는 신호였다.' },
      { type: 'text', speaker: '', text: '악사들도 곧 나가겠구나.' },
      { type: 'text', speaker: '', text: '호가 일어섰다.' },
      { type: 'text', speaker: '', text: '준비.' },
      { type: 'text', speaker: '', text: '특별히 챙길 게 없었다.' },
      { type: 'text', speaker: '', text: '한 가지만.' },
      { type: 'text', speaker: '', text: '호가 잠깐 뒤를 돌아봤다.' },
      { type: 'text', speaker: '', text: '부엌 창문으로 불빛이 새어 나왔다. 아주머니가 아직 일하고 있었다. 뒷모습이 보였다. 굽은 등.' },
      { type: 'text', speaker: '', text: '그 사람은 호한테 일부러 더 먹을 것을 챙겨준 적이 있었다. 말없이. 그냥 두고 갔다. 왜 그랬는지 물어본 적이 없었다.' },
      { type: 'text', speaker: '', text: '지금 물어볼 수가 없었다.' },
      { type: 'text', speaker: '', text: '호가 돌아섰다.' },
      { type: 'text', speaker: '', text: '나는 그 시간 동안 뒤꼍 담장 밖에서 대기하고 있었다.' },
      { type: 'text', speaker: '', text: '잠입은 며칠 전에 마쳤다.' },
      { type: 'text', speaker: '', text: '악사 패거리에 들어온 건 사흘 전이었다. 잔치 연주에 필요한 악사를 뽑는다는 말을 들었고, 거문고를 조금 안다고 했다. 조금은 사실이었다. 조금 더 안다는 건 거짓말이었다.' },
      { type: 'text', speaker: '', text: '하지만 들어가야 했다.' },
      { type: 'text', speaker: '', text: '시스템 창이 뜨면서 이 저택이라고 했다. 백호가 여기 있다고 했다. 찾아서 데리고 나와야 한다고 했다.' },
      { type: 'effect', effect: 'system', text: '【 신수 탐지 — 지정 위치에 미각성 신수(白虎)의 흔적이 감지되었습니다. 】' },
      { type: 'effect', effect: 'system', text: '【 잠재 기운 농도: 미약. 그러나 감정 격동 시 환경 반응이 관측됨. 주의 요망. 】' },
      { type: 'effect', effect: 'system', text: '【 참고: 본능적 공명 — 신수와 클리커 간의 인력이 작용할 수 있습니다. 상호 \'기다림\'의 감각은 체계의 일부입니다. 】' },
      { type: 'text', speaker: '', text: '들어오고 나서 첫날.' },
      { type: 'text', speaker: '', text: '저택 안을 훑었다.' },
      { type: 'text', speaker: '', text: '하녀가 다섯이었다. 부엌 아주머니 둘. 경비 셋. 마님. 그리고.' },
      { type: 'text', speaker: '', text: '뒤꼍.' },
      { type: 'text', speaker: '', text: '혼자 앉아 별을 보는 아이.' },
      { type: 'text', speaker: '', text: '그 아이가 눈에 들어왔다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에서 그쪽을 봤다.' },
      { type: 'text', speaker: '', text: '왜소한 신——시스템이 그렇게 표기한 존재였다. 이름도 정체도 알 수 없지만, 내 곁에 있는 작은 아이. 말을 하지 않고, 먹지도 자지도 않는 것 같은데, 옆에 있으면 편했다.' },
      { type: 'text', speaker: '', text: '그 작은 눈이 호를 봤다.' },
      { type: 'text', speaker: '', text: '그리고 내 발치로 와서 앉았다.' },
      { type: 'text', speaker: '', text: '다른 하녀들과 달리 고개가 곧았다. 어깨가 처지지 않았다. 하늘을 보는 눈이 달랐다.' },
      { type: 'text', speaker: '', text: '담장 안에 갇힌 눈이 아니었다.' },
      { type: 'text', speaker: '', text: '담장 너머를 아는 눈이었다.' },
      { type: 'text', speaker: '', text: '——이 아이는.' },
      { type: 'text', speaker: '', text: '저택에 있을 사람이 아니다.' },
      { type: 'text', speaker: '', text: '첫 느낌이었다.' },
      { type: 'text', speaker: '', text: '그날 밤부터 기다렸다.' },
      { type: 'text', speaker: '', text: '잔치 마지막 날.' },
      { type: 'text', speaker: '', text: '악사들이 나가는 날.' },
      { type: 'text', speaker: '', text: '그 날을 기다렸다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 매일 저택 담장 근처에 있었다. 경비들의 순찰 시간과 경로를 살피는 것처럼 보였다. 내가 없을 때도 거기 있었다.' },
      { type: 'text', speaker: '', text: '지금 당장은 다른 게 급했다.' },
      { type: 'text', speaker: '', text: '잔치가 시작됐다.' },
      { type: 'text', speaker: '', text: '나는 악사들과 함께 들어갔다.' },
      { type: 'text', speaker: '', text: '연주가 시작됐다.' },
      { type: 'text', speaker: '', text: '나는 거문고 옆에 앉아서 다른 사람들이 연주하는 걸 봤다.' },
      { type: 'text', speaker: '', text: '틀릴 수도 없고.' },
      { type: 'text', speaker: '', text: '잘 할 수도 없는.' },
      { type: 'text', speaker: '', text: '애매한 연주였다.' },
      { type: 'text', speaker: '', text: '하지만 아무도 눈치채지 않았다. 악사가 여덟이나 되는데 거문고는 둘이었고, 반주는 북과 장구가 주도했다. 거문고 소리가 묻혔다.' },
      { type: 'text', speaker: '', text: '잔치 소리가 크고 화려했다.' },
      { type: 'text', speaker: '', text: '중간에 잠깐 빠져나왔다.' },
      { type: 'text', speaker: '', text: '뒤꼍으로 갔다.' },
      { type: 'text', speaker: '', text: '거기서 호를 찾았다.' },
      { type: 'text', speaker: '', text: '우물 옆에서 텃밭을 손질하는 아이.' },
      { type: 'text', speaker: '', text: '나는 지금도 그 장면이 기억에 있다.' },
      { type: 'text', speaker: '', text: '처음 본 호.' },
      { type: 'text', speaker: '', text: '우물 옆에서 땅을 파는 아이.' },
      { type: 'text', speaker: '', text: '새벽부터 일했을 텐데.' },
      { type: 'text', speaker: '', text: '지쳐 있었다.' },
      { type: 'text', speaker: '', text: '하지만 티가 나지 않았다.' },
      { type: 'text', speaker: '', text: '표정이 고요했다.' },
      { type: 'text', speaker: '', text: '내가 다가갈 때.' },
      { type: 'text', speaker: '', text: '고개를 들었다.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '처음 보는 눈인데.' },
      { type: 'text', speaker: '', text: '처음 본 것 같지 않았다.' },
      { type: 'text', speaker: '', text: '기다린 것 같은 눈이었다.' },
      { type: 'text', speaker: '', text: '내가 이 아이를 찾아온 건데.' },
      { type: 'text', speaker: '', text: '이 아이도 나를 기다렸다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에서 그 눈을 봤다.' },
      { type: 'text', speaker: '', text: '그 작은 아이가 호를 올려다보다가.' },
      { type: 'text', speaker: '', text: '슬며시 내 발치에 앉았다.' },
      { type: 'text', speaker: '', text: '——이 아이가 기다렸다면, 나도 기다린 것이었다. 시스템이 보내서 온 건데. 시스템이 아니었어도 왔을 것 같다는 생각이 스쳤다. 그 생각이 이상했다. 하지만 지우지 않았다.' },
    ]
  },
  {
    title: '2장 — 잠입과 탈출',
    nodes: [
      { type: 'text', speaker: '', text: '계획은 단순했다.' },
      { type: 'text', speaker: '', text: '악사들이 퇴장할 때 함께 나간다. 짐 상자가 여럿이니 그 안에 호를 숨기면 된다.' },
      { type: 'text', speaker: '', text: '단순한 만큼 빈틈도 있었다.' },
      { type: 'text', speaker: '', text: '경비가 짐 상자를 하나하나 열어볼 수도 있었다.' },
      { type: 'text', speaker: '', text: '나는 잔치가 끝나가는 걸 보면서 뒤꼍으로 갔다.' },
      { type: 'text', speaker: '', text: '호가 거기 있었다.' },
      { type: 'text', speaker: '', text: '이미 일을 끝낸 얼굴이었다. 떠날 준비가 된 표정. 아니, 준비가 됐다기보다. 마음이 이미 나간 것 같은 표정이었다. 몸만 아직 저택 안에 있는.' },
      { type: 'text', speaker: '', text: '"됐어요?"' },
      { type: 'text', speaker: '', text: '내가 물었다.' },
      { type: 'text', speaker: '', text: '"아까부터요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '나는 악기 상자를 들었다. 크고 긴 거문고 상자였다. 미리 비워두었다. 호가 들어가기에 넉넉하지는 않지만 불가능하지는 않은.' },
      { type: 'text', speaker: '백호', text: '"들어가요."' },
      { type: 'text', speaker: '', text: '"지금이요?"' },
      { type: 'text', speaker: '', text: '"잔치가 끝나기 전에 자리 잡아야 돼요."' },
      { type: 'text', speaker: '', text: '호가 상자를 봤다.' },
      { type: 'text', speaker: '', text: '위에서 아래로.' },
      { type: 'text', speaker: '', text: '좁은 상자를.' },
      { type: 'text', speaker: '', text: '"......좁네요."' },
      { type: 'text', speaker: '', text: '"조금이요."' },
      { type: 'text', speaker: '', text: '"많이요."' },
      { type: 'text', speaker: '', text: '"......많이요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"설계를 잘못했네요."' },
      { type: 'text', speaker: '', text: '"더 큰 상자가 없었어요."' },
      { type: 'text', speaker: '', text: '"그게 핑계예요?"' },
      { type: 'text', speaker: '', text: '나는 잠시 숨을 들이쉬었다.' },
      { type: 'text', speaker: '', text: '"빨리요. 시간이 없어요."' },
      { type: 'text', speaker: '', text: '호가 상자를 한 번 더 봤다. 입술을 꽉 다물었다. 그리고.' },
      { type: 'text', speaker: '', text: '들어갔다.' },
      { type: 'text', speaker: '', text: '작은 몸이 상자 안으로 들어가 웅크렸다. 무릎이 가슴 앞으로 왔다. 팔이 끼어 어정쩡한 자세가 됐다. 뭔가 불편한 자세가 분명한데.' },
      { type: 'text', speaker: '', text: '"됐어요?"' },
      { type: 'text', speaker: '', text: '내가 물었다.' },
      { type: 'text', speaker: '', text: '"됐어요."' },
      { type: 'text', speaker: '', text: '"불편해요?"' },
      { type: 'text', speaker: '', text: '"......아니요."' },
      { type: 'text', speaker: '', text: '"아니요가 아닌 것 같은데요."' },
      { type: 'text', speaker: '', text: '"됐다고요."' },
      { type: 'text', speaker: '', text: '나는 더 묻지 않고 뚜껑을 닫았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에서 상자를 봤다. 그 작은 눈에 뭔가 걱정 같은 것이 있었다.' },
      { type: 'text', speaker: '', text: '괜찮을 거야.' },
      { type: 'text', speaker: '', text: '나는 그 눈에 대고 속으로 말했다.' },
      { type: 'text', speaker: '', text: '잔치가 끝났다.' },
      { type: 'text', speaker: '', text: '악사 패거리가 짐을 싸기 시작했다. 나도 상자를 들었다. 가볍지 않았다. 호가 안에 있었으니까.' },
      { type: 'text', speaker: '', text: '하지만 티를 내지 않았다.' },
      { type: 'text', speaker: '', text: '저택 중문을 지나갔다.' },
      { type: 'text', speaker: '', text: '경비 둘이 서 있었다.' },
      { type: 'text', speaker: '', text: '"어이, 거기."' },
      { type: 'text', speaker: '', text: '한 명이 불렀다.' },
      { type: 'text', speaker: '', text: '나는 멈췄다.' },
      { type: 'text', speaker: '', text: '심장이 빠르게 뛰었다.' },
      { type: 'text', speaker: '', text: '"상자 열어봐."' },
      { type: 'text', speaker: '', text: '——열어보네.' },
      { type: 'text', speaker: '', text: '"아, 이거요? 거문고 상자예요. 악기가 있어서 충격을 주면 안 됩니다——"' },
      { type: 'text', speaker: '', text: '"열어봐."' },
      { type: 'text', speaker: '', text: '두 번 말하는 경비였다.' },
      { type: 'text', speaker: '', text: '나는 상자를 내려놓았다. 뚜껑 잠금쇠에 손을 올렸다.' },
      { type: 'text', speaker: '', text: '천천히.' },
      { type: 'text', speaker: '', text: '아주 천천히.' },
      { type: 'text', speaker: '', text: '상자 안에서 기척이 없었다. 호의 숨소리조차 들리지 않았다. 그 나이에 이 정도 인내가 가능한 건지. 아니면 애초에 저택이 그걸 가르친 건지.' },
      { type: 'text', speaker: '', text: '경비가 손을 뻗었다. 뚜껑이 손가락 하나 너비만큼 올라갔다. 틈 사이로 어둠이 보였다. 그 어둠 안에 호가 있었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 움직였다. 언제 경비 쪽으로 갔는지, 그 작은 아이가 경비 뒤에 있었다. 뒤쪽 담장에서 뭔가가 떨어지는 소리가 났다. 경비의 손이 뚜껑에서 떨어졌다.' },
      { type: 'text', speaker: '', text: '다른 경비가 말했다.' },
      { type: 'text', speaker: '', text: '"야, 됐어. 악기 상자야. 빨리 내보내. 마님이 인원 점검하라고 하셨어."' },
      { type: 'text', speaker: '', text: '"규정이——"' },
      { type: 'text', speaker: '', text: '"하녀 숫자 맞추는 게 먼저야. 잔치 뒷정리 끝나기 전에 인원 확인 안 하면 마님한테 혼나. 악기 다 내보내다가 밤 새. 됐어."' },
      { type: 'text', speaker: '', text: '짧은 침묵.' },
      { type: 'text', speaker: '', text: '경비가 서로를 봤다.' },
      { type: 'text', speaker: '', text: '"......가."' },
      { type: 'text', speaker: '', text: '경비가 손을 저었다.' },
      { type: 'text', speaker: '', text: '나는 상자를 들었다.' },
      { type: 'text', speaker: '', text: '천천히.' },
      { type: 'text', speaker: '', text: '저택 정문을 지나갔다.' },
      { type: 'text', speaker: '', text: '한 걸음.' },
      { type: 'text', speaker: '', text: '두 걸음.' },
      { type: 'text', speaker: '', text: '세 걸음.' },
      { type: 'text', speaker: '', text: '문 밖으로 나왔다.' },
      { type: 'text', speaker: '', text: '거리로 나왔다.' },
      { type: 'text', speaker: '', text: '악사 패거리가 뿔뿔이 흩어졌다. 나는 골목으로 빠졌다. 뒤를 봤다. 아무도 따라오지 않았다.' },
      { type: 'text', speaker: '', text: '나는 상자 뚜껑을 열었다.' },
      { type: 'text', speaker: '', text: '호가 나왔다.' },
      { type: 'text', speaker: '', text: '좁은 상자 안에 웅크렸던 탓에 다리를 펴는 데 잠깐 걸렸다. 팔을 쭉 뻗었다. 목을 좌우로 틀었다. 무릎을 폈다. 상자 바닥에 서리가 짙게 내려앉아 있었다. 호가 웅크리고 있던 자리를 본뜬 것처럼, 사람 형태로 서리가 남아 있었다. 밤공기 탓이라고 생각했다. 하지만 골목 바닥에는 서리가 없었다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '"정직하게 나갔으면 더 좋았을 텐데요."' },
      { type: 'text', speaker: '', text: '첫 마디가 그거였다.' },
      { type: 'text', speaker: '', text: '나는 잠시 멍했다.' },
      { type: 'text', speaker: '', text: '"......들켰을 거예요."' },
      { type: 'text', speaker: '', text: '"어떻게 알아요."' },
      { type: 'text', speaker: '', text: '"경비가 많았잖아요."' },
      { type: 'text', speaker: '', text: '"저는 경비를 설득할 수 있었을 거예요."' },
      { type: 'text', speaker: '', text: '"설득이요?"' },
      { type: 'text', speaker: '', text: '"설득이 안 되면 뚫고요."' },
      { type: 'text', speaker: '', text: '나는 그 말이 우스웠다. 웃음이 올라오려 했다. 억지로 눌렀다.' },
      { type: 'text', speaker: '', text: '"열세 살짜리가요?"' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '', text: '눈이 서늘했다.' },
      { type: 'text', speaker: '', text: '"나이는 관계없어요."' },
      { type: 'text', speaker: '', text: '"그렇긴 한데."' },
      { type: 'text', speaker: '', text: '"웃지 말아요."' },
      { type: 'text', speaker: '', text: '"안 웃었어요."' },
      { type: 'text', speaker: '', text: '"웃으려 했잖아요."' },
      { type: 'text', speaker: '', text: '나는 숨을 눌렀다.' },
      { type: 'text', speaker: '', text: '"......조금이요."' },
      { type: 'text', speaker: '', text: '"그 조금이 문제예요."' },
      { type: 'text', speaker: '', text: '호가 고개를 돌렸다. 저택 쪽을 봤다. 담장이 보였다. 저 안에서 두 해를 보낸 곳.' },
      { type: 'text', speaker: '', text: '어떤 표정을 지어야 할지 모르는 얼굴이었다.' },
      { type: 'text', speaker: '', text: '오래 봤다.' },
      { type: 'text', speaker: '', text: '담장 안에서 잔치 뒷정리 소리가 들렸다. 그릇 부딪히는 소리. 누군가 소리치는 소리. 발소리들.' },
      { type: 'text', speaker: '', text: '그 소리들 사이로 하녀 수장의 목소리가 들렸다. "호? 호가 어디 갔어!"' },
      { type: 'text', speaker: '', text: '호가 돌아섰다.' },
      { type: 'text', speaker: '백호', text: '"가요."' },
      { type: 'text', speaker: '', text: '그게 전부였다.' },
      { type: 'text', speaker: '', text: '미련 같은 게 없어 보였다. 하지만 미련이 없어서가 아니라, 있어도 돌아보지 않는 사람 같았다.' },
      { type: 'text', speaker: '', text: '나는 사실.' },
      { type: 'text', speaker: '', text: '저택 담장 앞에 서서.' },
      { type: 'text', speaker: '', text: '호가 뒤를 돌아보기를 기다렸다.' },
      { type: 'text', speaker: '', text: '기다렸다는 게.' },
      { type: 'text', speaker: '', text: '이상한 일이었다.' },
      { type: 'text', speaker: '', text: '그 아이한테 저택은 두 해를 보낸 곳이었다. 좋은 두 해는 아니었다. 맞았고, 혼났고, 무시당했고, 혼자였다. 그 어떤 것도 그리울 이유가 없는 두 해.' },
      { type: 'text', speaker: '', text: '그런데도.' },
      { type: 'text', speaker: '', text: '뒤를 돌아볼지 궁금했다.' },
      { type: 'text', speaker: '', text: '호는 뒤를 돌아봤다.' },
      { type: 'text', speaker: '', text: '아까 첫 번째 돌아봤을 때는 담장이었다. 이번엔 달랐다.' },
      { type: 'text', speaker: '', text: '아무것도 없는 쪽을 봤다.' },
      { type: 'text', speaker: '', text: '골목.' },
      { type: 'text', speaker: '', text: '어두운 돌길.' },
      { type: 'text', speaker: '', text: '저택 문의 횃불 그림자.' },
      { type: 'text', speaker: '', text: '그 아무것도 없는 걸.' },
      { type: 'text', speaker: '', text: '잠깐.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '봤다.' },
      { type: 'text', speaker: '', text: '뭘 보는 건지 나는 몰랐다.' },
      { type: 'text', speaker: '', text: '호가 고개를 돌렸다.' },
      { type: 'text', speaker: '', text: '그리고 걸었다.' },
      { type: 'text', speaker: '', text: '뒤돌아보지 않았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 우리 옆으로 왔다.' },
      { type: 'text', speaker: '', text: '그 아이가 내 발치에 슬쩍 앉더니.' },
      { type: 'text', speaker: '', text: '호를 봤다가.' },
      { type: 'text', speaker: '', text: '나를 봤다가.' },
      { type: 'text', speaker: '', text: '그러다가 내 발 옆으로 더 바짝 붙었다.' },
      { type: 'text', speaker: '', text: '호가 그 아이를 봤다.' },
      { type: 'text', speaker: '백호', text: '"저택 안에는 없었잖아요, 이 아이."' },
      { type: 'text', speaker: '', text: '"밖에서 기다렸어요."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 봤다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '"......아까부터 이 아이가 저를 보는 것 같았어요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"저택 안에서요. 가끔 창문 너머로 이 아이가 보였어요."' },
      { type: 'text', speaker: '', text: '"그랬어요?"' },
      { type: 'text', speaker: '', text: '"작은 아이가 가끔 창문 너머로 보였어요. 처음엔 착각인 줄 알았는데."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 봤다.' },
      { type: 'text', speaker: '백호', text: '"이 아이인 것 같아요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '그리고 내 쪽을 봤다.' },
      { type: 'text', speaker: '', text: '그리고 다시 호를 봤다.' },
      { type: 'text', speaker: '', text: '"왜 저를 봐요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 대답하지 않았다.' },
      { type: 'text', speaker: '', text: '"말 못 해요?"' },
      { type: 'text', speaker: '', text: '침묵.' },
      { type: 'text', speaker: '', text: '"하기 싫어요?"' },
      { type: 'text', speaker: '', text: '왜소한 신이 고개를 살짝 기울였다.' },
      { type: 'text', speaker: '', text: '그러더니 내 발치로 왔다.' },
      { type: 'text', speaker: '', text: '내 옆에 앉았다.' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"......이 아이, 재밌네요."' },
      { type: 'text', speaker: '', text: '"재밌어요?"' },
      { type: 'text', speaker: '', text: '"모를 때가 더 재밌잖아요."' },
      { type: 'text', speaker: '', text: '도시 밖으로 나왔을 때 날이 완전히 어두워졌다.' },
      { type: 'text', speaker: '', text: '별이 많았다.' },
      { type: 'text', speaker: '', text: '나는 모닥불을 피웠다. 왜소한 신이 어디선가 마른 잎을 더 가져왔다. 작은 손에 잎이 한가득 쌓여 있었다.' },
      { type: 'text', speaker: '', text: '불이 붙었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에 앉았다. 아주 바짝.' },
      { type: 'text', speaker: '', text: '어깨에 올라오려다가 내 눈이 마주치자 멈췄다.' },
      { type: 'text', speaker: '', text: '그냥 발치에 앉았다.' },
      { type: 'text', speaker: '', text: '호가 불 앞에 앉았다.' },
      { type: 'text', speaker: '', text: '무릎을 세우고 팔로 감쌌다. 하녀 옷이 낡아 있었다. 저택에서 내내 입던 옷. 탈출할 때 갈아입을 여유도 없었다.' },
      { type: 'text', speaker: '', text: '창피한 기색이 없는 건 아니었다. 그래도 그대로 입고 있었다.' },
      { type: 'text', speaker: '', text: '그때 풀숲 너머에서 소리가 났다.' },
      { type: 'text', speaker: '', text: '낮은 울음. 짐승이었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 먼저 고개를 돌렸다. 불빛 밖으로 두 개의 눈이 빛났다. 늑대였다. 마른 몸에 갈비뼈가 드러나 있었다. 굶주린 눈이었다.' },
      { type: 'text', speaker: '', text: '호가 일어섰다.' },
      { type: 'text', speaker: '', text: '빠르게. 자연스럽게. 불 앞에 앉아 있던 몸이 소리 쪽으로 반 박자 만에 돌았다.' },
      { type: 'effect', effect: 'system', text: '【 위협 감지. 야생 포식자 접근. 미각성 신수의 본능 반응 관측 중. 】' },
      { type: 'text', speaker: '', text: '늑대가 이빨을 드러냈다. 호가 한 발짝 앞으로 나갔다. 모닥불의 나뭇가지 하나를 집어 들었다. 끝에 불이 붙어 있었다.' },
      { type: 'text', speaker: '', text: '호의 발 아래 풀이 하얗게 변했다. 서리였다. 반경 한 걸음. 늑대의 콧김이 하얗게 피어올랐다. 차가운 것이 호에게서 번진 것이었다.' },
      { type: 'text', speaker: '', text: '늑대가 멈췄다. 뒷걸음질쳤다. 이빨을 세운 채 으르렁거리다가, 몸을 돌려 어둠 속으로 사라졌다.' },
      { type: 'text', speaker: '', text: '호가 나뭇가지를 불에 돌려놓았다.' },
      { type: 'text', speaker: '백호', text: '"겁먹었어요?"' },
      { type: 'text', speaker: '', text: '내가 물었다.' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '호의 목소리가 평소와 같았다. 하지만 손끝이 미세하게 떨렸다. 긴장이 풀리는 떨림이었다.' },
      { type: 'text', speaker: '백호', text: '"잘했어요."' },
      { type: 'text', speaker: '', text: '"......뭘요."' },
      { type: 'text', speaker: '', text: '호가 다시 앉았다.' },
      { type: 'text', speaker: '백호', text: '"시스템 창이에요?"' },
      { type: 'text', speaker: '', text: '호가 물었다.' },
      { type: 'text', speaker: '', text: '내가 시스템 창을 보다가 눈이 잠깐 딴 데 갔던 모양이었다.' },
      { type: 'text', speaker: '', text: '"어떻게 알았어요?"' },
      { type: 'text', speaker: '', text: '"눈이 잠깐 다른 데 있었어요."' },
      { type: 'text', speaker: '', text: '"예리하네요."' },
      { type: 'text', speaker: '', text: '"뭐라고 떠요?"' },
      { type: 'text', speaker: '', text: '나는 잠깐 고민했다.' },
      { type: 'effect', effect: 'system', text: '【 신수 탐지 시스템 — 백호(白虎) 식별 완료 】' },
      { type: 'effect', effect: 'system', text: '【 현재 상태: 미각성. 호감도 0단계. 성장 단계: 1성 】' },
      { type: 'effect', effect: 'system', text: '【 잠재 기운: 측정 불가(미각성). 추정 잠재치: 상위 0.1% 이상. 】' },
      { type: 'effect', effect: 'system', text: '【 훈련으로 각성을 유도할 것. 】' },
      { type: 'text', speaker: '', text: '1성. 아직 아무것도 깨어나지 않은 상태. 하지만 시스템이 이 아이를 찍었다는 건, 깨어날 수 있다는 뜻이었다. 그리고 잠재치 상위 0.1%. 그 수치가 선명했다.' },
      { type: 'text', speaker: '', text: '"당신에 대한 정보요."' },
      { type: 'text', speaker: '', text: '"저를 뭘 알아요, 그게."' },
      { type: 'text', speaker: '', text: '"이름. 상태. 성장 가능성."' },
      { type: 'text', speaker: '', text: '"저를 키우겠다는 거예요?"' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '표정이 달라지지 않았다. 화난 것도 아니었다. 그냥 확인하는 것 같았다.' },
      { type: 'text', speaker: '', text: '"같이 강해지는 거예요."' },
      { type: 'text', speaker: '', text: '"강해지면요?"' },
      { type: 'text', speaker: '', text: '"그때 가서 알아요."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"또 그 말이에요."' },
      { type: 'text', speaker: '', text: '"당신은 아는 게 없는 거예요?"' },
      { type: 'text', speaker: '', text: '나는 솔직하게 말했다.' },
      { type: 'text', speaker: '', text: '"많지 않아요."' },
      { type: 'text', speaker: '', text: '"그러면 왜 나를 데리러 온 거예요."' },
      { type: 'text', speaker: '', text: '"시스템이 시켜서요. 하지만."' },
      { type: 'text', speaker: '', text: '"하지만?"' },
      { type: 'text', speaker: '', text: '"와서 보니까, 가져와야 할 것 같았어요."' },
      { type: 'text', speaker: '', text: '"그게 무슨 뜻이에요."' },
      { type: 'text', speaker: '', text: '"당신이 여기 있으면 안 된다는 느낌이요. 직관이요."' },
      { type: 'text', speaker: '', text: '호가 불을 보면서 잠시 있었다.' },
      { type: 'text', speaker: '백호', text: '"직관을 믿어요?"' },
      { type: 'text', speaker: '', text: '"지금 이 상황에서요. 네."' },
      { type: 'text', speaker: '', text: '"......저도요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"당신이 올 거라는 직관이요. 오래전부터 있었어요. 뭔가가 올 거라는 감각. 그게 당신인지는 몰랐지만."' },
      { type: 'text', speaker: '', text: '왜소한 신이 불 옆에 앉았다. 그 아이의 눈이 호를 봤다.' },
      { type: 'text', speaker: '', text: '따뜻한 눈이었다.' },
      { type: 'text', speaker: '', text: '호가 그 눈을 보다가.' },
      { type: 'text', speaker: '백호', text: '"이 아이는요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"당신보다 뭔가 더 아는 것 같아요."' },
      { type: 'text', speaker: '', text: '나는 왜소한 신을 봤다.' },
      { type: 'text', speaker: '', text: '그 아이가 무표정했다.' },
      { type: 'text', speaker: '', text: '"그럴 수도 있어요."' },
      { type: 'text', speaker: '', text: '"이상한 사람들이랑 여행하게 됐네요."' },
      { type: 'text', speaker: '', text: '호가 중얼거렸다.' },
      { type: 'text', speaker: '백호', text: '"불편하면 말해요."' },
      { type: 'text', speaker: '', text: '"불편한 사람은 저희 셋 중에 하나도 없어요."' },
      { type: 'text', speaker: '', text: '"어떻게 알아요?"' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신은 이상해서 불편함을 못 느끼는 것 같고. 저 아이는 뭔지 모르겠고. 저는요."' },
      { type: 'text', speaker: '', text: '호가 잠깐 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"저는 지금 불편한 것보다 이상한 게 더 많아요."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"이상한 게 나쁜 건 아니잖아요. 저택은 평범했는데. 평범하다고 좋은 게 아니었으니까요."' },
      { type: 'text', speaker: '', text: '호가 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '별이 많은 하늘.' },
      { type: 'text', speaker: '', text: '담장이 없는 하늘.' },
      { type: 'text', speaker: '', text: '"......하늘이 넓네요."' },
      { type: 'text', speaker: '', text: '작게 말했다.' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '대답이 필요 없는 말이었다.' },
      { type: 'text', speaker: '', text: '셋이서.' },
      { type: 'text', speaker: '', text: '담장 없는 하늘 아래.' },
      { type: 'text', speaker: '', text: '첫 밤을 보냈다.' },
      { type: 'text', speaker: '', text: '그 밤의 공기가 유난히 맑았다. 호가 앉아 있는 주변으로 풀잎에 이슬이 내렸는데, 다른 곳보다 조금 더 차갑게 맺혀 있었다. 호 주변 반경으로만 풀잎이 하얗게 변해 있었다. 달빛 때문이라고 생각했다.' },
      { type: 'text', speaker: '', text: '밤이 깊어졌다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 불 근처에서 눈을 감았다. 자는 건지 쉬는 건지 알 수 없었다.' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"자요?"' },
      { type: 'text', speaker: '', text: '"그 아이요?"' },
      { type: 'text', speaker: '', text: '"이 아이가 자는 걸 본 적 있어요?"' },
      { type: 'text', speaker: '', text: '나는 생각했다.' },
      { type: 'text', speaker: '', text: '"......없는 것 같아요."' },
      { type: 'text', speaker: '', text: '"먹는 것도 못 봤어요."' },
      { type: 'text', speaker: '', text: '"그러게요."' },
      { type: 'text', speaker: '', text: '"그러면 어떻게 살아요."' },
      { type: 'text', speaker: '', text: '"......그게 이상하긴 한데요."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 봤다.' },
      { type: 'text', speaker: '백호', text: '"아직도 따뜻한 것 같아요."' },
      { type: 'text', speaker: '', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"저 아이한테서요. 가까이 있으면 뭔가 따뜻한 게 있어요. 그냥 온도가 아니라요. 다른 뭔가가."' },
      { type: 'text', speaker: '', text: '나는 왜소한 신을 봤다.' },
      { type: 'text', speaker: '', text: '그 아이가 눈을 감은 채 앉아 있었다.' },
      { type: 'text', speaker: '', text: '나도 느꼈다.' },
      { type: 'text', speaker: '', text: '이 아이 옆에 있으면 편했다. 말을 안 해도. 표정이 없어도. 그냥 있는 것만으로도.' },
      { type: 'text', speaker: '', text: '"저도 느껴요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"뭔지 알아요?"' },
      { type: 'text', speaker: '', text: '"몰라요."' },
      { type: 'text', speaker: '', text: '"모르는 게 많네요, 당신."' },
      { type: 'text', speaker: '', text: '"그런 사람이에요."' },
      { type: 'text', speaker: '', text: '"모르면 찾으면서 가요."' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"......그 방법도 있겠네요."' },
      { type: 'text', speaker: '', text: '"당신은 어때요? 모르는 게 무서워요?"' },
      { type: 'text', speaker: '', text: '"무서워요."' },
      { type: 'text', speaker: '', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"아무것도 없는 게요. 담장 밖이 어떤지. 모르니까요."' },
      { type: 'text', speaker: '', text: '"무서운데 아쉽지 않아요?"' },
      { type: 'text', speaker: '', text: '"무서운 거랑 아쉬운 건 달라요."' },
      { type: 'text', speaker: '', text: '호가 다시 하늘을 봤다.' },
      { type: 'text', speaker: '백호', text: '"저택에서 무서운 적 있었어요."' },
      { type: 'text', speaker: '', text: '"어떤 게요."' },
      { type: 'text', speaker: '', text: '"혼자라는 거요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"혼자가 뭔지 몰랐어요. 그게 무서웠어요."' },
      { type: 'text', speaker: '', text: '"지금은요?"' },
      { type: 'text', speaker: '', text: '"지금도 몰라요."' },
      { type: 'text', speaker: '', text: '"그러면 지금도 무서워요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"...... 조금 덜해요."' },
      { type: 'text', speaker: '', text: '"왜요."' },
      { type: 'text', speaker: '', text: '"비교할 게 생겼잖아요."' },
      { type: 'text', speaker: '', text: '호가 우리 셋을 가리키는 것처럼 손을 조금 들었다.' },
      { type: 'text', speaker: '백호', text: '"이게 혼자가 아닌 거면요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그러면 이전에 혼자였다는 거잖아요."' },
      { type: 'text', speaker: '', text: '"그렇죠."' },
      { type: 'text', speaker: '', text: '"그게 뭔지 알면."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"무서움이 조금 달라져요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 눈을 살짝 떴다가 다시 감았다.' },
      { type: 'text', speaker: '', text: '호가 무릎에 이마를 대고 눈을 감았다.' },
      { type: 'text', speaker: '', text: '얼마 안 지나서 숨이 고르게 됐다.' },
      { type: 'text', speaker: '', text: '잠든 것 같았다.' },
      { type: 'text', speaker: '', text: '나는 오래 그 불을 봤다.' },
      { type: 'text', speaker: '', text: '그때, 시스템 창이 조용히 떴다.' },
      { type: 'effect', effect: 'system', text: '【 백호(白虎) — 호감도 0단계 → 1단계 진입 감지. 경계 완화 중. 】' },
      { type: 'effect', effect: 'system', text: '【 참고: 각성 전에도 미세한 기운 반응이 감지되고 있습니다. 주시하십시오. 】' },
      { type: 'effect', effect: 'system', text: '【 유대 에너지 추적 개시 — 현재: 0 → 1. 동행 간 감정 교류 시 축적 예정. 】' },
      { type: 'effect', effect: 'system', text: '【 유대 에너지 보정 활성 — 동행 유대 수준에 따라 성장 효율 최대 1.5배 적용. 】' },
      { type: 'text', speaker: '', text: '나는 잠든 호를 봤다. 미세한 기운이라. 달빛 아래 호의 손끝에서 아주 희미한 빛이 스쳐 가는 것 같기도 했다. 착각일 수도 있었다.' },
      { type: 'text', speaker: '', text: '하지만 시스템은 착각을 기록하지 않는다.' },
      { type: 'text', speaker: '', text: '유대 에너지가 0에서 1이 됐다. 작은 숫자였지만, 0이 아니라는 것이 달랐다. 0은 아무것도 없는 것이고, 1은 뭔가가 시작된 것이다.' },
      { type: 'text', speaker: '', text: '호감도도 움직였다. 하루 만에. 이 아이가 아무도 믿지 않는다고 했는데, 그래도 옆에 앉았다. 하늘을 봤다. 말을 했다. 그게 1이 된 것이었다.' },
      { type: 'text', speaker: '', text: '숫자가 오르는 것보다, 이 아이가 옆에 앉아서 하늘이 넓다고 말한 것이 더 선명했다.' },
    ]
  },
  {
    title: '3장 — 부러지지 않는 아이',
    nodes: [
      { type: 'text', speaker: '', text: '훈련은 다음 날 아침부터 시작됐다.' },
      { type: 'text', speaker: '', text: '아침이라는 게. 해가 뜨자마자. 이슬이 아직 마르지 않은 풀밭 위에서.' },
      { type: 'text', speaker: '', text: '"왜 지금이에요?"' },
      { type: 'text', speaker: '', text: '호가 물었다.' },
      { type: 'text', speaker: '백호', text: '"몸이 깨어 있을 때가 좋아요."' },
      { type: 'text', speaker: '', text: '"저 아직 안 깨어 있어요."' },
      { type: 'text', speaker: '', text: '"움직이면 깨어나요."' },
      { type: 'text', speaker: '', text: '"그건 당신 논리잖아요."' },
      { type: 'text', speaker: '', text: '"맞는 논리예요."' },
      { type: 'text', speaker: '', text: '호가 눈을 비볐다.' },
      { type: 'text', speaker: '', text: '잠이 덜 깬 얼굴이었다. 저택에서는 새벽에 일어나는 게 당연했을 텐데. 어제 긴장이 풀려서 깊게 잠든 것이었다.' },
      { type: 'text', speaker: '', text: '담장 없는 하늘 아래.' },
      { type: 'text', speaker: '', text: '처음으로 편하게 잠든 것이었다.' },
      { type: 'text', speaker: '', text: '"준비운동부터요."' },
      { type: 'text', speaker: '', text: '내가 먼저 보여줬다. 몸을 풀어주는 간단한 동작들. 어깨를 돌리고, 허리를 좌우로 틀고, 다리를 뻗어 앉는 것들.' },
      { type: 'text', speaker: '', text: '호가 따라했다.' },
      { type: 'text', speaker: '', text: '흉내가 아니었다. 정확히 관찰하고, 그대로 옮겼다.' },
      { type: 'text', speaker: '', text: '빠른 눈이었다.' },
      { type: 'text', speaker: '', text: '본격적인 훈련이 시작됐다.' },
      { type: 'text', speaker: '', text: '기본 자세부터.' },
      { type: 'text', speaker: '', text: '호는 처음 보여준 자세를 금방 익혔다. 하지만 외우는 게 아니라 자신의 것으로 만드는 데는 시간이 걸렸다.' },
      { type: 'text', speaker: '', text: '"이 자세가 불편해요."' },
      { type: 'text', speaker: '', text: '"처음에는 다 불편해요."' },
      { type: 'text', speaker: '', text: '"익숙해지면 편해지는 거예요?"' },
      { type: 'text', speaker: '', text: '"편해지거나, 익숙해지거나."' },
      { type: 'text', speaker: '', text: '"차이가 있어요?"' },
      { type: 'text', speaker: '', text: '나는 생각했다.' },
      { type: 'text', speaker: '', text: '"편해진 건 몸이 받아들인 거고, 익숙해진 건 뇌가 받아들인 거예요."' },
      { type: 'text', speaker: '', text: '호가 그 말을 잠시 씹었다.' },
      { type: 'text', speaker: '백호', text: '"그러면 몸이 먼저예요."' },
      { type: 'text', speaker: '', text: '"사람마다 달라요."' },
      { type: 'text', speaker: '', text: '호가 입을 닫았다.' },
      { type: 'text', speaker: '', text: '그리고 자세를 다시 잡았다.' },
      { type: 'text', speaker: '', text: '내가 시키지 않았는데.' },
      { type: 'text', speaker: '', text: '스스로.' },
      { type: 'text', speaker: '', text: '여러 번.' },
      { type: 'text', speaker: '', text: '자세를 잡고, 고치고, 잡고, 고쳤다.' },
      { type: 'text', speaker: '', text: '그게 눈에 들어왔다.' },
      { type: 'text', speaker: '', text: '이 아이는 가르침을 받는 데 익숙하지 않다.' },
      { type: 'text', speaker: '', text: '그러나 배우는 것 자체는 싫어하지 않는다.' },
      { type: 'text', speaker: '', text: '가르치는 사람한테 의존하는 것이 싫은 거다.' },
      { type: 'text', speaker: '', text: '스스로 찾아야 하는 거다.' },
      { type: 'text', speaker: '', text: '——그러면 방법이 달라야 한다.' },
      { type: 'text', speaker: '', text: '나는 방향을 바꿨다.' },
      { type: 'text', speaker: '', text: '"이렇게 해봐요."' },
      { type: 'text', speaker: '', text: '내가 먼저 해봤다. 공격 동작 하나.' },
      { type: 'text', speaker: '', text: '호가 봤다.' },
      { type: 'text', speaker: '백호', text: '"따라 하지 말고, 당신만의 방식으로 해봐요."' },
      { type: 'text', speaker: '', text: '"같은 걸 하는데요?"' },
      { type: 'text', speaker: '', text: '"목표는 같아요. 방법은 달라도 돼요."' },
      { type: 'text', speaker: '', text: '호가 잠시 나를 봤다.' },
      { type: 'text', speaker: '', text: '의심하는 눈이었다. 함정인가? 틀리면 혼나는 건가?' },
      { type: 'text', speaker: '', text: '그게 읽혔다.' },
      { type: 'text', speaker: '', text: '저택에서 오래 살아온 사람의 눈.' },
      { type: 'text', speaker: '', text: '시키는 대로 하지 않으면 혼난다는 걸 몸으로 알고 있는 사람의 눈.' },
      { type: 'text', speaker: '', text: '"틀려도 돼요."' },
      { type: 'text', speaker: '', text: '내가 먼저 말했다.' },
      { type: 'text', speaker: '', text: '"......진짜요?"' },
      { type: 'text', speaker: '', text: '"진짜요."' },
      { type: 'text', speaker: '', text: '"왜요."' },
      { type: 'text', speaker: '', text: '"처음부터 맞으면 배운 게 아니에요."' },
      { type: 'text', speaker: '', text: '호가 한참을 나를 봤다.' },
      { type: 'text', speaker: '', text: '그 눈이 무언가를 재는 것 같았다.' },
      { type: 'text', speaker: '', text: '믿어도 될지.' },
      { type: 'text', speaker: '', text: '이 말이 진짜인지.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '해봤다.' },
      { type: 'text', speaker: '', text: '내가 한 것과 달랐다. 발을 먼저 움직이고, 허리를 비틀고, 그다음에 팔이 나가는 순서였다.' },
      { type: 'text', speaker: '', text: '나는 따라 해봤다.' },
      { type: 'text', speaker: '', text: '빠르긴 했다.' },
      { type: 'text', speaker: '', text: '"이 방법, 속도가 빠르네요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"그렇죠."' },
      { type: 'text', speaker: '', text: '"하지만 힘이 덜 담겨요."' },
      { type: 'text', speaker: '', text: '"속도가 힘을 보완해요."' },
      { type: 'text', speaker: '', text: '"어느 정도만요."' },
      { type: 'text', speaker: '', text: '"그러면 같이요?"' },
      { type: 'text', speaker: '', text: '"같이?"' },
      { type: 'text', speaker: '', text: '"제 방법에 당신 방법을 더하면요."' },
      { type: 'text', speaker: '', text: '나는 생각했다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '"해봐요."' },
      { type: 'text', speaker: '', text: '호가 시도했다.' },
      { type: 'text', speaker: '', text: '한 번.' },
      { type: 'text', speaker: '', text: '발이 먼저, 허리, 팔. 그런데 팔이 나가는 순간에 어깨에 힘을 더해.' },
      { type: 'text', speaker: '', text: '두 번.' },
      { type: 'text', speaker: '', text: '조금 달랐다. 더 나아졌다.' },
      { type: 'text', speaker: '', text: '세 번.' },
      { type: 'text', speaker: '', text: '——달랐다.' },
      { type: 'text', speaker: '', text: '속도가 있었다. 거기에 무게가 실렸다. 빠르고 묵직하게. 주먹이 나간 방향의 풀이 쓰러졌다. 바람이 아니었다. 주먹에서 밀려나간 기압이었다. 그리고 호의 손이 스친 자리에 이슬이 얼어 있었다. 아침 햇살에 녹지 않는 서리. 옆에 서 있던 어린 나무의 가지가 갈라져 있었다. 주먹이 닿지 않았는데, 기압만으로 껍질이 벗겨진 것이었다. 아무도 알아채지 못한 흔적이었다.' },
      { type: 'text', speaker: '', text: '호가 자신의 손을 봤다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '"이게."' },
      { type: 'text', speaker: '', text: '"그게 당신 방식이에요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"처음부터 이걸 말하지 그랬어요."' },
      { type: 'text', speaker: '', text: '"당신이 먼저 찾아야 했어요."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"자기 방법은 자기가 찾아야 진짜 자기 것이에요."' },
      { type: 'text', speaker: '', text: '호가 잠시 나를 봤다.' },
      { type: 'text', speaker: '', text: '표정이 조금 달라졌다.' },
      { type: 'text', speaker: '', text: '뭔가를 인정하는 것 같은.' },
      { type: 'text', speaker: '', text: '"......맞는 말이에요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '쉽게 인정하지 않는 사람이 인정했다.' },
      { type: 'text', speaker: '', text: '기분이 좋았다.' },
      { type: 'text', speaker: '', text: '시스템 창이 잠깐 떴다가 사라졌다.' },
      { type: 'effect', effect: 'system', text: '【 호감도 1단계 → 2단계 진입. 유대 에너지: 1 → 3. 】' },
      { type: 'text', speaker: '', text: '숫자가 올랐다. 작은 변화였지만, 숫자가 아닌 것이 변한 것 같았다.' },
      { type: 'text', speaker: '', text: '실랑이가 계속됐다.' },
      { type: 'text', speaker: '', text: '훈련을 시작한 지 사흘째.' },
      { type: 'text', speaker: '', text: '"이 방향으로 도는 게 맞아요."' },
      { type: 'text', speaker: '', text: '"저는 이 방향이 맞는데요."' },
      { type: 'text', speaker: '', text: '"당신 방향은 약점이 노출돼요."' },
      { type: 'text', speaker: '', text: '"제 약점은 속도로 커버해요."' },
      { type: 'text', speaker: '', text: '"상대가 더 빠르면요?"' },
      { type: 'text', speaker: '', text: '호가 잠깐 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"그러면 다른 방법으로요."' },
      { type: 'text', speaker: '', text: '"미리 준비하는 게 낫지 않아요?"' },
      { type: 'text', speaker: '', text: '"전부 미리 준비하면 몸이 무거워요. 상황에 맞게 쓰는 게 낫죠."' },
      { type: 'text', speaker: '', text: '나는 그 말을 생각했다.' },
      { type: 'text', speaker: '', text: '"......맞는 부분이 있어요."' },
      { type: 'text', speaker: '', text: '"맞는 거잖아요."' },
      { type: 'text', speaker: '', text: '"맞는 부분이요. 전부는 아니에요."' },
      { type: 'text', speaker: '', text: '"어떤 부분이 안 맞아요?"' },
      { type: 'text', speaker: '', text: '"상황에 맞게 쓰는 건 상황을 읽어야 해요. 읽는 능력이 없으면 못 써요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"제가 읽는 능력이 없다는 거예요?"' },
      { type: 'text', speaker: '', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '"....."' },
      { type: 'text', speaker: '', text: '"있을 거예요. 훈련하면."' },
      { type: 'text', speaker: '', text: '호가 눈을 가늘게 떴다.' },
      { type: 'text', speaker: '백호', text: '"그 말 불쾌해요."' },
      { type: 'text', speaker: '', text: '"사실이에요."' },
      { type: 'text', speaker: '', text: '"사실이어도 불쾌할 수 있잖아요."' },
      { type: 'text', speaker: '', text: '"그건 맞아요."' },
      { type: 'text', speaker: '', text: '"그러면 말하지 말아야죠."' },
      { type: 'text', speaker: '', text: '"알면 고칠 수 있어요."' },
      { type: 'text', speaker: '', text: '호가 한참 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신은 쓴소리를 잘 하네요."' },
      { type: 'text', speaker: '', text: '"쓴소리가 아니라 솔직한 거예요."' },
      { type: 'text', speaker: '', text: '호가 발을 바꿔 섰다. 시선을 다른 데 뒀다.' },
      { type: 'text', speaker: '백호', text: '"......어쨌든 불쾌했어요."' },
      { type: 'text', speaker: '', text: '"미안해요."' },
      { type: 'text', speaker: '', text: '"사과하지 말아요."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"사과하면 당신이 잘못한 거잖아요. 잘못한 게 아닌 것에 사과하면 거짓말이잖아요."' },
      { type: 'text', speaker: '', text: '나는 잠시 멍했다.' },
      { type: 'text', speaker: '', text: '"......호도 솔직하네요."' },
      { type: 'text', speaker: '', text: '호가 정면을 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신처럼요."' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '좋았다.' },
      { type: 'text', speaker: '', text: '사흘째 저녁.' },
      { type: 'text', speaker: '', text: '불 앞에서 밥을 먹을 때였다.' },
      { type: 'text', speaker: '', text: '된장국이 있었다. 나물이 있었다. 밥이 있었다.' },
      { type: 'text', speaker: '', text: '호가 젓가락을 들었다. 국을 봤다.' },
      { type: 'text', speaker: '백호', text: '"됐어요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"먹어도 돼요."' },
      { type: 'text', speaker: '', text: '"누가 안 된다고 했어요?"' },
      { type: 'text', speaker: '', text: '나는 잠깐 멍했다.' },
      { type: 'text', speaker: '', text: '"아. 그냥."' },
      { type: 'text', speaker: '', text: '"국이 맛있어 보여서 봤어요. 눈치채지 않아도 돼요."' },
      { type: 'text', speaker: '', text: '호가 국을 한 숟가락 떴다.' },
      { type: 'text', speaker: '백호', text: '"......됩니까."' },
      { type: 'text', speaker: '', text: '말이 달랐다. 조심스러운 말투였다. 저택 말버릇이 나온 것이었다. 하녀들이 음식을 먹을 때 쓰는 말.' },
      { type: 'text', speaker: '', text: '호가 그걸 알아챘다.' },
      { type: 'text', speaker: '', text: '뺨이 조금 붉어졌다.' },
      { type: 'text', speaker: '', text: '"됩니다."' },
      { type: 'text', speaker: '', text: '내가 맞춰서 말했다.' },
      { type: 'text', speaker: '', text: '"......됩니까 같은 말 안 해도 돼요. 이제는."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"그냥 나왔어요. 말이."' },
      { type: 'text', speaker: '', text: '"그렇죠."' },
      { type: 'text', speaker: '', text: '호가 국을 먹었다.' },
      { type: 'text', speaker: '', text: '한참 침묵.' },
      { type: 'text', speaker: '', text: '"짜네요."' },
      { type: 'text', speaker: '', text: '"그래요?"' },
      { type: 'text', speaker: '', text: '"짠데 맛있어요."' },
      { type: 'text', speaker: '', text: '"다행이에요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 불 앞에 앉으려 했다. 내 쪽으로. 그러다가 호가 앉자 호 쪽을 봤다. 나 쪽을 봤다. 잠깐 고민하더니. 호 옆으로 갔다. 호와 나 사이에. 딱 끼어 앉았다.' },
      { type: 'text', speaker: '', text: '호가 그 아이를 봤다.' },
      { type: 'text', speaker: '백호', text: '"제 된장찌개 담당이었어요. 저택에서."' },
      { type: 'text', speaker: '', text: '"그래요?"' },
      { type: 'text', speaker: '', text: '"그래서 잘 알아요, 된장 맛. 여기 된장은 조금 달라요. 저택 건 깊은 맛인데. 이건 단 맛이 섞여 있어요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들으면서 호를 봤다.' },
      { type: 'text', speaker: '', text: '된장찌개 담당이었다는 말이 무심하게 나왔다.' },
      { type: 'text', speaker: '', text: '저택 시절이 그 안에 있었다.' },
      { type: 'text', speaker: '', text: '나쁜 것만이 아니었다는 게.' },
      { type: 'text', speaker: '', text: '그 된장찌개가 담겨 있었다.' },
      { type: 'text', speaker: '', text: '그날 밤.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 옆에 앉았다.' },
      { type: 'text', speaker: '', text: '불이 타오르고 있었다.' },
      { type: 'text', speaker: '', text: '호가 그 아이를 봤다.' },
      { type: 'text', speaker: '백호', text: '"이 아이."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"말을 한 번도 안 해요."' },
      { type: 'text', speaker: '', text: '"그렇죠."' },
      { type: 'text', speaker: '', text: '"하지만 싫다는 것도 아니에요."' },
      { type: 'text', speaker: '', text: '"어떻게 알아요."' },
      { type: 'text', speaker: '', text: '"싫으면 떠나면 되잖아요."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 봤다.' },
      { type: 'text', speaker: '백호', text: '"이 아이는 안 떠나요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '그 눈이 호에게서 떠나지 않았다.' },
      { type: 'text', speaker: '', text: '"......당신은 왜 안 떠나요?"' },
      { type: 'text', speaker: '', text: '호가 왜소한 신한테 물었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 말하지 않았다.' },
      { type: 'text', speaker: '', text: '"말 못 해요?"' },
      { type: 'text', speaker: '', text: '침묵.' },
      { type: 'text', speaker: '', text: '"아니면 하기 싫어요?"' },
      { type: 'text', speaker: '', text: '왜소한 신이 고개를 살짝 기울였다.' },
      { type: 'text', speaker: '', text: '"둘 다예요?"' },
      { type: 'text', speaker: '', text: '살짝 끄덕임.' },
      { type: 'text', speaker: '', text: '호가 그 아이를 오래 봤다.' },
      { type: 'text', speaker: '백호', text: '"나쁘지는 않아요. 옆에 있는 게."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '"말 없이도 뭔가 있어요. 당신한테서."' },
      { type: 'text', speaker: '', text: '왜소한 신이 끄덕였다.' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"저택에서는 없던 것이요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '"당신도요."' },
      { type: 'text', speaker: '', text: '호가 나한테 말했다.' },
      { type: 'text', speaker: '백호', text: '"저요?"' },
      { type: 'text', speaker: '', text: '"당신도 있어요. 그 따뜻한 거."' },
      { type: 'text', speaker: '', text: '나는 잠시 있었다.' },
      { type: 'text', speaker: '', text: '"저한테서요?"' },
      { type: 'text', speaker: '', text: '"가끔이요."' },
      { type: 'text', speaker: '', text: '"항상은 아니에요. 당신은 이상한 때가 더 많아서."' },
      { type: 'text', speaker: '', text: '"이상한 때가 더 많으면요."' },
      { type: 'text', speaker: '', text: '"이상한 사람이 가끔 따뜻한 게 더 눈에 들어와요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '"......그게 좋은 말인지 모르겠어요."' },
      { type: 'text', speaker: '', text: '"좋은 말이에요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"저 사실."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이상한 걸 잘 몰라요. 저도 이상하다는 소리를 들었어요. 저택에서. 버릇없다고. 이상하다고."' },
      { type: 'text', speaker: '', text: '"그랬겠죠."' },
      { type: 'text', speaker: '', text: '"근데요."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 봤다.' },
      { type: 'text', speaker: '백호', text: '"이 아이도 이상하고. 당신도 이상하고. 그러면."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"저도 그냥 이상한 거예요. 나쁜 게 아니라."' },
      { type: 'text', speaker: '', text: '"맞아요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '웃는 것 같았다.' },
      { type: 'text', speaker: '', text: '그렇게 나흘이 지나고, 닷새가 지났다. 매일 조금씩 달라졌다. 어깨가 넓어진 것은 아닌데 자세가 넓어졌다. 발이 커진 것은 아닌데 걸음이 달라졌다.' },
      { type: 'text', speaker: '', text: '훈련 나흘째 아침.' },
      { type: 'text', speaker: '', text: '호가 달리기를 시작했다. 풀밭 끝에서 강가까지. 왕복.' },
      { type: 'text', speaker: '', text: '처음엔 보통이었다.' },
      { type: 'text', speaker: '', text: '두 번째부터 달라졌다. 다리에 뭔가가 실리는 것 같았다. 발이 풀을 밟는 소리가 묵직해졌다. 빨라진 게 아니라 한 발짝에 담기는 힘이 달라진 것이었다. 발이 밟는 자리마다 풀이 눌리는 게 아니라 갈라졌다. 발자국 주위로 흙이 차갑게 식어 있었다.' },
      { type: 'text', speaker: '', text: '나는 시스템 창을 흘끗 봤다.' },
      { type: 'effect', effect: 'system', text: '【 신체 잠재력 반응 감지. 미각성 상태에서의 기초 능력치가 동연령 대비 상위 0.3%입니다. 】' },
      { type: 'effect', effect: 'system', text: '【 유대 에너지: 미량 축적 중. 훈련 시 감정 교류가 성장 효율에 영향을 줍니다. 】' },
      { type: 'text', speaker: '', text: '열세 살짜리의 근력이 아니었다. 저택에서 두 해 동안 새벽부터 물을 길러 나르고, 빨래를 두들기고, 마당을 쓴 몸이었다. 거기에 뭔가가 더해져 있었다. 타고난 것이.' },
      { type: 'text', speaker: '', text: '호는 그걸 모르고 있었다.' },
      { type: 'effect', effect: 'shake' },
      { type: 'combat', enemy: {"name":"산적","hp":70,"attack":9} },
      { type: 'text', speaker: '', text: '열흘째 되는 날. 기본 자세에서 공격으로, 공격에서 회피로. 순서가 쌓이면서 훈련의 색이 달라졌다. 이제 나는 가르치는 쪽보다 맞추는 쪽이 더 많았다.' },
      { type: 'text', speaker: '', text: '이른 아침에 매 한 마리가 훈련하는 풀밭 위를 날아갔다. 호가 잠깐 올려다봤다. 빠르고 날카로운 것이 하늘을 가르는 걸 봤다. 그리고 다시 훈련을 시작했다. 더 세게.' },
      { type: 'text', speaker: '', text: '호가 완전히 넘어졌다.' },
      { type: 'text', speaker: '', text: '발이 아니었다. 다리 힘이 풀린 거였다. 너무 많이 달렸다. 너무 많이 반복했다. 몸이 한계였는데 멈추지 않았다.' },
      { type: 'text', speaker: '', text: '호는 멈추지 않는 사람이었다.' },
      { type: 'text', speaker: '', text: '피곤하다고, 아프다고, 힘들다고 먼저 말하지 않았다.' },
      { type: 'text', speaker: '', text: '그 결과가.' },
      { type: 'text', speaker: '', text: '무릎이 바닥에 박히는 것이었다.' },
      { type: 'text', speaker: '', text: '손을 짚었다.' },
      { type: 'text', speaker: '', text: '손이 짚은 자리에 풀이 눌려 뭉개졌다. 돌멩이 하나가 손바닥 밑에서 갈라졌다. 호는 그걸 보지 못했다.' },
      { type: 'text', speaker: '', text: '"도와줄까요?"' },
      { type: 'text', speaker: '', text: '내가 걸어갔다.' },
      { type: 'text', speaker: '', text: '"필요 없어요."' },
      { type: 'text', speaker: '', text: '"손을——"' },
      { type: 'text', speaker: '', text: '"필요 없다고요."' },
      { type: 'text', speaker: '', text: '나는 멈췄다.' },
      { type: 'text', speaker: '', text: '호가 혼자 일어나려 했다.' },
      { type: 'text', speaker: '', text: '한 번.' },
      { type: 'text', speaker: '', text: '다리가 안 됐다.' },
      { type: 'text', speaker: '', text: '두 번.' },
      { type: 'text', speaker: '', text: '무릎이 펴지지 않았다.' },
      { type: 'text', speaker: '', text: '세 번.' },
      { type: 'text', speaker: '', text: '이번엔 손마저 떨렸다.' },
      { type: 'text', speaker: '', text: '뺨이 붉어졌다.' },
      { type: 'text', speaker: '', text: '창피함이었다. 읽혔다.' },
      { type: 'text', speaker: '', text: '눈에 뭔가가 고이는 것도.' },
      { type: 'text', speaker: '', text: '읽혔다.' },
      { type: 'text', speaker: '', text: '규칙이 있었다. 울지 않는다.' },
      { type: 'text', speaker: '', text: '그 규칙을 지키려고 이를 악무는 것도.' },
      { type: 'text', speaker: '', text: '보였다.' },
      { type: 'text', speaker: '', text: '나는 옆으로 갔다. 호처럼 바닥에 주저앉았다.' },
      { type: 'text', speaker: '', text: '호 옆에.' },
      { type: 'text', speaker: '', text: '땅에.' },
      { type: 'text', speaker: '', text: '"당신 뭐 하는 거예요."' },
      { type: 'text', speaker: '', text: '"앉아요."' },
      { type: 'text', speaker: '', text: '"뭘 하려고요."' },
      { type: 'text', speaker: '', text: '"그냥이요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다. 내가 땅에 주저앉아 있는 걸 봤다.' },
      { type: 'text', speaker: '', text: '어이없는 눈이었다.' },
      { type: 'text', speaker: '', text: '어이가 없으면서도.' },
      { type: 'text', speaker: '', text: '뭔가 힘이 조금 빠지는 눈이었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 멀리서 이쪽을 보다가, 조용히 걸어왔다. 와서 내 옆에 앉으려다가 호를 보고.' },
      { type: 'text', speaker: '', text: '호 반대편에 앉았다.' },
      { type: 'text', speaker: '', text: '셋이서 땅에 앉아 있었다.' },
      { type: 'text', speaker: '', text: '한참 후에.' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"저도 오늘 넘어졌어요."' },
      { type: 'text', speaker: '', text: '"뭐요?"' },
      { type: 'text', speaker: '', text: '"당신이 오른쪽 훈련할 때. 저쪽 바위에서. 발을 헛디뎌서."' },
      { type: 'text', speaker: '', text: '"......못 봤는데요."' },
      { type: 'text', speaker: '', text: '"안 보이게 했어요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"창피해서요?"' },
      { type: 'text', speaker: '', text: '"창피해서요."' },
      { type: 'text', speaker: '', text: '호가 잠시 있었다.' },
      { type: 'text', speaker: '백호', text: '"당신도요?"' },
      { type: 'text', speaker: '', text: '"저도요."' },
      { type: 'text', speaker: '', text: '"......진짜요?"' },
      { type: 'text', speaker: '', text: '"진짜요."' },
      { type: 'text', speaker: '', text: '호가 고개를 돌렸다.' },
      { type: 'text', speaker: '', text: '눈물이 흘렀다.' },
      { type: 'text', speaker: '', text: '소리 없이.' },
      { type: 'text', speaker: '', text: '빠르게 닦았다.' },
      { type: 'text', speaker: '', text: '"오늘은 봤어도 모른 척해요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"벌써 잊었어요."' },
      { type: 'text', speaker: '', text: '"......거짓말."' },
      { type: 'text', speaker: '', text: '"거짓말이에요."' },
      { type: 'text', speaker: '', text: '호가 입을 닫았다.' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '"고마워요."' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '오래 남았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 쪽에 있다가 호가 쓰러지자 호 쪽으로 왔다.' },
      { type: 'text', speaker: '', text: '호 손 근처에 자신의 손을 뒀다. 닿지 않게. 하지만 닿을 수 있는 거리에.' },
      { type: 'text', speaker: '', text: '호가 그 손을 봤다.' },
      { type: 'text', speaker: '', text: '그리고 잡았다.' },
      { type: 'text', speaker: '', text: '말없이.' },
      { type: 'text', speaker: '', text: '한참.' },
      { type: 'text', speaker: '', text: '세 개의 그림자가 풀밭 위에 길게 누웠다.' },
      { type: 'text', speaker: '', text: '호가 잡은 왜소한 신의 손 주위로, 풀잎에 서리가 맺혔다. 여름이었는데. 호의 눈물이 떨어진 자리도 차갑게 식어 있었다. 눈물방울이 닿은 풀잎이 하얗게 얼어붙었다. 작은 수정 같았다.' },
      { type: 'text', speaker: '', text: '해가 기울었다.' },
      { type: 'text', speaker: '', text: '훈련은 그날 거기서 멈췄다.' },
      { type: 'text', speaker: '', text: '그게 맞았다.' },
      { type: 'text', speaker: '', text: '그날 저녁.' },
      { type: 'text', speaker: '', text: '호가 물었다.' },
      { type: 'text', speaker: '백호', text: '"왜 그렇게 했어요?"' },
      { type: 'text', speaker: '', text: '"뭘요?"' },
      { type: 'text', speaker: '', text: '"같이 앉은 거요. 땅에."' },
      { type: 'text', speaker: '', text: '"......그냥이요."' },
      { type: 'text', speaker: '', text: '"그냥이요?"' },
      { type: 'text', speaker: '', text: '"그냥 그게 맞는 것 같았어요."' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"뭐가 맞다는 거예요."' },
      { type: 'text', speaker: '', text: '"도와주겠다고 하면 싫다고 할 것 같았어요. 그냥 옆에 있는 게 낫다 싶었어요."' },
      { type: 'text', speaker: '', text: '"어떻게 알았어요."' },
      { type: 'text', speaker: '', text: '"...... 그냥이요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신은 가끔 눈치가 있어요."' },
      { type: 'text', speaker: '', text: '"가끔이요?"' },
      { type: 'text', speaker: '', text: '"가끔이요."' },
      { type: 'text', speaker: '', text: '나는 웃었다.' },
      { type: 'text', speaker: '', text: '"고마워요."' },
      { type: 'text', speaker: '', text: '"사실을 말한 거예요."' },
      { type: 'text', speaker: '', text: '"그래도 고마워요."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신이 한 말 중에 괜찮은 게 있어요."' },
      { type: 'text', speaker: '', text: '"어떤 거요?"' },
      { type: 'text', speaker: '', text: '"자기 방법은 자기가 찾아야 진짜 자기 것이라고 한 거요."' },
      { type: 'text', speaker: '', text: '"기억했어요?"' },
      { type: 'text', speaker: '', text: '"기억해야 할 것 같았어요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '기억해야 할 것 같았다는 말.' },
      { type: 'text', speaker: '', text: '호가 내 말을 그쪽으로 분류했다는 것이.' },
      { type: 'text', speaker: '', text: '가슴 어딘가를 건드렸다.' },
      { type: 'text', speaker: '', text: '——이 아이가 기억하겠다고 한 것들이, 나중에 이 아이를 지킬 것이다. 그 확신이 어디서 왔는지 모르겠지만, 있었다.' },
      { type: 'text', speaker: '', text: '그리고 다시 불을 보면서.' },
      { type: 'text', speaker: '', text: '조용한 시간이 흘렀다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 옆에 앉아 있었다. 내가 아까 바위에서 진짜 넘어졌는지 아닌지, 이 아이는 알고 있을 것이다. 하지만 아무 반응이 없었다. 그게 이 아이의 방식이었다.' },
      { type: 'text', speaker: '', text: '호가 무릎에 이마를 대고 잠이 들었다.' },
      { type: 'text', speaker: '', text: '나는 그 모습을 봤다.' },
      { type: 'text', speaker: '', text: '오늘 넘어지고, 울고, 잡고, 앉았다.' },
      { type: 'text', speaker: '', text: '내일은 다시 일어날 것이다.' },
      { type: 'text', speaker: '', text: '같은 표정으로.' },
      { type: 'text', speaker: '', text: '이 아이는 그런 아이였다.' },
    ]
  },
  {
    title: '- 수정2: 4장 중반 "싸우는 방식에서~달라진 게 느껴졌다" 설명적 서술 1줄 압축 (-1줄)',
    nodes: [
      { type: 'effect', effect: 'system', text: '【 백호 성장 단계: 1성 → 2성 진입 】' },
      { type: 'effect', effect: 'system', text: '【 호감도 2단계 → 3단계. 훈련 효율 상승. 감정 변화 감지 중. 】' },
      { type: 'effect', effect: 'system', text: '【 2성 특성 해금: \'야수의 직감\' — 위협 감지 범위 확장. 】' },
      { type: 'text', speaker: '', text: '두 달이 됐다.' },
      { type: 'text', speaker: '', text: '2성.' },
      { type: 'text', speaker: '', text: '시스템 창이 새벽에 떴다.' },
      { type: 'text', speaker: '', text: '나는 눈을 비비며 봤다.' },
      { type: 'text', speaker: '', text: '2성.' },
      { type: 'text', speaker: '', text: '빠르다.' },
      { type: 'text', speaker: '', text: '이렇게 빠를 줄은 몰랐다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에서 하늘을 보고 있었다.' },
      { type: 'text', speaker: '', text: '"2성이 됐어."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 나를 봤다.' },
      { type: 'text', speaker: '', text: '그 눈이 잠깐 나를 봤다가.' },
      { type: 'text', speaker: '', text: '다시 호 쪽으로 돌아갔다.' },
      { type: 'text', speaker: '', text: '"좋은 거야, 아마도."' },
      { type: 'text', speaker: '', text: '나는 시스템 창을 닫았다.' },
      { type: 'text', speaker: '', text: '2성이 되면서 감각 훈련이 더해졌다.' },
      { type: 'text', speaker: '', text: '"눈을 감아요."' },
      { type: 'text', speaker: '', text: '"왜요."' },
      { type: 'text', speaker: '', text: '"소리로 위치를 파악하는 연습이에요."' },
      { type: 'text', speaker: '', text: '"눈 있는데 왜 소리로 해요."' },
      { type: 'text', speaker: '', text: '"눈을 속이는 게 더 쉬워요. 소리는 속이기 어려워요."' },
      { type: 'text', speaker: '', text: '호가 눈을 감았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 조용히 움직이기 시작했다. 풀 위를 걷는 소리가 아주 작게 났다.' },
      { type: 'text', speaker: '', text: '"위치요."' },
      { type: 'text', speaker: '', text: '호가 잠시 있다가.' },
      { type: 'text', speaker: '백호', text: '"오른쪽 앞 한 걸음."' },
      { type: 'text', speaker: '', text: '"맞아요."' },
      { type: 'text', speaker: '', text: '호가 눈을 떴다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 정말 한 걸음 앞 오른쪽에 있었다.' },
      { type: 'text', speaker: '', text: '"이 아이 발소리가 거의 안 나요."' },
      { type: 'text', speaker: '', text: '"그렇죠."' },
      { type: 'text', speaker: '', text: '"그런데 어떻게 맞혔어요?"' },
      { type: 'text', speaker: '', text: '호가 귀에 손을 댔다.' },
      { type: 'text', speaker: '백호', text: '"숨소리요. 발소리보다 숨소리가 더 잘 들려요."' },
      { type: 'text', speaker: '', text: '나는 놀랐다.' },
      { type: 'text', speaker: '', text: '"가르친 적 없는데요."' },
      { type: 'text', speaker: '', text: '"필요하면 찾아요."' },
      { type: 'text', speaker: '', text: '"......대단하네요."' },
      { type: 'text', speaker: '', text: '호가 고개를 들었다.' },
      { type: 'text', speaker: '백호', text: '"그 말 자주 해요."' },
      { type: 'text', speaker: '', text: '"아직 한 번밖에 안 했어요."' },
      { type: 'text', speaker: '', text: '"기록이에요. 앞으로 몇 번이나 할 건지."' },
      { type: 'text', speaker: '', text: '나는 웃었다.' },
      { type: 'text', speaker: '', text: '호가 못 본 척했다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '입꼬리가 조금 올라간 걸.' },
      { type: 'text', speaker: '', text: '봤다.' },
      { type: 'text', speaker: '', text: '그 감각이 쌓이면서 좌절도 깊어졌다.' },
      { type: 'text', speaker: '', text: '호의 강점은 속도였다.' },
      { type: 'text', speaker: '', text: '빠른 판단. 빠른 움직임. 빠른 적응.' },
      { type: 'text', speaker: '', text: '하지만 그 빠름이.' },
      { type: 'text', speaker: '', text: '오히려 약점이 됐다.' },
      { type: 'text', speaker: '', text: '"너무 빨리 움직이면 자기 몸의 무게를 못 써요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"빠른 게 강점인데요."' },
      { type: 'text', speaker: '', text: '"빠름과 묵직함이 같이 있어야 해요."' },
      { type: 'text', speaker: '', text: '호가 시도했다.' },
      { type: 'text', speaker: '', text: '빠르게 움직이면서 무게를 싣는.' },
      { type: 'text', speaker: '', text: '안 됐다.' },
      { type: 'text', speaker: '', text: '한 번. 두 번. 세 번.' },
      { type: 'text', speaker: '', text: '호가 멈췄다. 손을 봤다. 안 된다는 걸 인정하는 것이 고통스러운 얼굴이었다.' },
      { type: 'text', speaker: '백호', text: '"이건 안 되는 것 같아요."' },
      { type: 'text', speaker: '', text: '"돼요. 시간이 필요할 뿐이에요."' },
      { type: 'text', speaker: '', text: '호가 자세를 다시 잡았다.' },
      { type: 'text', speaker: '', text: '네 번. 다섯 번. 여섯 번.' },
      { type: 'text', speaker: '', text: '여섯 번째에 뭔가 달랐다. 발이 먼저 땅을 밀었다. 그 힘이 허리를 지나 팔에 실렸다.' },
      { type: 'text', speaker: '', text: '빠른데.' },
      { type: 'text', speaker: '', text: '무거웠다.' },
      { type: 'text', speaker: '', text: '일곱 번째.' },
      { type: 'text', speaker: '', text: '더 됐다.' },
      { type: 'text', speaker: '', text: '여덟 번째.' },
      { type: 'text', speaker: '', text: '이번엔 완벽했다.' },
      { type: 'text', speaker: '', text: '빠르고 묵직하게.' },
      { type: 'text', speaker: '', text: '달빛이 낮게 떠 있었다.' },
      { type: 'text', speaker: '', text: '호의 주먹이 공기를 갈랐다.' },
      { type: 'text', speaker: '', text: '파직.' },
      { type: 'text', speaker: '', text: '그 소리가 선명했다. 소리만이 아니었다. 주먹이 지나간 자리에 바람이 갈라지며 풀잎 서너 줄기가 베인 듯 끊어졌다. 끊어진 풀잎 단면에 서리가 맺혔다. 여름 밤인데. 차가운 것이 주먹을 따라 번진 것이었다. 주먹이 지나간 궤적 전체가 하얗게 얼어 있었다. 2성의 힘이 처음으로 보이는 형태를 가졌다.' },
      { type: 'text', speaker: '', text: '나는 봤다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 봤다.' },
      { type: 'text', speaker: '', text: '호가 그 소리를 들었다.' },
      { type: 'text', speaker: '', text: '눈을 가늘게 뜨면서.' },
      { type: 'text', speaker: '', text: '뭔가 쌓인 것이 차오르는 얼굴이었다.' },
      { type: 'text', speaker: '', text: '얼굴이 아직 그 표정에 익숙하지 않아 보였다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '보기 좋았다.' },
      { type: 'text', speaker: '', text: '그날 오후.' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '훈련이 끝난 뒤.' },
      { type: 'text', speaker: '', text: '호가 강가에서 손을 씻으면서.' },
      { type: 'text', speaker: '', text: '흥얼거렸다.' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '거의 들리지 않을 만큼.' },
      { type: 'text', speaker: '', text: '나는 가까이 가지 않았다.' },
      { type: 'text', speaker: '', text: '저 소리를 들으면 멈출 것 같아서.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에 서 있었다.' },
      { type: 'text', speaker: '', text: '"들어요?"' },
      { type: 'text', speaker: '', text: '왜소한 신이 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '나는 그 흥얼거림을 멀리서 들었다.' },
      { type: 'text', speaker: '', text: '담장이 없는 강가에서.' },
      { type: 'text', speaker: '', text: '호가 흥얼거리고 있었다.' },
      { type: 'text', speaker: '', text: '저택에서는 못 했을 것이다.' },
      { type: 'text', speaker: '', text: '좋아하는 소리를 내면 이상하다고 했을 테니까.' },
      { type: 'text', speaker: '', text: '지금은.' },
      { type: 'text', speaker: '', text: '자연스러웠다.' },
      { type: 'effect', effect: 'system', text: '【 호감도 3단계 → 4단계 진입. 백호의 감정 변화: \'경계\' → \'관심\' → \'친밀\'. 】' },
      { type: 'effect', effect: 'system', text: '【 호감도 이벤트 가능. 유대 에너지: 3 → 7. 】' },
      { type: 'text', speaker: '', text: '그날 저녁.' },
      { type: 'text', speaker: '', text: '모닥불 앞에서.' },
      { type: 'text', speaker: '', text: '호가 오래 조용히 있다가 말했다.' },
      { type: 'text', speaker: '백호', text: '"저 사실."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"외로운 게 뭔지 몰랐어요."' },
      { type: 'text', speaker: '', text: '나는 손을 멈췄다.' },
      { type: 'text', speaker: '', text: '"저택에서 아무도 없었는데, 외롭다는 감각이 없었어요."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"비교할 게 없었으니까요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 불 앞에 앉으려다가 내 쪽으로 왔다. 발치에 자리를 잡고 앉아서 불을 봤다. 그 작은 몸이 불빛을 받아 따뜻해 보였다.' },
      { type: 'text', speaker: '', text: '"지금은요?"' },
      { type: 'text', speaker: '', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '호가 말을 멈췄다.' },
      { type: 'text', speaker: '', text: '잠깐의 침묵이었다. 무언가를 고르는 침묵. 이 말을 해도 되는지 재는 침묵이었다.' },
      { type: 'text', speaker: '', text: '"지금은 무서워요. 이게 사라지면 어떡하나 싶어서."' },
      { type: 'text', speaker: '', text: '"이게요?"' },
      { type: 'text', speaker: '', text: '"이거요."' },
      { type: 'text', speaker: '', text: '호가 손을 들었다.' },
      { type: 'text', speaker: '', text: '우리 셋을 가리키는 것처럼. 모닥불을. 이 밤 전체를.' },
      { type: 'text', speaker: '', text: '"이 불이요. 이 시간이요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"이게 외로운 것의 반대예요. 그러면 이전에 외로웠던 거잖아요."' },
      { type: 'text', speaker: '', text: '호가 고개를 끄덕였다.' },
      { type: 'text', speaker: '백호', text: '"그런가봐요."' },
      { type: 'text', speaker: '', text: '"비교가 없으면 모르는 게 당연해요."' },
      { type: 'text', speaker: '', text: '"당연한 거예요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그러면 지금 외롭지 않은 게 당연하겠네요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"당연한 게 이렇게 좋을 줄 몰랐어요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 오래 들었다.' },
      { type: 'text', speaker: '', text: '당연한 게 좋다는 말.' },
      { type: 'text', speaker: '', text: '그게 가슴에 걸렸다.' },
      { type: 'text', speaker: '', text: '두 해를 저택에서 보낸 아이가.' },
      { type: 'text', speaker: '', text: '처음으로 당연함이 좋다고 말하는 것이.' },
      { type: 'text', speaker: '', text: '그 밤에 호가 울었다.' },
      { type: 'text', speaker: '', text: '자는 줄 알았는데.' },
      { type: 'text', speaker: '', text: '소리가 났다.' },
      { type: 'text', speaker: '', text: '아주 작은.' },
      { type: 'text', speaker: '', text: '거의 들리지 않는.' },
      { type: 'text', speaker: '', text: '나는 모른 척했다.' },
      { type: 'text', speaker: '', text: '들었지만.' },
      { type: 'text', speaker: '', text: '모른 척했다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 옆으로 가서 앉았다.' },
      { type: 'text', speaker: '', text: '그 손이 호의 손 근처에 있었다.' },
      { type: 'text', speaker: '', text: '호가 그 손을 잡았다.' },
      { type: 'text', speaker: '', text: '울음이 멈추지 않았다.' },
      { type: 'text', speaker: '', text: '하지만 소리는 더 작아졌다.' },
      { type: 'text', speaker: '', text: '한참 후에.' },
      { type: 'text', speaker: '', text: '조용해졌다.' },
      { type: 'text', speaker: '', text: '잠이 든 것 같았다.' },
      { type: 'text', speaker: '', text: '나는 그제야 눈을 떴다.' },
      { type: 'text', speaker: '', text: '하늘을 봤다.' },
      { type: 'text', speaker: '', text: '별이 많은 밤이었다.' },
      { type: 'text', speaker: '', text: '호가 자는 동안.' },
      { type: 'text', speaker: '', text: '나는 오래 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '이 아이가 저택에서 두 해 동안 혼자 버텨온 것들이. 고개를 숙이지 않으며 맞은 것들이. 울지 않으며 고인 눈물들이.' },
      { type: 'text', speaker: '', text: '지금 조금씩 흘러나오는 것 같았다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '좋은 거라는 걸.' },
      { type: 'text', speaker: '', text: '알았다.' },
      { type: 'text', speaker: '', text: '울어도 되는 자리.' },
      { type: 'text', speaker: '', text: '저택에서 두 해 동안.' },
      { type: 'text', speaker: '', text: '울 수 없었던 것들이.' },
      { type: 'text', speaker: '', text: '지금.' },
      { type: 'text', speaker: '', text: '이 강가에서.' },
      { type: 'text', speaker: '', text: '흘러도 되는 것이었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 그 자리에 있었다.' },
      { type: 'text', speaker: '', text: '떠밀지 않고, 하지만 옆에 있는.' },
      { type: 'text', speaker: '', text: '다음 날 아침.' },
      { type: 'text', speaker: '', text: '호가 일어났을 때.' },
      { type: 'text', speaker: '', text: '어젯밤에 울었다는 걸 아는지 모르는지.' },
      { type: 'text', speaker: '', text: '표정이 평소와 같았다.' },
      { type: 'text', speaker: '', text: '도도했다.' },
      { type: 'text', speaker: '', text: '고개가 곧았다.' },
      { type: 'text', speaker: '', text: '어깨가 처지지 않았다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '이 아이였다.' },
      { type: 'text', speaker: '', text: '울었어도.' },
      { type: 'text', speaker: '', text: '다음 날이 되면.' },
      { type: 'text', speaker: '', text: '같은 표정으로 일어났다.' },
      { type: 'text', speaker: '', text: '무너지지 않는다는 게.' },
      { type: 'text', speaker: '', text: '이런 거였다.' },
      { type: 'text', speaker: '', text: '"훈련이에요?"' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"응."' },
      { type: 'text', speaker: '', text: '"오늘은 뭐요."' },
      { type: 'text', speaker: '', text: '"어제 것을 더요."' },
      { type: 'text', speaker: '', text: '호가 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '어젯밤 얘기를 하지 않았다.' },
      { type: 'text', speaker: '', text: '나도 하지 않았다.' },
      { type: 'text', speaker: '', text: '할 필요가 없었다.' },
      { type: 'text', speaker: '', text: '어젯밤이 지나갔다는 것.' },
      { type: 'text', speaker: '', text: '그걸 서로 알고 있었다.' },
      { type: 'text', speaker: '', text: '그걸로 충분했다.' },
      { type: 'text', speaker: '', text: '3성에 가까워질 무렵.' },
      { type: 'text', speaker: '', text: '처음으로 위험한 상황이 왔다.' },
      { type: 'text', speaker: '', text: '마을과 마을 사이 길목에서였다.' },
      { type: 'text', speaker: '', text: '산적 다섯. 칼을 든 자가 둘이었고, 나머지 셋은 몽둥이와 도끼를 들고 있었다. 마른 체구였지만 눈이 사납고, 상대를 에워싸는 움직임이 익숙했다. 처음 하는 짓이 아닌 사람들이었다.' },
      { type: 'text', speaker: '', text: '나와 호가 마주쳤다.' },
      { type: 'text', speaker: '백호', text: '"저리 비켜."' },
      { type: 'text', speaker: '', text: '한 명이 말했다.' },
      { type: 'text', speaker: '', text: '"이 길은 우리 길이야."' },
      { type: 'text', speaker: '', text: '"길에 주인이 있어요?"' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '표정이 고요했다. 하지만 나는 봤다. 호의 손끝이 아주 미세하게 떨리는 걸. 처음 마주치는 적의. 처음 겪는 살기.' },
      { type: 'text', speaker: '', text: '그런데 떨리는 손끝에서 뭔가가 번뜩였다. 희미하게. 달빛도 없는 낮인데, 손톱 끝에 차갑고 하얀 빛이 한순간 스쳐 지나갔다.' },
      { type: 'text', speaker: '', text: '"주인이 있다고 하면 있는 거야."' },
      { type: 'text', speaker: '', text: '"그렇지 않아요."' },
      { type: 'text', speaker: '', text: '산적 다섯이 우리를 둘러쌌다.' },
      { type: 'text', speaker: '', text: '나는 호 옆에 섰다.' },
      { type: 'text', speaker: '', text: '"다섯이에요. 칼이 둘이에요."' },
      { type: 'text', speaker: '', text: '"봐요."' },
      { type: 'text', speaker: '', text: '호가 앞으로 한 발 나섰다.' },
      { type: 'text', speaker: '', text: '셋이 먼저 달려들었다.' },
      { type: 'text', speaker: '', text: '호가 첫 번째를 옆으로 피했다. 발이 먼저 밀었다. 손이 나갔다.' },
      { type: 'text', speaker: '', text: '파직.' },
      { type: 'text', speaker: '', text: '맞은 산적의 어깨가 뒤로 꺾였다. 열세 살짜리 주먹에 맞고 성인 남자가 밀렸다. 산적이 자기 어깨를 잡으며 눈이 커졌다. 이해할 수 없다는 얼굴이었다.' },
      { type: 'text', speaker: '', text: '두 번째가 옆에서 도끼를 휘둘렀다. 호가 아래로 피했다. 도끼가 머리 위를 스쳤다. 머리카락이 잘렸다. 간발이었다.' },
      { type: 'text', speaker: '', text: '호의 다리가 나갔다. 도끼를 든 산적의 무릎을 쓸었다. 관절이 꺾이는 소리가 났다.' },
      { type: 'text', speaker: '', text: '두 번 다. 넘어졌다.' },
      { type: 'text', speaker: '', text: '칼을 든 둘이 왔다.' },
      { type: 'text', speaker: '', text: '하나가 앞에서. 하나가 뒤에서.' },
      { type: 'text', speaker: '', text: '칼이 문제였다.' },
      { type: 'text', speaker: '', text: '나는 앞으로 나갔다.' },
      { type: 'text', speaker: '', text: '뒤의 한 명을 잡았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 어딘가에서 나타났다. 그 작은 몸이 칼을 든 산적의 발목 옆을 스쳤다. 닿은 건지 아닌지도 모를 움직임이었는데, 산적의 발이 제 발에 걸린 것처럼 꼬였다. 넘어졌다.' },
      { type: 'text', speaker: '', text: '앞의 칼을 든 산적이 남았다.' },
      { type: 'text', speaker: '', text: '호가 멈췄다.' },
      { type: 'text', speaker: '', text: '칼을 맨손으로 다루는 건 다른 문제였다.' },
      { type: 'text', speaker: '', text: '칼이 내려왔다.' },
      { type: 'text', speaker: '', text: '호가 옆으로 비켰다. 칼이 호의 옷자락을 스쳤다. 두 번째 베기가 왔다. 이번엔 피하지 않았다.' },
      { type: 'text', speaker: '', text: '들어갔다.' },
      { type: 'text', speaker: '', text: '칼을 쓸 수 없는 거리로.' },
      { type: 'text', speaker: '', text: '팔 안쪽으로 파고들어서.' },
      { type: 'text', speaker: '', text: '어깨로 밀었다.' },
      { type: 'text', speaker: '', text: '주먹이 한 번. 명치에.' },
      { type: 'text', speaker: '', text: '칼 든 사람이 꺾였다. 칼이 떨어졌다.' },
      { type: 'text', speaker: '', text: '다섯이 바닥에 있었다.' },
      { type: 'text', speaker: '', text: '호가 서 있는 자리 주변으로 풀잎에 서리가 내려 있었다. 한낮인데. 호의 주먹이 지나간 궤적을 따라, 공기가 차갑게 식어 있었다. 호는 그걸 눈치채지 못했다.' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"도움이 필요했어요?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '"그러면 됐어요."' },
      { type: 'text', speaker: '', text: '호가 걸음을 다시 시작했다.' },
      { type: 'text', speaker: '', text: '나는 그 뒷모습을 보면서 생각했다.' },
      { type: 'text', speaker: '', text: '이 아이가.' },
      { type: 'text', speaker: '', text: '달라졌다.' },
      { type: 'text', speaker: '', text: '앞으로 나섰을 때의 그 한 발짝에서.' },
      { type: 'text', speaker: '', text: '달라진 게 느껴졌다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에서 걸었다.' },
      { type: 'text', speaker: '', text: '그 작은 눈이.' },
      { type: 'text', speaker: '', text: '호를 봤다.' },
      { type: 'text', speaker: '', text: '하지만 호에게서 떠나지 않는 눈이었다.' },
      { type: 'text', speaker: '', text: '그날 밤, 왜소한 신이 한 번도 하지 않던 행동을 했다. 잠든 호와 나 사이에 앉더니, 먼 곳을 봤다. 산 너머를. 바람이 불어오는 쪽을. 그 작은 눈에 경계 같은 것이 처음으로 비쳤다.' },
    ]
  },
  {
    title: '5장 — 이름을 부르다',
    nodes: [
      { type: 'effect', effect: 'system', text: '【 백호 성장 단계: 2성 → 3성 진입 】' },
      { type: 'effect', effect: 'system', text: '【 호감도 5단계. 감정 변화: \'관심\' → \'신뢰\'. 전투 시 협동 효율 증가. 】' },
      { type: 'text', speaker: '', text: '석 달이 됐다.' },
      { type: 'text', speaker: '', text: '3성.' },
      { type: 'text', speaker: '', text: '시스템 창이 조용하게 알렸다.' },
      { type: 'text', speaker: '', text: '나는 강가에서 물을 떠오다가 잠시 멈췄다.' },
      { type: 'text', speaker: '', text: '3성이 됐다는 건.' },
      { type: 'text', speaker: '', text: '실력이 달라졌다는 거다.' },
      { type: 'text', speaker: '', text: '느껴졌다.' },
      { type: 'text', speaker: '', text: '훈련하면서 느껴졌다.' },
      { type: 'text', speaker: '', text: '호는 이제 달랐다. 빠른 것은 처음부터였다. 하지만 이제는 빠르면서 무거웠다. 그리고.' },
      { type: 'text', speaker: '', text: '읽었다.' },
      { type: 'text', speaker: '', text: '상대를 읽는 눈이 생겼다.' },
      { type: 'text', speaker: '', text: '"저쪽에서 공격이 오면요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"눈보다 발이 먼저 움직여요."' },
      { type: 'text', speaker: '', text: '"어떻게 알아요?"' },
      { type: 'text', speaker: '', text: '"무게중심이요. 공격하려면 무게중심이 앞으로 쏠려요."' },
      { type: 'text', speaker: '', text: '나는 해보려 했다.' },
      { type: 'text', speaker: '', text: '호가 봤다.' },
      { type: 'text', speaker: '백호', text: '"지금 무게중심이 가운데예요. 아직 공격 안 할 거예요."' },
      { type: 'text', speaker: '', text: '"어떻게 알아요."' },
      { type: 'text', speaker: '', text: '"발이 안 움직였잖아요."' },
      { type: 'text', speaker: '', text: '"......맞네요."' },
      { type: 'text', speaker: '', text: '"이게 읽는 거예요?"' },
      { type: 'text', speaker: '', text: '"그게 읽는 거예요."' },
      { type: 'text', speaker: '', text: '호가 고개를 끄덕였다.' },
      { type: 'text', speaker: '백호', text: '"몸이 말보다 먼저 해요."' },
      { type: 'text', speaker: '', text: '"사람이 그렇죠."' },
      { type: 'text', speaker: '', text: '"당신도요?"' },
      { type: 'text', speaker: '', text: '"저도요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"그러면 당신도 읽을 수 있겠네요."' },
      { type: 'text', speaker: '', text: '"뭘요?"' },
      { type: 'text', speaker: '', text: '"당신의 몸이요. 제가."' },
      { type: 'text', speaker: '', text: '나는 잠시 멍했다.' },
      { type: 'text', speaker: '', text: '"......무서운 말이네요."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"다 읽히면 숨길 게 없잖아요."' },
      { type: 'text', speaker: '', text: '호가 씩 웃었다.' },
      { type: 'text', speaker: '백호', text: '"숨기는 게 있어요?"' },
      { type: 'text', speaker: '', text: '"없는 건 아니에요."' },
      { type: 'text', speaker: '', text: '"그러면 조심해야겠네요."' },
      { type: 'text', speaker: '', text: '"그러게요."' },
      { type: 'text', speaker: '', text: '그 즈음 밤에.' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"손이 이상해요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"뭔가 있는 것 같아요."' },
      { type: 'text', speaker: '', text: '"무게요?"' },
      { type: 'text', speaker: '', text: '"아니요. 빛이요."' },
      { type: 'text', speaker: '', text: '나는 잠시 멈췄다.' },
      { type: 'text', speaker: '', text: '"빛이요?"' },
      { type: 'text', speaker: '', text: '"응. 느껴요. 손끝에서요."' },
      { type: 'text', speaker: '', text: '"집중하고 잡아봐요. 손끝에 있는 거요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '', text: '이해가 안 되는 눈으로.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '눈을 감았다.' },
      { type: 'text', speaker: '', text: '손을 들었다.' },
      { type: 'text', speaker: '', text: '집중했다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '왜소한 신이 그 장면을 봤다.' },
      { type: 'text', speaker: '', text: '그 작은 눈이.' },
      { type: 'text', speaker: '', text: '빛났다.' },
      { type: 'text', speaker: '', text: '한참.' },
      { type: 'text', speaker: '', text: '아무 말 없이.' },
      { type: 'text', speaker: '', text: '호가 집중했다.' },
      { type: 'text', speaker: '', text: '바람이 없었다.' },
      { type: 'text', speaker: '', text: '그런데 손끝에서 뭔가가.' },
      { type: 'text', speaker: '', text: '"......있어요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"있어요?"' },
      { type: 'text', speaker: '', text: '"뭔지 모르겠어요. 그런데 있어요."' },
      { type: 'text', speaker: '', text: '나는 그 손끝을 봤다.' },
      { type: 'text', speaker: '', text: '달빛이 모여드는 것 같은, 차갑고 선명한 기운이 손끝에 아주 조금 있는 것 같았다. 주위 풀잎이 살짝 고개를 숙였다. 서리가 맺히는 것처럼. 호가 집중하는 것만으로 공기가 차가워졌다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호의 손을 봤다.' },
      { type: 'text', speaker: '', text: '그러더니 내 발치로 슬그머니 돌아와서.' },
      { type: 'text', speaker: '', text: '내 발 위에 올라앉았다.' },
      { type: 'text', speaker: '', text: '작은 발이 내 발등을 꾹 눌렀다.' },
      { type: 'text', speaker: '', text: '"뭐예요, 이게."' },
      { type: 'text', speaker: '', text: '호가 눈을 떴다.' },
      { type: 'text', speaker: '백호', text: '"나중에 알게 될 거예요."' },
      { type: 'text', speaker: '', text: '"그 말 버릇이에요."' },
      { type: 'text', speaker: '', text: '"이번에는 진짜예요."' },
      { type: 'text', speaker: '', text: '호가 손끝을 봤다.' },
      { type: 'text', speaker: '', text: '이미 꺼진 것 같은.' },
      { type: 'text', speaker: '', text: '있었다가 사라진.' },
      { type: 'text', speaker: '', text: '"......다시 해봐요."' },
      { type: 'text', speaker: '', text: '"될 때까지요?"' },
      { type: 'text', speaker: '', text: '"될 때까지요."' },
      { type: 'text', speaker: '', text: '그 말버릇을 이제 호가 썼다.' },
      { type: 'text', speaker: '', text: '나는 웃었다.' },
      { type: 'text', speaker: '', text: '호도 웃은 것 같았다.' },
      { type: 'text', speaker: '', text: '그리고 다시.' },
      { type: 'text', speaker: '', text: '집중했다.' },
      { type: 'text', speaker: '', text: '그달에 실전 전투가 있었다.' },
      { type: 'text', speaker: '', text: '도적 무리였다.' },
      { type: 'text', speaker: '', text: '이 지역에 자주 나타난다는 말을 마을에서 들었다. 상인들을 털고, 홀로 다니는 여행객을 노렸다.' },
      { type: 'text', speaker: '', text: '우리가 딱 걸렸다.' },
      { type: 'text', speaker: '', text: '낮이었다. 산길을 가다가.' },
      { type: 'text', speaker: '', text: '"거기 서."' },
      { type: 'text', speaker: '', text: '다섯이 나왔다.' },
      { type: 'text', speaker: '', text: '무기가 있었다. 칼도 있고 몽둥이도 있었다. 다 거칠게 생긴 사람들이었다. 4장의 산적들과 달리, 몸집이 컸다. 근육이 있었다. 이쪽을 보는 눈이 사냥감을 보는 눈이었다.' },
      { type: 'text', speaker: '', text: '나는 뒤로 한 발짝 물러나려 했다.' },
      { type: 'text', speaker: '', text: '"뒤로 가요."' },
      { type: 'text', speaker: '', text: '호가 먼저 말했다.' },
      { type: 'text', speaker: '백호', text: '"당신이요?"' },
      { type: 'text', speaker: '', text: '"저요."' },
      { type: 'text', speaker: '', text: '"다섯이에요."' },
      { type: 'text', speaker: '', text: '"저번에도 다섯이었어요."' },
      { type: 'text', speaker: '', text: '"이번은 달라요. 칼이 셋이에요."' },
      { type: 'text', speaker: '', text: '호가 잠시 앞을 봤다.' },
      { type: 'text', speaker: '', text: '맞았다. 이번은 달랐다. 저번 산적은 굶주린 사람들이었다. 이번은 직업이 도적인 자들이었다.' },
      { type: 'text', speaker: '', text: '"봐요."' },
      { type: 'text', speaker: '', text: '호가 앞으로 나섰다.' },
      { type: 'text', speaker: '', text: '도적들이 웃었다.' },
      { type: 'text', speaker: '', text: '"야, 애잖아."' },
      { type: 'text', speaker: '', text: '"겁이 없는 거지."' },
      { type: 'text', speaker: '', text: '호가 그 웃음들을 들었다.' },
      { type: 'text', speaker: '', text: '표정이 달라지지 않았다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '"다섯이 나왔는데 셋이 떠들고 있어요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '도적들의 웃음이 멈췄다.' },
      { type: 'text', speaker: '', text: '"떠드는 동안 나머지 둘이 뒤로 돌아가려는 거 보여요."' },
      { type: 'text', speaker: '', text: '도적들의 표정이 굳었다.' },
      { type: 'text', speaker: '', text: '"......봤어요."' },
      { type: 'text', speaker: '', text: '호가 뒤도 안 보고 말했다.' },
      { type: 'text', speaker: '백호', text: '"뒤로 돌아가면 안 좋아요."' },
      { type: 'text', speaker: '', text: '뒤로 돌던 두 명이 멈췄다.' },
      { type: 'text', speaker: '', text: '호가 앞의 셋을 봤다.' },
      { type: 'text', speaker: '백호', text: '"준비됐으면 오세요."' },
      { type: 'text', speaker: '', text: '첫 번째가 달려들었다.' },
      { type: 'text', speaker: '', text: '호가 옆으로 비켰다. 3성의 몸이었다. 두 달 전과는 다른 밀도가 팔에 실려 있었다.' },
      { type: 'text', speaker: '', text: '달려드는 힘을 흘렸다. 손이 등에 닿았다.' },
      { type: 'text', speaker: '', text: '팔 하나가 꺾였다.' },
      { type: 'text', speaker: '', text: '소리가 났다.' },
      { type: 'text', speaker: '', text: '두 번째가 옆에서 왔다.' },
      { type: 'text', speaker: '', text: '호가 아래로 내려갔다. 발이 다리를 쓸었다. 넘어졌다.' },
      { type: 'text', speaker: '', text: '세 번째가 칼을 들었다.' },
      { type: 'text', speaker: '', text: '호가 멈췄다.' },
      { type: 'text', speaker: '', text: '칼이 문제였다.' },
      { type: 'text', speaker: '', text: '칼을 맨손으로 다루는 건 다른 문제였다.' },
      { type: 'text', speaker: '', text: '뒤의 둘도 움직이기 시작했다.' },
      { type: 'text', speaker: '', text: '나는 앞으로 나갔다.' },
      { type: 'text', speaker: '', text: '뒤의 둘 사이로.' },
      { type: 'effect', effect: 'shake' },
      { type: 'combat', enemy: {"name":"저택 호위무사","hp":100,"attack":13} },
      { type: 'text', speaker: '', text: '왜소한 신이 어딘가에서 나타났다. 그 작은 몸이 도적의 발목 옆을 스치며 지나갔다. 보이지 않는 손이 복사뼈를 건드린 것처럼 도적의 발이 꼬였다. 넘어졌다.' },
      { type: 'text', speaker: '', text: '나는 나머지 하나를 처리했다.' },
      { type: 'text', speaker: '', text: '칼을 든 셋이 문제였다.' },
      { type: 'text', speaker: '', text: '"호."' },
      { type: 'text', speaker: '', text: '"봐요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"칼 든 사람은 칼을 쓸 때 팔꿈치가 먼저예요."' },
      { type: 'text', speaker: '', text: '"......"' },
      { type: 'text', speaker: '', text: '"팔꿈치가 올라가면 칼이 올라가는 거예요. 그 전에 들어가면 돼요."' },
      { type: 'text', speaker: '', text: '"그 전이 너무 짧아요."' },
      { type: 'text', speaker: '', text: '"보면 돼요."' },
      { type: 'text', speaker: '', text: '칼을 든 사람이 움직였다.' },
      { type: 'text', speaker: '', text: '팔꿈치가 올라가는 순간.' },
      { type: 'text', speaker: '', text: '호가 파고들었다.' },
      { type: 'text', speaker: '', text: '가슴팍으로. 팔 안쪽으로.' },
      { type: 'text', speaker: '', text: '칼을 쓸 수 없는 거리로.' },
      { type: 'text', speaker: '', text: '어깨로 밀었다.' },
      { type: 'text', speaker: '', text: '주먹이 한 번.' },
      { type: 'text', speaker: '', text: '명치에.' },
      { type: 'text', speaker: '', text: '칼 든 사람이 꺾였다.' },
      { type: 'text', speaker: '', text: '나머지 둘도 처리됐다.' },
      { type: 'text', speaker: '', text: '다섯이 바닥에 있었다. 호가 서 있는 자리 주변으로 풀잎에 서리가 내려 있었다. 한낮인데. 호의 주먹이 지나간 궤적을 따라, 공기가 차갑게 식어 있었다. 서리의 범위가 반경 다섯 걸음이었다. 3성의 기운이 전투 중 무의식으로 퍼진 것이었다. 호는 그걸 눈치채지 못했다.' },
      { type: 'text', speaker: '', text: '한참 후에.' },
      { type: 'text', speaker: '', text: '호가 나한테 물었다.' },
      { type: 'text', speaker: '백호', text: '"어깨요."' },
      { type: 'text', speaker: '', text: '나는 호의 어깨를 봤다. 칼이 스친 자국이 있었다. 얕은 상처. 옷이 찢겼다.' },
      { type: 'text', speaker: '백호', text: '"얕아요?"' },
      { type: 'text', speaker: '', text: '"얕아요."' },
      { type: 'text', speaker: '', text: '"아파요?"' },
      { type: 'text', speaker: '', text: '"......조금이요."' },
      { type: 'text', speaker: '', text: '나는 천으로 어깨를 감았다.' },
      { type: 'text', speaker: '', text: '호가 가만히 있었다.' },
      { type: 'text', speaker: '백호', text: '"아프면 말해도 돼요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"여기서는요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"......나쁘지 않아요. 그 말."' },
      { type: 'text', speaker: '', text: '왜소한 신이 다가왔다. 호의 어깨 근처에서 잠깐 멈췄다. 그 작은 손이 어깨 천 위에 살짝 닿았다.' },
      { type: 'text', speaker: '', text: '차갑고 따뜻한.' },
      { type: 'text', speaker: '', text: '이상한 온도.' },
      { type: 'text', speaker: '', text: '호가 고개를 들었다.' },
      { type: 'text', speaker: '', text: '길이 이어졌다.' },
      { type: 'text', speaker: '', text: '"가요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '호가 먼저 걷기 시작했다.' },
      { type: 'text', speaker: '', text: '뒷모습이.' },
      { type: 'text', speaker: '', text: '조금 전보다.' },
      { type: 'text', speaker: '', text: '더 가벼워 보였다.' },
      { type: 'text', speaker: '', text: '그날 저녁.' },
      { type: 'text', speaker: '', text: '된장찌개를 끓였다.' },
      { type: 'text', speaker: '', text: '마을 장터에서 된장을 샀다. 채소를 샀다. 두부도 샀다.' },
      { type: 'text', speaker: '', text: '호가 옆에 앉아서 봤다.' },
      { type: 'text', speaker: '백호', text: '"된장찌개예요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '호가 냄새를 맡았다.' },
      { type: 'text', speaker: '백호', text: '"짜요."' },
      { type: 'text', speaker: '', text: '"아직 끓지도 않았는데요."' },
      { type: 'text', speaker: '', text: '"냄새가 짜요."' },
      { type: 'text', speaker: '', text: '나는 된장을 좀 덜어냈다. 물을 더 붓고. 채소를 넣고. 두부를 썰어서 넣고. 끓이기 시작했다.' },
      { type: 'text', speaker: '', text: '"저 사실 된장찌개 별로 안 좋아해요."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"저택에서 가장 싸게 먹인 게 된장찌개였어요. 국물에 밥 말아서요."' },
      { type: 'text', speaker: '', text: '"......아."' },
      { type: 'text', speaker: '', text: '"그래서 된장 냄새 나면 기분이 안 좋아요."' },
      { type: 'text', speaker: '', text: '나는 냄비를 봤다.' },
      { type: 'text', speaker: '', text: '"그러면 다른 걸——"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '"싫다면서요."' },
      { type: 'text', speaker: '', text: '"싫었어요. 지금 어떨지는 먹어봐야 알죠."' },
      { type: 'text', speaker: '', text: '호가 숟가락을 들었다.' },
      { type: 'text', speaker: '', text: '한 번.' },
      { type: 'text', speaker: '', text: '두 번.' },
      { type: 'text', speaker: '', text: '"......짜지 않네요."' },
      { type: 'text', speaker: '', text: '"다행이네요."' },
      { type: 'text', speaker: '', text: '"두부가 부드러워요."' },
      { type: 'text', speaker: '', text: '"저택 된장찌개는 두부가 딱딱했어요. 오래 끓여서요."' },
      { type: 'text', speaker: '', text: '호가 세 번째로 먹었다.' },
      { type: 'text', speaker: '백호', text: '"......맛있어요."' },
      { type: 'text', speaker: '', text: '작게.' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '나는 물었다.' },
      { type: 'text', speaker: '', text: '"된장찌개 기억 바뀔 것 같아요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"......모르겠어요. 아직은요."' },
      { type: 'text', speaker: '', text: '"그러면 자주 먹어요."' },
      { type: 'text', speaker: '', text: '"자주요?"' },
      { type: 'text', speaker: '', text: '"좋은 기억이 많아지면 나쁜 기억이 작아져요."' },
      { type: 'text', speaker: '', text: '호가 그 말을 씹었다.' },
      { type: 'text', speaker: '백호', text: '"......그런가요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 냄비 옆에 앉았다. 보글보글 끓는 걸 봤다.' },
      { type: 'text', speaker: '', text: '호가 그 아이한테 두부 한 점을 줬다.' },
      { type: 'text', speaker: '백호', text: '"좋아해요?"' },
      { type: 'text', speaker: '', text: '왜소한 신이 끄덕였다.' },
      { type: 'text', speaker: '', text: '"그러면 더 줄게요."' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '"......고마워요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"이유는 없어요. 그냥이요."' },
      { type: 'text', speaker: '', text: '이유 없이 고맙다는 말.' },
      { type: 'text', speaker: '', text: '어떤 이유 있는 감사보다 무거웠다.' },
      { type: 'text', speaker: '', text: '그 밤.' },
      { type: 'text', speaker: '', text: '불이 조용히 탔다. 셋이서 아무 말 없이 앉아 있는 시간이 길어졌다. 그 침묵이 어색하지 않았다. 그런 침묵이 생겼다는 게 변화였다.' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"제가 저택에서요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"좋아하는 게 있었어요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"뭐요."' },
      { type: 'text', speaker: '', text: '"밤이요."' },
      { type: 'text', speaker: '', text: '"밤이요?"' },
      { type: 'text', speaker: '', text: '"낮에는 일해야 했어요. 하녀 수장한테 혼날 수도 있었고. 마님한테 불려갈 수도 있었고. 밤에는요. 다 자면요. 아무것도 없었어요."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"그게 제 시간이었어요. 아무도 뭘 시키지 않는 시간이요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '제 시간.' },
      { type: 'text', speaker: '', text: '저택에서 유일하게 자신의 것이었던 시간.' },
      { type: 'text', speaker: '', text: '그게 밤이었다는 것.' },
      { type: 'text', speaker: '', text: '"지금은요?"' },
      { type: 'text', speaker: '', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"지금은 전부 제 시간이에요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '전부 제 시간이에요.' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '오래 남았다.' },
      { type: 'text', speaker: '', text: '"그거 알아요?"' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"뭐요."' },
      { type: 'text', speaker: '', text: '"저택에서의 밤이 지금 여기 있다는 거요."' },
      { type: 'text', speaker: '', text: '"무슨 말이에요."' },
      { type: 'text', speaker: '', text: '"그때 밤마다 혼자 앉아서 버텼잖아요. 그게 지금 여기 있는 호를 만든 거예요."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"......그 말이요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"당신이 한 말 중에 좋은 것들에 들어가요."' },
      { type: 'text', speaker: '', text: '"세고 있어요?"' },
      { type: 'text', speaker: '', text: '"세고 있어요."' },
      { type: 'text', speaker: '', text: '나는 웃었다.' },
      { type: 'text', speaker: '', text: '"몇 개예요?"' },
      { type: 'text', speaker: '', text: '"아직 안 알려줘요."' },
      { type: 'text', speaker: '', text: '"언제요."' },
      { type: 'text', speaker: '', text: '"때 되면요."' },
      { type: 'effect', effect: 'system', text: '【 호감도 5단계. 유대 에너지: 7 → 12. 】' },
      { type: 'effect', effect: 'system', text: '【 호감도 이벤트 가능. 백호의 감정 변화: \'신뢰\' → \'애착 형성 중\'. 】' },
      { type: 'text', speaker: '', text: '그 밤 늦게.' },
      { type: 'text', speaker: '', text: '호가 잠들기 전에.' },
      { type: 'text', speaker: '백호', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"저 사실."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름 불러준 게요. 아무도 없었어요."' },
      { type: 'text', speaker: '', text: '"호라는 이름요?"' },
      { type: 'text', speaker: '', text: '"아니요. 다른 이름이요."' },
      { type: 'text', speaker: '', text: '나는 잠시 있었다.' },
      { type: 'text', speaker: '', text: '"다른 이름이 있어요?"' },
      { type: 'text', speaker: '', text: '호가 머뭇거렸다.' },
      { type: 'text', speaker: '', text: '호가 머뭇거리는 걸 본 건 이번이 두 번째였다.' },
      { type: 'text', speaker: '백호', text: '"어렸을 때. 혼자서 지은 이름이 있어요."' },
      { type: 'text', speaker: '', text: '"혼자서요?"' },
      { type: 'text', speaker: '', text: '"저한테만 있는 이름이요. 아무도 부른 적 없는."' },
      { type: 'text', speaker: '', text: '"어떤 이름이에요?"' },
      { type: 'text', speaker: '', text: '"명이요."' },
      { type: 'text', speaker: '', text: '"명."' },
      { type: 'text', speaker: '', text: '"응. 밝을 명이요. 저 스스로 지었어요."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"밝고 싶어서요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '저택에서 두 해를 살면서.' },
      { type: 'text', speaker: '', text: '혼자 이름을 지었다.' },
      { type: 'text', speaker: '', text: '밝고 싶어서.' },
      { type: 'text', speaker: '', text: '아무도 부를 사람이 없었으니까.' },
      { type: 'text', speaker: '', text: '아무도 부를 사람이 없는 이름을.' },
      { type: 'text', speaker: '', text: '혼자.' },
      { type: 'text', speaker: '', text: '스스로.' },
      { type: 'text', speaker: '', text: '지었다.' },
      { type: 'text', speaker: '', text: '"명."' },
      { type: 'text', speaker: '', text: '내가 불렀다.' },
      { type: 'text', speaker: '', text: '호가 멈췄다.' },
      { type: 'text', speaker: '', text: '뺨이 조금 붉어졌다.' },
      { type: 'text', speaker: '', text: '"......일부러 그렇게 부드럽게 부른 거예요?"' },
      { type: 'text', speaker: '', text: '"그냥 불렀어요."' },
      { type: 'text', speaker: '', text: '"그냥이 그렇게 나와요?"' },
      { type: 'text', speaker: '', text: '"이름이 좋으면 그렇게 불러지는 것 같아요."' },
      { type: 'text', speaker: '', text: '호가 고개를 돌렸다.' },
      { type: 'text', speaker: '백호', text: '"......됐어요."' },
      { type: 'text', speaker: '', text: '"됐어요?"' },
      { type: 'text', speaker: '', text: '"부르는 거 들었어요."' },
      { type: 'text', speaker: '', text: '"또 불러도 돼요?"' },
      { type: 'text', speaker: '', text: '"......마음대로 해요."' },
      { type: 'text', speaker: '', text: '호가 별을 봤다.' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"명."' },
      { type: 'text', speaker: '', text: '"......"' },
      { type: 'text', speaker: '', text: '"명."' },
      { type: 'text', speaker: '', text: '"그만해요."' },
      { type: 'text', speaker: '', text: '"싫어요?"' },
      { type: 'text', speaker: '', text: '"싫지 않으니까 그만하라는 거예요."' },
      { type: 'text', speaker: '', text: '나는 이해했다.' },
      { type: 'text', speaker: '', text: '너무 좋으면 티가 나니까.' },
      { type: 'text', speaker: '', text: '티를 들키는 게 싫으니까.' },
      { type: 'text', speaker: '', text: '"명."' },
      { type: 'text', speaker: '', text: '"그만하라고요!"' },
      { type: 'text', speaker: '', text: '호가 돌아봤다.' },
      { type: 'text', speaker: '', text: '귀가 빨간 얼굴로.' },
      { type: 'text', speaker: '', text: '나는 아무 말 안 했다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 고개를 돌렸다.' },
      { type: 'text', speaker: '', text: '어딜 보는 건지.' },
      { type: 'text', speaker: '', text: '하늘인지 땅인지.' },
      { type: 'text', speaker: '', text: '그러나 그 아이의 눈이 웃는 것 같기도 했다.' },
      { type: 'text', speaker: '', text: '호가 다시 별을 봤다.' },
      { type: 'text', speaker: '백호', text: '"......당신이 한 말 중에 좋은 게 있어요."' },
      { type: 'text', speaker: '', text: '"뭐가요?"' },
      { type: 'text', speaker: '', text: '"나중에 알려줄게요."' },
      { type: 'text', speaker: '', text: '"언제요."' },
      { type: 'text', speaker: '', text: '"때 되면요."' },
      { type: 'text', speaker: '', text: '"그건 제 말 방식이잖아요."' },
      { type: 'text', speaker: '', text: '"빌렸어요."' },
      { type: 'text', speaker: '', text: '"잘 썼어요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '호가 짧게 웃었다.' },
      { type: 'text', speaker: '', text: '여전히 짧은 웃음이었지만.' },
      { type: 'text', speaker: '', text: '이제는 조금.' },
      { type: 'text', speaker: '', text: '덜 짧아졌다.' },
      { type: 'text', speaker: '', text: '그 웃음이.' },
      { type: 'text', speaker: '', text: '불빛 안에서.' },
      { type: 'text', speaker: '', text: '선명했다.' },
      { type: 'text', speaker: '', text: '나는 그 선명함을.' },
      { type: 'text', speaker: '', text: '오래 봤다.' },
      { type: 'text', speaker: '', text: '그 밤 늦게.' },
      { type: 'text', speaker: '', text: '호가 잠들기 전에.' },
      { type: 'text', speaker: '백호', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"저 사실."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름 불러준 사람이 당신이 처음이에요. 그 이름으로."' },
      { type: 'text', speaker: '', text: '"명이요?"' },
      { type: 'text', speaker: '', text: '"응. 아무도 부른 적 없어서."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"......오래됐어요?"' },
      { type: 'text', speaker: '', text: '"오래됐어요. 어릴 때 지었으니까요."' },
      { type: 'text', speaker: '', text: '"왜 저한테는 말했어요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 있었다.' },
      { type: 'text', speaker: '백호', text: '"......그냥 말하고 싶었어요. 오늘은."' },
      { type: 'text', speaker: '', text: '"......고마워요. 말해줘서."' },
      { type: 'text', speaker: '', text: '호가 눈을 감았다.' },
      { type: 'text', speaker: '백호', text: '"자요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"......잘 자요."' },
      { type: 'text', speaker: '', text: '짧게.' },
      { type: 'text', speaker: '', text: '잠들기 직전에.' },
      { type: 'text', speaker: '', text: '먼저.' },
      { type: 'text', speaker: '', text: '인사를 했다.' },
      { type: 'text', speaker: '', text: '나는 속으로 웃었다.' },
      { type: 'text', speaker: '', text: '그리고 오래.' },
      { type: 'text', speaker: '', text: '그 인사를 들었다.' },
      { type: 'text', speaker: '', text: '그때는 몰랐다.' },
      { type: 'text', speaker: '', text: '먼저 인사를 한 것이.' },
      { type: 'text', speaker: '', text: '얼마나 큰 변화였는지.' },
      { type: 'text', speaker: '', text: '저택에서 두 해.' },
      { type: 'text', speaker: '', text: '먼저 인사를 한 적이 없었다.' },
      { type: 'text', speaker: '', text: '먼저 말을 건 적이 없었다.' },
      { type: 'text', speaker: '', text: '먼저 나눠준 적이 없었다.' },
      { type: 'text', speaker: '', text: '먼저 고맙다고 한 적이 없었다.' },
      { type: 'text', speaker: '', text: '저택에서 먼저 하는 것은.' },
      { type: 'text', speaker: '', text: '위험한 일이었다.' },
      { type: 'text', speaker: '', text: '먼저 말하면. 먼저 튀면. 먼저 눈에 띄면.' },
      { type: 'text', speaker: '', text: '무언가가 왔다.' },
      { type: 'text', speaker: '', text: '혼나거나. 무시당하거나. 이용당하거나.' },
      { type: 'text', speaker: '', text: '그래서 먼저 하지 않았다.' },
      { type: 'text', speaker: '', text: '하지 않는 게 익숙해졌다.' },
      { type: 'text', speaker: '', text: '그런데.' },
      { type: 'text', speaker: '', text: '잘 자요.' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '먼저 나왔다.' },
      { type: 'text', speaker: '', text: '나는 그날 밤에 생각했다.' },
      { type: 'text', speaker: '', text: '호가 달라지고 있다.' },
      { type: 'text', speaker: '', text: '그리고 나도.' },
      { type: 'text', speaker: '', text: '처음에는 시스템이 시키는 대로 하는 것이 전부였다. 신수를 각성시키는 것. 그게 목표였다.' },
      { type: 'text', speaker: '', text: '하지만 지금은. 호가 먼저 인사를 했다는 것이 좋았다. 왜소한 신의 손을 잡았다는 것이 좋았다. 자신의 이름을 말했다는 것이 좋았다.' },
      { type: 'text', speaker: '', text: '목표가 있어야 움직이는 것이.' },
      { type: 'text', speaker: '', text: '지금은.' },
      { type: 'text', speaker: '', text: '목표 없이도.' },
      { type: 'text', speaker: '', text: '이 아이와 있고 싶다는 것이 있었다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '뭔지.' },
      { type: 'text', speaker: '', text: '나는 몰랐다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에서 눈을 감았다.' },
      { type: 'text', speaker: '', text: '"뭔지 알아?"' },
      { type: 'text', speaker: '', text: '내가 물었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 눈을 반쯤 뜨고 나를 봤다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '슬며시 내 발치에 더 가까이 붙어 앉았다.' },
      { type: 'text', speaker: '', text: '"......그렇군요."' },
      { type: 'text', speaker: '', text: '나는 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '별이 많았다.' },
      { type: 'text', speaker: '', text: '호가 매일 보던 별.' },
      { type: 'text', speaker: '', text: '저택 담장 너머로 봤던 별.' },
      { type: 'text', speaker: '', text: '지금은.' },
      { type: 'text', speaker: '', text: '아무것도 가리지 않는 별.' },
      { type: 'text', speaker: '', text: '나는 그 별을 오래 봤다.' },
      { type: 'text', speaker: '', text: '뭔지는 모르지만.' },
      { type: 'text', speaker: '', text: '이 아이 옆에 있는 게.' },
      { type: 'text', speaker: '', text: '좋다는 것만은.' },
      { type: 'text', speaker: '', text: '알았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 갑자기 멈췄다. 걷던 발이 멈추고, 먼 곳을 봤다. 산 너머를. 바람이 불어오는 쪽을. 그 작은 눈에 경계 같은 것이 비쳤다. 며칠 전부터 가끔 보이던 표정이었는데, 오늘은 유독 선명했다.' },
      { type: 'text', speaker: '', text: '그때였다. 시스템 창이 떴다. 이전과는 다른 색이었다. 붉은 빛.' },
      { type: 'effect', effect: 'system', text: '【 경고: 외부 세력 접근 감지. 백호의 존재가 노출되었습니다. 】' },
      { type: 'effect', effect: 'system', text: '【 대응 권고: 이동 경로 변경 또는 전투 준비. 유대 에너지 잔량: 12. 위기 시 소환 가능. 】' },
      { type: 'text', speaker: '', text: '나는 잠든 호를 봤다. 왜소한 신이 같은 방향을 봤다. 바람이 달라졌다. 찬바람이었다. 계절이 바뀌는 것이 아니라, 뭔가가 오고 있는 바람이었다.' },
      { type: 'text', speaker: '', text: '유대 에너지 12. 쓸 수 있는 양이 충분한지 모르겠다. 하지만 이 아이를 지키는 데 부족하다면, 숫자가 아닌 것으로 채울 것이다.' },
    ]
  },
  {
    title: '6장 — 세어봤어요',
    nodes: [
      { type: 'effect', effect: 'system', text: '【 백호 성장 단계: 3성 → 4성 진입 】' },
      { type: 'effect', effect: 'system', text: '【 호감도 7단계. 감정 변화: \'애착\' → \'의존과 저항 사이\'. 】' },
      { type: 'effect', effect: 'system', text: '【 호감도 7단계 이벤트 발동. 】' },
      { type: 'effect', effect: 'system', text: '【 4성 보너스: 신체 강화 +15%, 감각 범위 확장. 】' },
      { type: 'text', speaker: '', text: '넉 달.' },
      { type: 'text', speaker: '', text: '4성이 됐다.' },
      { type: 'text', speaker: '', text: '시스템 창을 보면서 나는 생각했다.' },
      { type: 'text', speaker: '', text: '빠르다.' },
      { type: 'text', speaker: '', text: '아주 빠르다.' },
      { type: 'text', speaker: '', text: '원래 이렇게 빠른 건지, 아니면 호가 유독 빠른 건지.' },
      { type: 'text', speaker: '', text: '후자 같았다.' },
      { type: 'text', speaker: '', text: '호는 느리게 배우지 않는다. 배우기 싫다고 저항하다가, 이해가 되면 즉시 흡수한다. 마치 마른 땅이 비를 먹듯이. 그 속도가 무서울 정도였다.' },
      { type: 'text', speaker: '', text: '문제는.' },
      { type: 'text', speaker: '', text: '이해가 되기 전까지는.' },
      { type: 'text', speaker: '', text: '정말 듣지 않는다는 것이지만.' },
      { type: 'text', speaker: '', text: '그것도 이제는 알았다.' },
      { type: 'text', speaker: '', text: '기다리면 됐다.' },
      { type: 'text', speaker: '', text: '이 아이는.' },
      { type: 'text', speaker: '', text: '기다리면 온다.' },
      { type: 'text', speaker: '', text: '4성이 되기까지 넉 달이었다.' },
      { type: 'text', speaker: '', text: '그 넉 달 동안.' },
      { type: 'text', speaker: '', text: '좋은 것들이 있었다.' },
      { type: 'text', speaker: '', text: '아침에 연습하다가 호가 처음으로 "됐다"고 외쳤던 것.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호가 뭔가를 잘 할 때마다 항상 고개를 끄덕인다는 것.' },
      { type: 'text', speaker: '', text: '처음으로 호가 먼저 된장찌개를 만들어줬던 날.' },
      { type: 'text', speaker: '백호', text: '"오늘은 제가 해요."' },
      { type: 'text', speaker: '', text: '"제가 해도 돼요."' },
      { type: 'text', speaker: '', text: '"아니요, 이번엔 제가요."' },
      { type: 'text', speaker: '', text: '그리고 끓인 된장찌개가.' },
      { type: 'text', speaker: '', text: '내가 끓인 것보다 맛있었다는 것.' },
      { type: 'text', speaker: '', text: '"어떻게 그렇게 잘 해요?"' },
      { type: 'text', speaker: '', text: '"저택에서 배웠으니까요."' },
      { type: 'text', speaker: '', text: '호가 그 말을 할 때.' },
      { type: 'text', speaker: '', text: '저택이라는 단어가.' },
      { type: 'text', speaker: '', text: '처음으로.' },
      { type: 'text', speaker: '', text: '그냥 나왔다.' },
      { type: 'text', speaker: '', text: '쓰게 씹히는 것 없이.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '사실처럼.' },
      { type: 'text', speaker: '', text: '그게 달라진 것이었다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '훈련 중에 호가 처음으로 내 방법을 인정한 날.' },
      { type: 'text', speaker: '백호', text: '"당신 방법이 맞는 것 같아요."' },
      { type: 'text', speaker: '', text: '"어떤 게요."' },
      { type: 'text', speaker: '', text: '"기다리는 것이요. 상대가 먼저 치고 나올 때 기다렸다가 들어가는 것이요."' },
      { type: 'text', speaker: '', text: '"그게 안 됐었잖아요."' },
      { type: 'text', speaker: '', text: '"이제 되잖아요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"기다리면 되니까요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '기다리면 된다는 말을 호가 했다.' },
      { type: 'text', speaker: '', text: '이 아이가.' },
      { type: 'text', speaker: '', text: '기다린다는 것을 배웠다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '작은 것 같아도.' },
      { type: 'text', speaker: '', text: '큰 것이었다.' },
      { type: 'text', speaker: '', text: '4성이 되면서 새로운 것이 나타났다.' },
      { type: 'text', speaker: '', text: '시스템 창에 처음 보는 항목이 떴다.' },
      { type: 'effect', effect: 'system', text: '【 기감(氣感) 해금. 잠재 도술 적성: S. 】' },
      { type: 'text', speaker: '', text: '기.' },
      { type: 'text', speaker: '', text: 'S등급. 지금까지 본 적 없는 수치였다. 이 아이 안에 잠든 것이 얼마나 큰지, 숫자가 말하고 있었다.' },
      { type: 'text', speaker: '', text: '아직 도술은 아니었다. 하지만 손끝에 뭔가가 맺히는 느낌이 있었다.' },
      { type: 'text', speaker: '', text: '"손이 이상해요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '아침에 눈을 뜨자마자.' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"뭔가 있는 것 같아요. 손끝에."' },
      { type: 'text', speaker: '', text: '"잡아봐요."' },
      { type: 'text', speaker: '', text: '"뭘요."' },
      { type: 'text', speaker: '', text: '"손끝에 있는 거요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"말이 안 되는 소리예요."' },
      { type: 'text', speaker: '', text: '"해봐요."' },
      { type: 'text', speaker: '', text: '호가 오른손을 들었다. 손끝을 봤다.' },
      { type: 'text', speaker: '', text: '집중했다.' },
      { type: 'text', speaker: '', text: '한참.' },
      { type: 'text', speaker: '', text: '"......아무것도 없어요."' },
      { type: 'text', speaker: '', text: '"될 때까지요."' },
      { type: 'text', speaker: '', text: '"얼마나요."' },
      { type: 'text', speaker: '', text: '"될 때까지요."' },
      { type: 'text', speaker: '', text: '"그게 무슨 기준이에요."' },
      { type: 'text', speaker: '', text: '"될 때 알아요."' },
      { type: 'text', speaker: '', text: '호가 한숨을 쉬었다.' },
      { type: 'text', speaker: '', text: '그리고 다시 집중했다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 옆에서 봤다. 그 눈이 호의 손끝을 봤다. 뭔가를 알아보는 눈이었다. 처음 보는 것이 아닌 것 같은.' },
      { type: 'text', speaker: '', text: '한참 후에.' },
      { type: 'text', speaker: '', text: '호의 손끝에서.' },
      { type: 'text', speaker: '', text: '아주 희미하게.' },
      { type: 'text', speaker: '', text: '빛이 맺혔다.' },
      { type: 'text', speaker: '', text: '하얗게.' },
      { type: 'text', speaker: '', text: '달빛 색으로.' },
      { type: 'text', speaker: '', text: '"느껴져요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"어때요?"' },
      { type: 'text', speaker: '', text: '"차가워요. 그런데 따뜻해요."' },
      { type: 'text', speaker: '', text: '"둘 다요?"' },
      { type: 'text', speaker: '', text: '"둘 다요."' },
      { type: 'text', speaker: '', text: '"이상해요?"' },
      { type: 'text', speaker: '', text: '"이상해요. 하지만."' },
      { type: 'text', speaker: '', text: '호가 손을 봤다.' },
      { type: 'text', speaker: '백호', text: '"이게 제 것 같아요."' },
      { type: 'text', speaker: '', text: '"맞아요."' },
      { type: 'text', speaker: '', text: '"어떻게 알아요."' },
      { type: 'text', speaker: '', text: '"당신만의 감각이에요."' },
      { type: 'text', speaker: '', text: '호가 손끝의 빛을 봤다.' },
      { type: 'text', speaker: '', text: '흰빛.' },
      { type: 'text', speaker: '', text: '달빛.' },
      { type: 'text', speaker: '', text: '그게 조금씩.' },
      { type: 'text', speaker: '', text: '선명해졌다.' },
      { type: 'text', speaker: '', text: '이건 시작이었다. 이 빛이 어디까지 갈지, 아직 아무도 모르는.' },
      { type: 'text', speaker: '', text: '왜소한 신이 그 장면을 보다가.' },
      { type: 'text', speaker: '', text: '슬그머니 내 쪽으로 왔다.' },
      { type: 'text', speaker: '', text: '내 발목에 기댔다.' },
      { type: 'text', speaker: '', text: '작은 몸이 따뜻했다.' },
      { type: 'text', speaker: '', text: '그 후로 열흘. 호가 손끝의 빛에 익숙해질 무렵, 몸도 달라졌다. 아침에 연습하면 나무를 잡을 때 손가락이 파고드는 깊이가 전과 달랐다. 4성의 감각은 조용히, 그러나 확실하게 호의 몸에 스며들고 있었다.' },
      { type: 'text', speaker: '', text: '마을에서 무술 대회 소문이 돌았다. 장터에서부터 들렸다. 호가 그 소문을 듣고 눈이 달라졌다. 뭔가를 찾은 눈이었다.' },
      { type: 'text', speaker: '', text: '대회 날.' },
      { type: 'text', speaker: '', text: '호가 나갔다.' },
      { type: 'text', speaker: '', text: '나는 출전을 말리지 않았다.' },
      { type: 'text', speaker: '', text: '이제는 알기 때문에.' },
      { type: 'text', speaker: '', text: '이 아이를 말리는 건 이 아이를 막는 것이라는 걸.' },
      { type: 'text', speaker: '', text: '막는 대신 따라갔다.' },
      { type: 'text', speaker: '', text: '예선은 세 경기.' },
      { type: 'text', speaker: '', text: '첫 번째 상대는 덩치가 컸다. 힘으로 밀어붙이는 타입이었다. 호가 옆으로 한 발 비키자 주먹이 허공을 갈랐고, 되돌아오기 전에 뒤로 돌아 어깨를 쳤다. 끝이었다.' },
      { type: 'text', speaker: '', text: '두 번째 상대는 빨랐다. 주먹이 두 개가 동시에 오는 것처럼 보였다. 하지만 호의 눈이 왼손이 먼저라는 걸 읽었다. 왼손을 흘려보내고 열린 옆구리에 손바닥을 넣었다. 상대가 무릎을 짚었다.' },
      { type: 'text', speaker: '', text: '세 번 다. 어렵지 않게.' },
      { type: 'text', speaker: '', text: '상대가 없다기보다, 호의 눈이 너무 잘 읽었다. 공격이 오기 전에 이미 어디로 올지 알고 있었다.' },
      { type: 'text', speaker: '', text: '예선 세 번째 경기.' },
      { type: 'text', speaker: '', text: '호가 상대의 왼발이 먼저 움직이는 걸 보면서.' },
      { type: 'text', speaker: '', text: '이미 오른쪽으로 비켜 있었다.' },
      { type: 'text', speaker: '', text: '상대가 허공을 친 뒤에.' },
      { type: 'text', speaker: '', text: '호의 손바닥이 그 등을 밀었다. 가볍게 보였지만, 상대의 몸이 공중에 뜬 것처럼 밀려났다.' },
      { type: 'text', speaker: '', text: '4성의 힘이었다. 보이는 것보다 묵직한. 열셋의 몸에서 나올 수 없는 무게가 실렸다.' },
      { type: 'text', speaker: '', text: '넘어졌다.' },
      { type: 'text', speaker: '', text: '구경하던 사람들이 웅성였다.' },
      { type: 'text', speaker: '', text: '"어이, 저 아이 보셨어요?"' },
      { type: 'text', speaker: '', text: '"어디서 온 애야?"' },
      { type: 'text', speaker: '', text: '"세 번 다 그랬잖아, 미리 알고 있는 것처럼."' },
      { type: 'text', speaker: '', text: '호는 그 소리들을 들었다.' },
      { type: 'text', speaker: '', text: '표정이 달라지지 않았다.' },
      { type: 'text', speaker: '', text: '당연하다는 얼굴이었다.' },
      { type: 'text', speaker: '', text: '"너무 일찍 읽혀요."' },
      { type: 'text', speaker: '', text: '경기 후에 호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"그게 실력이에요."' },
      { type: 'text', speaker: '', text: '"그렇긴 한데, 재미가 없어요."' },
      { type: 'text', speaker: '', text: '"재미요?"' },
      { type: 'text', speaker: '', text: '"긴장감이 없어요. 읽히면."' },
      { type: 'text', speaker: '', text: '"긴장감을 원해요?"' },
      { type: 'text', speaker: '', text: '"원해요. 그래야 좋잖아요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '호가 긴장감을 즐기는 쪽이라는 걸.' },
      { type: 'text', speaker: '', text: '그게 이 아이가 강해지는 방식이라는 걸.' },
      { type: 'text', speaker: '', text: '"강해질수록 그게 문제예요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"읽는 수준이 올라갈수록 비슷한 수준이 없어져요."' },
      { type: 'text', speaker: '', text: '"그러면요?"' },
      { type: 'text', speaker: '', text: '"더 강한 상대를 찾아야 해요."' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"그러면 오늘 결승 상대는요?"' },
      { type: 'text', speaker: '', text: '결승 상대는 이 지역에서 이름 있는 검사였다. 나이가 있었고, 수십 년을 갈고닦았다는 사람이었다.' },
      { type: 'text', speaker: '', text: '"긴장감이 있을 거예요."' },
      { type: 'text', speaker: '', text: '"있을 것 같아요?"' },
      { type: 'text', speaker: '', text: '"있어요."' },
      { type: 'text', speaker: '', text: '호가 고개를 끄덕였다.' },
      { type: 'text', speaker: '백호', text: '"가요."' },
      { type: 'text', speaker: '', text: '결승전.' },
      { type: 'text', speaker: '', text: '검사가 앞에 섰다.' },
      { type: 'text', speaker: '', text: '나이가 있었다. 머리가 반백이고 눈이 깊었다.' },
      { type: 'text', speaker: '', text: '호가 앞에 섰다.' },
      { type: 'text', speaker: '', text: '열세 살.' },
      { type: 'text', speaker: '', text: '하녀 옷에서 바꾼 지 한 달밖에 안 된 옷.' },
      { type: 'text', speaker: '', text: '아직 작은 몸.' },
      { type: 'text', speaker: '', text: '검사가 위아래로 봤다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '천천히.' },
      { type: 'text', speaker: '', text: '"아이가 여기까지 올라왔군."' },
      { type: 'text', speaker: '', text: '그 웃음이 비웃음이 아니었다. 진심으로 놀라는 것 같았다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '호가 그 말을 들었다.' },
      { type: 'text', speaker: '백호', text: '"어른이 아이한테 지면 부끄럽겠네요."' },
      { type: 'text', speaker: '', text: '검사의 표정이 달라졌다.' },
      { type: 'text', speaker: '', text: '비웃음이 아니었던 게 이제 진지한 얼굴이 됐다.' },
      { type: 'text', speaker: '', text: '"그런 말을 들어볼 줄 몰랐군."' },
      { type: 'text', speaker: '', text: '"이기면 어차피 들을 말이에요. 미리 해요."' },
      { type: 'text', speaker: '', text: '검사가 짧게 웃었다.' },
      { type: 'text', speaker: '', text: '이번엔 진짜 웃음이었다.' },
      { type: 'text', speaker: '', text: '"좋아. 시작하자."' },
      { type: 'text', speaker: '', text: '전투가 시작됐다.' },
      { type: 'text', speaker: '', text: '검사의 칼이 빠르게 들어왔다.' },
      { type: 'text', speaker: '', text: '바람이 잘렸다. 칼바람이 아니라, 진짜로 공기가 갈라지는 소리가 났다. 피부가 먼저 알았다. 날이 오기 전에 바람이 먼저 얼굴을 스쳤다.' },
      { type: 'text', speaker: '', text: '호가 옆으로 비켰다.' },
      { type: 'text', speaker: '', text: '간신히였다.' },
      { type: 'text', speaker: '', text: '첫 합.' },
      { type: 'text', speaker: '', text: '검사의 칼이 또 왔다.' },
      { type: 'text', speaker: '', text: '이번엔 방향이 달랐다. 첫 번째와 연결되는 움직임이었다. 예측하기 어려운 연속 공격.' },
      { type: 'text', speaker: '', text: '호가 뒤로 물러났다.' },
      { type: 'text', speaker: '', text: '칼끝이 어깨 앞을 스쳤다.' },
      { type: 'text', speaker: '', text: '아슬아슬했다.' },
      { type: 'text', speaker: '', text: '두 번째 합.' },
      { type: 'text', speaker: '', text: '호가 표정을 봤다.' },
      { type: 'text', speaker: '', text: '검사의 표정이 깊었다.' },
      { type: 'text', speaker: '', text: '수십 년의 것이었다.' },
      { type: 'text', speaker: '', text: '아무것도 읽히지 않는 얼굴.' },
      { type: 'text', speaker: '', text: '호의 읽는 눈이.' },
      { type: 'text', speaker: '', text: '여기서는 조금 달렸다.' },
      { type: 'text', speaker: '', text: '세 번째 합.' },
      { type: 'text', speaker: '', text: '검사가 왼쪽에서 들어왔다.' },
      { type: 'text', speaker: '', text: '호가 막았다.' },
      { type: 'text', speaker: '', text: '힘이 달렸다.' },
      { type: 'text', speaker: '', text: '팔이 밀렸다.' },
      { type: 'text', speaker: '', text: '뒤로 두 걸음.' },
      { type: 'text', speaker: '', text: '나는 이쪽에서 봤다.' },
      { type: 'text', speaker: '', text: '끼어들고 싶었다.' },
      { type: 'text', speaker: '', text: '그 순간.' },
      { type: 'text', speaker: '', text: '호가 손을 들었다.' },
      { type: 'text', speaker: '', text: '나를 향해.' },
      { type: 'text', speaker: '', text: '말하지 않아도 알았다.' },
      { type: 'text', speaker: '', text: '내 일이야.' },
      { type: 'text', speaker: '', text: '그 손짓이 말했다.' },
      { type: 'text', speaker: '', text: '나는 멈췄다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에 섰다. 조용하게. 호를 봤다.' },
      { type: 'text', speaker: '', text: '그리고 내 옷자락을 가볍게 잡았다.' },
      { type: 'text', speaker: '', text: '작은 손가락으로.' },
      { type: 'text', speaker: '', text: '호가 자세를 낮췄다.' },
      { type: 'text', speaker: '', text: '낮게. 더 낮게. 땅에 가깝게.' },
      { type: 'text', speaker: '', text: '검사의 눈이 달라졌다.' },
      { type: 'text', speaker: '', text: '이 낮은 자세는 빠르게 치고 들어오는 자세였다.' },
      { type: 'text', speaker: '', text: '검사가 칼을 세로로 세웠다.' },
      { type: 'text', speaker: '', text: '막을 준비.' },
      { type: 'text', speaker: '', text: '호가 달렸다.' },
      { type: 'text', speaker: '', text: '왼쪽으로.' },
      { type: 'text', speaker: '', text: '오른쪽으로.' },
      { type: 'text', speaker: '', text: '빠른 풋워크.' },
      { type: 'text', speaker: '', text: '검사가 따라갔다.' },
      { type: 'text', speaker: '', text: '그 순간.' },
      { type: 'text', speaker: '', text: '호가 방향을 바꿨다.' },
      { type: 'text', speaker: '', text: '왼쪽으로.' },
      { type: 'text', speaker: '', text: '검사의 칼이 오른쪽을 막은 상태에서.' },
      { type: 'text', speaker: '', text: '호가 왼쪽으로 파고들었다.' },
      { type: 'text', speaker: '', text: '팔꿈치가 먼저 들어갔다. 검사의 팔 안쪽으로.' },
      { type: 'text', speaker: '', text: '칼을 쓸 수 없는 거리.' },
      { type: 'text', speaker: '', text: '주먹이 세 번.' },
      { type: 'text', speaker: '', text: '명치. 검사의 갑옷 위로 둔탁한 충격음이 울렸다. 검사의 숨이 끊겼다.' },
      { type: 'text', speaker: '', text: '옆구리. 검사의 몸이 반 바퀴 돌았다.' },
      { type: 'text', speaker: '', text: '목 아래. 뼈가 울리는 소리가 났다. 세 번 모두 정확했다. 빗나간 것이 없었다.' },
      { type: 'text', speaker: '', text: '빠르고 묵직하게. 열세 살의 주먹이 아니었다. 4성의 주먹이었다.' },
      { type: 'text', speaker: '', text: '검사가 뒤로 비틀렸다.' },
      { type: 'text', speaker: '', text: '무릎을 꿇었다.' },
      { type: 'text', speaker: '', text: '일어나지 못했다.' },
      { type: 'text', speaker: '', text: '조용해졌다.' },
      { type: 'effect', effect: 'system', text: '【 결승전 결과: 타격 정확도 100%, 반응속도 4성 상한 돌파. 판정 — 압승. 】' },
      { type: 'text', speaker: '', text: '구경꾼들의 숨이 멎었다.' },
      { type: 'text', speaker: '', text: '호가 서서 내려다봤다.' },
      { type: 'text', speaker: '백호', text: '"아이한테 졌네요."' },
      { type: 'text', speaker: '', text: '검사가 고개를 들었다.' },
      { type: 'text', speaker: '', text: '긴 침묵.' },
      { type: 'text', speaker: '', text: '"졌다."' },
      { type: 'text', speaker: '', text: '"그리고요?"' },
      { type: 'text', speaker: '', text: '"강하다."' },
      { type: 'text', speaker: '', text: '"뭔가 더 있지 않아요?"' },
      { type: 'text', speaker: '', text: '검사가 호를 봤다.' },
      { type: 'text', speaker: '', text: '또 긴 침묵.' },
      { type: 'text', speaker: '', text: '"......인정한다."' },
      { type: 'text', speaker: '', text: '호의 표정이 미세하게 달라졌다.' },
      { type: 'text', speaker: '', text: '굳어 있던 것이.' },
      { type: 'text', speaker: '', text: '조금.' },
      { type: 'text', speaker: '', text: '풀렸다.' },
      { type: 'text', speaker: '', text: '사람들이 웅성였다. 박수가 났다.' },
      { type: 'text', speaker: '', text: '호는 그 소리를 들었다.' },
      { type: 'text', speaker: '', text: '박수가 아니라.' },
      { type: 'text', speaker: '', text: '인정한다는 말 세 글자를 들었다.' },
      { type: 'text', speaker: '', text: '대회가 끝나고.' },
      { type: 'text', speaker: '', text: '마을 사람들이 호를 봤다.' },
      { type: 'text', speaker: '', text: '"저 아이 어디서 온 거야?"' },
      { type: 'text', speaker: '', text: '"누가 가르쳤어?"' },
      { type: 'text', speaker: '', text: '사람들이 물었다.' },
      { type: 'text', speaker: '', text: '호는 그 물음들을 들었다.' },
      { type: 'text', speaker: '', text: '표정이 달라지지 않았다.' },
      { type: 'text', speaker: '', text: '나는 옆에서 그 물음들을 들었다.' },
      { type: 'text', speaker: '', text: '"누가 가르쳤어요?"' },
      { type: 'text', speaker: '', text: '나는 호한테 물었다.' },
      { type: 'text', speaker: '', text: '"뭐요?"' },
      { type: 'text', speaker: '', text: '"사람들이 물어보잖아요."' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"당신이 가르쳤죠."' },
      { type: 'text', speaker: '', text: '"그 전에는요. 저랑 만나기 전에도 그 눈이 있었어요. 상대를 읽는 눈이."' },
      { type: 'text', speaker: '', text: '"저택이요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '담담하게.' },
      { type: 'text', speaker: '', text: '"저택에서 배웠어요. 누가 화가 났는지, 누가 먼저 움직일지. 그걸 읽어야 했어요. 그래야 먼저 피할 수 있었으니까."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '저택에서 살아남기 위해 익힌 감각이.' },
      { type: 'text', speaker: '', text: '지금 싸움에서 쓰이고 있었다.' },
      { type: 'text', speaker: '', text: '두려움에서 시작된 것이 무기가 됐다.' },
      { type: 'text', speaker: '', text: '"나쁜 데서 배운 것도 있네요."' },
      { type: 'text', speaker: '', text: '"당신이 한 말이에요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"사람은 어디서든 배운다고요."' },
      { type: 'text', speaker: '', text: '"기억해요?"' },
      { type: 'text', speaker: '', text: '"기억해요."' },
      { type: 'text', speaker: '', text: '짧게.' },
      { type: 'text', speaker: '', text: '당연하다는 듯이.' },
      { type: 'text', speaker: '', text: '호가 기억하고 있었다.' },
      { type: 'text', speaker: '', text: '그 말을.' },
      { type: 'text', speaker: '', text: '그날 밤.' },
      { type: 'text', speaker: '', text: '모닥불 앞.' },
      { type: 'text', speaker: '', text: '호가 오래 말이 없다가.' },
      { type: 'text', speaker: '백호', text: '"인정한다는 말이 그렇게 좋을 줄 몰랐어요."' },
      { type: 'text', speaker: '', text: '나는 들었다.' },
      { type: 'text', speaker: '', text: '"처음으로요?"' },
      { type: 'text', speaker: '', text: '"처음이에요. 그 말을 들은 게."' },
      { type: 'text', speaker: '', text: '나는 조용히 있었다.' },
      { type: 'text', speaker: '', text: '"저택에서는 아무도 그런 말을 안 했어요. 잘했다는 것도, 맞다는 것도, 인정한다는 말도."' },
      { type: 'text', speaker: '', text: '"당연히 말했어야 했는데."' },
      { type: 'text', speaker: '', text: '"그랬겠죠."' },
      { type: 'text', speaker: '', text: '호가 손을 봤다.' },
      { type: 'text', speaker: '백호', text: '"오늘 들었어요. 처음으로."' },
      { type: 'text', speaker: '', text: '"어때요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다. 입술이 한 번 떨렸다. 빠르게. 삼키듯이.' },
      { type: 'text', speaker: '백호', text: '"울 것 같아요."' },
      { type: 'text', speaker: '', text: '나는 놀랐다.' },
      { type: 'text', speaker: '', text: '"울 것 같아요?"' },
      { type: 'text', speaker: '', text: '"안 울 거예요. 그냥 울 것 같다는 거예요."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"......이걸 이렇게 오래 기다렸다고 생각하니까요."' },
      { type: 'text', speaker: '', text: '나는 아무 말도 할 수 없었다.' },
      { type: 'text', speaker: '', text: '인정한다는 말.' },
      { type: 'text', speaker: '', text: '잘했다는 말.' },
      { type: 'text', speaker: '', text: '그 단순한 말을.' },
      { type: 'text', speaker: '', text: '이 아이가 얼마나 오래 기다렸는지.' },
      { type: 'text', speaker: '', text: '저택에서 두 해.' },
      { type: 'text', speaker: '', text: '그 전에는 어딨었는지도 모르지만.' },
      { type: 'text', speaker: '', text: '그 오래도록.' },
      { type: 'text', speaker: '', text: '단 한 번도.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 옆에 와서 손을 잡았다.' },
      { type: 'text', speaker: '', text: '차갑고 작은 손.' },
      { type: 'text', speaker: '', text: '호가 그 손을 봤다.' },
      { type: 'text', speaker: '백호', text: '"이 아이는 말없이도 위로가 돼요."' },
      { type: 'text', speaker: '', text: '"그러게요."' },
      { type: 'text', speaker: '', text: '"당신도요."' },
      { type: 'text', speaker: '', text: '"저요?"' },
      { type: 'text', speaker: '', text: '"응. 말없이도."' },
      { type: 'text', speaker: '', text: '나는.' },
      { type: 'text', speaker: '', text: '그 말을 오래 들었다.' },
      { type: 'text', speaker: '', text: '말없이도.' },
      { type: 'text', speaker: '', text: '위로가 된다는 말.' },
      { type: 'text', speaker: '', text: '뭔가를 해서가 아니라.' },
      { type: 'text', speaker: '', text: '그냥 옆에 있는 것만으로.' },
      { type: 'text', speaker: '', text: '"당신이 한 말 중에 좋은 게 있어요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"언제요?"' },
      { type: 'text', speaker: '', text: '"이것저것이요."' },
      { type: 'text', speaker: '', text: '"어떤 것들이요?"' },
      { type: 'text', speaker: '', text: '"세어봤어요."' },
      { type: 'text', speaker: '', text: '나는 놀랐다.' },
      { type: 'text', speaker: '', text: '"세어봤어요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"언제요."' },
      { type: 'text', speaker: '', text: '"훈련하면서요. 자면서요. 걸으면서요. 생각이 날 때마다요."' },
      { type: 'text', speaker: '', text: '"그 많은 때에요?"' },
      { type: 'text', speaker: '', text: '"몇 개예요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 생각하는 척했다.' },
      { type: 'text', speaker: '백호', text: '"많아요."' },
      { type: 'text', speaker: '', text: '"얼마나요."' },
      { type: 'text', speaker: '', text: '"많다는 거예요."' },
      { type: 'text', speaker: '', text: '"그 안에 오늘 것도 있어요?"' },
      { type: 'text', speaker: '', text: '"......오늘은 아직 세는 중이에요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '아직 세는 중이라는 말. 오늘이 아직 끝나지 않았다는 말.' },
      { type: 'text', speaker: '', text: '호가 오래전부터.' },
      { type: 'text', speaker: '', text: '내가 한 말들을 기억하고 있었다는 말. 하나도 흘리지 않고.' },
      { type: 'text', speaker: '', text: '"저도요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"당신이 한 말 중에 좋은 게 있어요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"세어봤어요?"' },
      { type: 'text', speaker: '', text: '"아직이요."' },
      { type: 'text', speaker: '', text: '"그러면 세요."' },
      { type: 'text', speaker: '', text: '"셀게요."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '', text: '모닥불이 흔들렸다.' },
      { type: 'text', speaker: '', text: '그 흔들림이.' },
      { type: 'text', speaker: '', text: '호의 얼굴에 닿았다.' },
      { type: 'text', speaker: '', text: '그 빛 안에서.' },
      { type: 'text', speaker: '', text: '호가 웃었다.' },
      { type: 'text', speaker: '', text: '아주 조금.' },
      { type: 'text', speaker: '', text: '짧게.' },
      { type: 'text', speaker: '', text: '하지만 숨기지 않은 웃음이었다.' },
      { type: 'text', speaker: '', text: '숨기지 않은 것이.' },
      { type: 'text', speaker: '', text: '이 아이가 얼마나 달라졌는지.' },
      { type: 'text', speaker: '', text: '그게 느껴졌다.' },
      { type: 'text', speaker: '', text: '밤이 깊어졌다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 우리 사이에 앉아서 불을 봤다.' },
      { type: 'text', speaker: '', text: '그 아이의 표정이.' },
      { type: 'text', speaker: '', text: '만족스럽다는 표정 같았다.' },
      { type: 'text', speaker: '', text: '아이에게 표정이 있는 건지 아닌지는 아직 모르겠지만.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '오늘만큼은.' },
      { type: 'text', speaker: '', text: '분명히 웃는 것 같았다.' },
      { type: 'text', speaker: '', text: '"이 아이."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 봤다.' },
      { type: 'text', speaker: '백호', text: '"오늘 경기 봤어요?"' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '"봤죠? 다 봤죠?"' },
      { type: 'text', speaker: '', text: '고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '"어떻게 봤어요?"' },
      { type: 'text', speaker: '', text: '대답이 없었다.' },
      { type: 'text', speaker: '', text: '"잘 했어요? 못 했어요?"' },
      { type: 'text', speaker: '', text: '왜소한 신이 끄덕였다.' },
      { type: 'text', speaker: '', text: '"잘 했다는 거예요?"' },
      { type: 'text', speaker: '', text: '또 끄덕였다.' },
      { type: 'text', speaker: '', text: '호가 뺨이 살짝 붉어졌다.' },
      { type: 'text', speaker: '백호', text: '"......이 아이한테 인정받는 것도 좋네요."' },
      { type: 'text', speaker: '', text: '"그렇죠."' },
      { type: 'text', speaker: '', text: '"이상하지 않아요? 말도 안 하는 아이한테서요."' },
      { type: 'text', speaker: '', text: '"이상하지 않아요."' },
      { type: 'text', speaker: '', text: '"왜요."' },
      { type: 'text', speaker: '', text: '"이 아이는 말 안 해도 알거든요. 눈으로 다 하니까요."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 봤다.' },
      { type: 'text', speaker: '백호', text: '"알아요?"' },
      { type: 'text', speaker: '', text: '왜소한 신이 끄덕였다.' },
      { type: 'text', speaker: '', text: '"......그러면 더 좋네요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '귀에 잘 들리지 않을 만큼.' },
      { type: 'text', speaker: '', text: '그러나.' },
      { type: 'text', speaker: '', text: '들렸다.' },
      { type: 'text', speaker: '', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '호가 또 말했다.' },
      { type: 'text', speaker: '', text: '나는 그 말버릇이 좋았다.' },
      { type: 'text', speaker: '', text: '\'있잖아요.\'' },
      { type: 'text', speaker: '', text: '뭔가 말하고 싶을 때 머리말로 쓰는 말.' },
      { type: 'text', speaker: '', text: '저택에서는 없었을 말버릇이었다.' },
      { type: 'text', speaker: '', text: '저택에서 호는 먼저 말하지 않았다.' },
      { type: 'text', speaker: '', text: '\'있잖아요.\'라고 시작하는 건.' },
      { type: 'text', speaker: '', text: '나한테 말하고 싶은 게 있다는 거니까.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '좋았다.' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"인정받는 게."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이렇게 좋은 줄 몰랐어요."' },
      { type: 'text', speaker: '', text: '"처음이에요?"' },
      { type: 'text', speaker: '', text: '"처음이에요."' },
      { type: 'text', speaker: '', text: '"앞으로는 자주 있을 거예요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"어떻게 알아요."' },
      { type: 'text', speaker: '', text: '"당신이 강하니까요."' },
      { type: 'text', speaker: '', text: '"강한 것과 인정받는 게 무슨 관계예요."' },
      { type: 'text', speaker: '', text: '"강하면 대할 때 달라지거든요. 무시하기 어려워요."' },
      { type: 'text', speaker: '', text: '"지금까지는 무시당했어요."' },
      { type: 'text', speaker: '', text: '"지금까지는 강하지 않아서가 아니라요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"알아보는 사람이 없어서요."' },
      { type: 'text', speaker: '', text: '"알아보는 사람이요?"' },
      { type: 'text', speaker: '', text: '"당신이 강하다는 걸 알아보는 사람이요."' },
      { type: 'text', speaker: '', text: '호가 그 말을 오래 들었다.' },
      { type: 'text', speaker: '백호', text: '"......그게 지금 당신이요?"' },
      { type: 'text', speaker: '', text: '"저도 있고요."' },
      { type: 'text', speaker: '', text: '"누가 더요."' },
      { type: 'text', speaker: '', text: '나는 왜소한 신을 봤다.' },
      { type: 'text', speaker: '', text: '"이 아이도요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '호가 그 아이를 봤다.' },
      { type: 'text', speaker: '백호', text: '"......처음으로 두 명이네요."' },
      { type: 'text', speaker: '', text: '"두 명이요?"' },
      { type: 'text', speaker: '', text: '"저를 알아보는 사람이요."' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '가슴 어딘가에 박혔다.' },
      { type: 'text', speaker: '', text: '처음으로 두 명.' },
      { type: 'text', speaker: '', text: '저택에서 두 해.' },
      { type: 'text', speaker: '', text: '아무도 없었다.' },
      { type: 'text', speaker: '', text: '지금.' },
      { type: 'text', speaker: '', text: '두 명.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '호한테.' },
      { type: 'text', speaker: '', text: '얼마나 큰 것인지.' },
      { type: 'text', speaker: '', text: '말하지 않아도.' },
      { type: 'text', speaker: '', text: '알았다.' },
    ]
  },
  {
    title: '7장 — 탑: 잘난 척하는 자들',
    nodes: [
      { type: 'text', speaker: '', text: '대회가 끝나고 며칠 뒤, 마을 노인이 호의 실력을 보더니 탑 이야기를 꺼냈다.' },
      { type: 'text', speaker: '', text: '노인의 눈이 달랐다. 탑을 말할 때만 눈동자가 떨렸다. 무서운 게 아니라, 경외하는 것처럼.' },
      { type: 'text', speaker: '', text: '산 깊은 곳. 폐탑. 백 층.' },
      { type: 'text', speaker: '', text: '꼭대기까지 오른 사람이 없다는 탑.' },
      { type: 'text', speaker: '', text: '각 층마다 수호자가 지키고 있다는.' },
      { type: 'text', speaker: '', text: '오래전에 어떤 술사가 세웠다는.' },
      { type: 'text', speaker: '', text: '그 이상은 모른다는.' },
      { type: 'text', speaker: '', text: '나는 그 이야기를 들었다.' },
      { type: 'text', speaker: '', text: '시스템 창이 떴다.' },
      { type: 'effect', effect: 'system', text: '【 탑 — 수련의 탑. 신수의 각성을 위한 최종 관문. 】' },
      { type: 'effect', effect: 'system', text: '【 백호의 4성 성장 완료. 탑 진입 가능. 】' },
      { type: 'effect', effect: 'system', text: '【 각성 아이템은 탑 내부에 존재. 】' },
      { type: 'text', speaker: '', text: '그리고 닫았다.' },
      { type: 'text', speaker: '', text: '"탑 이야기 들었어요?"' },
      { type: 'text', speaker: '', text: '호가 물었다.' },
      { type: 'text', speaker: '백호', text: '"들었어요."' },
      { type: 'text', speaker: '', text: '"가야겠네요."' },
      { type: 'text', speaker: '', text: '"가고 싶어요?"' },
      { type: 'text', speaker: '', text: '"가야 하는 것 같아요."' },
      { type: 'text', speaker: '', text: '"어떻게 알아요."' },
      { type: 'text', speaker: '', text: '"직관이요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '호의 직관은.' },
      { type: 'text', speaker: '', text: '지금까지 한 번도 틀린 적이 없었다.' },
      { type: 'text', speaker: '', text: '"가요."' },
      { type: 'text', speaker: '', text: '탑은 정말 산 깊은 곳에 있었다.' },
      { type: 'text', speaker: '', text: '이틀을 걸어서 갔다.' },
      { type: 'text', speaker: '', text: '길 없는 산을 넘었다.' },
      { type: 'text', speaker: '', text: '첫날 산을 오를 때.' },
      { type: 'text', speaker: '', text: '호가 앞서서 걸었다. 방향을 잘 잡았다. 길 없는 곳에서 길을 만드는 발이었다.' },
      { type: 'text', speaker: '백호', text: '"어떻게 알아요, 방향을."' },
      { type: 'text', speaker: '', text: '내가 뒤에서 물었다.' },
      { type: 'text', speaker: '', text: '"바람이요."' },
      { type: 'text', speaker: '', text: '"바람이요?"' },
      { type: 'text', speaker: '', text: '"산에서 바람은 낮은 데서 높은 데로 가요. 산 능선을 따라가요. 그 반대로 가면 아래로 가는 거고요."' },
      { type: 'text', speaker: '', text: '"그걸 어디서 배웠어요."' },
      { type: 'text', speaker: '', text: '"저택 뒤가 산이었어요. 가끔 심부름 갔어요."' },
      { type: 'text', speaker: '', text: '"......저택에서 배운 게 있네요."' },
      { type: 'text', speaker: '', text: '호가 잠시 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"......그러네요."' },
      { type: 'text', speaker: '', text: '뭔가 이상한 것을 발견한 얼굴이었다.' },
      { type: 'text', speaker: '', text: '저택에서 배운 게 있다는 사실이.' },
      { type: 'text', speaker: '', text: '싫은 건지. 그냥 이상한 건지.' },
      { type: 'text', speaker: '', text: '"나쁜 건 아니에요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"거기서 배운 게 있다는 게요."' },
      { type: 'text', speaker: '', text: '"나쁜 곳에서 배운 게 좋은 것도 있다는 거예요?"' },
      { type: 'text', speaker: '', text: '"사람은 어디서든 배워요."' },
      { type: 'text', speaker: '', text: '호가 다시 걷기 시작했다.' },
      { type: 'text', speaker: '백호', text: '"......그렇네요."' },
      { type: 'text', speaker: '', text: '탑이 보였다.' },
      { type: 'text', speaker: '', text: '높았다.' },
      { type: 'text', speaker: '', text: '백 층.' },
      { type: 'text', speaker: '', text: '오래된 돌로 쌓인, 이끼가 낀, 하지만 무너지지 않은.' },
      { type: 'text', speaker: '', text: '"높네요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"높아요."' },
      { type: 'text', speaker: '', text: '"다 올라가야 해요?"' },
      { type: 'text', speaker: '', text: '"아마도요."' },
      { type: 'text', speaker: '', text: '"그러면 올라가요."' },
      { type: 'text', speaker: '', text: '호가 탑 문 앞에 섰다.' },
      { type: 'text', speaker: '', text: '문이 무거웠다.' },
      { type: 'text', speaker: '', text: '호가 밀었다.' },
      { type: 'text', speaker: '', text: '열렸다.' },
      { type: 'text', speaker: '', text: '시스템 창이 떴다.' },
      { type: 'effect', effect: 'system', text: '【 수련의 탑 구조. 1~9층: 잔류 기운 소멸 구간(수호자 없음). 10층부터 수호자 배치. 난이도: 10층 D → 40층 B → 60층 A → 80층 S → 100층 ???. 층 돌파 시 경험치 +200~+2000(층별 차등). 】' },
      { type: 'text', speaker: '', text: '1층부터 9층까지는 비어 있었다. 벽에 오래된 부적의 자국만 남아 있었다. 한때 수호자가 있었지만, 탑을 세운 술사의 기운이 수백 년을 버티지 못하고 소멸한 구간이었다.' },
      { type: 'text', speaker: '', text: '10층에 첫 번째 수호자가 있었다.' },
      { type: 'text', speaker: '', text: '무기를 든 남자.' },
      { type: 'text', speaker: '', text: '어깨가 넓고 눈이 깊었다.' },
      { type: 'text', speaker: '', text: '"여기까지 올라온 자는 누구냐."' },
      { type: 'text', speaker: '', text: '"백호예요."' },
      { type: 'text', speaker: '', text: '수호자가 위아래로 봤다.' },
      { type: 'text', speaker: '', text: '"아이군."' },
      { type: 'text', speaker: '', text: '"아이가 올라오면 안 돼요?"' },
      { type: 'text', speaker: '', text: '"자격이 있어야 올라온다."' },
      { type: 'text', speaker: '', text: '"자격을 가진 아이면 어때요?"' },
      { type: 'text', speaker: '', text: '수호자가 잠시 봤다.' },
      { type: 'text', speaker: '', text: '"증명해."' },
      { type: 'text', speaker: '', text: '"이기면 증명 아닌가요."' },
      { type: 'text', speaker: '', text: '수호자가 웃었다.' },
      { type: 'text', speaker: '', text: '"그렇지."' },
      { type: 'text', speaker: '', text: '전투가 시작됐다.' },
      { type: 'text', speaker: '', text: '수호자의 무기는 도끼였다. 무겁고 느리지만, 바닥에 금이 갔다. 한 번에.' },
      { type: 'text', speaker: '', text: '호가 옆으로 빠졌다. 도끼가 공기를 갈랐다. 바닥이 갈라졌다. 파직. 돌가루가 튀었다.' },
      { type: 'text', speaker: '', text: '호가 눈을 가늘게 떴다. 맞으면 끝이었다.' },
      { type: 'text', speaker: '', text: '그래서 맞지 않았다.' },
      { type: 'text', speaker: '', text: '두 번째 도끼가 내려왔다. 호가 뒤로 빠지면서 도끼 자루를 잡았다. 무게를 이용해서 수호자의 중심을 옆으로 꺾었다. 도끼를 쓰는 자의 약점은 머리 위에서 내려오는 순간이었다. 양 팔이 올라가면 몸통이 빈다.' },
      { type: 'text', speaker: '', text: '호가 그 빈 곳으로 파고들었다.' },
      { type: 'text', speaker: '', text: '주먹 두 번. 명치와 턱 아래. 빠르고 정확하게.' },
      { type: 'text', speaker: '', text: '수호자가 무릎을 꿇었다.' },
      { type: 'text', speaker: '', text: '"......읽혔군."' },
      { type: 'text', speaker: '', text: '"느렸어요."' },
      { type: 'text', speaker: '', text: '호가 올라갔다. 뒤도 보지 않았다. 위만 봤다.' },
      { type: 'text', speaker: '', text: '20층과 30층은 10층과 비슷했다. 창을 든 수호자, 쌍검을 든 수호자. 호가 무기의 틈을 읽어 파고들면 끝이었다.' },
      { type: 'text', speaker: '', text: '40층.' },
      { type: 'text', speaker: '', text: '수호자는 이전과 달랐다. 힘이 아니라 말로 먼저 흔드는 사람이었다.' },
      { type: 'text', speaker: '', text: '"이 탑은 진짜 강한 자만 오를 수 있는 곳이야."' },
      { type: 'text', speaker: '', text: '"강한지 아닌지는 이기면 알잖아요."' },
      { type: 'text', speaker: '', text: '"이기는 것만이 강함이 아니야. 흔들리지 않는 것이지. 무서운 것 없이 서 있는 것이지."' },
      { type: 'text', speaker: '', text: '호가 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"무서운 게 없어야 강한 거예요?"' },
      { type: 'text', speaker: '', text: '"당연하지."' },
      { type: 'text', speaker: '', text: '호가 수호자를 봤다.' },
      { type: 'text', speaker: '백호', text: '"그러면 저는 약한 거예요. 무서운 게 있으니까요."' },
      { type: 'text', speaker: '', text: '수호자가 호를 봤다.' },
      { type: 'text', speaker: '', text: '"스스로 약하다고 하는군."' },
      { type: 'text', speaker: '', text: '"아니요. 제가 무서운 게 있어도 강할 수 있다고 생각해요."' },
      { type: 'text', speaker: '', text: '"앞뒤가 맞지 않는군."' },
      { type: 'text', speaker: '', text: '"맞아요. 무서워도 달리면 되니까요."' },
      { type: 'text', speaker: '', text: '수호자의 눈이 달라졌다.' },
      { type: 'text', speaker: '', text: '"......그게 무슨 뜻이야."' },
      { type: 'text', speaker: '', text: '"무서워서 멈추면 약한 거고, 무서워도 가면 강한 거예요."' },
      { type: 'text', speaker: '', text: '수호자가 잠시 있었다.' },
      { type: 'text', speaker: '', text: '"......누가 가르쳐준 말이냐."' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"제가 한 말이에요."' },
      { type: 'text', speaker: '', text: '"스스로?"' },
      { type: 'text', speaker: '', text: '"스스로요. 그런데."' },
      { type: 'text', speaker: '', text: '호가 잠깐 뒤를 봤다. 나를.' },
      { type: 'text', speaker: '백호', text: '"비슷한 말을 들은 적 있어요."' },
      { type: 'text', speaker: '', text: '수호자가 나를 봤다.' },
      { type: 'text', speaker: '', text: '나는 아무 말 하지 않았다.' },
      { type: 'text', speaker: '', text: '"......전투하자."' },
      { type: 'text', speaker: '', text: '수호자가 말했다.' },
      { type: 'text', speaker: '', text: '전투가 시작됐다.' },
      { type: 'text', speaker: '', text: '수호자는 빠르지 않았다. 하지만 무거웠다.' },
      { type: 'text', speaker: '', text: '한 번 맞으면 안 됐다.' },
      { type: 'text', speaker: '', text: '호가 계속 피했다.' },
      { type: 'text', speaker: '', text: '수호자가 말했다.' },
      { type: 'text', speaker: '', text: '"도망치는 거냐?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '"그렇게 보이는데."' },
      { type: 'text', speaker: '', text: '"피하면서 읽는 거예요."' },
      { type: 'text', speaker: '', text: '"뭘 읽어?"' },
      { type: 'text', speaker: '', text: '"당신이 지치는 것을요."' },
      { type: 'text', speaker: '', text: '호가 들어갔다. 전속력으로. 그런데 수호자의 팔이 올라왔다. 읽지 못한 동작이었다. 지친 척한 것이다.' },
      { type: 'text', speaker: '', text: '팔뚝이 호의 옆구리를 쳤다.' },
      { type: 'text', speaker: '', text: '호가 벽으로 밀려났다. 등이 돌벽에 부딪혔다. 숨이 끊겼다. 한 박자.' },
      { type: 'text', speaker: '', text: '입안에 피가 고였다.' },
      { type: 'text', speaker: '', text: '40층까지 처음으로 제대로 맞은 타격이었다.' },
      { type: 'text', speaker: '', text: '수호자가 말했다.' },
      { type: 'text', speaker: '', text: '"읽기만 해서는 안 돼. 읽힌다는 걸 아는 자도 있어."' },
      { type: 'text', speaker: '', text: '호가 벽에서 등을 뗐다. 다리가 풀리려 했다. 하지만 풀리지 않았다.' },
      { type: 'text', speaker: '', text: '이 아이는 한 번 맞은 걸로 무너지지 않는다.' },
      { type: 'text', speaker: '', text: '호가 자세를 낮췄다. 더 낮게.' },
      { type: 'text', speaker: '', text: '이번에는 읽히는 것까지 읽는다는 얼굴이었다.' },
      { type: 'text', speaker: '', text: '수호자가 다시 들어왔다. 무겁게.' },
      { type: 'text', speaker: '', text: '호가 피하지 않았다.' },
      { type: 'text', speaker: '', text: '받았다.' },
      { type: 'text', speaker: '', text: '힘이 부딪혔다.' },
      { type: 'text', speaker: '', text: '호가 밀렸다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '버텼다.' },
      { type: 'text', speaker: '', text: '버티면서 힘을 받아서.' },
      { type: 'text', speaker: '', text: '반대로 돌렸다.' },
      { type: 'text', speaker: '', text: '수호자가 중심을 잃었다.' },
      { type: 'text', speaker: '', text: '호가 옆구리를 쳤다.' },
      { type: 'text', speaker: '', text: '수호자가 벽으로 밀렸다.' },
      { type: 'text', speaker: '', text: '쿵.' },
      { type: 'text', speaker: '', text: '무릎을 꿇었다.' },
      { type: 'text', speaker: '', text: '"......방패 없이도 섰군."' },
      { type: 'text', speaker: '', text: '수호자가 말했다.' },
      { type: 'text', speaker: '', text: '"방패요?"' },
      { type: 'text', speaker: '', text: '"무서운 걸 숨기려는 방패 말이야. 너는 그게 없이 싸웠어."' },
      { type: 'text', speaker: '', text: '호가 잠시 있었다.' },
      { type: 'text', speaker: '백호', text: '"있었어요."' },
      { type: 'text', speaker: '', text: '"뭐?"' },
      { type: 'text', speaker: '', text: '"방패요. 저 사실 방패 엄청 많았어요. 창피한 거 들키지 않으려고. 약해 보이지 않으려고. 저택에서 그게 없으면 못 버텼어요."' },
      { type: 'text', speaker: '', text: '"지금은?"' },
      { type: 'text', speaker: '', text: '"지금은."' },
      { type: 'text', speaker: '', text: '호가 자신의 손을 봤다.' },
      { type: 'text', speaker: '백호', text: '"있어도 된다는 걸 알았어요. 방패가. 흔들려도 쓰러지지 않으면 되니까."' },
      { type: 'text', speaker: '', text: '수호자가 오래 침묵했다.' },
      { type: 'text', speaker: '', text: '"......올라가라."' },
      { type: 'text', speaker: '', text: '호가 올라갔다.' },
      { type: 'text', speaker: '', text: '60층.' },
      { type: 'text', speaker: '', text: '수호자는 키가 작았다.' },
      { type: 'text', speaker: '', text: '겉보기엔 평범한 사람이었다.' },
      { type: 'text', speaker: '', text: '하지만 눈이 평범하지 않았다.' },
      { type: 'text', speaker: '', text: '"나는 도술을 써."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"어떻게 알아?"' },
      { type: 'text', speaker: '', text: '"느껴요."' },
      { type: 'text', speaker: '', text: '수호자가 호를 봤다.' },
      { type: 'text', speaker: '', text: '"느껴진다고?"' },
      { type: 'text', speaker: '', text: '"손끝에 있는 게요. 저도 조금 있어요."' },
      { type: 'text', speaker: '', text: '수호자의 눈이 좁아졌다.' },
      { type: 'text', speaker: '', text: '"흥미롭군."' },
      { type: 'text', speaker: '', text: '"이기면 가르쳐줄 수 있어요?"' },
      { type: 'text', speaker: '', text: '"지는 게 아니라?"' },
      { type: 'text', speaker: '', text: '"당신이 질 거니까요."' },
      { type: 'text', speaker: '', text: '"......자신감이 넘치는군."' },
      { type: 'text', speaker: '', text: '"판단이에요."' },
      { type: 'text', speaker: '', text: '전투가 달랐다.' },
      { type: 'text', speaker: '', text: '수호자의 도술이 공기를 가로질렀다.' },
      { type: 'text', speaker: '', text: '보이지 않지만 느껴지는 것이었다.' },
      { type: 'text', speaker: '', text: '호가 손끝으로 감지했다.' },
      { type: 'text', speaker: '백호', text: '"온다."' },
      { type: 'text', speaker: '', text: '호가 말하면서.' },
      { type: 'text', speaker: '', text: '옆으로 비켰다.' },
      { type: 'text', speaker: '', text: '공기가 호가 있던 자리를 지나갔다.' },
      { type: 'text', speaker: '', text: '수호자의 입이 닫혔다.' },
      { type: 'text', speaker: '', text: '"막았어?"' },
      { type: 'text', speaker: '', text: '"피했어요."' },
      { type: 'text', speaker: '', text: '"어떻게 감지했어?"' },
      { type: 'text', speaker: '', text: '"손끝이 먼저 알아요."' },
      { type: 'text', speaker: '', text: '수호자가 다시 도술을 썼다.' },
      { type: 'text', speaker: '', text: '이번엔 방향이 달랐다.' },
      { type: 'text', speaker: '', text: '여러 방향에서.' },
      { type: 'text', speaker: '', text: '호가 움직였다.' },
      { type: 'text', speaker: '', text: '하나.' },
      { type: 'text', speaker: '', text: '둘.' },
      { type: 'text', speaker: '', text: '셋.' },
      { type: 'text', speaker: '', text: '세 번째를 피하다가.' },
      { type: 'text', speaker: '', text: '한 번 맞았다.' },
      { type: 'text', speaker: '', text: '어깨에.' },
      { type: 'text', speaker: '', text: '충격이 왔다.' },
      { type: 'text', speaker: '', text: '기침이 나왔다.' },
      { type: 'text', speaker: '', text: '"어떠냐?"' },
      { type: 'text', speaker: '', text: '"아파요."' },
      { type: 'text', speaker: '', text: '"그런데도?"' },
      { type: 'text', speaker: '', text: '"그런데도 해야죠."' },
      { type: 'text', speaker: '', text: '호가 손끝을 봤다.' },
      { type: 'text', speaker: '', text: '희미하게 빛이 맺혔다.' },
      { type: 'text', speaker: '', text: '달빛 같은.' },
      { type: 'text', speaker: '', text: '"이걸 쓰면요."' },
      { type: 'text', speaker: '', text: '"쓸 줄 알아?"' },
      { type: 'text', speaker: '', text: '"지금 배울 거예요."' },
      { type: 'effect', effect: 'shake' },
      { type: 'combat', enemy: {"name":"무술대회 결승","hp":140,"attack":17} },
      { type: 'text', speaker: '', text: '"전투 중에?"' },
      { type: 'text', speaker: '', text: '"지금 아니면 언제요."' },
      { type: 'text', speaker: '', text: '호가 손끝의 빛을 모았다.' },
      { type: 'text', speaker: '', text: '흩어졌다. 빛이 손가락 사이로 새어 나가 사라졌다.' },
      { type: 'text', speaker: '', text: '"......안 돼요."' },
      { type: 'text', speaker: '', text: '다시. 이를 악물고. 손끝에 집중했다.' },
      { type: 'text', speaker: '', text: '빛이 다시 맺혔다. 이번에는 흩어지지 않았다. 손 전체로 번졌다.' },
      { type: 'text', speaker: '', text: '차갑고 선명한.' },
      { type: 'effect', effect: 'system', text: '【 달빛 도술 Lv.1 발현. 공격력 +30%, 감지 범위 2배 확장. 성장형 — 사용할수록 강화. 】' },
      { type: 'text', speaker: '', text: '"전우치라는 이름 들어봤어요?"' },
      { type: 'text', speaker: '', text: '수호자가 눈을 가늘게 떴다.' },
      { type: 'text', speaker: '', text: '"......도술사."' },
      { type: 'text', speaker: '', text: '"저택 부엌 옆 벽장에 주인이 버린 책이 있었어요. 거기서 읽었어요. 빛으로 싸우는 술사."' },
      { type: 'text', speaker: '', text: '"그 스타일로 할게요."' },
      { type: 'text', speaker: '', text: '호가 달렸다.' },
      { type: 'text', speaker: '', text: '빠른 발.' },
      { type: 'text', speaker: '', text: '무거운 주먹.' },
      { type: 'text', speaker: '', text: '그 주먹에서.' },
      { type: 'text', speaker: '', text: '달빛 같은 빛이 퍼졌다.' },
      { type: 'text', speaker: '', text: '수호자가 막았다.' },
      { type: 'text', speaker: '', text: '충격이 왔다.' },
      { type: 'text', speaker: '', text: '도술과 주먹이 충돌하는 소리가 났다. 공기가 찢어지듯 갈라졌다.' },
      { type: 'text', speaker: '', text: '수호자가 밀렸다.' },
      { type: 'text', speaker: '', text: '뒤로 세 걸음.' },
      { type: 'text', speaker: '', text: '호가 계속 들어갔다.' },
      { type: 'text', speaker: '', text: '두 번.' },
      { type: 'text', speaker: '', text: '세 번.' },
      { type: 'text', speaker: '', text: '빛이 퍼질 때마다 수호자가 밀렸다.' },
      { type: 'text', speaker: '', text: '다섯 번째에.' },
      { type: 'text', speaker: '', text: '수호자가 멈췄다.' },
      { type: 'text', speaker: '', text: '더 이상 버티지 않았다.' },
      { type: 'text', speaker: '', text: '"......지는군."' },
      { type: 'text', speaker: '', text: '"이겼어요."' },
      { type: 'text', speaker: '', text: '"그 빛."' },
      { type: 'text', speaker: '', text: '"알고 싶어요?"' },
      { type: 'text', speaker: '', text: '"배워라. 네 것이야."' },
      { type: 'text', speaker: '', text: '"알아요. 그런데 당신도 알려줘요."' },
      { type: 'text', speaker: '', text: '수호자가 웃었다.' },
      { type: 'text', speaker: '', text: '"뻔뻔하군."' },
      { type: 'text', speaker: '', text: '"당당한 거예요."' },
      { type: 'text', speaker: '', text: '"......비슷하다."' },
      { type: 'text', speaker: '', text: '수호자가 일어섰다.' },
      { type: 'text', speaker: '', text: '"이다음은 올라가면서 스스로 배워라. 네 빛이니까."' },
      { type: 'text', speaker: '', text: '"알겠어요."' },
      { type: 'text', speaker: '', text: '호가 올라갔다.' },
      { type: 'text', speaker: '', text: '80층.' },
      { type: 'text', speaker: '', text: '수호자는 지금까지 본 것 중에 가장 강해 보였다.' },
      { type: 'text', speaker: '', text: '무기 없이 서 있었다.' },
      { type: 'text', speaker: '', text: '눈이 조용했다.' },
      { type: 'text', speaker: '', text: '"나는 이 탑에서 태어났다."' },
      { type: 'text', speaker: '', text: '"그게 자랑이에요?"' },
      { type: 'text', speaker: '', text: '"자랑이 아니야. 이 탑이 나야. 나는 이 탑을 위해 존재해."' },
      { type: 'text', speaker: '', text: '"그러면 탑이 끝나면요?"' },
      { type: 'text', speaker: '', text: '수호자가 멈췄다.' },
      { type: 'text', speaker: '', text: '"무슨 뜻이야."' },
      { type: 'text', speaker: '', text: '"탑이 없어지면 당신은 뭐예요."' },
      { type: 'text', speaker: '', text: '수호자가 호를 봤다.' },
      { type: 'text', speaker: '', text: '"그런 가정을 해본 적이 없군."' },
      { type: 'text', speaker: '', text: '"해봐요."' },
      { type: 'text', speaker: '', text: '"......탑이 없어지면."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"그건 생각해본 적이 없어."' },
      { type: 'text', speaker: '', text: '"그러면 불안하지 않아요? 자신이 뭔지."' },
      { type: 'text', speaker: '', text: '수호자가 오래 호를 봤다.' },
      { type: 'text', speaker: '', text: '"네가 왜 그걸 묻는 거냐."' },
      { type: 'text', speaker: '', text: '호가 잠시 있었다.' },
      { type: 'text', speaker: '백호', text: '"저도 뭔지 몰랐어요. 오래."' },
      { type: 'text', speaker: '', text: '"지금은?"' },
      { type: 'text', speaker: '', text: '"지금은 알아가고 있어요."' },
      { type: 'text', speaker: '', text: '"무엇인지?"' },
      { type: 'text', speaker: '', text: '"아직 다는 몰라요. 하지만."' },
      { type: 'text', speaker: '', text: '호가 손끝을 봤다.' },
      { type: 'text', speaker: '', text: '달빛이 맺혔다.' },
      { type: 'text', speaker: '', text: '"이게 저예요. 이게 제 것이에요."' },
      { type: 'text', speaker: '', text: '그 목소리에 떨림이 없었다. 처음으로 자신에 대해 말하면서 흔들리지 않았다.' },
      { type: 'text', speaker: '', text: '수호자가 그 빛을 봤다.' },
      { type: 'text', speaker: '', text: '"......그래서 여기까지 올라왔군."' },
      { type: 'text', speaker: '', text: '"올라가야 하는 게 더 있어요."' },
      { type: 'text', speaker: '', text: '"안다."' },
      { type: 'text', speaker: '', text: '전투가 시작됐다.' },
      { type: 'text', speaker: '', text: '80층의 전투는 달랐다.' },
      { type: 'text', speaker: '', text: '수호자가 움직이지 않았다.' },
      { type: 'text', speaker: '', text: '뭔가를 썼다.' },
      { type: 'text', speaker: '', text: '공간이 달라졌다.' },
      { type: 'text', speaker: '', text: '중력이 달라지는 것 같은.' },
      { type: 'text', speaker: '', text: '호가 무거워졌다.' },
      { type: 'text', speaker: '백호', text: '"뭐예요."' },
      { type: 'text', speaker: '', text: '"중압술이야. 공간을 무겁게 만들어."' },
      { type: 'effect', effect: 'system', text: '【 디버프 감지: \'중압술\' — 이동속도 -60%, 반응속도 -40%. 해제 조건: 시전자 격파 또는 도술로 상쇄. 】' },
      { type: 'text', speaker: '', text: '"......그러면요."' },
      { type: 'text', speaker: '', text: '호가 움직였다.' },
      { type: 'text', speaker: '', text: '무거운 상태에서.' },
      { type: 'text', speaker: '', text: '더 느렸다.' },
      { type: 'text', speaker: '', text: '수호자가 들어왔다.' },
      { type: 'text', speaker: '', text: '빠르게.' },
      { type: 'text', speaker: '', text: '이 공간에서 빠른 건 수호자뿐이었다.' },
      { type: 'text', speaker: '', text: '호가 맞았다.' },
      { type: 'text', speaker: '', text: '한 번.' },
      { type: 'text', speaker: '', text: '두 번.' },
      { type: 'text', speaker: '', text: '세 번.' },
      { type: 'text', speaker: '', text: '쓰러졌다.' },
      { type: 'text', speaker: '', text: '무릎이 바닥에 박혔다.' },
      { type: 'text', speaker: '', text: '손을 짚었다.' },
      { type: 'text', speaker: '', text: '일어났다.' },
      { type: 'text', speaker: '', text: '"......더 맞으면."' },
      { type: 'text', speaker: '', text: '수호자가 말했다.' },
      { type: 'text', speaker: '', text: '"그만해야 해."' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '호가 일어서면서 말했다.' },
      { type: 'text', speaker: '', text: '눈빛이 달랐다.' },
      { type: 'text', speaker: '', text: '무너진 게 아니었다.' },
      { type: 'text', speaker: '', text: '이 아이는 쓰러져도 눈빛이 꺾이지 않는다.' },
      { type: 'text', speaker: '', text: '"무서운 게 있어도 달리는 거잖아요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"지금 무서워요. 저. 이 공간이요."' },
      { type: 'text', speaker: '', text: '"......알고 있군."' },
      { type: 'text', speaker: '', text: '"알아도 가는 거예요."' },
      { type: 'text', speaker: '', text: '호가 손끝에 빛을 모았다.' },
      { type: 'text', speaker: '', text: '무거운 공간에서도.' },
      { type: 'text', speaker: '', text: '달빛이 맺혔다.' },
      { type: 'text', speaker: '', text: '공간이 무거우면, 빛으로 뚫는다.' },
      { type: 'text', speaker: '', text: '호가 달렸다.' },
      { type: 'text', speaker: '', text: '느린 달음.' },
      { type: 'text', speaker: '', text: '하지만 멈추지 않는.' },
      { type: 'text', speaker: '', text: '빛이 공간에 부딪혔다.' },
      { type: 'text', speaker: '', text: '중압술이 흔들렸다.' },
      { type: 'text', speaker: '', text: '호가 계속 달렸다.' },
      { type: 'text', speaker: '', text: '공간이 조금 가벼워졌다.' },
      { type: 'text', speaker: '', text: '빛이 중압술을 건드렸다.' },
      { type: 'text', speaker: '', text: '호가 더 빠르게 됐다.' },
      { type: 'text', speaker: '', text: '수호자가 막았다.' },
      { type: 'text', speaker: '', text: '충격이 왔다.' },
      { type: 'text', speaker: '', text: '수호자가 뒤로 밀렸다.' },
      { type: 'text', speaker: '', text: '세 걸음.' },
      { type: 'text', speaker: '', text: '중압술이 끊겼다.' },
      { type: 'text', speaker: '', text: '공간이 원래대로.' },
      { type: 'text', speaker: '', text: '호가 전속력으로 들어갔다.' },
      { type: 'text', speaker: '', text: '수호자가 막을 수 없었다.' },
      { type: 'text', speaker: '', text: '쿵.' },
      { type: 'text', speaker: '', text: '수호자가 벽에 닿았다.' },
      { type: 'text', speaker: '', text: '무릎을 꿇었다.' },
      { type: 'text', speaker: '', text: '수호자가 오래 침묵했다.' },
      { type: 'text', speaker: '', text: '"......너는 누구냐."' },
      { type: 'text', speaker: '', text: '"백호요."' },
      { type: 'text', speaker: '', text: '"백호."' },
      { type: 'text', speaker: '', text: '"알아요?"' },
      { type: 'text', speaker: '', text: '수호자가 호를 봤다.' },
      { type: 'text', speaker: '', text: '긴 침묵.' },
      { type: 'text', speaker: '', text: '"......백호."' },
      { type: 'text', speaker: '', text: '"알아요?"' },
      { type: 'text', speaker: '', text: '"백호라는 이름은 오래전부터 있었다. 이 탑이 기다린 이름이다."' },
      { type: 'text', speaker: '', text: '호가 수호자를 봤다.' },
      { type: 'text', speaker: '백호', text: '"무슨 말이에요."' },
      { type: 'text', speaker: '', text: '"올라가면 알아."' },
      { type: 'text', speaker: '', text: '수호자가 눈을 감았다.' },
      { type: 'text', speaker: '', text: '"......잘 가라. 백호."' },
      { type: 'text', speaker: '', text: '호가 올라갔다.' },
      { type: 'text', speaker: '', text: '나는 호를 따라 올라갔다.' },
      { type: 'text', speaker: '', text: '80층을 지나자.' },
      { type: 'text', speaker: '', text: '왜소한 신이 옆에서 걸었다.' },
      { type: 'text', speaker: '', text: '어느 틈에 내 옆에 붙어서.' },
      { type: 'text', speaker: '', text: '내 발걸음을 따라 왔다.' },
      { type: 'text', speaker: '', text: '"이 아이."' },
      { type: 'text', speaker: '', text: '호가 걸으면서 말했다.' },
      { type: 'text', speaker: '백호', text: '"계속 당신 옆에 있네요."' },
      { type: 'text', speaker: '', text: '"그러네요."' },
      { type: 'text', speaker: '', text: '"왜 말 안 해요, 이 아이는."' },
      { type: 'text', speaker: '', text: '"......말을 못 하는 건지, 안 하는 건지."' },
      { type: 'text', speaker: '', text: '"당신은 알아요?"' },
      { type: 'text', speaker: '', text: '"모르는 것 같아요."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 봤다.' },
      { type: 'text', speaker: '백호', text: '"알면 알려줘요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '"......고마워요."' },
      { type: 'text', speaker: '', text: '호가 그 아이한테 말했다.' },
      { type: 'text', speaker: '백호', text: '"이번 전투에서요. 옆에서 봐줬잖아요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 또 끄덕였다.' },
      { type: 'text', speaker: '', text: '호가 계단을 올랐다.' },
      { type: 'text', speaker: '', text: '빛이 맺힌 손으로.' },
      { type: 'text', speaker: '', text: '"이 아이는요."' },
      { type: 'text', speaker: '', text: '호가 걸으면서 말했다.' },
      { type: 'text', speaker: '백호', text: '"자꾸 당신 옆에만 있으려고 해요."' },
      { type: 'text', speaker: '', text: '"그래요?"' },
      { type: 'text', speaker: '', text: '"당신은 알아요?"' },
      { type: 'text', speaker: '', text: '"이 아이가 저한테는 말을 안 하는 것 같아요."' },
      { type: 'text', speaker: '', text: '"왜요."' },
      { type: 'text', speaker: '', text: '"몰라요."' },
      { type: 'text', speaker: '', text: '"당신한테는 말을 안 하는데 저한테는 고개를 끄덕이잖아요."' },
      { type: 'text', speaker: '', text: '"그러네요."' },
      { type: 'text', speaker: '', text: '"이상하지 않아요?"' },
      { type: 'text', speaker: '', text: '나는 왜소한 신을 봤다.' },
      { type: 'text', speaker: '', text: '그 아이가 걸으면서 우리를 봤다.' },
      { type: 'text', speaker: '', text: '"......이상하긴 한데요."' },
      { type: 'text', speaker: '', text: '호가 웃었다.' },
      { type: 'text', speaker: '', text: '짧게.' },
      { type: 'text', speaker: '', text: '"당신이 이상하다는 말을 할 때는요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"뭔가 진짜 이상할 때예요. 당신은 이상한 걸 이상하다고 잘 안 하는 사람이라."' },
      { type: 'text', speaker: '', text: '"그래요?"' },
      { type: 'text', speaker: '', text: '"그래요."' },
      { type: 'text', speaker: '', text: '"그럼 지금 진짜 이상한 거예요?"' },
      { type: 'text', speaker: '', text: '"그런 것 같아요."' },
      { type: 'text', speaker: '', text: '나는 왜소한 신을 다시 봤다.' },
      { type: 'text', speaker: '', text: '그 아이가 무표정으로 계단을 올랐다.' },
      { type: 'text', speaker: '', text: '진짜 이상한 아이였다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '좋았다.' },
      { type: 'text', speaker: '', text: '85층 계단 어딘가.' },
      { type: 'text', speaker: '', text: '호가 잠깐 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"쉬어요?"' },
      { type: 'text', speaker: '', text: '"조금이요."' },
      { type: 'text', speaker: '', text: '호가 계단 가장자리에 앉았다.' },
      { type: 'text', speaker: '', text: '벽에 등을 기댔다.' },
      { type: 'text', speaker: '', text: '눈을 감았다.' },
      { type: 'text', speaker: '', text: '숨을 길게 내쉬었다.' },
      { type: 'text', speaker: '', text: '나는 옆에 앉았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 반대쪽에 앉았다.' },
      { type: 'text', speaker: '', text: '그 작은 손이 호의 손등에 닿았다. 차가웠다. 하지만 호는 치우지 않았다.' },
      { type: 'text', speaker: '백호', text: '"80층 수호자가 무서웠어요."' },
      { type: 'text', speaker: '', text: '호가 눈을 감은 채로 말했다.' },
      { type: 'text', speaker: '백호', text: '"안 무서워 보였는데요."' },
      { type: 'text', speaker: '', text: '"무서웠어요. 처음에 공간이 무거워졌을 때요."' },
      { type: 'text', speaker: '', text: '"그런데 달렸잖아요."' },
      { type: 'text', speaker: '', text: '"무서우니까 빨리 끝내야 했어요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '무서우니까 빨리 끝낸다는 말.' },
      { type: 'text', speaker: '', text: '"저는 무서우면 멈추게 되던데요."' },
      { type: 'text', speaker: '', text: '"그게 더 이상한 거예요."' },
      { type: 'text', speaker: '', text: '"이상해요?"' },
      { type: 'text', speaker: '', text: '"무서우면 빨리 해야 해요. 멈추면 더 커져요."' },
      { type: 'text', speaker: '', text: '"......경험에서 나온 말이에요?"' },
      { type: 'text', speaker: '', text: '호가 눈을 떴다.' },
      { type: 'text', speaker: '', text: '천장을 봤다.' },
      { type: 'text', speaker: '', text: '"저택에서요. 새벽에 불려갈 때요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"빨리 일어나면 됐어요. 멈추면 발소리가 더 크게 들렸어요."' },
      { type: 'text', speaker: '', text: '호가 잠시 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"이불을 꼭 쥐면서요. 손가락이 아플 때까지요. 그러다가 일어나면 됐어요."' },
      { type: 'text', speaker: '', text: '호가 잠시 자신의 손가락을 봤다. 그 습관이 아직 손에 남아 있는 것처럼.' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '이불을 꼭 쥐는 열한 살의 손.' },
      { type: 'text', speaker: '', text: '발소리가 더 크게 들린다는 것.' },
      { type: 'text', speaker: '', text: '두려움 속에서 멈추면.' },
      { type: 'text', speaker: '', text: '그 두려움이 더 크게 들린다는 것.' },
      { type: 'text', speaker: '', text: '"그 방법이요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"지금도 써요?"' },
      { type: 'text', speaker: '', text: '"지금은 달라요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"지금은 무서운 게 달라요. 저택에서는 뭔가 나쁜 게 올까봐 무서웠어요."' },
      { type: 'text', speaker: '', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '호가 손끝을 봤다.' },
      { type: 'text', speaker: '', text: '달빛이 아주 조금.' },
      { type: 'text', speaker: '', text: '맺혔다가 꺼졌다.' },
      { type: 'text', speaker: '', text: '"지금은 못 할까봐 무서워요."' },
      { type: 'text', speaker: '', text: '"......그게 달라요?"' },
      { type: 'text', speaker: '', text: '"달라요. 저택에서 무서운 건 내가 잘못한 게 없어도 오는 거였어요."' },
      { type: 'text', speaker: '', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '호가 주먹을 쥐었다.' },
      { type: 'text', speaker: '백호', text: '"내가 하면 달라져요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '내가 하면 달라진다는 것.' },
      { type: 'text', speaker: '', text: '저택에서의 두려움과.' },
      { type: 'text', speaker: '', text: '지금의 두려움이.' },
      { type: 'text', speaker: '', text: '어떻게 다른지.' },
      { type: 'text', speaker: '', text: '그걸 열셋짜리 아이가.' },
      { type: 'text', speaker: '', text: '이미 알고 있었다. 배운 게 아니었다. 저택에서 뼈로 깨달은 것이었다.' },
      { type: 'text', speaker: '', text: '"무서운 거."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"나쁜 게 아니에요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"알아요?"' },
      { type: 'text', speaker: '', text: '"무서운 건 살아 있다는 거잖아요. 당신이 한 말이에요."' },
      { type: 'text', speaker: '', text: '"......제가 그런 말 했어요?"' },
      { type: 'text', speaker: '', text: '"했어요."' },
      { type: 'text', speaker: '', text: '호가 일어섰다.' },
      { type: 'text', speaker: '백호', text: '"기억도 못 해요?"' },
      { type: 'text', speaker: '', text: '"많이 말하다 보면 까먹을 수도 있어요."' },
      { type: 'text', speaker: '', text: '"그러면 제가 기억해줄게요."' },
      { type: 'text', speaker: '', text: '호가 위를 봤다.' },
      { type: 'text', speaker: '', text: '계단이 계속 있었다.' },
      { type: 'text', speaker: '', text: '"가요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그러면 빠르게 가요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 먼저 계단을 올라갔다.' },
      { type: 'text', speaker: '', text: '그 작은 발이 놀랍게도 빨랐다.' },
      { type: 'text', speaker: '', text: '호가 웃었다.' },
      { type: 'text', speaker: '', text: '짧게.' },
      { type: 'text', speaker: '', text: '그리고 따라갔다.' },
      { type: 'text', speaker: '', text: '나도 따라갔다.' },
      { type: 'text', speaker: '', text: '90층.' },
      { type: 'text', speaker: '', text: '계단을 올라가면서.' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"이 탑이 뭐예요?"' },
      { type: 'text', speaker: '', text: '"각자가 가진 강함이 뭔지 찾게 해주는 곳이에요."' },
      { type: 'text', speaker: '', text: '호가 계단을 올라가면서 생각했다.' },
      { type: 'text', speaker: '백호', text: '"저는 찾은 것 같아요. 조금씩."' },
      { type: 'text', speaker: '', text: '"어떤 걸요."' },
      { type: 'text', speaker: '', text: '"빠름이요. 그리고 달빛이요. 손끝의 빛이요. 차갑고 선명한."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '달빛 같은.' },
      { type: 'text', speaker: '', text: '그 말이 맞았다.' },
      { type: 'text', speaker: '', text: '호의 빛은 달빛 같았다.' },
      { type: 'text', speaker: '', text: '뜨겁지 않고. 타오르지 않았다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '선명하고. 차가웠다.' },
      { type: 'text', speaker: '', text: '그리고 넓었다.' },
      { type: 'text', speaker: '', text: '달이 밤 전체를 비추는 것처럼.' },
      { type: 'text', speaker: '', text: '"그게 당신이에요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '호가 잠시 계단을 오르다가 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"그 말."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"좋아요."' },
      { type: 'text', speaker: '', text: '그리고 다시 올라갔다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 우리 뒤를 따라 올라갔다.' },
      { type: 'text', speaker: '', text: '그 작은 발이 계단을 오르는 소리가.' },
      { type: 'text', speaker: '', text: '거의 나지 않았다.' },
      { type: 'text', speaker: '', text: '95층.' },
      { type: 'text', speaker: '', text: '아무것도 없었다.' },
      { type: 'text', speaker: '', text: '수호자도 없었다.' },
      { type: 'text', speaker: '', text: '방이 비어 있었다.' },
      { type: 'text', speaker: '', text: '대신.' },
      { type: 'text', speaker: '', text: '창이 있었다.' },
      { type: 'text', speaker: '', text: '작은 창.' },
      { type: 'text', speaker: '', text: '밖을 볼 수 있는.' },
      { type: 'text', speaker: '', text: '호가 창가로 갔다.' },
      { type: 'text', speaker: '', text: '밖을 봤다.' },
      { type: 'text', speaker: '', text: '높았다.' },
      { type: 'text', speaker: '', text: '산이 보였다. 구름이 보였다. 하늘이 보였다.' },
      { type: 'text', speaker: '', text: '드넓은 하늘.' },
      { type: 'text', speaker: '', text: '담장이 없는 하늘.' },
      { type: 'text', speaker: '', text: '"와."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '작게. 숨이 멎은 것처럼.' },
      { type: 'text', speaker: '', text: '그 한 글자에 저택 뒤꼍의 좁은 하늘이 전부 들어 있었다. 왜소한 신이 창가에서 호를 봤다. 그 작은 눈이 호의 표정을 오래 담았다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '"저택에서 보던 하늘이랑 달라요."' },
      { type: 'text', speaker: '', text: '"어떻게요?"' },
      { type: 'text', speaker: '', text: '"이쪽이 더 커요."' },
      { type: 'text', speaker: '', text: '"높은 곳에 있으니까요."' },
      { type: 'text', speaker: '', text: '"같은 하늘인데 다르네요."' },
      { type: 'text', speaker: '', text: '"보는 위치가 다르니까요."' },
      { type: 'text', speaker: '', text: '호가 창가에서 오래 밖을 봤다.' },
      { type: 'text', speaker: '', text: '나는 호의 옆모습을 봤다.' },
      { type: 'text', speaker: '', text: '창밖을 보는 눈.' },
      { type: 'text', speaker: '', text: '저택 뒤꼍에서 별을 보던 눈과.' },
      { type: 'text', speaker: '', text: '같은 눈인데.' },
      { type: 'text', speaker: '', text: '달랐다.' },
      { type: 'text', speaker: '', text: '그때는 담장 너머 하늘을 봤다. 담장이 세상의 끝인 줄 알았을 때의 눈이었다.' },
      { type: 'text', speaker: '', text: '지금은.' },
      { type: 'text', speaker: '', text: '담장도 없고, 아무것도 막는 게 없는 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '그 차이가 눈에 있었다.' },
      { type: 'text', speaker: '', text: '"올라가면 더 커요?"' },
      { type: 'text', speaker: '', text: '호가 물었다.' },
      { type: 'text', speaker: '백호', text: '"더 커요."' },
      { type: 'text', speaker: '', text: '"그러면 올라가요."' },
      { type: 'text', speaker: '', text: '호가 창에서 돌아섰다.' },
      { type: 'text', speaker: '', text: '다시 계단을 올랐다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 따라갔다.' },
      { type: 'text', speaker: '', text: '나도 따라갔다.' },
      { type: 'text', speaker: '', text: '더 높은 곳을 향해.' },
      { type: 'text', speaker: '', text: '97층.' },
      { type: 'text', speaker: '', text: '계단이 끝날 것 같지 않았다.' },
      { type: 'text', speaker: '', text: '호가 말없이 올랐다.' },
      { type: 'text', speaker: '', text: '피곤할 텐데.' },
      { type: 'text', speaker: '', text: '말이 없었다.' },
      { type: 'text', speaker: '', text: '"쉬어요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"다 왔어요."' },
      { type: 'text', speaker: '', text: '"100층이 아직 세 층 남았어요."' },
      { type: 'text', speaker: '', text: '"세 층은 금방이에요."' },
      { type: 'text', speaker: '', text: '"숨이 차 보여요."' },
      { type: 'text', speaker: '', text: '"안 차요."' },
      { type: 'text', speaker: '', text: '"어깨가요."' },
      { type: 'text', speaker: '', text: '호가 멈췄다.' },
      { type: 'text', speaker: '', text: '어깨를 봤다.' },
      { type: 'text', speaker: '', text: '"......조금요."' },
      { type: 'text', speaker: '', text: '"그러면 쉬어요."' },
      { type: 'text', speaker: '', text: '호가 계단 한켠에 앉았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 옆에 앉았다.' },
      { type: 'text', speaker: '', text: '나도 앉았다.' },
      { type: 'text', speaker: '', text: '한참 침묵.' },
      { type: 'text', speaker: '', text: '계단 사이로 바람이 들어왔다. 차가웠다.' },
      { type: 'text', speaker: '', text: '"이 탑."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"응?"' },
      { type: 'text', speaker: '', text: '"이 탑에서 배운 게 있어요."' },
      { type: 'text', speaker: '', text: '"뭐요."' },
      { type: 'text', speaker: '', text: '"싸움이요."' },
      { type: 'text', speaker: '', text: '"어떤 것이요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"방법만은 아니에요. 방법도 배웠는데."' },
      { type: 'text', speaker: '', text: '"그러면요?"' },
      { type: 'text', speaker: '', text: '"제가 어떤 싸움을 하는지요."' },
      { type: 'text', speaker: '', text: '나는 들었다.' },
      { type: 'text', speaker: '', text: '"저는요."' },
      { type: 'text', speaker: '', text: '호가 손을 봤다.' },
      { type: 'text', speaker: '', text: '달빛이 조금 맺혔다가 꺼졌다.' },
      { type: 'text', speaker: '', text: '"빠르게 들어가서, 상대가 생각하기 전에 끝내는 싸움을 좋아해요."' },
      { type: 'text', speaker: '', text: '"오래 끌리면요?"' },
      { type: 'text', speaker: '', text: '"무서워요. 맞을 수 있으니까요."' },
      { type: 'text', speaker: '', text: '"그게 나쁜 건 아니에요."' },
      { type: 'text', speaker: '', text: '"알아요. 그냥 알고 싶었어요. 제 싸움이 어떤 건지."' },
      { type: 'text', speaker: '', text: '호가 손끝을 봤다.' },
      { type: 'text', speaker: '백호', text: '"달빛을 쓰면요. 더 들어갈 수 있어요. 빛이 상대를 잠깐 흔들어요."' },
      { type: 'text', speaker: '', text: '"흔들어요?"' },
      { type: 'text', speaker: '', text: '"눈이 잠깐 달빛에 가요. 그 사이에 들어가요."' },
      { type: 'text', speaker: '', text: '나는 그 전략을 들었다.' },
      { type: 'text', speaker: '', text: '이걸 스스로 개발했다는 게.' },
      { type: 'text', speaker: '', text: '싸우면서 실패하면서.' },
      { type: 'text', speaker: '', text: '"대단해요."' },
      { type: 'text', speaker: '', text: '"또 그 말이에요."' },
      { type: 'text', speaker: '', text: '"기록이에요. 지금이 세 번째예요."' },
      { type: 'text', speaker: '', text: '호가 웃었다.' },
      { type: 'text', speaker: '', text: '아주 짧게.' },
      { type: 'text', speaker: '', text: '빠르게.' },
      { type: 'text', speaker: '', text: '그리고 무표정으로 돌아왔다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '왜소한 신이 그 웃음을 봤다.' },
      { type: 'text', speaker: '', text: '그 아이의 눈도 웃은 것 같았다.' },
      { type: 'text', speaker: '', text: '99층.' },
      { type: 'text', speaker: '', text: '계단에서 내려다보면.' },
      { type: 'text', speaker: '', text: '아래가 보였다.' },
      { type: 'text', speaker: '', text: '높은 곳이었다.' },
      { type: 'text', speaker: '', text: '어지러웠다.' },
      { type: 'text', speaker: '', text: '호는 어지럽지 않은 것 같았다.' },
      { type: 'text', speaker: '', text: '"높은 곳 무서워요?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '"저는요."' },
      { type: 'text', speaker: '', text: '"당신이요?"' },
      { type: 'text', speaker: '', text: '"처음에는요. 지금은 괜찮아요."' },
      { type: 'text', speaker: '', text: '호가 아래를 봤다.' },
      { type: 'text', speaker: '백호', text: '"왜 무서웠어요?"' },
      { type: 'text', speaker: '', text: '"높으면 잘못됐을 때 멀다는 게요. 바닥이."' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"저택에서는 낮은 곳에만 있었어요."' },
      { type: 'text', speaker: '', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '"지금은 높은 곳에 있고."' },
      { type: 'text', speaker: '', text: '호가 아래를 봤다.' },
      { type: 'text', speaker: '백호', text: '"무섭긴 한데요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"내려다보면 작아요. 아래가. 제가 있던 곳이."' },
      { type: 'text', speaker: '', text: '호의 눈이 아래를 보면서 멀어지는 것 같았다. 아래가 아니라 과거를 보는 눈이었다.' },
      { type: 'text', speaker: '', text: '저택이 작아 보인다는 말.' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '두 가지로 들렸다.' },
      { type: 'text', speaker: '', text: '실제로 아래가 작다는 것과.' },
      { type: 'text', speaker: '', text: '그 두 해가 작아지는 것 같다는 것과.' },
      { type: 'text', speaker: '', text: '호의 목소리가 떨리지 않았다. 그게 더 아팠다. 떨려야 할 말을 떨리지 않게 하는 것이, 이 아이가 얼마나 오래 연습한 것인지.' },
      { type: 'text', speaker: '', text: '나는 아무 말 하지 않았다.' },
      { type: 'text', speaker: '', text: '아무 말 하지 않는 게 맞을 때가 있었다.' },
      { type: 'text', speaker: '', text: '호가 고개를 들었다.' },
      { type: 'text', speaker: '', text: '100층이 보였다.' },
      { type: 'text', speaker: '', text: '"가요."' },
      { type: 'text', speaker: '', text: '호가 올라갔다.' },
      { type: 'text', speaker: '', text: '100층에 뭔가 있었다. 빛이 새어 나오고 있었다. 달빛과 닮은.' },
    ]
  },
  {
    title: '8장 — 부끄럽지 않다',
    nodes: [
      { type: 'effect', effect: 'system', text: '【 백호 성장 단계: 4성 → 5성 도달. 고유 능력 \'월광(月光)\' 해금. 】' },
      { type: 'effect', effect: 'system', text: '【 호감도 10단계 도달. 최고 이벤트 발동. 】' },
      { type: 'text', speaker: '', text: '100층.' },
      { type: 'text', speaker: '', text: '수호자가 없었다. 시스템 창이 떴다.' },
      { type: 'effect', effect: 'system', text: '【 100층: 각성의 방. 수호자 배치 없음 — 이 층은 시련이 아닌 선택의 공간. 자격이 있는 자만이 도달한다. 】' },
      { type: 'text', speaker: '', text: '빈 방이었다.' },
      { type: 'text', speaker: '', text: '그런데.' },
      { type: 'text', speaker: '', text: '비어 있지 않았다.' },
      { type: 'text', speaker: '', text: '한가운데에 오래된 제단이 있었다.' },
      { type: 'text', speaker: '', text: '제단 위에.' },
      { type: 'text', speaker: '', text: '백자 항아리.' },
      { type: 'text', speaker: '', text: '오래된 것이었다. 흰빛이었다. 균열이 있었지만 부서지지 않았다.' },
      { type: 'text', speaker: '', text: '호가 제단 앞에 섰다.' },
      { type: 'text', speaker: '', text: '나도 섰다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 우리 앞으로 걸어갔다.' },
      { type: 'text', speaker: '', text: '그 작은 아이가.' },
      { type: 'text', speaker: '', text: '제단 앞에서 멈췄다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '항아리를 봤다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '나는 그 눈을 봤다.' },
      { type: 'text', speaker: '', text: '고개를 갸웃했다.' },
      { type: 'text', speaker: '', text: '그 작은 눈이.' },
      { type: 'text', speaker: '', text: '항아리와 호를 번갈아 봤다. 뭔가를 확인하는 눈이었다. 기다리던 것을 찾은 것 같은.' },
      { type: 'text', speaker: '', text: '"이 아이."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"이게 뭔지 알아요?"' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '그러더니.' },
      { type: 'text', speaker: '', text: '내 발치 쪽으로 돌아와서 앉으려고 했다.' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 다시 봤다.' },
      { type: 'text', speaker: '백호', text: '"아니, 저한테 봐요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 흘끔 봤다가.' },
      { type: 'text', speaker: '', text: '다시 내 쪽으로 몸을 돌렸다.' },
      { type: 'text', speaker: '', text: '"이상한 아이예요."' },
      { type: 'text', speaker: '', text: '"그러네요."' },
      { type: 'text', speaker: '', text: '호가 항아리를 봤다.' },
      { type: 'text', speaker: '', text: '손을 들었다.' },
      { type: 'text', speaker: '', text: '뚜껑을 열었다.' },
      { type: 'text', speaker: '', text: '안에.' },
      { type: 'text', speaker: '', text: '달빛 같은 것이 고여 있었다.' },
      { type: 'text', speaker: '', text: '빛이었다.' },
      { type: 'text', speaker: '', text: '고인 빛.' },
      { type: 'text', speaker: '', text: '달빛 색.' },
      { type: 'text', speaker: '', text: '차갑고 선명한.' },
      { type: 'text', speaker: '', text: '호가 손을 뻗었다.' },
      { type: 'text', speaker: '백호', text: '"잡아봐요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '호가 손끝을 빛에 가져갔다.' },
      { type: 'text', speaker: '', text: '닿는 순간——' },
      { type: 'text', speaker: '', text: '호가 눈을 감았다.' },
      { type: 'text', speaker: '', text: '바람이 없었다.' },
      { type: 'text', speaker: '', text: '그런데 바람이 불었다.' },
      { type: 'text', speaker: '', text: '어디선가.' },
      { type: 'text', speaker: '', text: '안에서.' },
      { type: 'text', speaker: '', text: '호를 중심으로 바람이 나왔다.' },
      { type: 'text', speaker: '', text: '흰빛이 번졌다.' },
      { type: 'text', speaker: '', text: '달빛 같고.' },
      { type: 'text', speaker: '', text: '차갑고.' },
      { type: 'text', speaker: '', text: '폭풍 같고.' },
      { type: 'text', speaker: '', text: '탑 전체가 진동했다. 백 층짜리 돌탑이 흔들렸다. 수백 년을 버틴 벽에 금이 갔다. 바닥의 돌이 들떠 올랐다. 중력이 바뀐 것 같았다. 제단 주변의 돌 파편이 공중에 떠서 궤도를 그리다 벽에 박혔다. 탑 바깥에서도 산새들이 일제히 날아올랐을 것이다.' },
      { type: 'text', speaker: '', text: '나는 뒤로 물러났다.' },
      { type: 'text', speaker: '', text: '왜소한 신은 물러나지 않았다.' },
      { type: 'text', speaker: '', text: '그 아이가 호를 봤다.' },
      { type: 'text', speaker: '', text: '눈을 크게 뜨고.' },
      { type: 'text', speaker: '', text: '동그랗게 뜬 눈으로.' },
      { type: 'text', speaker: '', text: '빛이 번졌다.' },
      { type: 'text', speaker: '', text: '방 전체로.' },
      { type: 'text', speaker: '', text: '나는 팔로 눈을 가렸다.' },
      { type: 'text', speaker: '', text: '한참.' },
      { type: 'text', speaker: '', text: '빛이 가라앉았다.' },
      { type: 'text', speaker: '', text: '바람이 멎었다.' },
      { type: 'text', speaker: '', text: '호가 눈을 떴다.' },
      { type: 'text', speaker: '', text: '눈동자가 달랐다.' },
      { type: 'text', speaker: '', text: '금빛 테두리.' },
      { type: 'text', speaker: '', text: '은빛 동공.' },
      { type: 'text', speaker: '', text: '호랑이의 눈.' },
      { type: 'text', speaker: '', text: '시스템 창이 떴다.' },
      { type: 'effect', effect: 'system', text: '【 각성 완료. 고유 능력 \'월광(月光)\' 활성화. 】' },
      { type: 'effect', effect: 'system', text: '【 월광 효과: 달빛 도술 Lv.MAX, 공격 사거리 무제한, 감지 반경 1km, 신체 강화 +200%. 전투력 측정 불가. 】' },
      { type: 'text', speaker: '', text: '제단 밑 바닥돌이 갈라졌다. 달빛이 벽을 스치자 흰 금이 남았다.' },
      { type: 'text', speaker: '', text: '측정 불가. 숫자로 담을 수 없는 것이 이 아이 안에서 깨어났다.' },
      { type: 'text', speaker: '', text: '손끝에서 달빛이 맺혔다.' },
      { type: 'text', speaker: '', text: '선명하게.' },
      { type: 'text', speaker: '', text: '강하게.' },
      { type: 'text', speaker: '', text: '호가 자신의 손을 봤다.' },
      { type: 'text', speaker: '', text: '천천히.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '손끝으로 탑 벽을 건드렸다. 가볍게. 돌벽에 실금이 갈라지며 흰 가루가 떨어졌다. 호가 손을 거두고 금을 봤다. 아무 말 없이.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 앞으로 걸어갔다.' },
      { type: 'text', speaker: '', text: '그 작은 아이가 호를 올려다봤다.' },
      { type: 'text', speaker: '', text: '호가 그 아이를 봤다.' },
      { type: 'text', speaker: '', text: '그런데.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 앞에 오래 서 있지 않았다.' },
      { type: 'text', speaker: '', text: '잠깐 올려다보더니.' },
      { type: 'text', speaker: '', text: '내 쪽으로 다시 걸어왔다.' },
      { type: 'text', speaker: '', text: '내 발치에 앉았다.' },
      { type: 'text', speaker: '', text: '"이 아이."' },
      { type: 'text', speaker: '', text: '호가 웃었다.' },
      { type: 'text', speaker: '', text: '목소리가 달랐다.' },
      { type: 'text', speaker: '', text: '깊고 선명해졌다.' },
      { type: 'text', speaker: '', text: '"저한테는 관심이 없나봐요."' },
      { type: 'text', speaker: '', text: '"그런가요."' },
      { type: 'text', speaker: '', text: '"당신한테만 가잖아요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 발등 위에 앉아서 호를 봤다.' },
      { type: 'text', speaker: '', text: '그 작은 눈이 호를 봤다가.' },
      { type: 'text', speaker: '', text: '내 쪽을 봤다가.' },
      { type: 'text', speaker: '', text: '다시 호를 봤다.' },
      { type: 'text', speaker: '', text: '"......그러네요."' },
      { type: 'text', speaker: '', text: '호가 자신의 손을 폈다.' },
      { type: 'text', speaker: '', text: '달빛이 손끝에서 실처럼 맺혔다.' },
      { type: 'text', speaker: '', text: '"이게 저예요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"백호예요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"흰 호랑이요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"감사해요."' },
      { type: 'text', speaker: '', text: '"같이 한 거예요."' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '호가 고개를 저었다.' },
      { type: 'text', speaker: '백호', text: '"같이 한 게 아니에요."' },
      { type: 'text', speaker: '', text: '"......?"' },
      { type: 'text', speaker: '', text: '"당신이 아니었으면 여기까지 못 왔어요."' },
      { type: 'text', speaker: '', text: '"과장이에요."' },
      { type: 'text', speaker: '', text: '"과장이 아니에요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"저를 저택에서 꺼내줬잖아요. 잘못하지 않은 것에 무릎 꿇지 않아도 된다는 걸 알면서도 계속 그 안에 있었어요."' },
      { type: 'text', speaker: '', text: '"......호."' },
      { type: 'text', speaker: '', text: '"꺼내주지 않았으면. 저 혼자는."' },
      { type: 'text', speaker: '', text: '호가 말을 멈췄다.' },
      { type: 'text', speaker: '', text: '눈에 뭔가가 차올랐다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '흘리지 않았다.' },
      { type: 'text', speaker: '', text: '"감사해요."' },
      { type: 'text', speaker: '', text: '다시 말했다.' },
      { type: 'text', speaker: '', text: '나는 그 눈을 봤다.' },
      { type: 'text', speaker: '', text: '감사라는 말이 이렇게 무거울 수 있다는 걸.' },
      { type: 'text', speaker: '', text: '이 아이의 감사에는 두 해가 들어 있었다.' },
      { type: 'text', speaker: '', text: '처음 알았다.' },
      { type: 'text', speaker: '', text: '나는 밖으로 나왔다.' },
      { type: 'text', speaker: '', text: '탑 문 앞.' },
      { type: 'text', speaker: '', text: '호가 문을 밀면서 나왔다.' },
      { type: 'text', speaker: '', text: '바람이 불었다.' },
      { type: 'text', speaker: '', text: '차갑고 깨끗한 바람.' },
      { type: 'text', speaker: '', text: '왜소한 신이 따라왔다.' },
      { type: 'text', speaker: '', text: '그 아이도 바람을 맞았다.' },
      { type: 'text', speaker: '', text: '작은 몸이 바람에 흔들렸다.' },
      { type: 'text', speaker: '', text: '나는 그 아이를 봤다.' },
      { type: 'text', speaker: '', text: '이상한 아이였다.' },
      { type: 'text', speaker: '', text: '어디서 왔는지.' },
      { type: 'text', speaker: '', text: '왜 따라다니는지.' },
      { type: 'text', speaker: '', text: '뭘 원하는지.' },
      { type: 'text', speaker: '', text: '아직도 몰랐다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 쪽을 봤다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '내 발치에 앉았다.' },
      { type: 'text', speaker: '', text: '아주 가까이.' },
      { type: 'text', speaker: '', text: '바람이 차가웠다.' },
      { type: 'text', speaker: '', text: '왜소한 신의 작은 몸이 내 발에 기댔다.' },
      { type: 'text', speaker: '', text: '따뜻했다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '이상하게.' },
      { type: 'text', speaker: '', text: '고마웠다.' },
      { type: 'text', speaker: '', text: '그날 밤.' },
      { type: 'text', speaker: '', text: '탑 바깥.' },
      { type: 'text', speaker: '', text: '모닥불 앞에서.' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"저 사실, 오래 혼자가 좋다고 생각했어요."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"혼자면 창피한 걸 들킬 일이 없으니까요. 흔들리는 걸 볼 사람도 없으니까요."' },
      { type: 'text', speaker: '', text: '"그러면요?"' },
      { type: 'text', speaker: '', text: '"그러면 강한 것처럼 느껴졌어요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"지금은요?"' },
      { type: 'text', speaker: '', text: '"지금은."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"혼자가 아닌 걸 모르니까 혼자가 좋다고 했던 거예요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '"혼자가 아닌 게 뭔지 몰랐어요. 당신이 오기 전에는."' },
      { type: 'text', speaker: '', text: '"......호."' },
      { type: 'text', speaker: '', text: '"지금은 알아요. 혼자가 아니라는 게."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 옆에 앉았다. 손을 잡았다.' },
      { type: 'text', speaker: '', text: '호가 그 손을 잡았다.' },
      { type: 'text', speaker: '백호', text: '"이 아이도 혼자가 아니게 해줬어요. 저한테."' },
      { type: 'text', speaker: '', text: '왜소한 신이 고개를 들었다.' },
      { type: 'text', speaker: '', text: '"그리고 당신도요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"당신 덕분에요."' },
      { type: 'text', speaker: '', text: '"......나한테요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"제가요?"' },
      { type: 'text', speaker: '', text: '"당신이요."' },
      { type: 'text', speaker: '', text: '나는 말이 나오지 않았다.' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '', text: '뺨이 살짝 붉었다.' },
      { type: 'text', speaker: '', text: '별빛 탓일 수도 있었다.' },
      { type: 'text', speaker: '', text: '모닥불 탓일 수도 있었다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '아닌 것 같았다.' },
      { type: 'text', speaker: '', text: '"이상하죠."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"이렇게 말하는 게요."' },
      { type: 'text', speaker: '', text: '"이상하지 않아요."' },
      { type: 'text', speaker: '', text: '"저도요?"' },
      { type: 'text', speaker: '', text: '"호가 이상하지 않아요."' },
      { type: 'text', speaker: '', text: '호가 시선을 내렸다.' },
      { type: 'text', speaker: '백호', text: '"......처음으로 창피하지 않아요."' },
      { type: 'text', speaker: '', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"이런 말 하는 게요. 고맙다고, 외로웠다고, 좋았다고. 이런 말 하는 게. 전에는 창피했는데. 입이 안 열렸는데."' },
      { type: 'text', speaker: '', text: '"지금은요?"' },
      { type: 'text', speaker: '', text: '"지금은."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"부끄럽지 않아요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '부끄럽지 않다는 말.' },
      { type: 'text', speaker: '', text: '저택에서 두 해. 아무것에도 고개를 숙이지 않으면서, 하지만 자신의 감정을 내보이는 것만큼은 절대 하지 않던 아이가.' },
      { type: 'text', speaker: '', text: '부끄럽지 않다고 말했다.' },
      { type: 'text', speaker: '', text: '"강해요, 당신."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '호가 고개를 돌렸다.' },
      { type: 'text', speaker: '', text: '귀가 빨개졌다.' },
      { type: 'text', speaker: '', text: '"그 말은."' },
      { type: 'text', speaker: '', text: '"사실이에요."' },
      { type: 'text', speaker: '', text: '"......너무 직접적이에요."' },
      { type: 'text', speaker: '', text: '"사실이에요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '짧게.' },
      { type: 'text', speaker: '', text: '"알지만."' },
      { type: 'text', speaker: '', text: '호가 말을 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"당신한테 듣는 건 달라요."' },
      { type: 'text', speaker: '', text: '나는.' },
      { type: 'text', speaker: '', text: '그 말을 오래 들었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 우리 사이에 누웠다.' },
      { type: 'text', speaker: '', text: '하늘을 봤다.' },
      { type: 'text', speaker: '', text: '우리도 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '별이 많았다.' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"저, 무서운 게 있어요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"다시 혼자가 되는 게요."' },
      { type: 'text', speaker: '', text: '"......응."' },
      { type: 'text', speaker: '', text: '"당신이 없어지면이요."' },
      { type: 'text', speaker: '', text: '나는 숨을 참았다.' },
      { type: 'text', speaker: '', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"제가 한 말 중에 좋은 게 많다고 했잖아요."' },
      { type: 'text', speaker: '', text: '"했어요."' },
      { type: 'text', speaker: '', text: '"그게 뭐였어요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"흔들려도 쓰러지지 않는 게 강한 거라고 했잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"무서워도 달리는 게 강한 거라고 했잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"좋은 기억이 많아지면 나쁜 기억이 작아진다고 했잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그리고요."' },
      { type: 'text', speaker: '', text: '호가 별을 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신이 아직 여기 있다는 것도요."' },
      { type: 'text', speaker: '', text: '나는 아무 말도 할 수 없었다.' },
      { type: 'text', speaker: '', text: '"지금이 있잖아요. 그러면."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"......됐어요. 지금이 있으면."' },
      { type: 'text', speaker: '', text: '불이 흔들렸다.' },
      { type: 'text', speaker: '', text: '그 흔들림이.' },
      { type: 'text', speaker: '', text: '오래 남았다.' },
      { type: 'text', speaker: '', text: '밤이 더 깊어졌다.' },
      { type: 'text', speaker: '', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '호가 또 말했다.' },
      { type: 'text', speaker: '백호', text: '"응?"' },
      { type: 'text', speaker: '', text: '"저택에서 두 해가 있었잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그게 다 나쁜 것만은 아니었어요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"어떤 게요."' },
      { type: 'text', speaker: '', text: '"버티는 법을 배웠어요. 고개 숙이지 않는 법도요."' },
      { type: 'text', speaker: '', text: '"......그렇네요."' },
      { type: 'text', speaker: '', text: '"뒤꼍에서 별 보는 법도 배웠어요."' },
      { type: 'text', speaker: '', text: '"거기서요?"' },
      { type: 'text', speaker: '', text: '"혼자 앉아서 봤어요. 매일이요."' },
      { type: 'text', speaker: '', text: '"......외로웠겠네요."' },
      { type: 'text', speaker: '', text: '"그때는 외로운 줄 몰랐어요."' },
      { type: 'text', speaker: '', text: '"지금 생각하면요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"지금 생각하면. 그래도 그게 없었으면요."' },
      { type: 'text', speaker: '', text: '"없었으면?"' },
      { type: 'text', speaker: '', text: '"별을 이렇게 좋아하지 않았을 것 같아요."' },
      { type: 'text', speaker: '', text: '나는 호가 별을 보는 걸 봤다.' },
      { type: 'text', speaker: '', text: '별 보는 눈이 좋았다.' },
      { type: 'text', speaker: '', text: '도도하고 차가운 눈이.' },
      { type: 'text', speaker: '', text: '별 앞에서는.' },
      { type: 'text', speaker: '', text: '조금 달라졌다.' },
      { type: 'text', speaker: '', text: '조금 부드러워졌다.' },
      { type: 'text', speaker: '', text: '"좋은 게 있었네요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"아주 조금이요."' },
      { type: 'text', speaker: '', text: '"그래도요."' },
      { type: 'text', speaker: '', text: '호가 별을 봤다.' },
      { type: 'text', speaker: '백호', text: '"그래도요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 옆에서 눈을 감았다.' },
      { type: 'text', speaker: '', text: '세 개의 그림자가.' },
      { type: 'text', speaker: '', text: '별 아래에 있었다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '"저기요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"강해지는 게요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"처음에는 강해지고 싶었어요. 아무도 무시 못 하게요."' },
      { type: 'text', speaker: '', text: '"지금은요?"' },
      { type: 'text', speaker: '', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '호가 손을 봤다.' },
      { type: 'text', speaker: '', text: '달빛이 희미하게 맺혔다가 꺼졌다.' },
      { type: 'text', speaker: '', text: '"다른 이유가 생겼어요."' },
      { type: 'text', speaker: '', text: '"어떤 이유요."' },
      { type: 'text', speaker: '', text: '"이 빛이요. 제 것이 생겼잖아요. 그게 좋아서요."' },
      { type: 'text', speaker: '', text: '"좋아서 강해지고 싶어요?"' },
      { type: 'text', speaker: '', text: '"제 것으로 뭔가 하는 게요. 그게 좋아요. 저택에서는 아무것도 제 것이 없었어요. 일도, 음식도, 잠자리도. 다 저택 것이었어요."' },
      { type: 'text', speaker: '', text: '"지금은요?"' },
      { type: 'text', speaker: '', text: '호가 주먹을 쥐었다.' },
      { type: 'text', speaker: '백호', text: '"지금은 이게 제 거예요."' },
      { type: 'text', speaker: '', text: '달빛이 또 맺혔다.' },
      { type: 'text', speaker: '', text: '선명하게.' },
      { type: 'text', speaker: '', text: '"그래서 강해지고 싶어요. 제 것을 더 잘 쓰고 싶어서요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '무시당하지 않으려는 것에서.' },
      { type: 'text', speaker: '', text: '자신의 것을 쓰고 싶어서로.' },
      { type: 'text', speaker: '', text: '그게 달라진 것이었다.' },
      { type: 'text', speaker: '', text: '"그거 알아요?"' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"뭐요."' },
      { type: 'text', speaker: '', text: '"처음 만났을 때랑 달라요."' },
      { type: 'text', speaker: '', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"싸우는 이유가요."' },
      { type: 'text', speaker: '', text: '호가 잠시 있었다.' },
      { type: 'text', speaker: '백호', text: '"......좋은 이유예요?"' },
      { type: 'text', speaker: '', text: '"좋은 쪽이에요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"자신을 위해 강해지는 게요. 두려워서가 아니라, 자신의 것을 써서 하고 싶어서요."' },
      { type: 'text', speaker: '', text: '호가 그 말을 씹었다.' },
      { type: 'text', speaker: '백호', text: '"......그게 더 강해지는 이유예요?"' },
      { type: 'text', speaker: '', text: '"더 오래 가는 이유예요."' },
      { type: 'text', speaker: '', text: '"오래 가는요?"' },
      { type: 'text', speaker: '', text: '"두려움으로 강해지면 두려움이 없어질 때 멈춰요. 자신이 좋아서 강해지면, 자신이 있는 한 멈추지 않아요."' },
      { type: 'text', speaker: '', text: '호가 손끝의 달빛을 봤다. 그 빛이 대답인 것처럼.' },
      { type: 'text', speaker: '', text: '호가 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '"......당신이 한 말 중에."' },
      { type: 'text', speaker: '', text: '"또 기록해요?"' },
      { type: 'text', speaker: '', text: '"좋은 게 있는 것 같아서요."' },
      { type: 'text', speaker: '', text: '"이번 건요?"' },
      { type: 'text', speaker: '', text: '"이번 것도 들어가요."' },
      { type: 'text', speaker: '', text: '나는 웃었다.' },
      { type: 'text', speaker: '', text: '호가 못 본 척했다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '입꼬리가 조금 올라간 것 같았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 옆에서 눈을 뜨고 호를 봤다.' },
      { type: 'text', speaker: '', text: '"이 아이."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"응?"' },
      { type: 'text', speaker: '', text: '"항상 봐요. 제가 뭔가 하면요."' },
      { type: 'text', speaker: '', text: '"그렇죠."' },
      { type: 'text', speaker: '', text: '"왜요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '내 쪽으로 왔다.' },
      { type: 'text', speaker: '', text: '호를 보다가 내 쪽으로 온 것이었다.' },
      { type: 'text', speaker: '', text: '호가 그 뒷모습을 봤다.' },
      { type: 'text', speaker: '백호', text: '"저한테 안 와요."' },
      { type: 'text', speaker: '', text: '"그러네요."' },
      { type: 'text', speaker: '', text: '"이상한 아이예요."' },
      { type: 'text', speaker: '', text: '"이상하죠."' },
      { type: 'text', speaker: '', text: '"하지만."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신 쪽으로 가서.' },
      { type: 'text', speaker: '', text: '그 손을 잡았다.' },
      { type: 'text', speaker: '', text: '차갑고 작은 손.' },
      { type: 'text', speaker: '', text: '"좋아해요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 올려다봤다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '내 발을 한 번 쳐다봤다.' },
      { type: 'text', speaker: '', text: '다시 호를 봤다.' },
      { type: 'text', speaker: '', text: '고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '호가 별을 봤다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '"하나만 더요."' },
      { type: 'text', speaker: '', text: '호가 또 말했다.' },
      { type: 'text', speaker: '백호', text: '"또 있어요?"' },
      { type: 'text', speaker: '', text: '"많아요."' },
      { type: 'text', speaker: '', text: '"다 말해요."' },
      { type: 'text', speaker: '', text: '호가 잠깐 입을 닫았다가.' },
      { type: 'text', speaker: '백호', text: '"이름이요."' },
      { type: 'text', speaker: '', text: '"뭐요?"' },
      { type: 'text', speaker: '', text: '"명이라는 이름이요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 그 이름으로 불러줬잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"처음으로요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"좋았어요?"' },
      { type: 'text', speaker: '', text: '호가 고개를 돌렸다.' },
      { type: 'text', speaker: '백호', text: '"......그렇게 솔직하게 물어보지 말아요."' },
      { type: 'text', speaker: '', text: '"물어보면 안 돼요?"' },
      { type: 'text', speaker: '', text: '"물어보면 대답해야 하잖아요."' },
      { type: 'text', speaker: '', text: '"대답하기 싫어요?"' },
      { type: 'text', speaker: '', text: '"......좋았어요."' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '거의 들리지 않을 만큼.' },
      { type: 'text', speaker: '', text: '"그래서 오늘 또 불러주면 어때요?"' },
      { type: 'text', speaker: '', text: '"이미 불렀잖아요."' },
      { type: 'text', speaker: '', text: '"또요."' },
      { type: 'text', speaker: '', text: '"......됐어요."' },
      { type: 'text', speaker: '', text: '"됐다는 게 또 불러도 된다는 거예요?"' },
      { type: 'text', speaker: '', text: '"됐다는 게 됐다는 거예요."' },
      { type: 'text', speaker: '', text: '나는 웃었다.' },
      { type: 'text', speaker: '', text: '"명."' },
      { type: 'text', speaker: '', text: '짧게. 한 글자.' },
      { type: 'text', speaker: '', text: '"......그만하라고요."' },
      { type: 'text', speaker: '', text: '호가 고개를 돌렸다.' },
      { type: 'text', speaker: '', text: '귀가 아까보다 더 빨개졌다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 눈을 뜨고 우리를 봤다.' },
      { type: 'text', speaker: '', text: '그 아이의 눈이 또 웃는 것 같았다.' },
      { type: 'text', speaker: '', text: '"이 아이도 봤네요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"뭘 봤어요?"' },
      { type: 'text', speaker: '', text: '"당신이 이름 부르는 거요."' },
      { type: 'text', speaker: '', text: '"그게 부끄러워요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 있었다.' },
      { type: 'text', speaker: '백호', text: '"조금이요."' },
      { type: 'text', speaker: '', text: '"아까는 부끄럽지 않다고 했잖아요."' },
      { type: 'text', speaker: '', text: '"이름 불리는 건 다른 문제예요."' },
      { type: 'text', speaker: '', text: '"왜요."' },
      { type: 'text', speaker: '', text: '"......자꾸 좋으니까요."' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '나왔다.' },
      { type: 'text', speaker: '', text: '호가 자신이 한 말을 인식한 것 같았다.' },
      { type: 'text', speaker: '', text: '뺨이 더 달아올랐다.' },
      { type: 'text', speaker: '', text: '"그 말 듣지 못한 척해요."' },
      { type: 'text', speaker: '', text: '"이미 들었어요."' },
      { type: 'text', speaker: '', text: '"듣지 못한 척하라고요."' },
      { type: 'text', speaker: '', text: '"못 해요."' },
      { type: 'text', speaker: '', text: '"당신이요?"' },
      { type: 'text', speaker: '', text: '"네."' },
      { type: 'text', speaker: '', text: '"평소에는 모른 척도 잘 하면서요."' },
      { type: 'text', speaker: '', text: '"이건 달라요."' },
      { type: 'text', speaker: '', text: '호가 시선을 내렸다.' },
      { type: 'text', speaker: '백호', text: '"......왜요."' },
      { type: 'text', speaker: '', text: '"좋은 말이니까요. 모른 척하기 싫어요."' },
      { type: 'text', speaker: '', text: '호가 입술을 꾹 다물었다. 뭔가 참는 것 같았다. 웃음인지 울음인지 모를 것을.' },
      { type: 'text', speaker: '', text: '침묵.' },
      { type: 'text', speaker: '', text: '불이 흔들렸다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 다시 눈을 감았다.' },
      { type: 'text', speaker: '', text: '호가 별을 봤다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"또요."' },
      { type: 'text', speaker: '', text: '"마지막이에요."' },
      { type: 'text', speaker: '', text: '"그 말을 오늘 세 번째 들어요."' },
      { type: 'text', speaker: '', text: '"진짜 마지막이에요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '호가 별을 보면서 말했다.' },
      { type: 'text', speaker: '백호', text: '"당신한테 감사한 게요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"저를 이상한 사람이라고 안 했어요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"이상한 사람 맞잖아요."' },
      { type: 'text', speaker: '', text: '"그 이상한 게요."' },
      { type: 'text', speaker: '', text: '호가 별을 봤다.' },
      { type: 'text', speaker: '백호', text: '"저택에서는 이상한 게 나쁜 거였어요. 무릎을 꿇지 않는 게 이상한 거였고, 말이 많은 게 이상한 거였고, 고개를 드는 게 이상한 거였어요."' },
      { type: 'text', speaker: '', text: '"......응."' },
      { type: 'text', speaker: '', text: '"당신한테는요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이상한 게 그냥 이상한 거예요. 나쁜 게 아니라."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '"맞아요."' },
      { type: 'text', speaker: '', text: '"그게요."' },
      { type: 'text', speaker: '', text: '호가 별을 봤다.' },
      { type: 'text', speaker: '백호', text: '"제일 좋은 것 같아요."' },
      { type: 'text', speaker: '', text: '제일 좋은 것.' },
      { type: 'text', speaker: '', text: '그 말이 오래 남았다.' },
      { type: 'text', speaker: '', text: '"명."' },
      { type: 'text', speaker: '', text: '"진짜 그만해요!"' },
      { type: 'text', speaker: '', text: '호가 돌아봤다.' },
      { type: 'text', speaker: '', text: '뺨이 빨개진 얼굴로.' },
      { type: 'text', speaker: '', text: '왜소한 신이 그 장면을 봤다.' },
      { type: 'text', speaker: '', text: '그 작은 아이가.' },
      { type: 'text', speaker: '', text: '눈을 감은 채로.' },
      { type: 'text', speaker: '', text: '입꼬리가 올라간 것 같은.' },
      { type: 'text', speaker: '', text: '그런 표정이었다.' },
      { type: 'text', speaker: '', text: '아이에게 표정이 있는 건지 없는 건지.' },
      { type: 'text', speaker: '', text: '아직도 모르겠지만.' },
      { type: 'text', speaker: '', text: '그 아이도.' },
      { type: 'text', speaker: '', text: '분명히.' },
      { type: 'text', speaker: '', text: '지금.' },
      { type: 'text', speaker: '', text: '웃고 있었다.' },
    ]
  },
  {
    title: '9장 — 각성: 흰 호랑이',
    nodes: [
      { type: 'text', speaker: '', text: '다음 날.' },
      { type: 'text', speaker: '', text: '새벽.' },
      { type: 'text', speaker: '', text: '호가 혼자 일어나 있었다.' },
      { type: 'text', speaker: '', text: '강가에 나가 있었다.' },
      { type: 'text', speaker: '', text: '나는 눈을 뜨면서 호가 없는 걸 알았다. 강가로 걸어갔다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 따라왔다.' },
      { type: 'text', speaker: '', text: '호가 강물을 보고 있었다.' },
      { type: 'text', speaker: '', text: '물 위에 새벽빛이 흘렀다.' },
      { type: 'text', speaker: '', text: '강물이 흐르는 소리.' },
      { type: 'text', speaker: '', text: '호의 뒷모습.' },
      { type: 'text', speaker: '', text: '그 뒷모습이.' },
      { type: 'text', speaker: '', text: '어제와 달랐다.' },
      { type: 'text', speaker: '', text: '뭔가 달라진 것이 눈에 보이는 게 아니었다. 그런데도.' },
      { type: 'text', speaker: '', text: '달랐다.' },
      { type: 'text', speaker: '', text: '뭔가가 채워진 것 같았다.' },
      { type: 'text', speaker: '', text: '오래 비어 있던 곳에 이제 뭔가 들어온 것 같은.' },
      { type: 'text', speaker: '', text: '"언제 일어났어요?"' },
      { type: 'text', speaker: '', text: '내가 물었다.' },
      { type: 'text', speaker: '', text: '"한참 됐어요."' },
      { type: 'text', speaker: '', text: '"뭐 해요."' },
      { type: 'text', speaker: '', text: '"연습해요."' },
      { type: 'text', speaker: '', text: '"여기서요?"' },
      { type: 'text', speaker: '', text: '"물 앞에서 하면 집중이 돼요."' },
      { type: 'text', speaker: '', text: '나는 옆에 섰다.' },
      { type: 'text', speaker: '', text: '강물이 흘렀다.' },
      { type: 'text', speaker: '', text: '호가 손을 들었다.' },
      { type: 'text', speaker: '', text: '손끝에서 달빛이 맺혔다.' },
      { type: 'text', speaker: '', text: '어제보다 선명했다.' },
      { type: 'text', speaker: '', text: '더 진했다.' },
      { type: 'text', speaker: '', text: '"달라졌어요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"어떻게요?"' },
      { type: 'text', speaker: '', text: '"느껴져요. 달라진 게."' },
      { type: 'text', speaker: '', text: '"좋아요?"' },
      { type: 'text', speaker: '', text: '"좋아요."' },
      { type: 'text', speaker: '', text: '"어떻게요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"제 것 같아요. 진짜로요."' },
      { type: 'text', speaker: '', text: '그게 무슨 말인지.' },
      { type: 'text', speaker: '', text: '나는 알았다.' },
      { type: 'text', speaker: '', text: '각성 아이템을 잡기 전에는 손끝에 뭔가 있다는 건 알았지만, 그게 자신의 것이라는 확신이 없었다.' },
      { type: 'text', speaker: '', text: '잡은 후에.' },
      { type: 'text', speaker: '', text: '분명해졌다.' },
      { type: 'text', speaker: '', text: '이건 내 것이다.' },
      { type: 'text', speaker: '', text: '그 확신이 감각으로 느껴지는 것.' },
      { type: 'text', speaker: '', text: '호가 손을 폈다. 달빛이 퍼졌다. 손끝에서 팔까지, 몸 전체로. 8장에서 터진 빛과는 달랐다. 어제는 폭발이었다면, 오늘은 흐름이었다. 물처럼. 자연스럽게.' },
      { type: 'text', speaker: '', text: '호를 중심으로 소리가 없어졌다. 강물도. 바람도.' },
      { type: 'text', speaker: '', text: '그리고 달빛이 조용하게 번졌다.' },
      { type: 'text', speaker: '', text: '강 위에 흰빛이 퍼졌다. 어제처럼 터지는 게 아니라, 스며들 듯이. 나뭇잎이 흔들렸다. 새가 조용히 날아올랐다.' },
      { type: 'text', speaker: '', text: '빛이 가라앉았다.' },
      { type: 'text', speaker: '', text: '거기에 호가 서 있었다.' },
      { type: 'text', speaker: '', text: '같은 호인데 달라진 호가. 키가 자란 것도 아닌데 더 커 보이는.' },
      { type: 'text', speaker: '', text: '눈동자가 더 선명했다.' },
      { type: 'text', speaker: '', text: '금빛 테두리.' },
      { type: 'text', speaker: '', text: '은빛 동공.' },
      { type: 'text', speaker: '', text: '보름달 같은 빛이 눈 안에 있었다.' },
      { type: 'text', speaker: '', text: '손끝에서 바람이 맺혔다.' },
      { type: 'text', speaker: '', text: '달빛 바람이.' },
      { type: 'text', speaker: '', text: '실처럼.' },
      { type: 'text', speaker: '', text: '날카롭게.' },
      { type: 'text', speaker: '', text: '호가 손을 들었다.' },
      { type: 'text', speaker: '', text: '그 바람이.' },
      { type: 'text', speaker: '', text: '실처럼 뻗어 나가.' },
      { type: 'text', speaker: '', text: '강 건너 나무를 건드렸다.' },
      { type: 'text', speaker: '', text: '나뭇가지 하나가 잘렸다.' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '칼보다 조용하게. 잘린 단면이 거울처럼 매끄러웠다. 탑 80층의 수호자가 보면 입을 다물지 못할 거리였다.' },
      { type: 'effect', effect: 'system', text: '【 월광 숙련도 상승. 달빛 실(絲): 사거리 50m → 120m. 관통력 B → A. 정밀도 78% → 94%. 】' },
      { type: 'text', speaker: '', text: '호가 그 손을 봤다.' },
      { type: 'text', speaker: '백호', text: '"이게."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"백호예요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"......왔네."' },
      { type: 'text', speaker: '', text: '중얼거렸다.' },
      { type: 'text', speaker: '', text: '작게.' },
      { type: 'text', speaker: '', text: '"왔어."' },
      { type: 'text', speaker: '', text: '나를 봤다.' },
      { type: 'text', speaker: '', text: '"당신 덕분이에요."' },
      { type: 'text', speaker: '', text: '"같이 한 거예요."' },
      { type: 'text', speaker: '', text: '"아니요. 당신 덕분이에요."' },
      { type: 'text', speaker: '', text: '나는 더 말하지 않았다.' },
      { type: 'text', speaker: '', text: '호가 고맙다고 하면.' },
      { type: 'text', speaker: '', text: '그게 맞았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 앞으로 걸어갔다.' },
      { type: 'text', speaker: '', text: '그 작은 아이가 호를 올려다봤다.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '처음 본 눈이었다.' },
      { type: 'text', speaker: '', text: '왜소한 신의 눈에.' },
      { type: 'text', speaker: '', text: '뭔가가 있었다.' },
      { type: 'text', speaker: '', text: '신기함.' },
      { type: 'text', speaker: '', text: '호가 빛나는 걸 신기한 듯 올려다보는 눈.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '반짝였다.' },
      { type: 'text', speaker: '', text: '호가 그 눈을 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신한테 말했다.' },
      { type: 'text', speaker: '백호', text: '"왜 저를 봐요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 고개를 갸웃했다.' },
      { type: 'text', speaker: '', text: '"......계속 봐요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다가.' },
      { type: 'text', speaker: '', text: '내 쪽을 봤다가.' },
      { type: 'text', speaker: '', text: '다시 호를 봤다.' },
      { type: 'text', speaker: '', text: '"이 아이한테 물어봐도 말 못 하지."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신한테 말했다.' },
      { type: 'text', speaker: '백호', text: '"그냥 궁금해서요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '그러더니.' },
      { type: 'text', speaker: '', text: '내 발치 쪽으로 걸어왔다.' },
      { type: 'text', speaker: '', text: '호 앞에서 내 쪽으로.' },
      { type: 'text', speaker: '', text: '호가 그 뒷모습을 봤다.' },
      { type: 'text', speaker: '', text: '잠시 있더니.' },
      { type: 'text', speaker: '', text: '쪼그려 앉았다.' },
      { type: 'text', speaker: '', text: '왜소한 신의 눈 높이로.' },
      { type: 'text', speaker: '', text: '"같이 가요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '내 발을 한 번 봤다가.' },
      { type: 'text', speaker: '', text: '호를 봤다가.' },
      { type: 'text', speaker: '', text: '내 발을 봤다.' },
      { type: 'text', speaker: '', text: '"그 두 개 중에 하나만 해요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 발을 선택했다.' },
      { type: 'text', speaker: '', text: '꽉 붙었다.' },
      { type: 'text', speaker: '', text: '호가 웃었다.' },
      { type: 'text', speaker: '백호', text: '"알겠어요."' },
      { type: 'text', speaker: '', text: '호가 일어섰다.' },
      { type: 'text', speaker: '', text: '나를 봤다.' },
      { type: 'text', speaker: '', text: '"저."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이제 알아요."' },
      { type: 'text', speaker: '', text: '"뭘요."' },
      { type: 'text', speaker: '', text: '"뭔지를요. 제가."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"처음으로요. 뭔지 아는 상태로요."' },
      { type: 'text', speaker: '', text: '호가 손끝의 달빛을 봤다.' },
      { type: 'text', speaker: '', text: '선명하고, 차갑고, 자신의 것인.' },
      { type: 'text', speaker: '', text: '"백호."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '그 이름을.' },
      { type: 'text', speaker: '', text: '처음으로.' },
      { type: 'text', speaker: '', text: '스스로.' },
      { type: 'text', speaker: '', text: '자신을 부르듯이.' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"흰 호랑이요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"저는요."' },
      { type: 'text', speaker: '', text: '호가 강물을 봤다.' },
      { type: 'text', speaker: '백호', text: '"저는 호랑이잖아요."' },
      { type: 'text', speaker: '', text: '"그렇죠."' },
      { type: 'text', speaker: '', text: '"혼자 사냥하는 동물이잖아요."' },
      { type: 'text', speaker: '', text: '"그렇죠."' },
      { type: 'text', speaker: '', text: '"그런데요."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 봤다.' },
      { type: 'text', speaker: '백호', text: '"이 아이가 옆에 있어요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 올려다봤다.' },
      { type: 'text', speaker: '', text: '"......혼자인 호랑이지만 혼자가 아닌 것 같아요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '혼자인 호랑이지만 혼자가 아닌.' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '호를 가장 잘 설명하는 말 같았다.' },
      { type: 'text', speaker: '', text: '"지금부터는요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"더 강해질 거예요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"더 빠르게요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"그리고."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신이 어디 가도."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"찾아갈 거예요."' },
      { type: 'text', speaker: '', text: '나는.' },
      { type: 'text', speaker: '', text: '그 말에.' },
      { type: 'text', speaker: '', text: '뭔가 걸렸다.' },
      { type: 'text', speaker: '', text: '당신이 어디 가도.' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '어딘가를 건드렸다.' },
      { type: 'text', speaker: '', text: '시스템 창이 떴다. 닫혀 있어야 할 시간에.' },
      { type: 'effect', effect: 'system', text: '【 스토리 종료 조건 충족 임박. 신수 각성 완료. 】' },
      { type: 'text', speaker: '', text: '닫았다. 빠르게. 호가 보기 전에.' },
      { type: 'text', speaker: '', text: '이제 됐다는 감각이.' },
      { type: 'text', speaker: '', text: '왔다.' },
      { type: 'text', speaker: '', text: '무서운 감각이.' },
      { type: 'text', speaker: '', text: '시스템이 말하고 있었다. 이제 끝난다고. 이 아이가 혼자 설 수 있게 됐다고.' },
      { type: 'text', speaker: '', text: '가슴이 서늘해졌다. 여기까지 키운 것이 나인데, 끝내는 것도 나라는 게.' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '강물이 흘렀다.' },
      { type: 'text', speaker: '', text: '달빛 같은 빛이 강 위에 흘렀다.' },
      { type: 'text', speaker: '', text: '호가 그 빛 위에 서 있었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 옆에서.' },
      { type: 'text', speaker: '', text: '호의 손을 잡고 있었다.' },
      { type: 'text', speaker: '', text: '그 그림이.' },
      { type: 'text', speaker: '', text: '오래 눈에 박혔다.' },
      { type: 'text', speaker: '', text: '그날 낮에.' },
      { type: 'text', speaker: '', text: '호가 연습을 했다.' },
      { type: 'text', speaker: '', text: '달빛을 쓰는 연습.' },
      { type: 'text', speaker: '', text: '손끝에서 실처럼 뻗어나가는.' },
      { type: 'text', speaker: '', text: '"이게요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"응?"' },
      { type: 'text', speaker: '', text: '"달처럼 멀리까지 가요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"달빛이 어디까지 가는지 봐요. 아주 멀리까지 가잖아요. 이것도 그래요."' },
      { type: 'text', speaker: '', text: '나는 호가 빛을 쓰는 걸 봤다.' },
      { type: 'text', speaker: '', text: '손끝에서 빛이 나갔다.' },
      { type: 'text', speaker: '', text: '실처럼, 선명하게.' },
      { type: 'text', speaker: '', text: '나뭇가지 하나가 잘렸다.' },
      { type: 'text', speaker: '', text: '"됐어요?"' },
      { type: 'text', speaker: '', text: '"됐어요. 더 멀리도요."' },
      { type: 'text', speaker: '', text: '호가 더 멀리 뻗었다. 두 번째 나뭇가지가 잘렸다. 더 먼 곳에서.' },
      { type: 'text', speaker: '', text: '그때 숲에서 소리가 났다. 으르렁. 낮고 무거운. 산짐승이었다. 덩치가 소만 한 곰이 수풀을 헤치고 나왔다.' },
      { type: 'text', speaker: '', text: '호가 돌아봤다. 눈이 달라지지 않았다. 무서운 게 아니었다.' },
      { type: 'text', speaker: '', text: '손끝에서 달빛이 맺혔다. 실이 아니라 이번엔 막이었다. 반달 모양으로 퍼진 빛이 곰 앞에 내려섰다. 곰이 발을 멈췄다. 빛이 바닥에 닿자 풀이 하얗게 얼었다.' },
      { type: 'text', speaker: '', text: '곰이 한 발 물러섰다. 으르렁이 멈췄다. 돌아갔다.' },
      { type: 'text', speaker: '', text: '"......이것도 되네요."' },
      { type: 'text', speaker: '', text: '호가 말했다. 손에서 빛이 꺼졌다.' },
      { type: 'text', speaker: '백호', text: '"됐어요!"' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '처음으로.' },
      { type: 'text', speaker: '', text: '감탄하는 말이 나왔다.' },
      { type: 'text', speaker: '', text: '이 아이가 자신한테 감탄하는 것을 처음으로 봤다.' },
      { type: 'text', speaker: '', text: '저택에서 두 해 동안.' },
      { type: 'text', speaker: '', text: '감탄할 것이 없었을 테니까.' },
      { type: 'text', speaker: '', text: '지금.' },
      { type: 'text', speaker: '', text: '처음으로.' },
      { type: 'text', speaker: '', text: '자신이 한 것이.' },
      { type: 'text', speaker: '', text: '대단하다는 걸.' },
      { type: 'text', speaker: '', text: '말했다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '보기 좋았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 그 장면을 봤다.' },
      { type: 'text', speaker: '', text: '그 아이의 눈이.' },
      { type: 'text', speaker: '', text: '뭔가 따뜻해진 것 같았다.' },
      { type: 'text', speaker: '', text: '"이 아이도 좋아해요?"' },
      { type: 'text', speaker: '', text: '호가 왜소한 신한테 물었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 끄덕였다.' },
      { type: 'text', speaker: '', text: '"......그러면 더 보여줄게요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '더 큰 빛을.' },
      { type: 'text', speaker: '', text: '더 멀리.' },
      { type: 'text', speaker: '', text: '보냈다.' },
      { type: 'text', speaker: '', text: '달빛 같은.' },
      { type: 'text', speaker: '', text: '차갑고 선명한.' },
      { type: 'text', speaker: '', text: '폭풍 같은.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '백호였다.' },
      { type: 'text', speaker: '', text: '저녁에.' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"그러니까요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"제가 백호인 게요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"실감이 나요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"이 빛이요. 손끝의 빛이요. 이게 제 것이라는 게. 당연한 것처럼 느껴져요."' },
      { type: 'text', speaker: '', text: '"언제부터요?"' },
      { type: 'text', speaker: '', text: '"각성하고 나서요. 아니."' },
      { type: 'text', speaker: '', text: '호가 생각했다.' },
      { type: 'text', speaker: '백호', text: '"아까부터요. 더 멀리 빛을 보냈을 때요."' },
      { type: 'text', speaker: '', text: '"달랐어요?"' },
      { type: 'text', speaker: '', text: '"달랐어요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"제 것을 쓴다는 게 어떤 건지."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"처음 알았어요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '제 것을 쓴다는 게 어떤 건지.' },
      { type: 'text', speaker: '', text: '저택에서 두 해 동안.' },
      { type: 'text', speaker: '', text: '제 것이라는 게 없었을 테니까.' },
      { type: 'text', speaker: '', text: '쓰는 것도 모두 저택을 위해서.' },
      { type: 'effect', effect: 'shake' },
      { type: 'combat', enemy: {"name":"탑 최상층 수호자","hp":220,"attack":24} },
      { type: 'text', speaker: '', text: '입는 것도. 먹는 것도. 일하는 것도.' },
      { type: 'text', speaker: '', text: '모두.' },
      { type: 'text', speaker: '', text: '저택을 위해서.' },
      { type: 'text', speaker: '', text: '자신을 위해서가 아니라.' },
      { type: 'text', speaker: '', text: '그런데 지금.' },
      { type: 'text', speaker: '', text: '자신을 위해서.' },
      { type: 'text', speaker: '', text: '자신의 것을 써서.' },
      { type: 'text', speaker: '', text: '무언가를 하는 것.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '처음이라는 말.' },
      { type: 'text', speaker: '', text: '"좋아요?"' },
      { type: 'text', speaker: '', text: '내가 물었다.' },
      { type: 'text', speaker: '', text: '"좋아요."' },
      { type: 'text', speaker: '', text: '"많이요?"' },
      { type: 'text', speaker: '', text: '"많이요."' },
      { type: 'text', speaker: '', text: '"더 좋아질 거예요."' },
      { type: 'text', speaker: '', text: '"어떻게 알아요."' },
      { type: 'text', speaker: '', text: '"더 강해지면요. 더 멀리 빛을 보내면요. 더 많은 것을 할 수 있게 되면요."' },
      { type: 'text', speaker: '', text: '호가 생각했다.' },
      { type: 'text', speaker: '백호', text: '"......더 강해지고 싶어요."' },
      { type: 'text', speaker: '', text: '"될 거예요."' },
      { type: 'text', speaker: '', text: '"당신이 가르쳐줄 거잖아요."' },
      { type: 'text', speaker: '', text: '나는.' },
      { type: 'text', speaker: '', text: '그 말에.' },
      { type: 'text', speaker: '', text: '또.' },
      { type: 'text', speaker: '', text: '시스템 창이 또 떴다.' },
      { type: 'effect', effect: 'system', text: '【 이동 발동까지 24시간. 】' },
      { type: 'text', speaker: '', text: '이제 됐다는 감각이 왔다. 아까보다 선명하게.' },
      { type: 'text', speaker: '', text: '시간이 줄어드는 감각이. 숫자로 보이는 감각이.' },
      { type: 'text', speaker: '', text: '호는 아직 모른다.' },
      { type: 'text', speaker: '', text: '내가 곧 없어진다는 걸.' },
      { type: 'text', speaker: '', text: '모른 척하고 싶었다.' },
      { type: 'text', speaker: '', text: '조금만 더. 오늘 하루만.' },
      { type: 'text', speaker: '', text: '더 모른 척하고 싶었다.' },
      { type: 'text', speaker: '', text: '그날 낮.' },
      { type: 'text', speaker: '', text: '호가 달빛을 연습하는 걸 봤다.' },
      { type: 'text', speaker: '', text: '이번에는 나뭇가지가 아니었다. 강물이었다.' },
      { type: 'text', speaker: '', text: '달빛 실이 수면 위를 스쳤다. 물이 갈라졌다. 소리 없이. 그리고 다시 붙었다.' },
      { type: 'text', speaker: '', text: '"이건 실이에요. 아까는 막이었고."' },
      { type: 'text', speaker: '', text: '호가 말했다. 아침의 곰을 떠올리는 눈이었다.' },
      { type: 'text', speaker: '백호', text: '"해봐요. 다르게."' },
      { type: 'text', speaker: '', text: '호가 손을 벌렸다. 이번에는 부채처럼 넓게가 아니라, 손바닥을 뒤집어 강 위에 빛을 깔았다. 달빛이 수면 위에 얇은 판처럼 펼쳐졌다.' },
      { type: 'text', speaker: '', text: '강물이 그 빛 아래서 멈추는 것 같았다. 흐르는 물이 잠깐 거울이 됐다.' },
      { type: 'text', speaker: '', text: '호한테서 웃음이 나왔다. 저택에서는 없었을 웃음이.' },
      { type: 'text', speaker: '', text: '"이제는 얼마나 멀리요?"' },
      { type: 'text', speaker: '', text: '"저 산 능선까지요."' },
      { type: 'text', speaker: '', text: '"산 능선이요?"' },
      { type: 'text', speaker: '', text: '"달빛이 저기까지 가요. 달이 밤 전체를 비추는 것처럼이요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '달처럼.' },
      { type: 'text', speaker: '', text: '호의 빛이 뭔지를 말하는 것 같았다.' },
      { type: 'text', speaker: '', text: '뜨겁지 않아도. 타오르지 않아도.' },
      { type: 'text', speaker: '', text: '멀리까지, 차갑고 선명하게.' },
      { type: 'text', speaker: '', text: '비추는 것.' },
      { type: 'text', speaker: '', text: '"해봐요."' },
      { type: 'text', speaker: '', text: '호가 손을 들었다.' },
      { type: 'text', speaker: '', text: '달빛이 맺혔다.' },
      { type: 'text', speaker: '', text: '선명하게.' },
      { type: 'text', speaker: '', text: '강하게.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '뻗어나갔다.' },
      { type: 'text', speaker: '', text: '멀리.' },
      { type: 'text', speaker: '', text: '아주 멀리.' },
      { type: 'text', speaker: '', text: '산 능선을 건드렸다.' },
      { type: 'text', speaker: '', text: '나뭇잎이 흔들렸다.' },
      { type: 'text', speaker: '', text: '멀리서.' },
      { type: 'text', speaker: '', text: '호가 그 손을 봤다.' },
      { type: 'text', speaker: '백호', text: '"됐어요?"' },
      { type: 'text', speaker: '', text: '"됐어요."' },
      { type: 'text', speaker: '', text: '"......좋아요."' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '자신한테 하는 말처럼.' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '달빛처럼.' },
      { type: 'text', speaker: '', text: '멀리까지 퍼지는 것 같았다.' },
      { type: 'text', speaker: '', text: '나는 그날 저녁에 왜소한 신을 봤다.' },
      { type: 'text', speaker: '', text: '그 아이가 강가에 서 있었다.' },
      { type: 'text', speaker: '', text: '물을 보고 있었다.' },
      { type: 'text', speaker: '', text: '내가 다가갔다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 나를 봤다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '내 발치에 와서 앉으려고 했다.' },
      { type: 'text', speaker: '', text: '그런데.' },
      { type: 'text', speaker: '', text: '내가 쪼그려 앉으니까.' },
      { type: 'text', speaker: '', text: '그 옆에 와서 앉았다.' },
      { type: 'text', speaker: '', text: '"호."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 강을 봤다.' },
      { type: 'text', speaker: '', text: '"잘 될 거예요."' },
      { type: 'text', speaker: '', text: '내가 중얼거렸다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 나를 봤다.' },
      { type: 'text', speaker: '', text: '그 작은 눈이.' },
      { type: 'text', speaker: '', text: '잠깐 나를 봤다.' },
      { type: 'text', speaker: '', text: '그리고 다시 강을 봤다.' },
      { type: 'text', speaker: '', text: '모르겠다는 것도 아니고.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '옆에 있는 눈이었다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '이상하게.' },
      { type: 'text', speaker: '', text: '위로가 됐다.' },
      { type: 'text', speaker: '', text: '숨이 조금 가라앉았다.' },
      { type: 'text', speaker: '', text: '"다행이에요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 강을 봤다.' },
      { type: 'text', speaker: '', text: '나도 강을 봤다.' },
      { type: 'text', speaker: '', text: '달빛이 강 위에 흘렀다.' },
      { type: 'text', speaker: '', text: '그날 밤에 호가 처음으로 노래를 했다.' },
      { type: 'text', speaker: '', text: '노래라기보다는.' },
      { type: 'text', speaker: '', text: '흥얼거림이었다.' },
      { type: 'text', speaker: '', text: '불 앞에서.' },
      { type: 'text', speaker: '', text: '왜소한 신 옆에서.' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '거의 들리지 않을 만큼.' },
      { type: 'text', speaker: '', text: '"......저택에서 배운 거예요?"' },
      { type: 'text', speaker: '', text: '내가 조용히 물었다.' },
      { type: 'text', speaker: '', text: '호가 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"들었어요?"' },
      { type: 'text', speaker: '', text: '"들렸어요."' },
      { type: 'text', speaker: '', text: '호가 잠시 있었다.' },
      { type: 'text', speaker: '백호', text: '"잔치 때 악사들이 자주 했어요. 뒤꼍에서 들려오던 거요."' },
      { type: 'text', speaker: '', text: '"좋아했어요?"' },
      { type: 'text', speaker: '', text: '"......몰래요."' },
      { type: 'text', speaker: '', text: '"왜 몰래요."' },
      { type: 'text', speaker: '', text: '"하녀가 좋아하는 소리를 하면 이상하잖아요."' },
      { type: 'text', speaker: '', text: '"이상하지 않아요."' },
      { type: 'text', speaker: '', text: '"저택에서는 이상했어요."' },
      { type: 'text', speaker: '', text: '좋아하는 것을 좋아한다고 말할 수 없었던 곳. 그게 저택이었다.' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '"계속 해요."' },
      { type: 'text', speaker: '', text: '"싫어요."' },
      { type: 'text', speaker: '', text: '"들었는데요."' },
      { type: 'text', speaker: '', text: '"들은 거잖아요. 듣는 거랑 계속하는 거 달라요."' },
      { type: 'text', speaker: '', text: '"같이 들어도 돼요?"' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"......당신이 원하는 게 이상해요."' },
      { type: 'text', speaker: '', text: '"같이 들으면 이상해요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 있었다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '다시 흥얼거렸다.' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '왜소한 신이 눈을 감고 들었다.' },
      { type: 'text', speaker: '', text: '나도 들었다.' },
      { type: 'text', speaker: '', text: '불이 흔들렸다.' },
      { type: 'text', speaker: '', text: '그 흥얼거림이.' },
      { type: 'text', speaker: '', text: '불 소리와 섞였다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '호의 흥얼거림이 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"당신이 한 말 중에요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"응?"' },
      { type: 'text', speaker: '', text: '"좋은 기억이 많아지면 나쁜 기억이 작아진다고 했잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이게요."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"좋은 기억이에요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"지금이요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이 불이요. 이 소리요."' },
      { type: 'text', speaker: '', text: '"저도요?"' },
      { type: 'text', speaker: '', text: '호가 잠시 있었다.' },
      { type: 'text', speaker: '백호', text: '"......저도요."' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '"당신도 좋은 기억이에요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '좋은 기억.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '가슴 어딘가에 닿았다.' },
      { type: 'text', speaker: '', text: '"고마워요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"왜 고마워요."' },
      { type: 'text', speaker: '', text: '"좋은 기억이라고 해줘서요."' },
      { type: 'text', speaker: '', text: '호가 고개를 돌렸다.' },
      { type: 'text', speaker: '백호', text: '"......당신 감사가 많은 편이에요."' },
      { type: 'text', speaker: '', text: '"그게 나쁜 거예요?"' },
      { type: 'text', speaker: '', text: '"나쁘지는 않아요."' },
      { type: 'text', speaker: '', text: '호가 불을 봤다.' },
      { type: 'text', speaker: '백호', text: '"그냥 이상해요. 이렇게 자주 고마워하는 사람은 처음이에요."' },
      { type: 'text', speaker: '', text: '"저택에서는요?"' },
      { type: 'text', speaker: '', text: '"저택에서 아무도 고마워하지 않았어요. 감사인사가 없는 곳이었어요. 하녀가 일을 잘 해도 당연한 거였고, 특별히 뭔가 해줘도 그냥 당연한 거였고."' },
      { type: 'text', speaker: '', text: '"그러면 지금은요?"' },
      { type: 'text', speaker: '', text: '호가 별을 봤다.' },
      { type: 'text', speaker: '백호', text: '"지금은 당연하지 않아요."' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '오래 남았다.' },
    ]
  },
  {
    title: '10장 — 혼자 우는 호랑이',
    nodes: [
      { type: 'text', speaker: '', text: '마지막 밤.' },
      { type: 'text', speaker: '', text: '그것이 마지막 밤이라는 걸.' },
      { type: 'text', speaker: '', text: '나는 알았다.' },
      { type: 'text', speaker: '', text: '시스템 창이 여러 번 떴다가 닫혔다.' },
      { type: 'effect', effect: 'system', text: '【 백호 각성 완료. 스토리 종료 조건 충족. 】' },
      { type: 'effect', effect: 'system', text: '【 신수 육성 완료. 최종 등급: S. 다음 신수 배정 대기. 】' },
      { type: 'effect', effect: 'system', text: '【 플레이어 평가: 호감도 MAX, 성장 기여도 MAX. 】' },
      { type: 'effect', effect: 'system', text: '【 이동 발동까지 12시간. 】' },
      { type: 'text', speaker: '', text: '나는 열지 않았다.' },
      { type: 'text', speaker: '', text: '모른 척했다.' },
      { type: 'text', speaker: '', text: '알면 더 빨리 올 것 같아서.' },
      { type: 'text', speaker: '', text: '낮에 호가 훈련을 했다.' },
      { type: 'text', speaker: '', text: '빛을 쓰는 연습.' },
      { type: 'text', speaker: '', text: '이제 멀리까지 보냈다.' },
      { type: 'text', speaker: '', text: '이제 정확하게 보냈다.' },
      { type: 'text', speaker: '', text: '"됐어요?"' },
      { type: 'text', speaker: '', text: '호가 나한테 물었다.' },
      { type: 'text', speaker: '백호', text: '"됐어요."' },
      { type: 'text', speaker: '', text: '"더 할 수 있어요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"지금 할까요?"' },
      { type: 'text', speaker: '', text: '나는 잠시 있었다.' },
      { type: 'text', speaker: '', text: '"오늘은 쉬어요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"......그냥이요."' },
      { type: 'text', speaker: '', text: '"그냥이 이유예요?"' },
      { type: 'text', speaker: '', text: '"오늘은 쉬고 싶어요."' },
      { type: 'text', speaker: '', text: '호가 나를 오래 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신 눈."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"아까부터 이상해요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"......오래 보는 것 같아요."' },
      { type: 'text', speaker: '', text: '나는 고개를 돌렸다.' },
      { type: 'text', speaker: '', text: '"그런 것 같아요?"' },
      { type: 'text', speaker: '', text: '"그런 것 같아요."' },
      { type: 'text', speaker: '', text: '침묵.' },
      { type: 'text', speaker: '', text: '"뭔지 말해요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"......아직이에요."' },
      { type: 'text', speaker: '', text: '"아직이요?"' },
      { type: 'text', speaker: '', text: '"오늘은 아직이에요."' },
      { type: 'text', speaker: '', text: '"내일이요?"' },
      { type: 'text', speaker: '', text: '나는 대답하지 않았다.' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '이미 알고 있었다.' },
      { type: 'text', speaker: '', text: '"......알겠어요."' },
      { type: 'text', speaker: '', text: '호가 돌아섰다.' },
      { type: 'text', speaker: '백호', text: '"그러면 오늘은 쉬어요."' },
      { type: 'text', speaker: '', text: '그리고 걸어갔다.' },
      { type: 'text', speaker: '', text: '나는 그 뒷모습을 봤다.' },
      { type: 'text', speaker: '', text: '곧은 등.' },
      { type: 'text', speaker: '', text: '처지지 않은 어깨.' },
      { type: 'text', speaker: '', text: '멈추지 않는 걸음.' },
      { type: 'text', speaker: '', text: '이 아이는.' },
      { type: 'text', speaker: '', text: '알아도.' },
      { type: 'text', speaker: '', text: '걷는다.' },
      { type: 'text', speaker: '', text: '낮에 강가에서.' },
      { type: 'text', speaker: '', text: '호가 혼자 서 있었다.' },
      { type: 'text', speaker: '', text: '나는 조금 떨어져서 봤다.' },
      { type: 'text', speaker: '', text: '강물이 흐르는 소리만 있었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 옆에 앉아서 강을 봤다.' },
      { type: 'text', speaker: '', text: '호도 강을 봤다.' },
      { type: 'text', speaker: '', text: '그 둘이서.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '말없이.' },
      { type: 'text', speaker: '', text: '"이 강이요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"응?"' },
      { type: 'text', speaker: '', text: '"저 처음에 여기서 발목 다쳤잖아요."' },
      { type: 'text', speaker: '', text: '"맞아요."' },
      { type: 'text', speaker: '', text: '"그때요."' },
      { type: 'text', speaker: '', text: '호가 강물을 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신이 발목을 감아줬잖아요. 아픈 거 말해도 된다고요."' },
      { type: 'text', speaker: '', text: '"기억해요?"' },
      { type: 'text', speaker: '', text: '"당신이 한 말 중에 좋은 것들에 들어있으니까요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '"지금도 세고 있어요?"' },
      { type: 'text', speaker: '', text: '"지금도요."' },
      { type: 'text', speaker: '', text: '"몇 개예요."' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"많아요."' },
      { type: 'text', speaker: '', text: '"얼마나요."' },
      { type: 'text', speaker: '', text: '"셀 수 없을 만큼이요."' },
      { type: 'text', speaker: '', text: '그 말이.' },
      { type: 'text', speaker: '', text: '강물 소리랑 같이.' },
      { type: 'text', speaker: '', text: '흘렀다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 옆에서 무릎을 세웠다.' },
      { type: 'text', speaker: '', text: '그 작은 아이가.' },
      { type: 'text', speaker: '', text: '강을 봤다.' },
      { type: 'text', speaker: '', text: '둘이 보는 강이 같은 강인지.' },
      { type: 'text', speaker: '', text: '다른 강인지.' },
      { type: 'text', speaker: '', text: '그걸 나는 몰랐다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '그 둘이.' },
      { type: 'text', speaker: '', text: '나란히 앉아서.' },
      { type: 'text', speaker: '', text: '강을 보는 장면이.' },
      { type: 'text', speaker: '', text: '좋았다.' },
      { type: 'text', speaker: '', text: '"훈련할까요?"' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"오늘은 쉰다고 했잖아요."' },
      { type: 'text', speaker: '', text: '"당신이요. 저는 안 쉰다고 했잖아요."' },
      { type: 'text', speaker: '', text: '"그랬나요?"' },
      { type: 'text', speaker: '', text: '"그랬어요."' },
      { type: 'text', speaker: '', text: '호가 일어섰다.' },
      { type: 'text', speaker: '백호', text: '"마지막까지 연습해요."' },
      { type: 'text', speaker: '', text: '"마지막이라는 거 알고 있어요?"' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '달랐다.' },
      { type: 'text', speaker: '', text: '흔들리지 않았다.' },
      { type: 'text', speaker: '', text: '"마지막이어도요."' },
      { type: 'text', speaker: '', text: '호가 손끝에 달빛을 맺혔다.' },
      { type: 'text', speaker: '', text: '차갑고 선명한.' },
      { type: 'text', speaker: '', text: '"지금 이게 제 것이에요."' },
      { type: 'text', speaker: '', text: '호가 손을 뻗었다. 달빛이 강물 위를 갈랐다. 어제보다 넓게. 어제보다 멀리. 강 건너 바위에 빛이 닿았다. 바위 표면에 흰 금이 생겼다. 소리 없이.' },
      { type: 'text', speaker: '', text: '그 빛이.' },
      { type: 'text', speaker: '', text: '강물 위로.' },
      { type: 'text', speaker: '', text: '넓게.' },
      { type: 'text', speaker: '', text: '번졌다.' },
      { type: 'text', speaker: '', text: '저녁이 됐다.' },
      { type: 'text', speaker: '', text: '호가 된장찌개를 끓였다.' },
      { type: 'text', speaker: '백호', text: '"오늘도요?"' },
      { type: 'text', speaker: '', text: '"된장찌개가 맛있잖아요."' },
      { type: 'text', speaker: '', text: '"이미 여러 번 먹었는데요."' },
      { type: 'text', speaker: '', text: '"당신이 처음 끓여줬을 때부터요."' },
      { type: 'text', speaker: '', text: '호가 냄비를 봤다.' },
      { type: 'text', speaker: '백호', text: '"저택에서는 된장찌개가 싫었어요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '보글보글 끓는 소리가 났다.' },
      { type: 'text', speaker: '', text: '"좋아요."' },
      { type: 'text', speaker: '', text: '짧게.' },
      { type: 'text', speaker: '', text: '담담하게.' },
      { type: 'text', speaker: '', text: '"같은 음식인데요."' },
      { type: 'text', speaker: '', text: '"사람이 달라졌으니까요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"당신이요."' },
      { type: 'text', speaker: '', text: '"제가요?"' },
      { type: 'text', speaker: '', text: '"처음 끓여준 사람이 당신이잖아요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '같은 된장찌개인데.' },
      { type: 'text', speaker: '', text: '처음 끓여준 사람 때문에.' },
      { type: 'text', speaker: '', text: '달라진 것.' },
      { type: 'text', speaker: '', text: '"......그런가요."' },
      { type: 'text', speaker: '', text: '"그런 거예요."' },
      { type: 'text', speaker: '', text: '호가 두부를 넣었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 냄비 옆에 앉아서 봤다.' },
      { type: 'text', speaker: '', text: '"이 아이도 좋아해요?"' },
      { type: 'text', speaker: '', text: '왜소한 신이 끄덕였다.' },
      { type: 'text', speaker: '', text: '"그러면 더 넣어요."' },
      { type: 'text', speaker: '', text: '두부가 더 들어갔다.' },
      { type: 'text', speaker: '', text: '오늘이 마지막이라는 걸.' },
      { type: 'text', speaker: '', text: '아는 것 같기도, 모르는 것 같기도 한 셋이.' },
      { type: 'text', speaker: '', text: '마지막 밥을 먹었다.' },
      { type: 'text', speaker: '', text: '맛있었다.' },
      { type: 'text', speaker: '', text: '밥을 다 먹고.' },
      { type: 'text', speaker: '', text: '호가 설거지를 했다.' },
      { type: 'text', speaker: '', text: '나도 도우려 했다.' },
      { type: 'text', speaker: '', text: '"됐어요."' },
      { type: 'text', speaker: '', text: '"하나라도요."' },
      { type: 'text', speaker: '', text: '"당신이 오늘 이상하게 도우려 해요."' },
      { type: 'text', speaker: '', text: '"그래요?"' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"오늘이 마지막이라는 걸 알아서요?"' },
      { type: 'text', speaker: '', text: '나는.' },
      { type: 'text', speaker: '', text: '말이 나오지 않았다.' },
      { type: 'text', speaker: '', text: '호가 설거지를 계속했다.' },
      { type: 'text', speaker: '백호', text: '"괜찮아요."' },
      { type: 'text', speaker: '', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"마지막 밥을 맛있게 먹으면 됐어요."' },
      { type: 'text', speaker: '', text: '"......호."' },
      { type: 'text', speaker: '', text: '"됐어요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '단호하게.' },
      { type: 'text', speaker: '', text: '"마지막이어도."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"맛있었으면 된 거예요."' },
      { type: 'text', speaker: '', text: '나는 그 말을 들었다.' },
      { type: 'text', speaker: '', text: '마지막이어도 맛있으면 된다는 말.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '이 아이였다.' },
      { type: 'text', speaker: '', text: '막으려 하지 않는.' },
      { type: 'text', speaker: '', text: '무너지지 않는.' },
      { type: 'text', speaker: '', text: '그러면서도.' },
      { type: 'text', speaker: '', text: '단단한.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에서 걸었다.' },
      { type: 'text', speaker: '', text: '그 작은 눈이 나를 봤다.' },
      { type: 'text', speaker: '', text: '왜 그러는지 모르겠지만.' },
      { type: 'text', speaker: '', text: '오늘은 내 발치에 더 가까이 붙어서 걸었다.' },
      { type: 'text', speaker: '', text: '평소보다.' },
      { type: 'text', speaker: '', text: '더 꼭.' },
      { type: 'text', speaker: '', text: '"......뭐예요."' },
      { type: 'text', speaker: '', text: '내가 중얼거렸다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 내 옆에서 계속 걸었다.' },
      { type: 'text', speaker: '', text: '그 작은 발이 내 발과 같은 박자로.' },
      { type: 'text', speaker: '', text: '함께.' },
      { type: 'text', speaker: '', text: '"이 아이."' },
      { type: 'text', speaker: '', text: '나는 그 아이를 봤다.' },
      { type: 'text', speaker: '', text: '뭔가 알고 있는 것 같지는 않았다.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '옆에 있는 것 같았다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '"잘 될 거야."' },
      { type: 'text', speaker: '', text: '나는 속으로 말했다.' },
      { type: 'text', speaker: '', text: '호가.' },
      { type: 'text', speaker: '', text: '반드시.' },
      { type: 'text', speaker: '', text: '나는 그 생각을 했다.' },
      { type: 'text', speaker: '', text: '가슴 어딘가가.' },
      { type: 'text', speaker: '', text: '한 번.' },
      { type: 'text', speaker: '', text: '무너지는 것 같았다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '다시 섰다.' },
      { type: 'text', speaker: '', text: '모닥불 앞에 셋이서 앉았다.' },
      { type: 'text', speaker: '', text: '오늘이 마지막이라는 것을.' },
      { type: 'text', speaker: '', text: '아직.' },
      { type: 'text', speaker: '', text: '모른 척하고 싶었다.' },
      { type: 'text', speaker: '', text: '"당신."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"응?"' },
      { type: 'text', speaker: '', text: '"오늘 이상해요."' },
      { type: 'text', speaker: '', text: '"어떻게요."' },
      { type: 'text', speaker: '', text: '"눈이 달라요."' },
      { type: 'text', speaker: '', text: '"뭐가요."' },
      { type: 'text', speaker: '', text: '"......없어질 것 같은 눈이에요."' },
      { type: 'text', speaker: '', text: '나는.' },
      { type: 'text', speaker: '', text: '말을 잃었다.' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"떠나는 거 알아요?"' },
      { type: 'text', speaker: '', text: '"......어떻게요."' },
      { type: 'text', speaker: '', text: '"직관이요."' },
      { type: 'text', speaker: '', text: '나는 대답할 수 없었다.' },
      { type: 'text', speaker: '', text: '"괜찮아요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"괜찮지 않아도 괜찮다고 하는 게 아니에요."' },
      { type: 'text', speaker: '', text: '"그러면요."' },
      { type: 'text', speaker: '', text: '"알면 준비할 수 있잖아요."' },
      { type: 'text', speaker: '', text: '"뭘 준비해요."' },
      { type: 'text', speaker: '', text: '"할 말이요."' },
      { type: 'text', speaker: '', text: '호가 나를 똑바로 봤다.' },
      { type: 'text', speaker: '백호', text: '"저 말하고 싶은 게 있어요."' },
      { type: 'text', speaker: '', text: '"말해요."' },
      { type: 'text', speaker: '', text: '"많아요."' },
      { type: 'text', speaker: '', text: '"다 말해요."' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '', text: '불이 흔들렸다.' },
      { type: 'text', speaker: '', text: '"처음에 당신이 왔을 때, 저는 혼자가 좋다고 생각했어요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"혼자가 아닌 걸 모르니까 혼자가 좋다고 했던 거예요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"지금은 혼자가 싫어요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 없어지면 다시 혼자가 되는 게."' },
      { type: 'text', speaker: '', text: '호가 말을 멈췄다.' },
      { type: 'text', speaker: '백호', text: '"무서워요."' },
      { type: 'text', speaker: '', text: '나는 숨을 참았다.' },
      { type: 'text', speaker: '', text: '호가 무서운 걸 말했다.' },
      { type: 'text', speaker: '', text: '저택에서 두 해. 맞아도 울지 않고, 혼나도 고개 숙이지 않고, 창피한 것도 두려운 것도 내보이지 않던 아이가.' },
      { type: 'text', speaker: '', text: '무서운 걸 말했다.' },
      { type: 'text', speaker: '', text: '"하지만."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"이제는 알아요. 외롭다는 게 뭔지."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"알면 견딜 수 있어요."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"뭔지 아니까요. 외로움이 뭔지 알면, 그 안에서도 갈 방향이 보여요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"당신은."' },
      { type: 'text', speaker: '', text: '"뭐요."' },
      { type: 'text', speaker: '', text: '"진짜 강한 사람이에요."' },
      { type: 'text', speaker: '', text: '호가 고개를 돌렸다.' },
      { type: 'text', speaker: '', text: '귀가 빨개졌다.' },
      { type: 'text', speaker: '', text: '"그 말은."' },
      { type: 'text', speaker: '', text: '"사실이에요."' },
      { type: 'text', speaker: '', text: '"......너무 직접적이에요."' },
      { type: 'text', speaker: '', text: '"사실이에요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '짧게.' },
      { type: 'text', speaker: '', text: '"알지만, 당신한테 듣는 건 달라요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 우리 사이에 누웠다.' },
      { type: 'text', speaker: '', text: '하늘을 봤다.' },
      { type: 'text', speaker: '', text: '우리도 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '별이 더 많아졌다.' },
      { type: 'text', speaker: '', text: '"저, 울지 않을 거예요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"응."' },
      { type: 'text', speaker: '', text: '"울고 싶어도요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이상하죠?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '"왜요."' },
      { type: 'text', speaker: '', text: '"강해서요."' },
      { type: 'text', speaker: '', text: '호가 또 고개를 돌렸다.' },
      { type: 'text', speaker: '백호', text: '"그 말 또 하지 말아요."' },
      { type: 'text', speaker: '', text: '"사실이에요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '호가 별을 봤다.' },
      { type: 'text', speaker: '백호', text: '"알기 때문에 더 힘들어요."' },
      { type: 'text', speaker: '', text: '나는 그 말이 가슴에 박혔다.' },
      { type: 'text', speaker: '', text: '알기 때문에.' },
      { type: 'text', speaker: '', text: '자신이 강하다는 걸 알기 때문에.' },
      { type: 'text', speaker: '', text: '더 힘들다는 말.' },
      { type: 'text', speaker: '', text: '강한 게 무거운 것이라는 걸.' },
      { type: 'text', speaker: '', text: '이 아이는 이미 알고 있었다.' },
      { type: 'text', speaker: '', text: '한참 후에.' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"내일이에요?"' },
      { type: 'text', speaker: '', text: '"......아마도요."' },
      { type: 'text', speaker: '', text: '"그러면 자야겠네요."' },
      { type: 'text', speaker: '', text: '"자요."' },
      { type: 'text', speaker: '', text: '"당신도 자요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"......눈 뜨면 있어요?"' },
      { type: 'text', speaker: '', text: '나는 대답하지 못했다.' },
      { type: 'text', speaker: '', text: '호가 그 침묵을 들었다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '그 침묵이 무슨 뜻인지.' },
      { type: 'text', speaker: '', text: '알고 있는 눈으로.' },
      { type: 'text', speaker: '', text: '"알겠어요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '눈물이 고였다가 흘리지 않았다.' },
      { type: 'text', speaker: '', text: '"그러면요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"오늘 하나만 더 부탁해요."' },
      { type: 'text', speaker: '', text: '"뭐요."' },
      { type: 'text', speaker: '', text: '호가 잠시 생각했다.' },
      { type: 'text', speaker: '백호', text: '"이름 한 번만 더요."' },
      { type: 'text', speaker: '', text: '"뭐요?"' },
      { type: 'text', speaker: '', text: '"명이요. 한 번만 더요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '흔들렸다.' },
      { type: 'text', speaker: '', text: '무너지지 않으면서.' },
      { type: 'text', speaker: '', text: '흔들렸다.' },
      { type: 'text', speaker: '', text: '"명."' },
      { type: 'text', speaker: '', text: '호가 눈을 감았다.' },
      { type: 'text', speaker: '백호', text: '"......응."' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '거의 들리지 않을 만큼.' },
      { type: 'text', speaker: '', text: '응.' },
      { type: 'text', speaker: '', text: '그 한 글자가.' },
      { type: 'text', speaker: '', text: '오래 남았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 옆에서 눈을 감았다.' },
      { type: 'text', speaker: '', text: '세 개의 그림자가.' },
      { type: 'text', speaker: '', text: '마지막 불빛 아래에 있었다.' },
      { type: 'text', speaker: '', text: '나는 오래 그 불을 봤다.' },
      { type: 'text', speaker: '', text: '내일이 오기를 바라지 않았다.' },
      { type: 'text', speaker: '', text: '아직. 오늘이 좀 더 길었으면 했다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '불이 흔들렸다.' },
      { type: 'text', speaker: '', text: '호가 눈을 감았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호의 손을 잡았다.' },
      { type: 'text', speaker: '', text: '나는 그래도 그 불을 봤다.' },
      { type: 'text', speaker: '', text: '이 불이 꺼지면.' },
      { type: 'text', speaker: '', text: '이 밤이 지나면.' },
      { type: 'text', speaker: '', text: '오늘이 끝나면.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '그 다음이 오면.' },
      { type: 'text', speaker: '', text: '나는 오래 그 생각을 했다.' },
      { type: 'text', speaker: '', text: '아침이 왔다.' },
      { type: 'text', speaker: '', text: '나는 일어나자마자 알았다.' },
      { type: 'text', speaker: '', text: '오늘이다.' },
      { type: 'text', speaker: '', text: '몸이 알았다.' },
      { type: 'text', speaker: '', text: '발이 무거웠다.' },
      { type: 'text', speaker: '', text: '시스템 창이 떴다.' },
      { type: 'effect', effect: 'system', text: '【 이동 발동까지 2시간. 이동 방식: 공간 치환형. 플레이어의 존재가 빛으로 분해되어 다음 배정지로 전송됨. 발동 조건: 신수 자립 확인 후 시스템 자동 개시. 플레이어 의지로 중단 불가. 】' },
      { type: 'text', speaker: '', text: '나는 닫았다.' },
      { type: 'text', speaker: '', text: '호도 알고 있었다.' },
      { type: 'text', speaker: '', text: '이미 일어나 있었다.' },
      { type: 'text', speaker: '', text: '강가.' },
      { type: 'text', speaker: '', text: '물이 흘렀다.' },
      { type: 'text', speaker: '', text: '어제 빛이 폭발했던 강.' },
      { type: 'text', speaker: '', text: '호가 물가에 서 있었다.' },
      { type: 'text', speaker: '', text: '나도 걸어갔다.' },
      { type: 'text', speaker: '', text: '왜소한 신도 따라왔다. 그 아이가 내 발치에 바짝 붙어 걸었다.' },
      { type: 'text', speaker: '', text: '평소보다 더 가까이.' },
      { type: 'text', speaker: '', text: '호를 한 번 보고, 나를 한 번 보고.' },
      { type: 'text', speaker: '', text: '다시 호를 봤다.' },
      { type: 'text', speaker: '', text: '그 작은 몸이 불안해 보였다.' },
      { type: 'text', speaker: '', text: '호가 강물을 봤다.' },
      { type: 'text', speaker: '', text: '나도 강물을 봤다.' },
      { type: 'text', speaker: '', text: '한참이나 아무 말 없었다.' },
      { type: 'text', speaker: '', text: '물 흐르는 소리.' },
      { type: 'text', speaker: '', text: '새 우는 소리.' },
      { type: 'text', speaker: '', text: '해가 천천히 올라왔다.' },
      { type: 'text', speaker: '', text: '붉고 맑은 아침이었다.' },
      { type: 'text', speaker: '', text: '"예쁘네요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"응."' },
      { type: 'text', speaker: '', text: '"아침이 이렇게 예쁜 걸 몰랐어요."' },
      { type: 'text', speaker: '', text: '"저택에서는 보기 어려웠겠죠."' },
      { type: 'text', speaker: '', text: '"저택에서는 아침이 일 시작이었어요. 예쁘다고 볼 여유가 없었어요."' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '"지금은 볼 수 있어요."' },
      { type: 'text', speaker: '', text: '"지금은 봐요."' },
      { type: 'text', speaker: '', text: '호가 물을 봤다.' },
      { type: 'text', speaker: '', text: '강물이 햇빛에 반짝였다.' },
      { type: 'text', speaker: '', text: '달빛이 없어도.' },
      { type: 'text', speaker: '', text: '낮에도.' },
      { type: 'text', speaker: '', text: '강이 빛났다.' },
      { type: 'text', speaker: '', text: '"이 강."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"응?"' },
      { type: 'text', speaker: '', text: '"어제 제가 빛을 폭발시킨 강이잖아요."' },
      { type: 'text', speaker: '', text: '"그렇죠."' },
      { type: 'text', speaker: '', text: '"그러면 이 강이 기억할까요. 그 빛을요."' },
      { type: 'text', speaker: '', text: '나는 강을 봤다.' },
      { type: 'text', speaker: '', text: '"강이 기억을 해요?"' },
      { type: 'text', speaker: '', text: '"모르겠어요. 그런데요."' },
      { type: 'text', speaker: '', text: '호가 물 위에 손을 내밀었다.' },
      { type: 'text', speaker: '', text: '달빛이 맺혔다.' },
      { type: 'text', speaker: '', text: '그 빛이 강물 위에 비쳤다.' },
      { type: 'text', speaker: '', text: '"이게 있으면요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"제가 여기 있었다는 게 남는 것 같아요."' },
      { type: 'text', speaker: '', text: '나는 그 빛을 봤다.' },
      { type: 'text', speaker: '', text: '강물 위에 달빛이 흘렀다.' },
      { type: 'text', speaker: '', text: '차갑고 선명하게.' },
      { type: 'text', speaker: '', text: '이 강이 기억할 것 같았다.' },
      { type: 'text', speaker: '', text: '정말로.' },
      { type: 'text', speaker: '', text: '"당신은요?"' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"응?"' },
      { type: 'text', speaker: '', text: '"당신도 기억할 거예요?"' },
      { type: 'text', speaker: '', text: '나는 호를 봤다.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '흔들리지 않았다.' },
      { type: 'text', speaker: '', text: '뭔가를 참는 것도 아니었다.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '알고 싶어서 묻는 눈이었다.' },
      { type: 'text', speaker: '', text: '"기억해요."' },
      { type: 'text', speaker: '', text: '내가 말했다.' },
      { type: 'text', speaker: '', text: '"얼마나요."' },
      { type: 'text', speaker: '', text: '"오래요."' },
      { type: 'text', speaker: '', text: '호가 고개를 끄덕였다.' },
      { type: 'text', speaker: '백호', text: '"저도요."' },
      { type: 'text', speaker: '', text: '그리고 다시 강물을 봤다.' },
      { type: 'text', speaker: '', text: '"당신 이름요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"오늘 알려줘요."' },
      { type: 'text', speaker: '', text: '나는.' },
      { type: 'text', speaker: '', text: '그 말에.' },
      { type: 'text', speaker: '', text: '잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '"지금 말해요."' },
      { type: 'text', speaker: '', text: '호가 나를 봤다.' },
      { type: 'text', speaker: '백호', text: '"잊어버리기 전에요."' },
      { type: 'text', speaker: '', text: '"잊지 않을 거예요."' },
      { type: 'text', speaker: '', text: '"그래도요. 이름을 알아야 찾아갈 때 부를 수 있잖아요."' },
      { type: 'text', speaker: '', text: '나는.' },
      { type: 'text', speaker: '', text: '내 이름을 말했다.' },
      { type: 'text', speaker: '', text: '호가 그 이름을 들었다.' },
      { type: 'text', speaker: '', text: '입술을 움직여 따라 했다.' },
      { type: 'text', speaker: '', text: '소리는 내지 않았다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '"기억할게요."' },
      { type: 'text', speaker: '', text: '눈이 흔들렸다.' },
      { type: 'text', speaker: '', text: '강물이 흘렀다.' },
      { type: 'text', speaker: '', text: '새 우는 소리.' },
      { type: 'text', speaker: '', text: '물 흐르는 소리.' },
      { type: 'text', speaker: '', text: '바람 소리.' },
      { type: 'text', speaker: '', text: '그것 외에는 아무것도 없었다.' },
      { type: 'text', speaker: '', text: '한참 후에.' },
      { type: 'text', speaker: '', text: '발 아래서 빛이 올라왔다.' },
      { type: 'text', speaker: '', text: '황금빛.' },
      { type: 'text', speaker: '', text: '나는 내려다봤다.' },
      { type: 'text', speaker: '', text: '황금빛이 발목 위로 차오르고 있었다.' },
      { type: 'text', speaker: '', text: '호가 그것을 봤다.' },
      { type: 'text', speaker: '', text: '눈을 감았다.' },
      { type: 'text', speaker: '', text: '다시 떴다.' },
      { type: 'text', speaker: '', text: '나를 봤다.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '무너지지 않았다.' },
      { type: 'text', speaker: '', text: '흔들렸다.' },
      { type: 'text', speaker: '', text: '그러나 무너지지 않았다.' },
      { type: 'text', speaker: '', text: '"당신."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름."' },
      { type: 'text', speaker: '', text: '나는 다시 말했다.' },
      { type: 'text', speaker: '', text: '호가 들었다.' },
      { type: 'text', speaker: '', text: '이번에는.' },
      { type: 'text', speaker: '', text: '소리 내어 따라 했다.' },
      { type: 'text', speaker: '', text: '작게.' },
      { type: 'text', speaker: '', text: '"기억할게요."' },
      { type: 'text', speaker: '', text: '빛이 올라왔다.' },
      { type: 'text', speaker: '', text: '"호."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"찾아갈 거예요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"혼자서도 갈 수 있어요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"당신이 어디 있든요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '빛이 허리까지 올라왔다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호 옆으로 왔다.' },
      { type: 'text', speaker: '', text: '그 작은 손이 호의 손을 잡았다.' },
      { type: 'text', speaker: '', text: '호가 그 손을 꽉 쥐었다.' },
      { type: 'text', speaker: '백호', text: '"무서워요?"' },
      { type: 'text', speaker: '', text: '호가 물었다.' },
      { type: 'text', speaker: '백호', text: '"응."' },
      { type: 'text', speaker: '', text: '나는 솔직하게 말했다.' },
      { type: 'text', speaker: '', text: '"저도요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"같이 무서운 거네요."' },
      { type: 'text', speaker: '', text: '"그러네요."' },
      { type: 'text', speaker: '', text: '"그러면."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"같이 무서운 건데, 혼자 사라지는 게 불공평하잖아요."' },
      { type: 'text', speaker: '', text: '나는 웃었다.' },
      { type: 'text', speaker: '', text: '웃으면서 눈물이 났다.' },
      { type: 'text', speaker: '', text: '빛이 어깨까지 올라왔다.' },
      { type: 'text', speaker: '', text: '"호."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"강해요, 당신."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"당신이 서 있는 자리가 어디든."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그게 호의 자리예요."' },
      { type: 'text', speaker: '백호', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"그걸 기억해요."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '빛이 목까지 올라왔다.' },
      { type: 'text', speaker: '', text: '"마지막으로요."' },
      { type: 'text', speaker: '', text: '나는 말했다.' },
      { type: 'text', speaker: '', text: '"말하고 싶은 게 있어요."' },
      { type: 'text', speaker: '', text: '호가 봤다.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '흔들렸다.' },
      { type: 'text', speaker: '', text: '무너지지 않으면서.' },
      { type: 'text', speaker: '', text: '흔들렸다.' },
      { type: 'text', speaker: '', text: '"당신을 만나서."' },
      { type: 'text', speaker: '', text: '빛이 차올랐다.' },
      { type: 'text', speaker: '', text: '"제가 이 세계에 온 이유를 알 것 같았어요."' },
      { type: 'text', speaker: '', text: '"......뭔데요."' },
      { type: 'text', speaker: '', text: '"당신이에요."' },
      { type: 'text', speaker: '', text: '빛이 터졌다.' },
      { type: 'text', speaker: '', text: '사라졌다.' },
      { type: 'text', speaker: '', text: '빛의 잔상만 남았다.' },
      { type: 'text', speaker: '', text: '강물이 흘렀다.' },
      { type: 'text', speaker: '', text: '호는 그 자리에 서 있었다.' },
      { type: 'text', speaker: '', text: '아무것도 없는 자리.' },
      { type: 'text', speaker: '', text: '빛이 있던 자리.' },
      { type: 'text', speaker: '', text: '거기에.' },
      { type: 'text', speaker: '', text: '아무것도 없었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호의 손을 꽉 쥐고 있었다.' },
      { type: 'text', speaker: '', text: '차갑고 작은 손.' },
      { type: 'text', speaker: '', text: '호가 그 손을 꽉 쥐었다.' },
      { type: 'text', speaker: '', text: '한참.' },
      { type: 'text', speaker: '', text: '강물이 흘렀다.' },
      { type: 'text', speaker: '', text: '새가 어딘가에서 울었다.' },
      { type: 'text', speaker: '', text: '바람이 불었다.' },
      { type: 'text', speaker: '', text: '호의 머리카락이 흔들렸다.' },
      { type: 'text', speaker: '', text: '눈물이 흘렀다.' },
      { type: 'text', speaker: '', text: '소리 없이.' },
      { type: 'text', speaker: '', text: '울었다.' },
      { type: 'text', speaker: '', text: '강물 소리가 그 울음을 감췄다.' },
      { type: 'text', speaker: '', text: '아무도 없었다.' },
      { type: 'text', speaker: '', text: '왜소한 신만.' },
      { type: 'text', speaker: '', text: '그 아이가 호의 손을 놓지 않았다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '한참.' },
      { type: 'text', speaker: '', text: '호의 울음이 멈추지 않았다.' },
      { type: 'text', speaker: '', text: '소리가 없었다.' },
      { type: 'text', speaker: '', text: '소리가 없는 울음이.' },
      { type: 'text', speaker: '', text: '더 깊었다.' },
      { type: 'text', speaker: '', text: '저택에서 두 해 동안.' },
      { type: 'text', speaker: '', text: '울지 않았던 것들이.' },
      { type: 'text', speaker: '', text: '지금.' },
      { type: 'text', speaker: '', text: '흘렀다.' },
      { type: 'text', speaker: '', text: '스스로 정한 규칙이 있었다. 절대로 울지 않는다.' },
      { type: 'text', speaker: '', text: '그 규칙이.' },
      { type: 'text', speaker: '', text: '지금.' },
      { type: 'text', speaker: '', text: '처음으로.' },
      { type: 'text', speaker: '', text: '허락되는 것 같았다.' },
      { type: 'text', speaker: '', text: '여기서는 울어도 된다.' },
      { type: 'text', speaker: '', text: '아무도 없으니까.' },
      { type: 'text', speaker: '', text: '강물이 감추니까.' },
      { type: 'text', speaker: '', text: '왜소한 신이 듣고 있지만.' },
      { type: 'text', speaker: '', text: '왜소한 신은 혼내지 않으니까.' },
      { type: 'text', speaker: '', text: '그래서.' },
      { type: 'text', speaker: '', text: '울었다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '한참.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '멈췄다.' },
      { type: 'text', speaker: '', text: '호가 눈을 닦았다.' },
      { type: 'text', speaker: '', text: '빠르게.' },
      { type: 'text', speaker: '', text: '고개를 들었다.' },
      { type: 'text', speaker: '', text: '앞을 봤다.' },
      { type: 'text', speaker: '', text: '"당신이 한 말 기억해요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '목소리가 떨렸다.' },
      { type: 'text', speaker: '', text: '하지만 끊기지 않았다.' },
      { type: 'text', speaker: '', text: '"혼자가 아닌 걸 모르니까 혼자가 좋다고 했다고요."' },
      { type: 'text', speaker: '', text: '강물이 흘렀다.' },
      { type: 'text', speaker: '', text: '"이제 알아요. 혼자가 아니라는 게."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '"이 아이가 있잖아요."' },
      { type: 'text', speaker: '', text: '호가 왜소한 신을 봤다.' },
      { type: 'text', speaker: '', text: '그 작은 눈을.' },
      { type: 'text', speaker: '', text: '깊은 눈을.' },
      { type: 'text', speaker: '', text: '"그리고 저도 알게 됐잖아요. 당신 덕분에."' },
      { type: 'text', speaker: '', text: '바람이 불었다.' },
      { type: 'text', speaker: '', text: '호의 머리카락이 흔들렸다.' },
      { type: 'text', speaker: '백호', text: '"갈 거야."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '목소리가 달랐다.' },
      { type: 'text', speaker: '', text: '무너지지 않았다. 울었지만 무너지지 않았다.' },
      { type: 'text', speaker: '', text: '울어도 무너지지 않는 것.' },
      { type: 'text', speaker: '', text: '흔들려도 쓰러지지 않는 것.' },
      { type: 'text', speaker: '', text: '그것이 강한 것이다.' },
      { type: 'text', speaker: '', text: '"당신한테 한 소리 할 거야. 인사도 없이 사라지면 어떡하냐고."' },
      { type: 'text', speaker: '', text: '왜소한 신이 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '호가 웃었다.' },
      { type: 'text', speaker: '', text: '짧게. 빠르게.' },
      { type: 'text', speaker: '', text: '눈물과 웃음이 같이 있는.' },
      { type: 'text', speaker: '', text: '이상한 얼굴이었다.' },
      { type: 'text', speaker: '', text: '"같이 무서운 건데 혼자 사라진 거잖아요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"불공평하잖아요."' },
      { type: 'text', speaker: '', text: '강물이 흘렀다.' },
      { type: 'text', speaker: '', text: '"그러니까 찾아갈 거야."' },
      { type: 'text', speaker: '', text: '호가 강 건너를 봤다.' },
      { type: 'text', speaker: '', text: '먼 곳.' },
      { type: 'text', speaker: '', text: '길이 없는 곳.' },
      { type: 'text', speaker: '', text: '"혼자서도."' },
      { type: 'text', speaker: '', text: '"무서워도."' },
      { type: 'text', speaker: '', text: '"달려서."' },
      { type: 'text', speaker: '', text: '흰빛이 호의 손끝에서 맺혔다.' },
      { type: 'text', speaker: '', text: '달빛 같은.' },
      { type: 'text', speaker: '', text: '폭풍 같은.' },
      { type: 'text', speaker: '', text: '선명한.' },
      { type: 'text', speaker: '', text: '호가 주먹을 쥐었다. 빛이 응축됐다. 발밑의 돌이 갈라졌다. 가만히 서 있는 것만으로 압력이 생기는 몸이 됐다. 5성의 몸이.' },
      { type: 'text', speaker: '', text: '호가 걷기 시작했다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 옆에서 걸었다.' },
      { type: 'text', speaker: '', text: '그 작은 발이.' },
      { type: 'text', speaker: '', text: '큰 발 옆에서.' },
      { type: 'text', speaker: '', text: '나란히.' },
      { type: 'text', speaker: '', text: '두 그림자가 길게 누웠다.' },
      { type: 'text', speaker: '', text: '해가 올라오면서.' },
      { type: 'text', speaker: '', text: '강 위에.' },
      { type: 'text', speaker: '', text: '흰빛과 조용한 빛이.' },
      { type: 'text', speaker: '', text: '함께 흘렀다.' },
      { type: 'text', speaker: '', text: '호는 걸으면서.' },
      { type: 'text', speaker: '', text: '멈추지 않았다.' },
      { type: 'text', speaker: '', text: '뒤를 보지 않았다.' },
      { type: 'text', speaker: '', text: '아니.' },
      { type: 'text', speaker: '', text: '한 번.' },
      { type: 'text', speaker: '', text: '한 번만 봤다.' },
      { type: 'text', speaker: '', text: '강물이 흐르는 자리.' },
      { type: 'text', speaker: '', text: '빛이 있던 자리.' },
      { type: 'text', speaker: '', text: '아무것도 없는 자리.' },
      { type: 'text', speaker: '', text: '그 자리를.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '봤다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '다시.' },
      { type: 'text', speaker: '', text: '앞을 봤다.' },
      { type: 'text', speaker: '', text: '걸음이 멈추지 않았다.' },
      { type: 'text', speaker: '', text: '흰 호랑이가 걸어갔다.' },
      { type: 'text', speaker: '', text: '혼자였지만.' },
      { type: 'text', speaker: '', text: '혼자가 아니었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호의 손을 잡은 채 함께 걸었다. 그 작은 아이의 눈이 가끔 호를 올려다봤다.' },
      { type: 'text', speaker: '', text: '뭔가를 말하고 싶은 것 같았다.' },
      { type: 'text', speaker: '', text: '하지만 말은 없었다.' },
      { type: 'text', speaker: '', text: '그냥 옆에서 걸었다. 손을 잡은 채.' },
      { type: 'text', speaker: '', text: '그게 이 작은 아이가 할 수 있는 전부인 것 같았다.' },
      { type: 'text', speaker: '', text: '그리고 그게 충분했다.' },
      { type: 'text', speaker: '', text: '호는 걸으면서 생각했다.' },
      { type: 'text', speaker: '', text: '당신이 한 말 중에 좋은 게 있었어요.' },
      { type: 'text', speaker: '', text: '세어봤어요. 아직 다 못 셌어요.' },
      { type: 'text', speaker: '', text: '당신이 없어도 계속 셀 거예요.' },
      { type: 'text', speaker: '', text: '그게 쌓이면, 언젠가 당신한테 말해줄 거예요. 이만큼이나 좋은 게 있었다고.' },
      { type: 'text', speaker: '', text: '반드시.' },
      { type: 'text', speaker: '', text: '바람이 불었다. 달빛 같은 빛이 호의 손끝에서 맺혔다. 바람에 흔들렸다. 꺼지지 않았다. 바람이 불어도 꺼지지 않는 빛이었다. 그게 백호의 빛이었다.' },
      { type: 'text', speaker: '', text: '세고 있던 좋은 말들이 입안에서 맴돌았다.' },
      { type: 'text', speaker: '', text: '하나씩 꺼내지 않아도 됐다. 이미 몸이 기억하고 있었다.' },
      { type: 'text', speaker: '', text: '손끝이 기억했고. 발이 기억했고. 걸음이 기억했다.' },
      { type: 'text', speaker: '', text: '말보다 먼저 온 것들이 있었다.' },
      { type: 'text', speaker: '', text: '발목을 감아준 손. 된장찌개를 끓여준 저녁. 이름을 불러준 목소리.' },
      { type: 'text', speaker: '', text: '그것들이 지금 호의 걸음 안에 있었다.' },
      { type: 'text', speaker: '', text: '호가 멈췄다. 강물을 봤다. 빛이 강 위에 흘렀다. 달빛 같은. 차갑고 선명한.' },
      { type: 'text', speaker: '백호', text: '"이 강이 기억할 거예요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '"당신 이름을요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '"저도 기억해요."' },
      { type: 'text', speaker: '', text: '호가 손끝을 폈다. 달빛이 맺혔다. 선명하게. 강하게. 달빛이 호의 손에서 강 위로 퍼졌다. 그 빛이 강을 건넜다. 멀리. 아주 멀리. 달이 밤 전체를 비추는 것처럼.' },
      { type: 'text', speaker: '', text: '왜소한 신이 호의 손을 잡았다.' },
      { type: 'text', speaker: '백호', text: '"당신은요. 왜 같이 다녔어요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 오래 호를 봤다. 아무 대답 없이 호의 손을 더 꽉 잡았다.' },
      { type: 'text', speaker: '백호', text: '"......이상한 아이예요. 당신이랑 비슷하네요."' },
      { type: 'text', speaker: '', text: '호가 웃었다. 눈물이 마른 자국이 뺨에 있었지만. 웃었다. 그게 강한 것이었다.' },
      { type: 'text', speaker: '', text: '걸음을 다시 시작했다. 호와 왜소한 신. 두 그림자가 강을 따라 걸었다. 큰 그림자와 작은 그림자. 나란히. 해가 더 올라왔다. 그 길어진 그림자가 강 위에 겹쳐서 흘렀다.' },
      { type: 'text', speaker: '', text: '한참 걸어서.' },
      { type: 'text', speaker: '', text: '산길에 사람이 셋 막아 섰다. 낡은 칼을 들고 있었다. 산적인 것 같았다. 호가 멈추지 않았다. 걸음이 그대로였다. 가까워지자 가운데 남자가 칼을 올렸다.' },
      { type: 'text', speaker: '', text: '호의 손끝에서 빛이 한 번 번졌다. 소리도 없이. 달빛 실이 세 자루의 칼날을 동시에 스쳤다. 칼이 손에서 빠져나가 풀밭에 꽂혔다. 빛이 닿은 칼날에 서리가 폈다. 칼자루까지 하얗게 얼었다.' },
      { type: 'effect', effect: 'system', text: '【 월광(月光) 실전 적용. 달빛 실(絲) — 동시 제압 3체. 소모 기력: 2%. 대상 전투력 측정: 위협 없음. 】' },
      { type: 'text', speaker: '', text: '셋이 뒷걸음을 쳤다. 발밑 풀이 서리에 덮여 바스락거렸다. 반경 세 걸음까지 하얀 결정이 깔렸다. 한여름 산길에 숨이 하얗게 나올 만큼 차가워졌다.' },
      { type: 'text', speaker: '', text: '호가 지나갔다. 걸음이 멈추지 않았다. 왜소한 신이 뒤따르면서 산적들을 한 번 봤다.' },
      { type: 'text', speaker: '', text: '마을이 보이는 산 위.' },
      { type: 'text', speaker: '', text: '호가 멈췄다.' },
      { type: 'text', speaker: '', text: '발 아래로 마을이 보였다.' },
      { type: 'text', speaker: '', text: '낮에 보는 마을.' },
      { type: 'text', speaker: '', text: '사람들이 있었다.' },
      { type: 'text', speaker: '', text: '장터가 있었다.' },
      { type: 'text', speaker: '', text: '아이들이 뛰어다녔다.' },
      { type: 'text', speaker: '', text: '"저기 내려갈 거예요?"' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '"내려가야죠."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"더 강해지려면 더 많은 것을 봐야 하니까."' },
      { type: 'text', speaker: '', text: '호가 손끝을 봤다.' },
      { type: 'text', speaker: '', text: '달빛이 희미하게 맺혔다.' },
      { type: 'text', speaker: '', text: '"이것도 더 써야 하고."' },
      { type: 'text', speaker: '', text: '왜소한 신이 끄덕였다.' },
      { type: 'text', speaker: '', text: '"당신이 가르쳐준 거 있죠."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '"말없이 가르쳐준 것들이요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 고개를 기울였다.' },
      { type: 'text', speaker: '', text: '"옆에 있는 것만으로요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"차갑고 따뜻한 손으로요."' },
      { type: 'text', speaker: '', text: '왜소한 신이 호를 봤다.' },
      { type: 'text', speaker: '', text: '그 눈이.' },
      { type: 'text', speaker: '', text: '뭔가 가득 찬 것 같았다.' },
      { type: 'text', speaker: '', text: '"고마워요."' },
      { type: 'text', speaker: '', text: '호가 말했다.' },
      { type: 'text', speaker: '백호', text: '"이유 없이."' },
      { type: 'text', speaker: '', text: '"그냥이요."' },
      { type: 'text', speaker: '', text: '왜소한 신이.' },
      { type: 'text', speaker: '', text: '손을 들었다.' },
      { type: 'text', speaker: '', text: '호의 손을 잡았다.' },
      { type: 'text', speaker: '', text: '말없이.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '둘이서 산을 내려갔다.' },
      { type: 'text', speaker: '', text: '호가 앞서 걷고. 왜소한 신이 따라 걸었다. 호는 그 발소리를 들을 수 있었다. 당신한테서 배운 것이었다.' },
      { type: 'text', speaker: '', text: '저녁이 됐다. 호가 불을 피웠다. 왜소한 신이 옆에 앉았다.' },
      { type: 'text', speaker: '백호', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '호가 말했다. 왜소한 신만 있었다. 그래도 호는 말했다.' },
      { type: 'text', speaker: '백호', text: '"당신도 좋은 기억이에요."' },
      { type: 'text', speaker: '', text: '왜소한 신의 눈이 따뜻해졌다.' },
      { type: 'text', speaker: '', text: '"세고 있어요. 당신이 한 것들이요. 셀 수 없는 것들은 그냥 기억해요."' },
      { type: 'text', speaker: '', text: '담장 없는 하늘에 별이 많았다. 저택 뒤꼍보다 훨씬 많았다.' },
      { type: 'text', speaker: '', text: '밤이 깊어졌다. "잘 자요." 호가 먼저 말했다. 이제는 자연스러웠다. 먼저 인사하는 게. 먼저 고맙다고 하는 게. 당신한테서 배운 것들이.' },
      { type: 'text', speaker: '', text: '달이 떴다. 호의 손끝에서 달빛이 조금 맺혔다가 꺼졌다. 저절로. 마치 잠든 것처럼. 호랑이가 잠들면 같이 잠든 것처럼.' },
      { type: 'text', speaker: '', text: '멀리서. 당신이 있을 어딘가에서. 별이 빛났다.' },
      { type: 'text', speaker: '', text: '그 별을 보는 호가 기억하고 있었다. 세고 있었다. 당신이 한 말 중에 좋은 것들을. 그 별만큼. 많이.' },
      { type: 'text', speaker: '', text: '백호(白虎) 메인 스토리 완결 "호랑이는 혼자 운다"' },
    ]
  },
];
