      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"너무 큰 거 아니야?"' },
      { type: 'text', speaker: '', text: '"이 정도면 괜찮아요."' },
      { type: 'text', speaker: '', text: '"방이 탈 것 같아."' },
      { type: 'text', speaker: '', text: '"안 타요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 손바닥 크기로 줄였다.' },
      { type: 'text', speaker: '주작', text: '"이게 좋아요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그럼 이걸로 할게요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작의 불꽃을 봤다.' },
      { type: 'text', speaker: '', text: '"어떻게 줄여?"' },
      { type: 'text', speaker: '', text: '"느끼면 돼요."' },
      { type: 'text', speaker: '', text: '"느끼면?"' },
      { type: 'text', speaker: '', text: '"당신이 불꽃 피울 때요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 봤다.' },
      { type: 'text', speaker: '주작', text: '"이걸 키우고 싶으면 당신 이름 부르는 거 생각하면 커지고. 줄이고 싶으면 이 불꽃이 제 거라는 거 느끼면 줄어요."' },
      { type: 'text', speaker: '', text: '"설명이 감각적이네."' },
      { type: 'text', speaker: '', text: '"달리 설명을 못 하겠어요."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"이게 제 거니까요. 제가 조절하는 거니까요."' },
      { type: 'text', speaker: '', text: '"자기 거라고 느끼면 돼?"' },
      { type: 'text', speaker: '', text: '"응. 내 것이면 내가 결정하는 거잖아요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"그게 언제부터 됐어?"' },
      { type: 'text', speaker: '', text: '"당신이 이름 불러준 다음부터요."' },
      { type: 'text', speaker: '', text: '탑 8층을 올랐다. 탑이 울린 이유를 8층에서 알았다. 층이 바뀌면 시험도 바뀐다는 뜻이었다.' },
      { type: 'text', speaker: '', text: '주작이 앞에서 걸었다.' },
      { type: 'text', speaker: '', text: '층 안이 어두웠다.' },
      { type: 'text', speaker: '', text: '무거운 공기.' },
      { type: 'text', speaker: '', text: '습한 냄새.' },
      { type: 'text', speaker: '', text: '안에서 소리가 났다.' },
      { type: 'text', speaker: '', text: '짐승 소리.' },
      { type: 'text', speaker: '', text: '여러 마리.' },
      { type: 'text', speaker: '', text: '"들려요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"몇 마리 같아요?"' },
      { type: 'text', speaker: '', text: '플레이어가 생각했다.' },
      { type: 'text', speaker: '', text: '"다섯 이상."' },
      { type: 'text', speaker: '', text: '"저도요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 피웠다.' },
      { type: 'text', speaker: '', text: '손 전체에서.' },
      { type: 'text', speaker: '', text: '"같이 가요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"제가 앞에 서도 돼요?"' },
      { type: 'text', speaker: '', text: '"괜찮아?"' },
      { type: 'text', speaker: '', text: '"이 층은 좁아요. 제가 앞에 서면 당신이 안으로 들어갈 필요가 없어요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 생각했다.' },
      { type: 'text', speaker: '', text: '"그래."' },
      { type: 'text', speaker: '', text: '"그럼 갈게요."' },
      { type: 'text', speaker: '', text: '주작이 앞으로 달렸다.' },
      { type: 'text', speaker: '', text: '빠르게.' },
      { type: 'text', speaker: '', text: '어두운 층 안으로.' },
      { type: 'text', speaker: '', text: '층 안에 짐승이 있었다.' },
      { type: 'text', speaker: '', text: '크고 검은.' },
      { type: 'text', speaker: '', text: '눈이 빛났다.' },
      { type: 'text', speaker: '', text: '여섯 마리.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '', text: '여섯.' },
      { type: 'text', speaker: '', text: '더 빠른 게 앞으로 왔다.' },
      { type: 'text', speaker: '', text: '주작이 받았다.' },
      { type: 'text', speaker: '', text: '정면으로.' },
      { type: 'text', speaker: '', text: '불꽃 타격.' },
      { type: 'text', speaker: '', text: '짐승이 물러섰다.' },
      { type: 'text', speaker: '', text: '두 마리가 옆에서 왔다.' },
      { type: 'text', speaker: '', text: '주작이 회전했다.' },
      { type: 'text', speaker: '', text: '불꽃이 원을 그렸다.' },
      { type: 'text', speaker: '', text: '두 마리가 튕겨났다.' },
      { type: 'text', speaker: '', text: '나머지 세 마리가 동시에 달렸다.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '', text: '세 마리.' },
      { type: 'text', speaker: '', text: '하나가 더 크다.' },
      { type: 'text', speaker: '', text: '먼저.' },
      { type: 'text', speaker: '', text: '큰 것부터.' },
      { type: 'text', speaker: '', text: '앞으로 달렸다.' },
      { type: 'text', speaker: '', text: '큰 것이 발로 쳤다.' },
      { type: 'text', speaker: '', text: '주작이 피했다.' },
      { type: 'text', speaker: '', text: '옆으로.' },
      { type: 'text', speaker: '', text: '빗나갔다.' },
      { type: 'text', speaker: '', text: '거의.' },
      { type: 'text', speaker: '', text: '어깨를 스쳤다.' },
      { type: 'text', speaker: '', text: '아팠다.' },
      { type: 'text', speaker: '', text: '괜찮다.' },
      { type: 'text', speaker: '', text: '달렸다.' },
      { type: 'text', speaker: '', text: '큰 것의 옆으로 돌아서.' },
      { type: 'text', speaker: '', text: '불꽃 직격.' },
      { type: 'text', speaker: '', text: '쓰러졌다.' },
      { type: 'text', speaker: '', text: '남은 두 마리가 왔다.' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 폭발시켰다.' },
      { type: 'text', speaker: '', text: '전신에서.' },
      { type: 'text', speaker: '', text: '두 마리가 날아갔다.' },
      { type: 'text', speaker: '', text: '앞서 쓰러진 세 마리가 다시 일어났다.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '', text: '강하다.' },
      { type: 'text', speaker: '', text: '그래도.' },
      { type: 'text', speaker: '', text: '있다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '뒤에서 플레이어가 불렀다.' },
      { type: 'text', speaker: '', text: '그 소리가 들렸다.' },
      { type: 'text', speaker: '', text: '불꽃이 강해졌다.' },
      { type: 'text', speaker: '', text: '반응이었다.' },
      { type: 'text', speaker: '', text: '자기도 모르게.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"알아요."' },
      { type: 'text', speaker: '', text: '달렸다.' },
      { type: 'effect', effect: 'system', text: '【전투 종료.】' },
      { type: 'text', speaker: '', text: '주작이 숨을 골랐다.' },
      { type: 'text', speaker: '', text: '어깨가 아팠다.' },
      { type: 'text', speaker: '', text: '스쳤던 곳.' },
      { type: 'text', speaker: '', text: '"어깨."' },
      { type: 'text', speaker: '', text: '"응. 스쳤어요."' },
      { type: 'text', speaker: '', text: '"봐."' },
      { type: 'text', speaker: '', text: '플레이어가 주작의 어깨를 봤다.' },
      { type: 'text', speaker: '', text: '옷이 찢겼다.' },
      { type: 'text', speaker: '', text: '피는 조금.' },
      { type: 'text', speaker: '', text: '"괜찮아?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"진짜?"' },
      { type: 'text', speaker: '', text: '"진짜요. 피 별로 안 났어요."' },
      { type: 'text', speaker: '', text: '플레이어가 처치를 했다.' },
      { type: 'text', speaker: '', text: '주작이 그 손을 봤다.' },
      { type: 'text', speaker: '', text: '빠르고 조심스러운 손.' },
      { type: 'text', speaker: '', text: '다치는 게 싫은 손.' },
      { type: 'text', speaker: '', text: '"당신이 항상 처치해요."' },
      { type: 'text', speaker: '', text: '"당연하지."' },
      { type: 'text', speaker: '', text: '"당연하지 않아요. 당신이 안 해도 되는데."' },
      { type: 'text', speaker: '', text: '"안 해?"' },
      { type: 'text', speaker: '', text: '"안 해도 된다는 게 아니에요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"해주는 게 좋아요. 당연하지 않아도 해준다는 게."' },
      { type: 'text', speaker: '', text: '플레이어가 처치를 마쳤다.' },
      { type: 'text', speaker: '', text: '"나한테 당연한 거야."' },
      { type: 'text', speaker: '', text: '"그래도요."' },
      { type: 'text', speaker: '', text: '주작이 어깨를 봤다.' },
      { type: 'text', speaker: '주작', text: '"감사해요."' },
      { type: 'text', speaker: '', text: '탑 9층.' },
      { type: 'text', speaker: '', text: '입구가 열리자 공기가 달랐다. 짐승 냄새가 아니라 땀과 먼지 냄새가 났다. 탑은 가끔 이랬다. 높은 층일수록 시험의 형태가 바뀐다고 플레이어가 말한 적이 있었다.' },
      { type: 'text', speaker: '', text: '이 층은 다른 층과 달랐다. 몬스터가 아니라 사람이 있는 층이었다.' },
      { type: 'text', speaker: '', text: '주작이 처음으로 멈춘 건 입구에서였다.' },
      { type: 'text', speaker: '', text: '소리가 들렸다.' },
      { type: 'text', speaker: '', text: '울음소리.' },
      { type: 'text', speaker: '', text: '아이가 울고 있었다.' },
      { type: 'text', speaker: '', text: '어두운 층.' },
      { type: 'text', speaker: '', text: '소리가 먼저였다.' },
      { type: 'text', speaker: '', text: '그 소리를.' },
      { type: 'text', speaker: '', text: '주작이 알고 있었다.' },
      { type: 'text', speaker: '', text: '울면 안 되는데 우는 소리.' },
      { type: 'text', speaker: '', text: '참으려다 나오는 소리.' },
      { type: 'text', speaker: '', text: '"들어요?"' },
      { type: 'text', speaker: '', text: '플레이어가 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '주작이 앞으로 나갔다.' },
      { type: 'text', speaker: '', text: '층 안.' },
      { type: 'text', speaker: '', text: '구석에 사람들이 웅크려 있었다.' },
      { type: 'text', speaker: '', text: '어른도 있고. 아이도 있었다.' },
      { type: 'text', speaker: '', text: '가운데서 덩치 큰 무리가 그들을 둘러싸고 있었다. 여섯 명. 하나같이 무장하고, 구석의 사람들과는 체격부터 달랐다.' },
      { type: 'text', speaker: '', text: '주변을 막아서.' },
      { type: 'text', speaker: '', text: '나가지 못하게.' },
      { type: 'text', speaker: '', text: '"야, 이름 대봐."' },
      { type: 'text', speaker: '', text: '무리 중 하나가 말했다.' },
      { type: 'text', speaker: '', text: '구석의 사람들이 고개를 들지 못했다.' },
      { type: 'text', speaker: '', text: '"야, 들려? 이름이라고."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"이름도 없어? 빈민가 애들은 이름도 없어?"' },
      { type: 'text', speaker: '', text: '웃음소리가 났다.' },
      { type: 'text', speaker: '', text: '주작이 그 소리를 들었다.' },
      { type: 'text', speaker: '', text: '가슴이 서늘해졌다.' },
      { type: 'text', speaker: '', text: '이름도 없어.' },
      { type: 'text', speaker: '', text: '이름도 없어.' },
      { type: 'text', speaker: '', text: '이름도 없어.' },
      { type: 'text', speaker: '', text: '그 말이 귀에서 떠나지 않았다.' },
      { type: 'text', speaker: '', text: '이름이 없으면.' },
      { type: 'text', speaker: '', text: '존재가 없다.' },
      { type: 'text', speaker: '', text: '있어도 없는 것이다.' },
      { type: 'text', speaker: '', text: '야. 거기. 저거.' },
      { type: 'text', speaker: '', text: '그게 이름 없는 사람에게 붙는 말들이다.' },
      { type: 'text', speaker: '', text: '물건에 붙는 말들.' },
      { type: 'text', speaker: '', text: '주작이 그걸 알고 있었다.' },
      { type: 'text', speaker: '', text: '몸으로.' },
      { type: 'text', speaker: '', text: '뼈로.' },
      { type: 'text', speaker: '', text: '손으로 느낀 것들로.' },
      { type: 'text', speaker: '', text: '주작이 앞을 봤다.' },
      { type: 'text', speaker: '주작', text: '"아니요."' },
      { type: 'text', speaker: '', text: '그리고 달려갔다.' },
      { type: 'effect', effect: 'system', text: '【전투 개시.】' },
      { type: 'text', speaker: '', text: '무리가 돌아봤다.' },
      { type: 'text', speaker: '', text: '"뭐야 이게."' },
      { type: 'text', speaker: '', text: '"방해하지 마."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 피웠다.' },
      { type: 'text', speaker: '', text: '뜨겁고 강한 불꽃.' },
      { type: 'text', speaker: '', text: '분노가 끌어올렸다.' },
      { type: 'text', speaker: '', text: '이름도 없어라고 말하는 사람들에 대한 분노.' },
      { type: 'text', speaker: '', text: '약자를 구석으로 모는 사람들에 대한 분노.' },
      { type: 'text', speaker: '', text: '이름을 빼앗는 사람들에 대한 분노.' },
      { type: 'text', speaker: '', text: '첫 번째가 달려왔다.' },
      { type: 'text', speaker: '', text: '주작이 받았다.' },
      { type: 'text', speaker: '', text: '정면으로.' },
      { type: 'text', speaker: '', text: '불꽃 타격.' },
      { type: 'text', speaker: '', text: '충격이 울렸다.' },
      { type: 'text', speaker: '', text: '적이 날아갔다.' },
      { type: 'text', speaker: '', text: '두 번째와 세 번째가 양쪽에서 왔다.' },
      { type: 'text', speaker: '', text: '주작이 돌아섰다.' },
      { type: 'text', speaker: '', text: '두 번째 방향으로.' },
      { type: 'text', speaker: '', text: '팔꿈치로 막고.' },
      { type: 'text', speaker: '', text: '불꽃 연속 타격.' },
      { type: 'text', speaker: '', text: '세 번째가 뒤에서 잡으려 했다.' },
      { type: 'text', speaker: '', text: '불꽃이 터졌다.' },
      { type: 'text', speaker: '', text: '주작의 몸에서.' },
      { type: 'text', speaker: '', text: '전신에서.' },
      { type: 'text', speaker: '', text: '반경 두 걸음.' },
      { type: 'text', speaker: '', text: '세 번째가 날아갔다.' },
      { type: 'text', speaker: '', text: '네 번째가 무기를 들었다.' },
      { type: 'text', speaker: '', text: '긴 창.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '', text: '빠르다.' },
      { type: 'text', speaker: '', text: '달려들었다.' },
      { type: 'text', speaker: '', text: '창이 스쳐갔다.' },
      { type: 'text', speaker: '', text: '옆구리.' },
      { type: 'text', speaker: '', text: '얕게 베였다.' },
      { type: 'text', speaker: '', text: '주작이 이를 악물었다.' },
      { type: 'text', speaker: '', text: '아파.' },
      { type: 'text', speaker: '', text: '괜찮아.' },
      { type: 'text', speaker: '', text: '뒤를 돌아봤다.' },
      { type: 'text', speaker: '', text: '구석의 아이.' },
      { type: 'text', speaker: '', text: '아직 거기 있었다.' },
      { type: 'text', speaker: '', text: '괜찮다.' },
      { type: 'text', speaker: '', text: '아직 거기 있다.' },
      { type: 'text', speaker: '', text: '다섯 번째가 약자들 쪽으로 달려갔다.' },
      { type: 'text', speaker: '', text: '주작이 더 빠르게 달렸다.' },
      { type: 'text', speaker: '', text: '앞에 섰다.' },
      { type: 'text', speaker: '', text: '막았다.' },
      { type: 'text', speaker: '', text: '"이 사람들한테 가려면 나한테 먼저 와야 해."' },
      { type: 'text', speaker: '', text: '다섯 번째가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"뭐야 너."' },
      { type: 'text', speaker: '', text: '"주작이에요."' },
      { type: 'text', speaker: '주작', text: '"이름이?"' },
      { type: 'text', speaker: '', text: '"이름이에요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"이름 있는 사람이에요."' },
      { type: 'text', speaker: '', text: '다섯 번째가 달려들었다.' },
      { type: 'text', speaker: '', text: '주작이 피했다.' },
      { type: 'text', speaker: '', text: '옆으로.' },
      { type: 'text', speaker: '', text: '불꽃이 손에서 폭발했다.' },
      { type: 'text', speaker: '', text: '강하게.' },
      { type: 'text', speaker: '', text: '다섯 번째가 쓰러졌다.' },
      { type: 'text', speaker: '', text: '여섯 번째가 네 번째와 함께 왔다.' },
      { type: 'text', speaker: '', text: '주작이 두 명을 봤다.' },
      { type: 'text', speaker: '', text: '달렸다.' },
      { type: 'text', speaker: '', text: '여섯 번째를 먼저 쳤다.' },
      { type: 'text', speaker: '', text: '쓰러졌다.' },
      { type: 'text', speaker: '', text: '네 번째가 창을 찔렀다.' },
      { type: 'text', speaker: '', text: '주작이 옆으로 피했다.' },
      { type: 'text', speaker: '', text: '창이 스쳤다.' },
      { type: 'text', speaker: '', text: '팔에서 피가 났다.' },
      { type: 'text', speaker: '', text: '빨갛고 선명하게.' },
      { type: 'text', speaker: '', text: '주작이 멈추지 않았다.' },
      { type: 'text', speaker: '', text: '불꽃이 팔에서.' },
      { type: 'text', speaker: '', text: '전신에서.' },
      { type: 'text', speaker: '', text: '지키겠다는 마음이 불꽃이 됐다. 이름을 빼앗기던 날들의 분노가 불꽃이 됐다.' },
      { type: 'text', speaker: '', text: '네 번째가 눈을 크게 떴다.' },
      { type: 'text', speaker: '', text: '불꽃이 넘쳐흘렀다.' },
      { type: 'text', speaker: '', text: '주먹이 불꽃을 담아 떨어졌다.' },
      { type: 'text', speaker: '', text: '네 번째가 쓰러졌다.' },
      { type: 'text', speaker: '', text: '마지막 하나가 도망갔다.' },
      { type: 'text', speaker: '', text: '주작이 뒤를 좇지 않았다.' },
      { type: 'effect', effect: 'system', text: '【전투 종료. 주작의 신력 대폭 상승 감지. 보호 본능 스킬 각성. 효과: 반경 3보 이내 아군 피해 32% 감소. 지속 시간: 전투 중 상시.】' },
      { type: 'text', speaker: '', text: '숨을 골랐다.' },
      { type: 'text', speaker: '', text: '팔이 아팠다.' },
      { type: 'text', speaker: '', text: '옆구리가 아팠다.' },
      { type: 'text', speaker: '', text: '괜찮았다.' },
      { type: 'text', speaker: '', text: '구석의 사람들이 나왔다.' },
      { type: 'text', speaker: '', text: '다들 살아 있었다.' },
      { type: 'text', speaker: '', text: '아이가 있었다.' },
      { type: 'text', speaker: '', text: '울고 있던 아이가.' },
      { type: 'text', speaker: '', text: '"이름이 뭐야?"' },
      { type: 'text', speaker: '', text: '주작이 물었다.' },
      { type: 'text', speaker: '', text: '아이가 고개를 들었다.' },
      { type: 'text', speaker: '', text: '눈이 빨갰다.' },
      { type: 'text', speaker: '', text: '조용히 이름을 말했다.' },
      { type: 'text', speaker: '', text: '주작이 들었다.' },
      { type: 'text', speaker: '주작', text: '"그거야."' },
      { type: 'text', speaker: '', text: '주작이 아이 눈을 봤다.' },
      { type: 'text', speaker: '주작', text: '"그게 네 이름이야."' },
      { type: 'text', speaker: '', text: '아이의 눈이 크게 떠졌다. 누가 이름을 물어본 적이 없는 것 같았다. 이름이 있다는 걸 확인받아본 적이 없는 것 같았다.' },
      { type: 'text', speaker: '', text: '주작이 알고 있었다. 그 표정을. 고아원에서 거울 볼 때 자기가 짓던 표정이었다.' },
      { type: 'text', speaker: '주작', text: '"아무도 안 불러줘도."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"그게 네 이름이야. 그 이름이 있어야 네가 있어. 알겠어?"' },
      { type: 'text', speaker: '', text: '아이가 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '주작이 일어섰다.' },
      { type: 'text', speaker: '', text: '어른들이 고개를 숙였다.' },
      { type: 'text', speaker: '', text: '"괜찮아요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"이름 잊지 마세요. 아무도 빼앗을 수 없어요. 이름은."' },
      { type: 'text', speaker: '', text: '잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '"이름이 있어야 당신이 있는 거예요. 당신이 있어야 당신 사람들이 있는 거고요."' },
      { type: 'text', speaker: '', text: '어른들이 고개를 들었다.' },
      { type: 'text', speaker: '', text: '"이름을 뺏기면 안 돼요. 야, 거기, 저거 그런 것들로 불려도."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"마음속에 이름이 있으면 당신은 있는 거예요."' },
      { type: 'text', speaker: '', text: '아이가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"언니 이름은요?"' },
      { type: 'text', speaker: '', text: '"주작이에요."' },
      { type: 'text', speaker: '주작', text: '"예쁜 이름이다."' },
      { type: 'text', speaker: '', text: '목이 메었다. 예쁜 이름이라고 말해준 사람은 미나 다음이었다. 뼈 안쪽이 뜨거워졌다. 고아원에서 아무도 해주지 않았던 말을, 지금 이 아이가 했다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '눈이 젖었지만 닦지 않았다.' },
      { type: 'text', speaker: '', text: '"당신 이름도 예뻐요."' },
      { type: 'text', speaker: '', text: '아이가 웃었다.' },
      { type: 'text', speaker: '', text: '처음으로.' },
      { type: 'text', speaker: '', text: '조금.' },
      { type: 'text', speaker: '', text: '그 조금이 전부였다. 이름을 가진 사람이 웃는 것, 그게 전부였다.' },
      { type: 'text', speaker: '', text: '주작이 그걸 봤다.' },
      { type: 'text', speaker: '', text: '다행이었다.' },
      { type: 'text', speaker: '', text: '플레이어가 다가왔다.' },
      { type: 'text', speaker: '', text: '표정이 굳어 있었다.' },
      { type: 'text', speaker: '', text: '"왜 그래요?"' },
      { type: 'text', speaker: '', text: '"팔."' },
      { type: 'text', speaker: '', text: '"아, 이거요?"' },
      { type: 'text', speaker: '', text: '주작이 팔을 봤다.' },
      { type: 'text', speaker: '주작', text: '"생각보다 많이 났네요."' },
      { type: 'text', speaker: '', text: '"많이 났어."' },
      { type: 'text', speaker: '', text: '"그래도 괜찮아요."' },
      { type: 'text', speaker: '', text: '"안 괜찮아."' },
      { type: 'text', speaker: '', text: '플레이어가 응급 처치를 했다.' },
      { type: 'text', speaker: '', text: '빠르게.' },
      { type: 'text', speaker: '', text: '눈에 불안이 있었다.' },
      { type: 'text', speaker: '', text: '주작이 그 손을 봤다.' },
      { type: 'text', speaker: '', text: '급하게 움직이는 손.' },
      { type: 'text', speaker: '', text: '다친 게 싫은 손.' },
      { type: 'text', speaker: '', text: '"처음에는 제가 다쳐도 별로 신경 안 쓰는 줄 알았어요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"고아원에서는요. 제가 다쳐도 별로 신경 안 썼거든요. 나중에 봐, 이러거나. 그냥 너 조심을 안 하니까 다치지, 이러거나."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신은 바로 봐요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"바로 처치해요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그게."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"제가 중요한 것 같아서요."' },
      { type: 'text', speaker: '', text: '플레이어가 처치를 마치고 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"당연하지."' },
      { type: 'text', speaker: '', text: '"당연하지 않아요."' },
      { type: 'text', speaker: '', text: '"여기선 당연해."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 봤다.' },
      { type: 'text', speaker: '주작', text: '"...감사해요."' },
      { type: 'text', speaker: '', text: '"또 감사해?"' },
      { type: 'text', speaker: '', text: '"이름 말고 다른 게 감사할 때도 있어요."' },
      { type: 'text', speaker: '', text: '플레이어가 웃었다.' },
      { type: 'text', speaker: '', text: '주작이 그 웃음을 봤다.' },
      { type: 'text', speaker: '', text: '심장이 뛰었다.' },
      { type: 'text', speaker: '', text: '이상하게.' },
      { type: 'text', speaker: '', text: '빠르게.' },
      { type: 'text', speaker: '', text: '탑 9층을 클리어하고.' },
      { type: 'text', speaker: '', text: '주작이 잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '아이가 기억났다.' },
      { type: 'text', speaker: '', text: '이름 있는 아이.' },
      { type: 'text', speaker: '', text: '잘 있을까.' },
      { type: 'text', speaker: '', text: '손 안의 잔열이 아직 남아 있었다. 지키겠다는 마음이 남긴 열기. 그게 식지 않았다.' },
      { type: 'text', speaker: '', text: '탑 밖으로 나왔다.' },
      { type: 'text', speaker: '', text: '하늘이 맑았다.' },
      { type: 'text', speaker: '', text: '가을이 오려는 하늘.' },
      { type: 'text', speaker: '', text: '파랗고 높은.' },
      { type: 'text', speaker: '', text: '주작이 올려봤다.' },
      { type: 'text', speaker: '', text: '깃털에서 전해진 기억은 끝이 없었다. 한 생이 아니었다.' },
      { type: 'text', speaker: '', text: '수천 년.' },
      { type: 'text', speaker: '', text: '그게 기억 어딘가에 있었다.' },
      { type: 'text', speaker: '', text: '수천 년 동안 이 하늘을 봤을 것이다.' },
      { type: 'text', speaker: '', text: '이름을 가지고.' },
      { type: 'text', speaker: '', text: '불꽃을 가지고.' },
      { type: 'text', speaker: '', text: '혼자.' },
      { type: 'text', speaker: '', text: '이제.' },
      { type: 'text', speaker: '', text: '이름을 불러주는 사람이 있었다.' },
      { type: 'text', speaker: '', text: '혼자가 아니었다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '플레이어가 불렀다.' },
      { type: 'text', speaker: '', text: '주작이 돌아봤다.' },
      { type: 'text', speaker: '주작', text: '"응."' },
      { type: 'text', speaker: '', text: '"왜 서 있어?"' },
      { type: 'text', speaker: '', text: '"하늘 봤어요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"예쁘잖아요."' },
      { type: 'text', speaker: '', text: '플레이어가 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '"오늘 특히 파랗네."' },
      { type: 'text', speaker: '', text: '"응. 가을 하늘 같아요."' },
      { type: 'text', speaker: '', text: '"아직 여름."' },
      { type: 'text', speaker: '', text: '"이제 가을 오는 것 같아요."' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '주작', text: '"저 하늘 좋아요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"당신이 있어서요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"하늘이 좋은 게 나 때문이야?"' },
      { type: 'text', speaker: '', text: '"당신이랑 같이 봐서요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"같이 보는 게 당신이잖아요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 말이 없었다.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '하늘을 봤다.' },
      { type: 'text', speaker: '', text: '둘이.' },
      { type: 'text', speaker: '', text: '같이.' },
      { type: 'text', speaker: '', text: '집으로 돌아오는 길.' },
      { type: 'text', speaker: '', text: '왜소한 신이 따라왔다.' },
      { type: 'text', speaker: '', text: '주작이 뒤를 봤다.' },
      { type: 'text', speaker: '주작', text: '"거기 있었어요?"' },
      { type: 'text', speaker: '', text: '신이 고개를 끄덕이는 것 같았다.' },
      { type: 'text', speaker: '', text: '"싸우는 거 봤어요?"' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"봤죠?"' },
      { type: 'text', speaker: '', text: '신이 조용히 있었다.' },
      { type: 'text', speaker: '', text: '"...저 잘했어요?"' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '그러더니 주작 발치에 와서.' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '톡톡.' },
      { type: 'text', speaker: '', text: '발을 쳤다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"잘했다는 거죠? 당신한테도 그 말 듣고 싶었어요."' },
      { type: 'text', speaker: '', text: '신이 고개를 기울였다.' },
      { type: 'text', speaker: '', text: '"당신이 항상 있잖아요. 근데 말을 안 하니까."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"뭘 생각하는지 모르겠어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"근데 봐줬잖아요. 항상. 그게 좋아요."' },
      { type: 'text', speaker: '', text: '신이 걸었다.' },
      { type: 'text', speaker: '', text: '주작 옆으로.' },
      { type: 'text', speaker: '', text: '"오늘 저랑 같이 가요?"' },
      { type: 'text', speaker: '', text: '신이 멈추지 않았다.' },
      { type: 'text', speaker: '', text: '걸었다.' },
      { type: 'text', speaker: '', text: '같이.' },
      { type: 'text', speaker: '', text: '주작이 그걸 보고 웃었다.' },
      { type: 'text', speaker: '주작', text: '"...좋아요."' },
      { type: 'text', speaker: '', text: '탑 9층을 클리어한 밤.' },
      { type: 'text', speaker: '', text: '주작이 방에 누웠다.' },
      { type: 'text', speaker: '', text: '천장을 봤다.' },
      { type: 'text', speaker: '', text: '이상한 기분.' },
      { type: 'text', speaker: '', text: '뭔가 가까워지고 있는 기분.' },
      { type: 'text', speaker: '', text: '탑이 끝에 가까워지고 있는 기분.' },
      { type: 'text', speaker: '', text: '당신이 말했다.' },
      { type: 'text', speaker: '', text: '다음에 올라가야 해.' },
      { type: 'text', speaker: '', text: '마지막 층.' },
      { type: 'text', speaker: '', text: '마지막이 뭔지 몰랐다.' },
      { type: 'text', speaker: '', text: '탑이 끝나면 어떻게 되는지.' },
      { type: 'text', speaker: '', text: '당신이 말했다.' },
      { type: 'text', speaker: '', text: '각성 조건 충족 시 이동.' },
      { type: 'text', speaker: '', text: '이동.' },
      { type: 'text', speaker: '', text: '어디로.' },
      { type: 'text', speaker: '', text: '주작이 눈을 감았다.' },
      { type: 'text', speaker: '', text: '생각하지 말자.' },
      { type: 'text', speaker: '', text: '오늘은.' },
      { type: 'text', speaker: '', text: '오늘은 여기 있잖아.' },
      { type: 'text', speaker: '', text: '탑이 끝나도.' },
      { type: 'text', speaker: '', text: '오늘은 여기 있잖아.' },
      { type: 'text', speaker: '', text: '이름이 불렸다.' },
      { type: 'text', speaker: '', text: '아까.' },
      { type: 'text', speaker: '', text: '탑에서 나오면서.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '괜찮아.' },
      { type: 'text', speaker: '', text: '그 소리가 귀에 남아 있었다.' },
      { type: 'text', speaker: '', text: '이름이 있어야 자기가 있다.' },
      { type: 'text', speaker: '', text: '이름이 불려야 자기가 있다.' },
      { type: 'text', speaker: '', text: '지금 이 이름이 귀에 남아 있었다.' },
      { type: 'text', speaker: '', text: '그러니까 있었다.' },
      { type: 'text', speaker: '', text: '자기가.' },
      { type: 'text', speaker: '', text: '여기.' },
      { type: 'text', speaker: '', text: '탑 9층을 클리어하고.' },
      { type: 'text', speaker: '', text: '10층 앞에 섰다.' },
      { type: 'text', speaker: '', text: '거대한 문.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '주작', text: '"저게 마지막이에요?"' },
      { type: 'text', speaker: '', text: '"모르겠어."' },
      { type: 'text', speaker: '', text: '"올라가야 해요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"오늘요?"' },
      { type: 'text', speaker: '', text: '"아니. 다음에."' },
      { type: 'text', speaker: '', text: '주작이 고개를 끄덕였다.' },
      { type: 'text', speaker: '주작', text: '"준비되면 말해요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 준비됐을 때요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"내가요?"' },
      { type: 'text', speaker: '', text: '"저는 항상 준비됐어요. 당신만 있으면."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 탑 문을 봤다.' },
      { type: 'text', speaker: '주작', text: '"저기 올라가면요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그다음엔 어떻게 되는 거예요?"' },
      { type: 'text', speaker: '', text: '플레이어가 대답을 못 했다.' },
      { type: 'effect', effect: 'system', text: '【각성 조건 충족 시 이동 개시.】' },
      { type: 'text', speaker: '', text: '시스템 창이 떴다.' },
      { type: 'text', speaker: '', text: '플레이어만 보이는.' },
      { type: 'text', speaker: '', text: '주작은 몰랐다.' },
      { type: 'text', speaker: '', text: '"모르는 거죠?"' },
      { type: 'text', speaker: '', text: '"...응."' },
      { type: 'text', speaker: '', text: '"그래도 괜찮아요. 같이 알아가면 되니까."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신이랑 같이면 뭐든 괜찮아요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '눈에 뭔가가 있었다.' },
      { type: 'text', speaker: '', text: '죄책감 같은 것.' },
      { type: 'text', speaker: '', text: '주작이 눈치챘다.' },
      { type: 'text', speaker: '주작', text: '"왜 그런 눈이에요?"' },
      { type: 'text', speaker: '', text: '"뭐가?"' },
      { type: 'text', speaker: '', text: '"뭔가 아는 것 같은 눈이에요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"나중에 말해요. 지금 말하기 싫으면."' },
      { type: 'text', speaker: '', text: '"나중에."' },
      { type: 'text', speaker: '', text: '"알겠어요."' },
      { type: 'text', speaker: '', text: '주작이 돌아섰다.' },
      { type: 'text', speaker: '주작', text: '"집 가요. 밥 해야 해요."' },
      { type: 'text', speaker: '', text: '두 사람이 걸었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 뒤에서 따라왔다.' },
      { type: 'text', speaker: '', text: '탑 문이 뒤에서 거대하게 서 있었다.' },
      { type: 'text', speaker: '', text: '아직 열리지 않은 문.' },
      { type: 'text', speaker: '', text: '마지막 문.' },
      { type: 'text', speaker: '', text: '그 앞에서.' },
      { type: 'text', speaker: '', text: '세 개의 그림자가 멀어졌다.' },
      { type: 'text', speaker: '', text: '집으로 돌아오는 날 저녁.' },
      { type: 'text', speaker: '', text: '주작이 밥을 하면서 생각했다.' },
      { type: 'text', speaker: '', text: '이름.' },
      { type: 'text', speaker: '', text: '아이에게 말했다.' },
      { type: 'text', speaker: '', text: '이름을 빼앗기면 안 된다고.' },
      { type: 'text', speaker: '', text: '이름이 있어야 당신이 있다고.' },
      { type: 'text', speaker: '', text: '마음속에 이름이 있으면 당신은 있는 거라고.' },
      { type: 'text', speaker: '', text: '그 말들이 다 맞았다.' },
      { type: 'text', speaker: '', text: '자기가 살면서 느낀 것들이었다.' },
      { type: 'text', speaker: '', text: '당신이 주작이라고 불러주기 전에는.' },
      { type: 'text', speaker: '', text: '이름이 있어도 없는 것 같았다.' },
      { type: 'text', speaker: '', text: '미나만 불러줬다.' },
      { type: 'text', speaker: '', text: '고아원에서.' },
      { type: 'text', speaker: '', text: '주작 언니.' },
      { type: 'text', speaker: '', text: '그 한 명이.' },
      { type: 'text', speaker: '', text: '이름이 있다는 걸 실감하게 해줬다.' },
      { type: 'text', speaker: '', text: '그리고 당신이.' },
      { type: 'text', speaker: '', text: '이름을 계속 불러줬다.' },
      { type: 'text', speaker: '', text: '밥 먹을 때.' },
      { type: 'text', speaker: '', text: '훈련할 때.' },
      { type: 'text', speaker: '', text: '탑에서.' },
      { type: 'text', speaker: '', text: '돌아오는 길에.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '그게 쌓였다.' },
      { type: 'text', speaker: '', text: '이름이 뼈에 박혔다.' },
      { type: 'text', speaker: '', text: '이름이 자기가 됐다. 야, 거기, 저거 — 그 말들이 껍질처럼 벗겨지고, 아래에 주작이라는 이름이 선명하게 남았다.' },
      { type: 'text', speaker: '', text: '주작이 솥뚜껑을 열었다.' },
      { type: 'text', speaker: '', text: '김이 올라왔다.' },
      { type: 'text', speaker: '', text: '맛있는 냄새.' },
      { type: 'text', speaker: '', text: '밥이 됐다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응. 밥 됐어요."' },
      { type: 'text', speaker: '', text: '"알아. 맛있는 냄새가 나서."' },
      { type: 'text', speaker: '', text: '플레이어가 부엌으로 왔다.' },
      { type: 'text', speaker: '', text: '주작이 밥을 담았다.' },
      { type: 'text', speaker: '주작', text: '"오늘 뭐 하고 싶어요?"' },
      { type: 'text', speaker: '', text: '"밥 먹고 싶어."' },
      { type: 'text', speaker: '', text: '"그 다음에요."' },
      { type: 'text', speaker: '', text: '"자고 싶어."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"탑이 힘들었어."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"어딘가 다쳤어요?"' },
      { type: 'text', speaker: '', text: '"아니."' },
      { type: 'text', speaker: '', text: '"진짜?"' },
      { type: 'text', speaker: '', text: '"진짜."' },
      { type: 'text', speaker: '', text: '"그럼 쉬면 되죠."' },
      { type: 'text', speaker: '', text: '주작이 밥을 건넸다.' },
      { type: 'text', speaker: '주작', text: '"많이 먹어요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '두 사람이 밥을 먹었다.' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '편안하게.' },
      { type: 'text', speaker: '', text: '이게 매일이었으면 했다.' },
      { type: 'text', speaker: '', text: '이 조용함이.' },
      { type: 'text', speaker: '', text: '이 편안함이.' },
      { type: 'text', speaker: '', text: '매일이었으면.' },
      { type: 'text', speaker: '', text: '그날 밤.' },
      { type: 'text', speaker: '', text: '왜소한 신이 마당에 있었다.' },
      { type: 'text', speaker: '', text: '플레이어가 나왔다.' },
      { type: 'text', speaker: '', text: '신이 플레이어를 봤다.' },
      { type: 'text', speaker: '', text: '그리고 슬쩍.' },
      { type: 'text', speaker: '', text: '플레이어 발치에 붙었다.' },
      { type: 'text', speaker: '', text: '발등 위에 살포시 앉으려 하는 것처럼.' },
      { type: 'text', speaker: '', text: '플레이어가 신을 내려봤다.' },
      { type: 'text', speaker: '', text: '시스템 창이 떴다.' },
      { type: 'effect', effect: 'system', text: '【각성이 임박했습니다. 이동 준비를 하십시오. 유대 에너지 회수 예정.】' },
      { type: 'text', speaker: '', text: '플레이어의 손이 떨렸다. 주먹을 쥐었다. 풀었다.' },
      { type: 'text', speaker: '', text: '플레이어가 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '신이 플레이어 발치에서 하늘을 올려봤다.' },
      { type: 'text', speaker: '', text: '나란히.' },
      { type: 'text', speaker: '', text: '신이 담장 위로 올라갔다.' },
      { type: 'text', speaker: '', text: '별을 봤다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '주작성.' },
      { type: 'text', speaker: '', text: '빛났다.' },
      { type: 'text', speaker: '', text: '밝게.' },
      { type: 'text', speaker: '', text: '오래간만에.' },
      { type: 'text', speaker: '', text: '플레이어가 별을 봤다.' },
      { type: 'text', speaker: '', text: '이동이 임박했다.' },
      { type: 'text', speaker: '', text: '주작은 모른다.' },
      { type: 'text', speaker: '', text: '주작은 지금 방 안에서 자고 있다.' },
      { type: 'text', speaker: '', text: '리본을 가방에 달고 자고 있을 것이다.' },
      { type: 'text', speaker: '', text: '붉은 리본을.' },
      { type: 'text', speaker: '', text: '플레이어가 눈을 감았다.' },
      { type: 'text', speaker: '', text: '신이 플레이어 어깨를 슬쩍 봤다.' },
      { type: 'text', speaker: '', text: '그쪽에 앉고 싶은 듯.' },
      { type: 'text', speaker: '', text: '망설이다가.' },
      { type: 'text', speaker: '', text: '담장 위에 그냥 있었다.' },
    ]
  },
  {
