  {
    title: '기대 효과: "당신이 ~해줘서" 밀집도 분산, 대사 호흡 개선. 3장 고점수 유지하면서 반복 패턴만 최소 정리.',
    nodes: [
      { type: 'text', speaker: '', text: '타겟 평가자: 감사 표현 패턴 변주 기대 효과: "당신이 ~해줘서" 밀집도 분산, 대사 호흡 개선. 3장 고점수 유지하면서 반복 패턴만 최소 정리.' },
      { type: 'text', speaker: '', text: '3장. 감사가 쌓이는 시간' },
      { type: 'text', speaker: '', text: '훈련이 시작됐다.' },
      { type: 'text', speaker: '', text: '"오늘부터 훈련할 거야."' },
      { type: 'text', speaker: '', text: '플레이어가 목검을 내밀었다. 나중에 진짜 검을 쥐게 될 손을 위한 첫 번째 연습.' },
      { type: 'text', speaker: '', text: '주작이 받았다.' },
      { type: 'text', speaker: '', text: '나무 냄새가 났다. 단단하고 묵직했다.' },
      { type: 'text', speaker: '', text: '손잡이를 감쌌다.' },
      { type: 'text', speaker: '', text: '이상하게 손에 맞았다.' },
      { type: 'text', speaker: '', text: '"뭘 위한 건지 물어봐도 돼요?"' },
      { type: 'text', speaker: '', text: '"강해져야 해."' },
      { type: 'text', speaker: '', text: '"뭘 지키려고요?"' },
      { type: 'text', speaker: '', text: '플레이어가 멈췄다.' },
      { type: 'text', speaker: '', text: '"당신이요? 아니면 저요? 아니면 다른 사람이요?"' },
      { type: 'text', speaker: '', text: '"셋 다."' },
      { type: 'text', speaker: '', text: '주작이 고개를 끄덕였다.' },
      { type: 'text', speaker: '주작', text: '"좋아요. 셋 다 지킬 수 있으면 좋죠."' },
      { type: 'text', speaker: '', text: '목검을 잡았다.' },
      { type: 'text', speaker: '', text: '무게를 느껴봤다.' },
      { type: 'text', speaker: '', text: '앞이 뒤보다 무거웠다.' },
      { type: 'text', speaker: '', text: '그걸 손목으로 느꼈다.' },
      { type: 'text', speaker: '', text: '"어디서 시작해요?"' },
      { type: 'text', speaker: '', text: '첫날 훈련은 자세 잡기였다.' },
      { type: 'text', speaker: '', text: '자세. 발 위치. 손목 각도.' },
      { type: 'text', speaker: '', text: '플레이어가 보여줬다.' },
      { type: 'text', speaker: '', text: '오른발 앞. 왼발 뒤. 무릎을 살짝 굽히고. 목검을 이 각도로.' },
      { type: 'text', speaker: '', text: '주작은 빠르게 따라했다.' },
      { type: 'text', speaker: '', text: '몸이 이상하게 잘 알아들었다.' },
      { type: 'text', speaker: '', text: '익숙한 것 같았다.' },
      { type: 'text', speaker: '', text: '처음인데.' },
      { type: 'text', speaker: '', text: '익숙한 것 같았다.' },
      { type: 'text', speaker: '', text: '"잘하네."' },
      { type: 'text', speaker: '', text: '"그래요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 잘한다고 하면 잘한 거예요?"' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"좋아요."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '처음으로.' },
      { type: 'text', speaker: '', text: '훈련하면서 웃었다.' },
      { type: 'text', speaker: '', text: '훈련 이틀째.' },
      { type: 'text', speaker: '', text: '주작이 땀을 흘렸다.' },
      { type: 'text', speaker: '', text: '얼굴이 빨갰다.' },
      { type: 'text', speaker: '', text: '"잠깐 쉬어."' },
      { type: 'text', speaker: '', text: '"괜찮아요."' },
      { type: 'text', speaker: '', text: '"쉬어."' },
      { type: 'text', speaker: '', text: '주작이 목검을 내렸다.' },
      { type: 'text', speaker: '', text: '땀을 닦았다.' },
      { type: 'text', speaker: '', text: '"당신은 어떻게 이걸 가르쳐요?"' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"훈련이요. 어떻게 알아요?"' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 생각했다.' },
      { type: 'text', speaker: '', text: '"시스템이 알려줘."' },
      { type: 'text', speaker: '', text: '"시스템이요?"' },
      { type: 'text', speaker: '', text: '"응. 네가 뭘 필요로 하는지."' },
      { type: 'text', speaker: '', text: '주작이 고개를 기울였다.' },
      { type: 'text', speaker: '주작', text: '"그럼 당신은요?"' },
      { type: 'text', speaker: '', text: '"나는?"' },
      { type: 'text', speaker: '', text: '"당신이 진심으로 가르쳐주는 거예요. 시스템이 시켜서 가르쳐주는 거예요?"' },
      { type: 'text', speaker: '', text: '플레이어가 멈췄다.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '주작', text: '"모르겠어요?"' },
      { type: 'text', speaker: '', text: '"...둘 다인 것 같아."' },
      { type: 'text', speaker: '', text: '"그래요."' },
      { type: 'text', speaker: '', text: '주작이 수건으로 땀을 닦았다.' },
      { type: 'text', speaker: '주작', text: '"시스템이 시키는 것도 있고요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 진심으로 하는 것도 있고요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그러면요."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"진심인 부분에 감사해요."' },
      { type: 'text', speaker: '', text: '"시스템 때문인 부분은?"' },
      { type: 'text', speaker: '', text: '"그건요."' },
      { type: 'text', speaker: '', text: '주작이 고개를 기울였다.' },
      { type: 'text', speaker: '주작', text: '"나쁜 이유가 있어도. 좋은 일이 있으면 그게 좋은 거잖아요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"그런가."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 목검을 다시 잡았다.' },
      { type: 'text', speaker: '주작', text: '"계속 해요."' },
      { type: 'text', speaker: '', text: '훈련은 매일 했다.' },
      { type: 'text', speaker: '', text: '주작이 빠르게 늘었다.' },
      { type: 'text', speaker: '', text: '몸이 이상하게 잘 따라왔다.' },
      { type: 'text', speaker: '', text: '자세가 무너지지 않았다. 발이 말을 잘 들었다. 손목이 유연했다.' },
      { type: 'text', speaker: '', text: '처음부터 알고 있었던 것처럼.' },
      { type: 'text', speaker: '', text: '아주 오래전에.' },
      { type: 'text', speaker: '', text: '배웠던 것처럼.' },
      { type: 'text', speaker: '', text: '불꽃이 처음 손에서 일었을 때는 열흘째 됐을 때였다.' },
      { type: 'text', speaker: '', text: '"어?"' },
      { type: 'text', speaker: '', text: '손을 봤다.' },
      { type: 'text', speaker: '', text: '손가락 끝에서 작은 불꽃이 피었다 꺼졌다 했다. 심장이 미친 듯이 뛰었다. 이건 뭐지. 이건 뭐지. 멈출 수가 없었다.' },
      { type: 'effect', effect: 'system', text: '【신수 주작. 첫 번째 신력 발현 감지. 화속성. 등급 측정 중.】' },
      { type: 'text', speaker: '', text: '주황빛. 아주 작은.' },
      { type: 'text', speaker: '', text: '귀여웠다.' },
      { type: 'text', speaker: '', text: '"이게 뭐예요?"' },
      { type: 'text', speaker: '', text: '"신력이야."' },
      { type: 'text', speaker: '', text: '"저한테 있는 거요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"처음부터요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 봤다.' },
      { type: 'text', speaker: '', text: '피었다. 꺼졌다. 피었다. 꺼졌다.' },
      { type: 'text', speaker: '', text: '귀엽다고 생각했다.' },
      { type: 'text', speaker: '', text: '내 거라는 게 실감이 나지 않았다.' },
      { type: 'text', speaker: '', text: '"이걸로 뭘 할 수 있어요?"' },
      { type: 'text', speaker: '', text: '"지금은 작으니까. 훈련하면서 커져."' },
      { type: 'text', speaker: '', text: '"커지면요?"' },
      { type: 'text', speaker: '', text: '"제대로 된 불꽃이 돼."' },
      { type: 'text', speaker: '', text: '주작이 고개를 끄덕였다.' },
      { type: 'text', speaker: '주작', text: '"불꽃이."' },
      { type: 'text', speaker: '', text: '주작이 중얼거렸다.' },
      { type: 'text', speaker: '', text: '어디서 온 느낌인지.' },
      { type: 'text', speaker: '', text: '불꽃이라는 말이 익숙했다.' },
      { type: 'text', speaker: '', text: '마치 원래부터 알던 것처럼.' },
      { type: 'text', speaker: '', text: '비 오는 날이었다.' },
      { type: 'text', speaker: '', text: '주작이 먼저 시장에 가겠다고 했다. 재료를 사오겠다고.' },
      { type: 'text', speaker: '', text: '돌아오는 길에 비가 쏟아졌다.' },
      { type: 'text', speaker: '', text: '처마 밑에서 피했다.' },
      { type: 'text', speaker: '', text: '비를 봤다.' },
      { type: 'text', speaker: '', text: '많이 왔다.' },
      { type: 'text', speaker: '', text: '"주작!"' },
      { type: 'text', speaker: '', text: '멀리서 소리가 났다.' },
      { type: 'text', speaker: '', text: '주작이 고개를 들었다.' },
      { type: 'text', speaker: '', text: '플레이어가 달려오고 있었다.' },
      { type: 'text', speaker: '', text: '우산을 들고.' },
      { type: 'text', speaker: '', text: '비를 맞으면서.' },
      { type: 'text', speaker: '', text: '이름을 부르면서.' },
      { type: 'text', speaker: '', text: '주작의 눈이 커졌다.' },
      { type: 'text', speaker: '', text: '"여기 있었어. 걱정했잖아."' },
      { type: 'text', speaker: '', text: '플레이어가 우산을 주작 쪽으로 기울였다.' },
      { type: 'text', speaker: '', text: '주작이 멍하니 서 있었다.' },
      { type: 'text', speaker: '', text: '달려왔다.' },
      { type: 'text', speaker: '', text: '이름을 부르면서 달려왔다.' },
      { type: 'text', speaker: '', text: '비를 맞으면서.' },
      { type: 'text', speaker: '', text: '"왜 그래?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '주작이 눈을 깜박였다.' },
      { type: 'text', speaker: '주작', text: '"그냥."' },
      { type: 'text', speaker: '', text: '"그냥?"' },
      { type: 'text', speaker: '', text: '"당신이 제 이름 부르면서 달려온 사람이 처음이라서요."' },
      { type: 'text', speaker: '', text: '코끝이 시큰했다. 빗물인지 다른 것인지 모를 게 볼을 타고 흘렀다. 손 안의 잔열이 비에 젖으면서도 꺼지지 않았다.' },
      { type: 'text', speaker: '', text: '플레이어가 멈췄다.' },
      { type: 'text', speaker: '', text: '"처음?"' },
      { type: 'text', speaker: '', text: '"고아원에서 달려온 어른은 혼내러 달려오거나, 시키러 달려오거나. 이름을 부르면서 걱정돼서 달려온 건 처음이에요."' },
      { type: 'text', speaker: '', text: '주작이 우산 아래로 들어갔다.' },
      { type: 'text', speaker: '주작', text: '"...다행이에요. 당신이어서."' },
      { type: 'text', speaker: '', text: '플레이어가 아무 말도 안 했다.' },
      { type: 'text', speaker: '', text: '하지만 우산을 좀 더 주작 쪽으로 기울였다.' },
      { type: 'text', speaker: '', text: '주작이 그걸 느꼈다.' },
      { type: 'text', speaker: '', text: '그냥 같이 비를 피했다.' },
      { type: 'text', speaker: '', text: '훈련에서 넘어졌다.' },
      { type: 'text', speaker: '', text: '무릎이 까졌다.' },
      { type: 'text', speaker: '', text: '마당 바닥이 딱딱했다.' },
      { type: 'text', speaker: '', text: '플레이어가 봤다.' },
      { type: 'text', speaker: '', text: '"일어날 수 있어?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 혼자 일어섰다.' },
      { type: 'text', speaker: '', text: '플레이어가 약을 가져와 발라줬다.' },
      { type: 'text', speaker: '', text: '"아파?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '"거짓말하지 마."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '거짓말인 걸 알았다.' },
      { type: 'text', speaker: '', text: '"...조금요."' },
      { type: 'text', speaker: '', text: '"그래."' },
      { type: 'text', speaker: '', text: '플레이어가 처치를 마쳤다.' },
      { type: 'text', speaker: '', text: '"다음엔 이쪽 발 먼저야."' },
      { type: 'text', speaker: '', text: '다시 훈련을 설명했다.' },
      { type: 'text', speaker: '', text: '아프다고 쉬라고 하지 않았다.' },
      { type: 'text', speaker: '', text: '할 수 있다고 봤다.' },
      { type: 'text', speaker: '', text: '그게 좋았다.' },
      { type: 'text', speaker: '', text: '날들이 지났다. 어떤 날은 빠르고, 어떤 날은 느렸다. 하지만 같은 것이 하나 있었다. 매일 밤, 남쪽 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '별 밑에서 같이 있어줬을 때가 있었다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '주작성이 빛나는 밤.' },
      { type: 'text', speaker: '', text: '플레이어가 옆에 앉아 있었다.' },
      { type: 'text', speaker: '', text: '아무 말도 안 했다.' },
      { type: 'text', speaker: '', text: '그냥 앉아 있었다.' },
      { type: 'text', speaker: '', text: '주작도 아무 말 안 했다.' },
      { type: 'text', speaker: '', text: '그냥 별을 봤다.' },
      { type: 'text', speaker: '', text: '한 시간이 지났다.' },
      { type: 'text', speaker: '', text: '"들어갈까?"' },
      { type: 'text', speaker: '', text: '플레이어가 물었다.' },
      { type: 'text', speaker: '', text: '"조금만 더요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '그러면서 더 있어줬다.' },
      { type: 'text', speaker: '', text: '그게 가장 따뜻한 순간이었다.' },
      { type: 'text', speaker: '', text: '조금만 더 있어달라고 했을 때.' },
      { type: 'text', speaker: '', text: '그냥 있어준 것.' },
      { type: 'text', speaker: '', text: '한 달이 지난 어느 저녁.' },
      { type: 'text', speaker: '', text: '왜소한 신이 밥을 먹을 때 처음으로 나타났다.' },
      { type: 'text', speaker: '', text: '플레이어 옆자리.' },
      { type: 'text', speaker: '', text: '슬금슬금.' },
      { type: 'text', speaker: '', text: '아주 조심스럽게.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '주작', text: '"어? 같이 먹어요?"' },
      { type: 'text', speaker: '', text: '신이 멈췄다.' },
      { type: 'text', speaker: '', text: '그러더니.' },
      { type: 'text', speaker: '', text: '아주 조금.' },
      { type: 'text', speaker: '', text: '플레이어 쪽으로 더 다가갔다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"그러면 밥 더 담아요."' },
      { type: 'text', speaker: '', text: '밥을 한 그릇 더 담았다.' },
      { type: 'text', speaker: '', text: '신 앞에 놓았다.' },
      { type: 'text', speaker: '', text: '신이 봤다.' },
      { type: 'text', speaker: '', text: '"먹어요."' },
      { type: 'text', speaker: '', text: '신이 그릇을 봤다.' },
      { type: 'text', speaker: '', text: '그러더니.' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '뭔가를 먹는 것 같았다.' },
      { type: 'text', speaker: '', text: '먹는 건지 안 먹는 건지 모르겠지만.' },
      { type: 'text', speaker: '', text: '그 앞에 있었다.' },
      { type: 'text', speaker: '', text: '그것만으로도.' },
      { type: 'text', speaker: '', text: '좋은 것 같았다.' },
      { type: 'text', speaker: '', text: '"맛있어요?"' },
      { type: 'text', speaker: '', text: '신이 고개를 기울였다.' },
      { type: 'text', speaker: '', text: '갸웃.' },
      { type: 'text', speaker: '', text: '주작이 밥을 먹었다.' },
      { type: 'text', speaker: '주작', text: '"당신 좋아해요."' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"말 안 해도요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"말 안 해도 여기 있잖아요."' },
      { type: 'text', speaker: '', text: '신이 다시 앞을 봤다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '플레이어가 봤다.' },
      { type: 'text', speaker: '', text: '"신이 좋아?"' },
      { type: 'text', speaker: '', text: '"응. 귀여워요."' },
      { type: 'text', speaker: '', text: '플레이어가 신을 봤다.' },
      { type: 'text', speaker: '', text: '신이 슬쩍.' },
      { type: 'text', speaker: '', text: '플레이어 쪽으로 더 바짝 붙었다.' },
      { type: 'text', speaker: '', text: '주작이 그걸 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신 것 같은데요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"당신 옆에 더 붙잖아요."' },
      { type: 'text', speaker: '', text: '플레이어가 신을 봤다.' },
      { type: 'text', speaker: '', text: '신이 아무것도 아닌 것처럼 앞을 봤다.' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '세 명이 밥을 먹었다.' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '그게 좋았다.' },
      { type: 'text', speaker: '', text: '훈련 중에.' },
      { type: 'text', speaker: '', text: '어느 날 주작이 넘어지지 않았다.' },
      { type: 'text', speaker: '', text: '발이 정확하게 움직였다.' },
      { type: 'text', speaker: '', text: '전에는 넘어졌던 자리.' },
      { type: 'text', speaker: '', text: '이번엔 버텼다.' },
      { type: 'text', speaker: '', text: '"어."' },
      { type: 'text', speaker: '', text: '주작이 발을 봤다.' },
      { type: 'text', speaker: '', text: '넘어지지 않았다.' },
      { type: 'text', speaker: '', text: '"됐어."' },
      { type: 'text', speaker: '', text: '플레이어가 봤다.' },
      { type: 'text', speaker: '', text: '"됐어요?"' },
      { type: 'text', speaker: '', text: '"응. 넘어지지 않았잖아."' },
      { type: 'text', speaker: '', text: '주작이 다시 해봤다.' },
      { type: 'text', speaker: '', text: '같은 자세.' },
      { type: 'text', speaker: '', text: '같은 동작.' },
      { type: 'text', speaker: '', text: '또 버텼다.' },
      { type: 'text', speaker: '', text: '"됐다."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"네가 잘 한 거야."' },
      { type: 'text', speaker: '', text: '"당신이 가르쳐줬어요."' },
      { type: 'text', speaker: '', text: '"네가 배운 거야."' },
      { type: 'text', speaker: '', text: '주작이 고개를 저었다.' },
      { type: 'text', speaker: '주작', text: '"그거 구분 안 해요."' },
      { type: 'text', speaker: '', text: '"그건 또 과장이야."' },
      { type: 'text', speaker: '', text: '"과장 아니에요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 피웠다.' },
      { type: 'text', speaker: '주작', text: '"당신이 이름 불러줘서 불꽃이 생겼고요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"불꽃이 있어서 강해졌고요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"다 연결돼요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '훈련이 한 달째 됐다.' },
      { type: 'text', speaker: '', text: '주작의 불꽃이 커졌다.' },
      { type: 'text', speaker: '', text: '처음엔 손가락 끝에 작게 피었던 불꽃이.' },
      { type: 'text', speaker: '', text: '이제 손 전체를 감쌌다.' },
      { type: 'text', speaker: '', text: '주황빛에서 붉은빛으로.' },
      { type: 'text', speaker: '', text: '더 강하게.' },
      { type: 'text', speaker: '', text: '열기가 달라졌다. 체온이 아니라 불의 온도였다. 마당 구석 풀밭에 손을 뻗으니 반경 한 뼘이 마르며 갈색으로 죽었다.' },
      { type: 'text', speaker: '', text: '"이게 계속 커져요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"어디까지요?"' },
      { type: 'text', speaker: '', text: '"모르겠어."' },
      { type: 'text', speaker: '', text: '"그래도 돼요?"' },
      { type: 'text', speaker: '', text: '"모르는 게 다 나쁜 건 아니야."' },
      { type: 'text', speaker: '', text: '주작이 고개를 기울였다.' },
      { type: 'text', speaker: '주작', text: '"그렇기도 하겠네요."' },
      { type: 'text', speaker: '', text: '불꽃을 봤다.' },
      { type: 'text', speaker: '', text: '손 위에서 춤추는 불꽃.' },
      { type: 'text', speaker: '', text: '"이게 뭔지 알 것 같기도 해요."' },
      { type: 'text', speaker: '', text: '"뭐야?"' },
      { type: 'text', speaker: '', text: '"불꽃인데요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"이름 같아요."' },
      { type: 'text', speaker: '', text: '"이름?"' },
      { type: 'text', speaker: '', text: '"당신이 이름 불러줄 때마다 이게 커지는 것 같아서요."' },
      { type: 'text', speaker: '', text: '플레이어가 봤다.' },
      { type: 'text', speaker: '', text: '"진짜요?"' },
      { type: 'text', speaker: '', text: '"몰라요. 그냥 그런 것 같아요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 꽉 쥐었다.' },
      { type: 'text', speaker: '', text: '뜨겁지 않았다.' },
      { type: 'text', speaker: '', text: '제 것이었다.' },
      { type: 'text', speaker: '', text: '"이름이 불릴 때마다 뭔가가 커지는 것 같아요."' },
      { type: 'text', speaker: '', text: '플레이어가 말했다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '불꽃이 반짝했다.' },
      { type: 'effect', effect: 'system', text: '【이름 호명 시 신력 반응 확인. 유대 기반 성장형으로 분류. 상위 각성 시 화력 등급 재측정 필요.】' },
      { type: 'text', speaker: '', text: '주작이 눈을 크게 떴다.' },
      { type: 'text', speaker: '주작', text: '"봤어요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"진짜네요."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '처음으로.' },
      { type: 'text', speaker: '', text: '이름이 불꽃이라는 걸 알아서 웃었다. 가슴속에서 뭔가가 활활 타오르는 것 같았다.' },
      { type: 'text', speaker: '', text: '하지만 감사가 쌓이면 무서운 것도 쌓인다.' },
      { type: 'text', speaker: '', text: '잃을 것이 생긴다는 뜻이니까. 불꽃이 클수록 꺼질 때의 어둠도 크다는 걸, 주작은 아직 몰랐다.' },
      { type: 'text', speaker: '', text: '어느 오후.' },
      { type: 'text', speaker: '', text: '훈련이 끝나고.' },
      { type: 'text', speaker: '', text: '주작이 마당에 앉아 있었다.' },
      { type: 'text', speaker: '', text: '플레이어가 옆에 왔다.' },
      { type: 'text', speaker: '', text: '"피곤해?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '"근데 왜 앉아 있어?"' },
      { type: 'text', speaker: '', text: '"그냥요."' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신한테 물어봐도 돼요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"저 왜 데려온 거예요. 진짜로."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '"말했잖아. 강해져야 해."' },
      { type: 'text', speaker: '', text: '"그것 말고요."' },
      { type: 'text', speaker: '', text: '"그것 말고?"' },
      { type: 'text', speaker: '', text: '"진심으로요."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"시스템 창이 시키는 거잖아요. 그것 말고. 당신 진심으로 왜 데려온 거예요."' },
      { type: 'text', speaker: '', text: '플레이어가 대답을 못 했다.' },
      { type: 'text', speaker: '', text: '주작이 고개를 끄덕였다.' },
      { type: 'text', speaker: '주작', text: '"모르는 거죠?"' },
      { type: 'text', speaker: '', text: '"...응."' },
      { type: 'text', speaker: '', text: '"그래도 괜찮아요."' },
      { type: 'text', speaker: '', text: '"괜찮아?"' },
      { type: 'text', speaker: '', text: '"당신이 왜 데려왔든. 데려온 다음에 진심으로 챙겨줬으니까요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"그게 보여요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 하늘을 다시 봤다.' },
      { type: 'text', speaker: '주작', text: '"이름 불러주는 게 보여요. 비 오는 날 달려온 게 보여요. 약 발라준 게 보여요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"다 보여요."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"당신이 진심으로 하는 건 다 보여요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 담장 위에서 그걸 봤다.' },
      { type: 'text', speaker: '', text: '신이 담장 아래로 내려왔다.' },
      { type: 'text', speaker: '', text: '주작 옆을 지나가려 했다.' },
      { type: 'text', speaker: '', text: '주작이 신을 봤다.' },
      { type: 'text', speaker: '주작', text: '"어디 가요?"' },
      { type: 'text', speaker: '', text: '신이 멈췄다.' },
      { type: 'text', speaker: '', text: '"같이 있으면 안 돼요?"' },
      { type: 'text', speaker: '', text: '신이 돌아봤다.' },
      { type: 'text', speaker: '', text: '마당에 앉았다.' },
      { type: 'text', speaker: '', text: '주작 옆.' },
      { type: 'text', speaker: '', text: '아주 조금 거리를 두고.' },
      { type: 'text', speaker: '', text: '플레이어와 주작 사이.' },
      { type: 'text', speaker: '', text: '"여기 있어줘서 좋아요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '', text: '신이 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '주작도 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '주작성이 빛났다.' },
      { type: 'text', speaker: '', text: '"저 별이요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"저기서 이름이 온 것 같아요."' },
      { type: 'text', speaker: '', text: '신이 별을 봤다.' },
      { type: 'text', speaker: '', text: '오래 봤다.' },
      { type: 'text', speaker: '', text: '그러다 슬쩍.' },
      { type: 'text', speaker: '', text: '주작 쪽으로 한 걸음 다가왔다.' },
      { type: 'text', speaker: '', text: '주작이 그걸 봤다.' },
      { type: 'text', speaker: '', text: '웃었다.' },
      { type: 'text', speaker: '', text: '그냥 같이 별을 봤다.' },
      { type: 'text', speaker: '', text: '이름 없는 작은 것과.' },
      { type: 'text', speaker: '', text: '이름을 되찾은 주작이.' },
      { type: 'text', speaker: '', text: '같이.' },
      { type: 'text', speaker: '', text: '별을 봤다.' },
    ]
  },
  {
    title: '기대 효과: 탑 진입 시 물리적 긴장감 부여, 4장 내 반복 대사 제거',
    nodes: [
      { type: 'text', speaker: '', text: '타겟 평가자: 강철(전투 감각), 탑 1-2층 보완 기대 효과: 탑 진입 시 물리적 긴장감 부여, 4장 내 반복 대사 제거' },
      { type: 'text', speaker: '', text: '4장. 신뢰' },
      { type: 'text', speaker: '', text: '훈련이 두 달째 됐다.' },
      { type: 'text', speaker: '', text: '주작이 처음으로 혼자 탑 근처까지 갔다 왔다.' },
      { type: 'text', speaker: '', text: '플레이어가 기다리고 있었다.' },
      { type: 'text', speaker: '', text: '마당에.' },
      { type: 'text', speaker: '', text: '"어디 갔었어?"' },
      { type: 'text', speaker: '', text: '"탑 주변을 봐왔어요. 들어가진 않았어요."' },
      { type: 'text', speaker: '', text: '"괜찮아?"' },
      { type: 'text', speaker: '', text: '"네. 근데."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 멈췄다.' },
      { type: 'text', speaker: '주작', text: '"당신이 걱정할까봐 빨리 왔어요."' },
      { type: 'text', speaker: '', text: '플레이어가 멈췄다.' },
      { type: 'text', speaker: '', text: '"나 걱정하면서 왔어?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '주작이 고개를 기울였다.' },
      { type: 'text', speaker: '주작', text: '"당신이 어떻게 생각하는지가 중요하니까요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"이상해요?"' },
      { type: 'text', speaker: '', text: '"아니야."' },
      { type: 'text', speaker: '', text: '"당신이 안 이상하다고 하면 안 이상한 거예요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"내 기준이 맞는 게 아닐 수도 있어."' },
      { type: 'text', speaker: '', text: '"당신 기준이 제 기준이에요. 지금은요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"어느 날부터 당신이 어떻게 생각하는지가 기준이 됐어요. 나중에는 제 기준도 생기겠지만요. 지금은 당신이에요."' },
      { type: 'text', speaker: '', text: '처음엔 기대하지 않았다.' },
      { type: 'text', speaker: '', text: '기대하면 실망한다는 걸 알았다.' },
      { type: 'text', speaker: '', text: '고아원에서 배웠다.' },
      { type: 'text', speaker: '', text: '기대하지 않으면 실망하지 않는다.' },
      { type: 'text', speaker: '', text: '그래서 기대하지 않았다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '플레이어는 기대를 만들어냈다.' },
      { type: 'text', speaker: '', text: '담요가 없어지지 않을 것이라는 기대. 밥이 있을 것이라는 기대. 이름이 불릴 것이라는 기대.' },
      { type: 'text', speaker: '', text: '그 기대들이 모두 맞았다.' },
      { type: 'text', speaker: '', text: '계속 맞았다.' },
      { type: 'text', speaker: '', text: '훈련 두 달째가 됐을 무렵.' },
      { type: 'text', speaker: '', text: '어느 아침.' },
      { type: 'text', speaker: '', text: '주작이 일어났을 때.' },
      { type: 'text', speaker: '', text: '몸이 무거웠다.' },
      { type: 'text', speaker: '', text: '평소보다 무거웠다.' },
      { type: 'text', speaker: '', text: '팔이 묵직했다. 다리도 묵직했다.' },
      { type: 'text', speaker: '', text: '어제 훈련이 많았던 탓인 것 같았다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"오늘 훈련 쉬어."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"몸 무거워 보여."' },
      { type: 'text', speaker: '', text: '"괜찮아요."' },
      { type: 'text', speaker: '', text: '"쉬어."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 멈췄다.' },
      { type: 'text', speaker: '주작', text: '"쉬면 뒤처지잖아요."' },
      { type: 'text', speaker: '', text: '"하루 쉬어도 안 뒤처져."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"쉬는 것도 훈련이야."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"그런 말 처음 들어요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"고아원에서는 쉬면 게으른 거였어요."' },
      { type: 'text', speaker: '', text: '"여기선 달라."' },
      { type: 'text', speaker: '', text: '"어떻게요?"' },
      { type: 'text', speaker: '', text: '"지쳐서 쓰러지는 것보다. 쉬고 다음 날 제대로 하는 게 나아."' },
      { type: 'text', speaker: '', text: '주작이 생각했다.' },
      { type: 'text', speaker: '주작', text: '"...알겠어요."' },
      { type: 'text', speaker: '', text: '주작이 앉았다.' },
      { type: 'text', speaker: '주작', text: '"그러면 뭐 해요. 쉬는 날에는."' },
      { type: 'text', speaker: '', text: '"하고 싶은 거."' },
      { type: 'text', speaker: '', text: '"하고 싶은 거요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 생각했다.' },
      { type: 'text', speaker: '', text: '하고 싶은 거.' },
      { type: 'text', speaker: '', text: '"...책이요."' },
      { type: 'text', speaker: '', text: '"책?"' },
      { type: 'text', speaker: '', text: '"고아원에 책이 없었어요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"읽어보고 싶었어요. 책."' },
      { type: 'text', speaker: '', text: '플레이어가 일어났다.' },
      { type: 'text', speaker: '', text: '방에서 책 한 권을 가져왔다.' },
      { type: 'text', speaker: '', text: '"이거."' },
      { type: 'text', speaker: '', text: '주작이 받았다.' },
      { type: 'text', speaker: '', text: '두꺼운 책.' },
      { type: 'text', speaker: '', text: '냄새가 좋았다.' },
      { type: 'text', speaker: '', text: '종이 냄새.' },
      { type: 'text', speaker: '', text: '조금 낡은.' },
      { type: 'text', speaker: '', text: '"이게 뭐예요?"' },
      { type: 'text', speaker: '', text: '"그냥 이야기책이야."' },
      { type: 'text', speaker: '', text: '"읽어도 돼요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 책을 봤다.' },
      { type: 'text', speaker: '', text: '첫 장을 넘겼다.' },
      { type: 'text', speaker: '', text: '글자들이 빽빽했다.' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '플레이어가 옆에 앉았다.' },
      { type: 'text', speaker: '', text: '"읽어줄까?"' },
      { type: 'text', speaker: '', text: '"...응."' },
      { type: 'text', speaker: '', text: '처음으로 책을 읽어주는 사람이 옆에 앉았다.' },
      { type: 'text', speaker: '', text: '목소리가 들리자마자 코끝이 시큰했다. 왜인지는 몰랐다. 그냥, 이런 게 처음이어서.' },
      { type: 'text', speaker: '', text: '플레이어가 읽었다.' },
      { type: 'text', speaker: '', text: '천천히.' },
      { type: 'text', speaker: '', text: '주작이 들었다.' },
      { type: 'text', speaker: '', text: '이야기가 흘렀다.' },
      { type: 'text', speaker: '', text: '주작이 눈을 감았다.' },
      { type: 'text', speaker: '', text: '그냥 들었다.' },
      { type: 'text', speaker: '', text: '이야기를.' },
      { type: 'text', speaker: '', text: '당신의 목소리를.' },
      { type: 'text', speaker: '', text: '쉬는 날.' },
      { type: 'text', speaker: '', text: '어느 날 주작이 물었다.' },
      { type: 'text', speaker: '주작', text: '"저 민폐예요?"' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"뭔가 많이 챙겨주잖아요. 그게 민폐일 것 같아서요."' },
      { type: 'text', speaker: '', text: '플레이어가 고개를 저었다.' },
      { type: 'text', speaker: '', text: '"아니야."' },
      { type: 'text', speaker: '', text: '"진짜요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 힘들지 않아요?"' },
      { type: 'text', speaker: '', text: '"안 힘들어."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 봤다.' },
      { type: 'text', speaker: '주작', text: '"고아원에서는요. 제가 뭔가 해달라고 하면 힘들다고 했거든요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그래서 말 안 했어요. 말해봤자 힘들다고 하니까."' },
      { type: 'text', speaker: '', text: '"여기선 달라."' },
      { type: 'text', speaker: '', text: '"어떻게요?"' },
      { type: 'text', speaker: '', text: '"말해."' },
      { type: 'text', speaker: '', text: '플레이어가 말했다.' },
      { type: 'text', speaker: '', text: '"필요한 거 있으면 말해. 힘들다고 안 할 테니까."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"어떻게 믿어요?"' },
      { type: 'text', speaker: '', text: '"믿어봐."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '플레이어가 기다렸다.' },
      { type: 'text', speaker: '', text: '"...훈련하다 발목이 좀 아파요."' },
      { type: 'text', speaker: '', text: '"언제부터?"' },
      { type: 'text', speaker: '', text: '"어제부터요."' },
      { type: 'text', speaker: '', text: '"왜 어제 말 안 했어?"' },
      { type: 'text', speaker: '', text: '"말하면 힘들다고 할 것 같아서요."' },
      { type: 'text', speaker: '', text: '플레이어가 일어났다.' },
      { type: 'text', speaker: '', text: '약을 가져왔다.' },
      { type: 'text', speaker: '', text: '"앉아."' },
      { type: 'text', speaker: '', text: '발목을 봤다.' },
      { type: 'text', speaker: '', text: '살짝 부어 있었다.' },
      { type: 'text', speaker: '', text: '약을 발랐다.' },
      { type: 'text', speaker: '', text: '손이 정확했다. 아픈 곳을 알고. 그 부분에 약을 발랐다.' },
      { type: 'text', speaker: '', text: '"내일 훈련 쉬어."' },
      { type: 'text', speaker: '', text: '"아닌데요."' },
      { type: 'text', speaker: '', text: '"쉬어."' },
      { type: 'text', speaker: '', text: '"하루 쉬어도 돼."' },
      { type: 'text', speaker: '', text: '주작이 멈췄다.' },
      { type: 'text', speaker: '주작', text: '"...힘들다고 안 하는 거죠?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그러면 한 가지만 더 말해도 돼요?"' },
      { type: 'text', speaker: '', text: '"말해."' },
      { type: 'text', speaker: '', text: '"담요가 좀 더 있으면 좋겠어요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"왜 이제 말해?"' },
      { type: 'text', speaker: '', text: '"말해도 된다는 걸 이제 알았어요."' },
      { type: 'text', speaker: '', text: '플레이어가 일어났다.' },
      { type: 'text', speaker: '', text: '담요 하나를 더 가져왔다.' },
      { type: 'text', speaker: '', text: '주작이 받았다.' },
      { type: 'text', speaker: '', text: '두꺼운 담요.' },
      { type: 'text', speaker: '', text: '냄새가 좋았다.' },
      { type: 'text', speaker: '', text: '햇빛 냄새.' },
      { type: 'text', speaker: '', text: '"감사해요."' },
      { type: 'text', speaker: '', text: '"더 필요한 거 있어?"' },
      { type: 'text', speaker: '', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '주작이 담요를 꼭 안았다.' },
      { type: 'text', speaker: '주작', text: '"없어요."' },
      { type: 'text', speaker: '', text: '어느 날.' },
      { type: 'text', speaker: '', text: '주작이 아침에 일어났는데 비가 왔다.' },
      { type: 'text', speaker: '', text: '장마가 시작된 것 같았다.' },
      { type: 'text', speaker: '', text: '흐릿한 아침.' },
      { type: 'text', speaker: '', text: '빗소리가 지붕을 두드렸다.' },
      { type: 'text', speaker: '', text: '주작이 창문을 열었다.' },
      { type: 'text', speaker: '', text: '빗냄새가 들어왔다.' },
      { type: 'text', speaker: '주작', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"아침 먹어야지."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '부엌으로 갔다.' },
      { type: 'text', speaker: '', text: '밥이 돼 있었다.' },
      { type: 'text', speaker: '', text: '플레이어가 만들어뒀었다.' },
      { type: 'text', speaker: '', text: '"...제가 할 거였는데."' },
      { type: 'text', speaker: '', text: '"오늘은 내가 했어."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"비 오는 날에는 좀 더 자도 돼."' },
      { type: 'text', speaker: '', text: '주작이 앉았다.' },
      { type: 'text', speaker: '', text: '밥을 한 숟갈 먹었다.' },
      { type: 'text', speaker: '', text: '"...맛있어요."' },
      { type: 'text', speaker: '', text: '"그래?"' },
      { type: 'text', speaker: '', text: '"당신이 만들어서 맛있어요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"당신이 만든 밥이 맛있어서가 아니야?"' },
      { type: 'text', speaker: '', text: '"그것도요."' },
      { type: 'text', speaker: '', text: '주작이 밥을 먹으면서 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신이 만들었다는 게 더 맛있어요."' },
      { type: 'text', speaker: '', text: '"이상한 말이야."' },
      { type: 'text', speaker: '', text: '"이상해요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 이상하다고 하네요."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"처음으로 이상하다고 했어요."' },
      { type: 'text', speaker: '', text: '주작이 그 말을 곱씹었다. 이상하다. 이 사람도 나를 판단하는구나. 그런데 이상하게, 싫지 않았다.' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '"...그렇네."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"나도 몰랐어."' },
      { type: 'text', speaker: '', text: '주작이 숟가락을 내려놓았다.' },
      { type: 'text', speaker: '주작', text: '"그러면 제가 이상한 거예요?"' },
      { type: 'text', speaker: '', text: '"아니야."' },
      { type: 'text', speaker: '', text: '"이상하지 않은데 이상하다고 했어요?"' },
      { type: 'text', speaker: '', text: '"...실수했어."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '크게.' },
      { type: 'text', speaker: '', text: '"당신도 실수하네요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"좋아요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"당신도 실수한다는 게요."' },
      { type: 'text', speaker: '', text: '주작이 밥을 다시 먹었다.' },
      { type: 'text', speaker: '주작', text: '"당신이 실수하면요. 당신이 사람인 것 같아서 좋아요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"사람인 것 같아서?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신이 저한테 완벽하면 거리가 느껴져요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"실수하면 가까워요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '비가 온 지 사흘째 됐을 때.' },
      { type: 'text', speaker: '', text: '플레이어가 탑 쪽에 나갔다가 돌아오는 시간이 늦었다.' },
      { type: 'text', speaker: '', text: '주작이 창문을 봤다.' },
      { type: 'text', speaker: '', text: '비가 왔다.' },
      { type: 'text', speaker: '', text: '늦었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 마당에 있었다.' },
      { type: 'text', speaker: '', text: '비를 맞고 있었다.' },
      { type: 'text', speaker: '', text: '움직이지 않았다.' },
      { type: 'text', speaker: '', text: '탑 쪽을 보면서.' },
      { type: 'text', speaker: '', text: '주작이 문을 열었다.' },
      { type: 'text', speaker: '주작', text: '"안으로 들어와요."' },
      { type: 'text', speaker: '', text: '신이 들어오지 않았다.' },
      { type: 'text', speaker: '', text: '탑 쪽을 보고 있었다.' },
      { type: 'text', speaker: '', text: '"아."' },
      { type: 'text', speaker: '', text: '주작이 우산을 집었다.' },
      { type: 'text', speaker: '', text: '나갔다.' },
      { type: 'text', speaker: '', text: '탑 근처 골목에서 플레이어를 만났다.' },
      { type: 'text', speaker: '', text: '비를 맞고 있었다.' },
      { type: 'text', speaker: '', text: '"여기 있었어."' },
      { type: 'text', speaker: '', text: '주작이 우산을 플레이어 위로 들었다.' },
      { type: 'text', speaker: '주작', text: '"내 걱정했어?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"우산 없이 나갔잖아요."' },
      { type: 'text', speaker: '', text: '둘이 걸었다.' },
      { type: 'text', speaker: '', text: '우산 하나 아래.' },
      { type: 'text', speaker: '', text: '주작이 우산을 플레이어 쪽으로 기울였다.' },
      { type: 'text', speaker: '', text: '자기가 더 맞으면서.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"너도 맞잖아."' },
      { type: 'text', speaker: '', text: '"이쪽 덜 와요."' },
      { type: 'text', speaker: '', text: '거짓말이었다.' },
      { type: 'text', speaker: '', text: '플레이어가 우산을 도로 주작 쪽으로 기울였다.' },
      { type: 'text', speaker: '', text: '주작이 다시 기울였다.' },
      { type: 'text', speaker: '주작', text: '"당신이 중요하니까요."' },
      { type: 'text', speaker: '', text: '플레이어가 걸으면서 말했다.' },
      { type: 'text', speaker: '', text: '"너도 중요해."' },
      { type: 'text', speaker: '', text: '"당신이 더 중요해요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '주작이 대답하지 않았다.' },
      { type: 'text', speaker: '', text: '걸으면서.' },
      { type: 'text', speaker: '', text: '빗소리.' },
      { type: 'text', speaker: '', text: '"...이름 불러주는 사람이니까요."' },
      { type: 'text', speaker: '', text: '그게 대답이었다.' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 걸음을 늦췄다가 다시 걸었다.' },
      { type: 'text', speaker: '', text: '우산을 그냥 뒀다.' },
      { type: 'text', speaker: '', text: '주작이 기울인 대로.' },
      { type: 'text', speaker: '', text: '집에 돌아와서.' },
      { type: 'text', speaker: '', text: '주작이 수건을 가져왔다.' },
      { type: 'text', speaker: '주작', text: '"머리 닦아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '받아서 닦았다.' },
      { type: 'text', speaker: '', text: '"주작은?"' },
      { type: 'text', speaker: '', text: '"저는 괜찮아요."' },
      { type: 'text', speaker: '', text: '"머리 닦아."' },
      { type: 'text', speaker: '', text: '주작이 수건을 받았다.' },
      { type: 'text', speaker: '', text: '따뜻한 차를 마셨다.' },
      { type: 'text', speaker: '', text: '빗소리가 들렸다.' },
      { type: 'text', speaker: '', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"비 오는 날이요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"고아원에서는요. 비 오는 날 더 추웠어요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"지붕이 낡아서요. 물이 들어왔어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"담요가 젖으면 더 추워요."' },
      { type: 'text', speaker: '', text: '플레이어가 들었다.' },
      { type: 'text', speaker: '', text: '"여기 지붕은요."' },
      { type: 'text', speaker: '', text: '주작이 차를 마셨다.' },
      { type: 'text', speaker: '주작', text: '"안 샤요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"따뜻해요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"고마워요."' },
      { type: 'text', speaker: '', text: '"지붕에?"' },
      { type: 'text', speaker: '', text: '"지붕이 있는 사람한테요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"당신이 기준이니까요."' },
      { type: 'text', speaker: '', text: '비가 그친 날.' },
      { type: 'text', speaker: '', text: '물기가 마르면서, 무언가가 바뀌었다. 기다림이 끝나고, 움직일 차례가 온 것 같았다.' },
      { type: 'text', speaker: '', text: '탑 근처를 걸었다.' },
      { type: 'text', speaker: '', text: '훈련 겸.' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 피웠다 껐다 했다.' },
      { type: 'text', speaker: '', text: '연습.' },
      { type: 'text', speaker: '', text: '불꽃을 피우고. 꺼뜨리고. 다시 피우고. 크기를 조절하고.' },
      { type: 'text', speaker: '', text: '"많이 좋아졌네."' },
      { type: 'text', speaker: '', text: '"그래요?"' },
      { type: 'text', speaker: '', text: '"응. 전에는 그냥 피우고 끄는 게 전부였는데."' },
      { type: 'text', speaker: '', text: '"지금은요?"' },
      { type: 'text', speaker: '', text: '"조절해."' },
      { type: 'text', speaker: '', text: '"그게 달라요?"' },
      { type: 'text', speaker: '', text: '"많이 달라."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 봤다.' },
      { type: 'text', speaker: '', text: '손바닥 위에서.' },
      { type: 'text', speaker: '', text: '작게. 크게. 작게. 크게.' },
      { type: 'text', speaker: '', text: '"이게 제 거예요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름처럼요."' },
      { type: 'text', speaker: '', text: '"이름처럼?"' },
      { type: 'text', speaker: '', text: '"이름도 제 거잖아요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"아무도 뺏어갈 수 없는 것들이요."' },
      { type: 'text', speaker: '', text: '"불꽃이랑 이름이?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 불러줘서 더 제 거예요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"논리가 이상해."' },
      { type: 'text', speaker: '', text: '"이상해요?"' },
      { type: 'text', speaker: '', text: '"...논리는 이상한데."' },
      { type: 'text', speaker: '', text: '"맞죠?"' },
      { type: 'text', speaker: '', text: '"...맞는 것 같기도 해."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"맞아요."' },
      { type: 'text', speaker: '', text: '어느 날 주작이 탑 이야기를 꺼냈다.' },
      { type: 'text', speaker: '주작', text: '"이제 탑에 들어가도 될 것 같아요."' },
      { type: 'text', speaker: '', text: '"어느 정도 됐어?"' },
      { type: 'text', speaker: '', text: '"불꽃이 많이 커졌어요."' },
      { type: 'text', speaker: '', text: '불꽃을 보여줬다.' },
      { type: 'text', speaker: '', text: '손 전체를 감싸는 불꽃.' },
      { type: 'effect', effect: 'shake' },
      { type: 'combat', enemy: {"name":"폐허의 짐승","hp":90,"attack":11} },
      { type: 'text', speaker: '', text: '뜨겁고 안정적인.' },
      { type: 'text', speaker: '', text: '"탑이 뭔지 알아?"' },
      { type: 'text', speaker: '', text: '"아직 안 들어가봐서 몰라요."' },
      { type: 'text', speaker: '', text: '"들어가면 싸워야 해."' },
      { type: 'text', speaker: '', text: '"알아요. 훈련한 이유잖아요."' },
      { type: 'text', speaker: '', text: '"무섭지 않아?"' },
      { type: 'text', speaker: '', text: '주작이 잠깐 생각했다.' },
      { type: 'text', speaker: '주작', text: '"무서울 것 같아요."' },
      { type: 'text', speaker: '', text: '"그런데도?"' },
      { type: 'text', speaker: '', text: '"그런데도 해야 하는 것 같아요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"당신이랑 같이 알아가야 하는 거잖아요. 강해지는 것도. 탑도. 이유도."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"같이 알아가는 거라고 했잖아요. 처음에."' },
      { type: 'text', speaker: '', text: '"...응."' },
      { type: 'text', speaker: '', text: '"그러니까 같이 가요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"탑에."' },
      { type: 'text', speaker: '', text: '플레이어가 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '"가자."' },
      { type: 'text', speaker: '', text: '탑 입구.' },
      { type: 'text', speaker: '', text: '거대한 문이었다.' },
      { type: 'text', speaker: '', text: '낡고 오래된 문.' },
      { type: 'text', speaker: '', text: '돌로 된 문틀에 이끼가 끼어 있었다.' },
      { type: 'text', speaker: '', text: '오래된 냄새가 났다. 차갑고 습한 냄새.' },
      { type: 'text', speaker: '', text: '탑 앞에 서서 올려다봤다.' },
      { type: 'text', speaker: '', text: '끝이 보이지 않았다. 마치 하늘에 구멍이 뚫린 것처럼, 탑이 구름 속으로 사라져 있었다.' },
      { type: 'text', speaker: '', text: '주작이 목을 젖혔다.' },
      { type: 'text', speaker: '주작', text: '"몇 층이에요?"' },
      { type: 'text', speaker: '', text: '"모르겠어. 올라가봐야 알아."' },
      { type: 'text', speaker: '', text: '"그래요."' },
      { type: 'text', speaker: '', text: '주작이 손에 불꽃을 피웠다.' },
      { type: 'text', speaker: '', text: '확인했다.' },
      { type: 'text', speaker: '', text: '안정적이었다.' },
      { type: 'text', speaker: '', text: '흔들리지 않았다.' },
      { type: 'text', speaker: '', text: '"괜찮아요."' },
      { type: 'text', speaker: '', text: '플레이어가 문을 열었다.' },
      { type: 'text', speaker: '', text: '무거운 소리가 났다.' },
      { type: 'text', speaker: '', text: '돌이 돌에 닿는 소리.' },
      { type: 'text', speaker: '', text: '주작이 들어갔다.' },
      { type: 'text', speaker: '', text: '어두웠다.' },
      { type: 'text', speaker: '', text: '주작의 불꽃이 어둠을 조금 밀어냈다.' },
      { type: 'text', speaker: '', text: '붉은 빛이 벽을 물들였다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 뒤에서 따라왔다.' },
      { type: 'text', speaker: '', text: '항상 그랬듯이.' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '말없이.' },
      { type: 'text', speaker: '', text: '탑 1층은 별것 없었다.' },
      { type: 'text', speaker: '', text: '별것 없는데도 심장이 빨랐다. 처음이라서. 불꽃을 밝히자 벽 그림자가 흔들렸다. 손에 힘이 들어갔다.' },
      { type: 'text', speaker: '', text: '어두웠다.' },
      { type: 'text', speaker: '', text: '횃불이 몇 군데 있었지만 빛이 약했다.' },
      { type: 'text', speaker: '', text: '2층도 별것 없었다. 하지만 공기가 달랐다. 무겁고 눅눅한 기운이 피부를 눌렀다.' },
      { type: 'text', speaker: '', text: '벽에 뭔가 새겨져 있었다.' },
      { type: 'text', speaker: '', text: '글자 같은 것.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '주작', text: '"이게 뭐예요?"' },
      { type: 'text', speaker: '', text: '"모르겠어."' },
      { type: 'text', speaker: '', text: '주작이 손으로 벽을 짚었다.' },
      { type: 'text', speaker: '', text: '차가운 돌.' },
      { type: 'text', speaker: '', text: '오래된 냄새.' },
      { type: 'text', speaker: '', text: '글자 중 하나가 눈에 밟혔다. \'이름을 가진 자만이 꼭대기에 선다.\'' },
      { type: 'text', speaker: '', text: '"계속 가요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '3층에서 처음으로 적이 나왔다.' },
      { type: 'text', speaker: '', text: '주작이 앞으로 나갔다.' },
      { type: 'text', speaker: '', text: '플레이어가 뒤에 있었다.' },
      { type: 'effect', effect: 'system', text: '【전투 개시.】' },
      { type: 'text', speaker: '', text: '첫 번째 적.' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 날렸다.' },
      { type: 'text', speaker: '', text: '적이 피했다.' },
      { type: 'text', speaker: '', text: '빠르다. 원거리는 안 통한다.' },
      { type: 'text', speaker: '', text: '주작이 이를 악물었다. 훈련에서 배운 대로. 거리를 좁혔다. 두 발짝 만에 닿았다.' },
      { type: 'text', speaker: '', text: '근접.' },
      { type: 'text', speaker: '', text: '불꽃을 주먹에 감았다. 걷어찼다.' },
      { type: 'text', speaker: '', text: '공기가 갈라졌다.' },
      { type: 'text', speaker: '', text: '적이 쓰러졌다.' },
      { type: 'text', speaker: '', text: '두 번째 적.' },
      { type: 'text', speaker: '', text: '옆에서 왔다.' },
      { type: 'text', speaker: '', text: '주작이 돌아서며 불꽃으로 막았다.' },
      { type: 'text', speaker: '', text: '밀었다.' },
      { type: 'text', speaker: '', text: '불꽃이 적의 가슴을 훑고 지나가며, 벽에 검은 자국을 남겼다.' },
      { type: 'text', speaker: '', text: '적이 날아갔다.' },
      { type: 'effect', effect: 'system', text: '【전투 종료. 경험치 획득. 잔열 소모율: 12%. 유대 에너지 연동 확인. 근접 화염 적성: 양호. 유대 수치 효과: 이름 호명 시 신력 출력 15% 증가.】' },
      { type: 'text', speaker: '', text: '주작이 숨을 골랐다.' },
      { type: 'text', speaker: '', text: '손이 떨렸다. 처음 싸웠다. 진짜로. 훈련이 아니라 진짜로. 그런데 이상하게, 몸 안의 불꽃은 떨리지 않았다. 오히려 더 뜨겁게 타오르고 있었다.' },
      { type: 'text', speaker: '', text: '"괜찮아?"' },
      { type: 'text', speaker: '', text: '플레이어가 왔다.' },
      { type: 'text', speaker: '', text: '"응. 좀 이상해요."' },
      { type: 'text', speaker: '', text: '"어디?"' },
      { type: 'text', speaker: '', text: '"불꽃이요. 불꽃이 제 것인 것 같아요."' },
      { type: 'text', speaker: '', text: '"당연하지."' },
      { type: 'text', speaker: '', text: '"아니요. 제 불꽃이라는 게 실감난다고요."' },
      { type: 'text', speaker: '', text: '주작이 손을 봤다.' },
      { type: 'text', speaker: '', text: '불꽃이 피었다 꺼졌다 했다.' },
      { type: 'text', speaker: '', text: '"이게 제 이름 같아요."' },
      { type: 'text', speaker: '', text: '플레이어가 봤다.' },
      { type: 'text', speaker: '', text: '"주작의 불꽃이 제 이름 같아요."' },
      { type: 'text', speaker: '', text: '플레이어가 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '불꽃이 반짝했다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"봤죠?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름 부를 때마다 이래요."' },
      { type: 'text', speaker: '', text: '플레이어가 웃었다.' },
      { type: 'text', speaker: '', text: '주작이 그 웃음을 봤다.' },
      { type: 'text', speaker: '', text: '가슴이 이상하게 뛰었다.' },
      { type: 'text', speaker: '', text: '탑 3층을 클리어한 다음 날.' },
      { type: 'text', speaker: '', text: '주작이 손을 봤다.' },
      { type: 'text', speaker: '', text: '훈련 후.' },
      { type: 'text', speaker: '', text: '마당에 앉아서.' },
      { type: 'text', speaker: '', text: '손에서 불꽃을 피웠다.' },
      { type: 'text', speaker: '', text: '작게.' },
      { type: 'text', speaker: '', text: '크게.' },
      { type: 'text', speaker: '', text: '조절했다.' },
      { type: 'text', speaker: '', text: '더 강하게. 더 뜨겁게. 더 조용하게. 더 안정적으로.' },
      { type: 'text', speaker: '', text: '"잘하고 있어."' },
      { type: 'text', speaker: '', text: '플레이어가 말했다.' },
      { type: 'text', speaker: '', text: '주작이 돌아봤다.' },
      { type: 'text', speaker: '주작', text: '"봤어요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"보고 있었어요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 다시 손을 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신이 보고 있을 때요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"더 잘 되는 것 같아요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"봐주는 게 이름 같아요."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '불꽃을 껐다.' },
      { type: 'text', speaker: '', text: '"훈련 더 할게요."' },
      { type: 'text', speaker: '', text: '탑을 다녀온 날.' },
      { type: 'text', speaker: '', text: '주작이 저녁을 먹으면서 조용했다.' },
      { type: 'text', speaker: '주작', text: '"왜 그래?"' },
      { type: 'text', speaker: '', text: '"생각하고 있어요."' },
      { type: 'text', speaker: '', text: '"뭘?"' },
      { type: 'text', speaker: '', text: '"탑이요."' },
      { type: 'text', speaker: '', text: '주작이 밥을 먹었다.' },
      { type: 'text', speaker: '주작', text: '"탑이 뭔지 이제 좀 알 것 같아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"강한 것들이 있는 곳이에요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"근데요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"약한 사람들도 있었어요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"탑에 갇혀 있는 사람들이요."' },
      { type: 'text', speaker: '', text: '플레이어가 들었다.' },
      { type: 'text', speaker: '', text: '"강한 사람들한테 짓눌린 사람들이요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"고아원이랑 똑같았어요."' },
      { type: 'text', speaker: '', text: '주작이 국을 떴다.' },
      { type: 'text', speaker: '주작', text: '"이름 없이 불리던 사람들처럼요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"저 그 사람들을 보면 화가 나요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당연하죠?"' },
      { type: 'text', speaker: '', text: '"당연해."' },
      { type: 'text', speaker: '', text: '주작이 고개를 끄덕였다.' },
      { type: 'text', speaker: '주작', text: '"그럼 됐어요."' },
      { type: 'text', speaker: '', text: '밥을 다 먹었다.' },
      { type: 'text', speaker: '', text: '"다음에 그 사람들 또 있으면요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"제가 먼저 갈게요."' },
      { type: 'text', speaker: '', text: '밤이었다.' },
      { type: 'text', speaker: '', text: '주작이 방에서 나왔다.' },
      { type: 'text', speaker: '주작', text: '"잠이 안 와요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"자꾸 생각해서요."' },
      { type: 'text', speaker: '', text: '"뭘?"' },
      { type: 'text', speaker: '', text: '"당신이 어떤 사람인지요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '부엌.' },
      { type: 'text', speaker: '', text: '달빛이 들어왔다.' },
      { type: 'text', speaker: '', text: '차가운 달빛 아래.' },
      { type: 'text', speaker: '', text: '둘이 마주 앉았다.' },
      { type: 'text', speaker: '', text: '"결론이 뭔데?"' },
      { type: 'text', speaker: '', text: '"믿을 수 있는 사람."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"고아원에서 믿을 수 있는 사람이 없었어요. 항상 뺏어가거나 이용하거나."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신은 아니에요."' },
      { type: 'text', speaker: '', text: '"왜 그렇게 생각해?"' },
      { type: 'text', speaker: '', text: '주작이 대답했다.' },
      { type: 'text', speaker: '주작', text: '"이름 불러주는 사람이 나쁜 사람일 리 없어요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '"그게 근거야?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름이?"' },
      { type: 'text', speaker: '', text: '"이름이요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"이름을 부른다는 건요. 그 사람을 보고 있다는 거잖아요. 그 사람이 있다는 걸 안다는 거잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이 절 이름으로 불러요. 처음부터. 그게."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 멈췄다.' },
      { type: 'text', speaker: '주작', text: '"그게 믿음이에요."' },
      { type: 'text', speaker: '', text: '목소리가 떨렸다. 하지만 눈은 떨리지 않았다. 처음으로 확신을 말하는 아이의 눈이었다. 그 눈 속에 불꽃이 비쳤다. 작지만 꺼지지 않는. 고아원에서 사 년을 버틴 아이가, 버틴 게 아니라 기다린 거였다는 걸 알아버린 눈이었다. 플레이어의 심장이 한 박자 늦게 뛰었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 그걸 들었다.' },
      { type: 'text', speaker: '', text: '담장 위에서.' },
      { type: 'text', speaker: '', text: '플레이어 어깨 쪽을 봤다.' },
      { type: 'text', speaker: '', text: '그쪽에 앉고 싶은 것처럼.' },
      { type: 'text', speaker: '', text: '꼬리를 한 번 흔들었다가 멈췄다.' },
      { type: 'text', speaker: '', text: '그 자리에 그냥 있었다.' },
    ]
  },
  {
    title: '5장. 의존',
    nodes: [
      { type: 'text', speaker: '', text: '어느 여름 아침.' },
      { type: 'text', speaker: '', text: '주작이 혼자 마당에서 훈련을 하고 있었다.' },
      { type: 'text', speaker: '', text: '플레이어가 아직 나오지 않았을 때.' },
      { type: 'text', speaker: '', text: '혼자.' },
      { type: 'text', speaker: '', text: '목검을 들고.' },
      { type: 'text', speaker: '', text: '자세를 잡고.' },
      { type: 'text', speaker: '', text: '움직였다.' },
      { type: 'text', speaker: '', text: '발. 손목. 불꽃.' },
      { type: 'text', speaker: '', text: '하나씩.' },
      { type: 'text', speaker: '', text: '연습이었다.' },
      { type: 'text', speaker: '', text: '땀이 났다.' },
      { type: 'text', speaker: '', text: '여름 아침이라 뜨거웠다.' },
      { type: 'text', speaker: '', text: '이마에서 땀이 흘렀다.' },
      { type: 'text', speaker: '', text: '닦지 않았다.' },
      { type: 'text', speaker: '', text: '계속 했다.' },
      { type: 'text', speaker: '', text: '불꽃이 손에서 일었다.' },
      { type: 'text', speaker: '', text: '이상하게.' },
      { type: 'text', speaker: '', text: '이 불꽃이.' },
      { type: 'text', speaker: '', text: '내 거다.' },
      { type: 'text', speaker: '', text: '라는 게.' },
      { type: 'text', speaker: '', text: '오늘은 더 강하게 실감났다.' },
      { type: 'text', speaker: '', text: '내 불꽃.' },
      { type: 'text', speaker: '', text: '내 이름.' },
      { type: 'text', speaker: '', text: '주작의 불꽃.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '주작이 혼자 중얼거렸다.' },
      { type: 'text', speaker: '', text: '자기 이름을 불렀다.' },
      { type: 'text', speaker: '', text: '불꽃이 반짝했다.' },
      { type: 'text', speaker: '', text: '"봐요."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '당신이 가르쳐줬다.' },
      { type: 'text', speaker: '', text: '이름을 부르면 불꽃이 커진다는 걸.' },
      { type: 'text', speaker: '', text: '그래서 혼자서도 부를 수 있었다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '한 번 더 불렀다.' },
      { type: 'text', speaker: '', text: '불꽃이 또 반짝했다.' },
      { type: 'text', speaker: '', text: '뜨겁고 밝게.' },
      { type: 'text', speaker: '', text: '"...있어."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '', text: '자기한테.' },
      { type: 'text', speaker: '', text: '있어.' },
      { type: 'text', speaker: '', text: '주작이.' },
      { type: 'text', speaker: '', text: '있어.' },
      { type: 'text', speaker: '', text: '세 달이 지났다.' },
      { type: 'text', speaker: '', text: '여름이 왔다.' },
      { type: 'text', speaker: '', text: '뜨거운 여름.' },
      { type: 'text', speaker: '', text: '마당의 풀이 무성하게 자랐다.' },
      { type: 'text', speaker: '', text: '주작이 많이 컸다.' },
      { type: 'text', speaker: '', text: '키도 조금 컸다.' },
      { type: 'text', speaker: '', text: '불꽃도 많이 커졌다.' },
      { type: 'text', speaker: '', text: '탑을 오르면서 쌓인 것들이 있었다.' },
      { type: 'text', speaker: '', text: '경험. 싸움. 분노. 보호 본능.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '플레이어 없이는 불안해지는 마음.' },
      { type: 'text', speaker: '', text: '처음으로 알아챈 날.' },
      { type: 'text', speaker: '', text: '플레이어가 혼자 시내에 나갔다.' },
      { type: 'text', speaker: '', text: '볼일이 있다고 했다.' },
      { type: 'text', speaker: '', text: '주작이 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '같이 가도 되는데.' },
      { type: 'text', speaker: '', text: '말하지 않았다.' },
      { type: 'text', speaker: '', text: '네 시간이 지났다.' },
      { type: 'text', speaker: '', text: '주작이 마당에 있었다.' },
      { type: 'text', speaker: '', text: '왜소한 신과 둘이.' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '주작이 문 쪽을 봤다.' },
      { type: 'text', speaker: '', text: '여섯 시간이 됐다. 해가 기울고 있었다.' },
      { type: 'text', speaker: '', text: '주작이 마당을 왔다 갔다 했다.' },
      { type: 'text', speaker: '', text: '신이 주작을 따라 왔다 갔다 했다.' },
      { type: 'text', speaker: '', text: '주작이 돌아보면. 신이 돌아봤다.' },
      { type: 'text', speaker: '', text: '주작이 멈추면. 신이 멈췄다.' },
      { type: 'text', speaker: '', text: '문이 열렸다.' },
      { type: 'text', speaker: '', text: '플레이어가 들어왔다.' },
      { type: 'text', speaker: '', text: '신이 먼저 달려갔다.' },
      { type: 'text', speaker: '', text: '플레이어 발치에 탁 붙었다.' },
      { type: 'text', speaker: '', text: '발등 위에.' },
      { type: 'text', speaker: '', text: '주작도 달려갔다.' },
      { type: 'text', speaker: '', text: '"왜 이렇게 늦었어요?"' },
      { type: 'text', speaker: '', text: '"길이 막혔어."' },
      { type: 'text', speaker: '', text: '"다친 데 없어요?"' },
      { type: 'text', speaker: '', text: '"없어."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 위아래로 봤다.' },
      { type: 'text', speaker: '', text: '멀쩡했다.' },
      { type: 'text', speaker: '', text: '"...다행이에요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"기다렸어?"' },
      { type: 'text', speaker: '', text: '"여섯 시간."' },
      { type: 'text', speaker: '', text: '"마당에서?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"당신이 없으면 이상해서요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"이상하죠?"' },
      { type: 'text', speaker: '', text: '"아니야."' },
      { type: 'text', speaker: '', text: '"당신이 아니라고 하면 아닌 거예요."' },
      { type: 'text', speaker: '', text: '주작이 부엌으로 갔다.' },
      { type: 'text', speaker: '주작', text: '"밥 만들었어요. 식기 전에 먹어요."' },
      { type: 'text', speaker: '', text: '어느 날.' },
      { type: 'text', speaker: '', text: '주작이 시장을 혼자 다녀오다가.' },
      { type: 'text', speaker: '', text: '아는 얼굴을 봤다.' },
      { type: 'text', speaker: '', text: '미나였다.' },
      { type: 'text', speaker: '', text: '"언니!"' },
      { type: 'text', speaker: '', text: '미나가 달려왔다.' },
      { type: 'text', speaker: '', text: '주작이 무릎을 꿇었다.' },
      { type: 'text', speaker: '주작', text: '"미나야."' },
      { type: 'text', speaker: '', text: '"언니다."' },
      { type: 'text', speaker: '', text: '"응. 왔어."' },
      { type: 'text', speaker: '', text: '미나가 주작의 얼굴을 들여다봤다.' },
      { type: 'text', speaker: '', text: '"살쪘어요."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"밥 많이 먹어."' },
      { type: 'text', speaker: '', text: '미나가 눈을 빛냈다.' },
      { type: 'text', speaker: '', text: '"언니 또 와요?"' },
      { type: 'text', speaker: '', text: '"응. 올게."' },
      { type: 'text', speaker: '', text: '"약속?"' },
      { type: 'text', speaker: '', text: '"약속."' },
      { type: 'text', speaker: '', text: '미나가 주작의 손을 잡았다.' },
      { type: 'text', speaker: '', text: '작고 따뜻한 손.' },
      { type: 'text', speaker: '', text: '"이름 잊지 말아요."' },
      { type: 'text', speaker: '', text: '"알아."' },
      { type: 'text', speaker: '', text: '"주작이에요."' },
      { type: 'text', speaker: '주작', text: '"알아, 미나야."' },
      { type: 'text', speaker: '', text: '미나가 웃었다.' },
      { type: 'text', speaker: '', text: '선생님이 미나를 불렀다.' },
      { type: 'text', speaker: '', text: '"가봐."' },
      { type: 'text', speaker: '', text: '미나가 달려갔다.' },
      { type: 'text', speaker: '', text: '작은 발.' },
      { type: 'text', speaker: '', text: '뛰어가는 뒷모습.' },
      { type: 'text', speaker: '', text: '주작이 그걸 봤다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '그리고 돌아서서 걸었다.' },
      { type: 'text', speaker: '', text: '집으로.' },
      { type: 'text', speaker: '', text: '그날 저녁.' },
      { type: 'text', speaker: '', text: '주작이 플레이어한테 말했다.' },
      { type: 'text', speaker: '주작', text: '"미나를 봤어요."' },
      { type: 'text', speaker: '', text: '"미나가 누구야?"' },
      { type: 'text', speaker: '', text: '"고아원에서요. 제 이름을 처음으로 불러준 아이요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"잘 있었어요."' },
      { type: 'text', speaker: '', text: '"다행이네."' },
      { type: 'text', speaker: '', text: '주작이 조용했다.' },
      { type: 'text', speaker: '주작', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 아니었으면요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"저 거기서 계속 야, 거기, 로 살았을 거예요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"제가 주작인 게 됐어요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"계속이 아니면 이름이 아닌 것 같아요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 차를 한 모금 마셨다.' },
      { type: 'text', speaker: '', text: '탑 5층.' },
      { type: 'text', speaker: '', text: '그날이었다.' },
      { type: 'text', speaker: '', text: '주작이 처음으로 분노를 느낀 날.' },
      { type: 'text', speaker: '', text: '5층 안.' },
      { type: 'text', speaker: '', text: '어두운 층이었다.' },
      { type: 'text', speaker: '', text: '소리가 먼저 들렸다.' },
      { type: 'text', speaker: '', text: '낮은 웃음소리.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '작은 울음소리.' },
      { type: 'text', speaker: '', text: '주작이 멈췄다.' },
      { type: 'text', speaker: '', text: '구석에 사람들이 있었다.' },
      { type: 'text', speaker: '', text: '강한 자들이 약한 자들을 몰아붙이고 있었다.' },
      { type: 'text', speaker: '', text: '벽에 등을 붙이고. 고개를 숙이고. 무릎을 끌어안고.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '', text: '심장이 쿵 내려앉았다.' },
      { type: 'text', speaker: '', text: '저 사람들.' },
      { type: 'text', speaker: '', text: '이름이 없을 것 같았다.' },
      { type: 'text', speaker: '', text: '야. 거기. 저거.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '플레이어가 불렀다.' },
      { type: 'text', speaker: '', text: '"들어갈 거야?"' },
      { type: 'text', speaker: '', text: '"들어가요."' },
      { type: 'text', speaker: '', text: '주작이 달려갔다.' },
      { type: 'effect', effect: 'system', text: '【전투 개시.】' },
      { type: 'text', speaker: '', text: '칼을 든 놈이 먼저 왔다. 빠르고 가벼운 놈이었다.' },
      { type: 'text', speaker: '', text: '주작이 피했다.' },
      { type: 'text', speaker: '', text: '옆으로.' },
      { type: 'text', speaker: '', text: '불꽃이 손에서 일었다.' },
      { type: 'text', speaker: '', text: '강하게.' },
      { type: 'text', speaker: '', text: '분노가 끌어올렸다.' },
      { type: 'text', speaker: '', text: '주먹에 불꽃을 담아 쳤다.' },
      { type: 'text', speaker: '', text: '적이 날아갔다.' },
      { type: 'text', speaker: '', text: '도끼를 든 놈이 뒤에서 왔다. 한 방이 무거웠다.' },
      { type: 'text', speaker: '', text: '돌아서며 발을 걸었다.' },
      { type: 'text', speaker: '', text: '넘어졌다.' },
      { type: 'text', speaker: '', text: '불꽃 연속 타격.' },
      { type: 'text', speaker: '', text: '쓰러졌다.' },
      { type: 'text', speaker: '', text: '세 번째는 대장이었다. 갑옷을 입고 있었다. 불꽃이 쉽게 안 통했다.' },
      { type: 'text', speaker: '', text: '주작이 맞았다.' },
      { type: 'text', speaker: '', text: '뒤로 두 걸음.' },
      { type: 'text', speaker: '', text: '옆구리.' },
      { type: 'text', speaker: '', text: '숨이 막혔다.' },
      { type: 'text', speaker: '', text: '이를 악물었다.' },
      { type: 'text', speaker: '', text: '저 사람들이 저기 있다.' },
      { type: 'text', speaker: '', text: '이름 없이.' },
      { type: 'text', speaker: '', text: '주작이 눈을 감았다.' },
      { type: 'text', speaker: '', text: '한 번 숨을 쉬었다.' },
      { type: 'text', speaker: '', text: '그리고 떴다.' },
      { type: 'text', speaker: '', text: '주작의 불꽃이 폭발했다.' },
      { type: 'text', speaker: '', text: '손에서. 팔에서. 전신에서.' },
      { type: 'text', speaker: '', text: '불꽃이 뜨겁고 강하게 터졌다.' },
      { type: 'text', speaker: '', text: '세 번째 적이 쓰러졌다.' },
      { type: 'text', speaker: '', text: '마지막 놈은 활을 든 저격수였다. 도망가려 했다.' },
      { type: 'text', speaker: '', text: '주작이 불꽃으로 길을 막았다.' },
      { type: 'text', speaker: '주작', text: '"항복해요."' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '하지만 뜨겁게. 잔열이 공기를 일그러뜨렸다.' },
      { type: 'text', speaker: '', text: '적이 무기를 내렸다.' },
      { type: 'effect', effect: 'system', text: '【전투 종료. 경험치 획득. 화염 적성 B→A 승격. 잔열 폭주 임계치 78%. 경고: 감정 기반 출력은 제어 불능 위험. 폭주 후 24시간 쿨다운 권장.】' },
      { type: 'text', speaker: '', text: '숨을 골랐다.' },
      { type: 'text', speaker: '', text: '가슴이 뛰었다.' },
      { type: 'text', speaker: '', text: '불꽃이 아직 손에서 타오르고 있었다.' },
      { type: 'text', speaker: '', text: '손이 떨렸다. 불꽃이 꺼지지 않았다. 끄려고 하는데 안 꺼졌다.' },
      { type: 'text', speaker: '', text: '불꽃이 조금 줄었다.' },
      { type: 'text', speaker: '', text: '약자들이 나왔다.' },
      { type: 'text', speaker: '', text: '주작이 그들을 봤다.' },
      { type: 'text', speaker: '주작', text: '"괜찮아요?"' },
      { type: 'text', speaker: '', text: '"네. 당신은요?"' },
      { type: 'text', speaker: '', text: '주작의 팔에서 피가 났다.' },
      { type: 'text', speaker: '', text: '"조금 다쳤어요."' },
      { type: 'text', speaker: '', text: '"이름이 뭐예요?"' },
      { type: 'text', speaker: '', text: '주작이 물었다.' },
      { type: 'text', speaker: '', text: '사람들이 서로 봤다.' },
      { type: 'text', speaker: '', text: '이름이 있었다.' },
      { type: 'text', speaker: '', text: '하나씩 말했다.' },
      { type: 'text', speaker: '', text: '주작이 들었다.' },
      { type: 'text', speaker: '', text: '하나씩.' },
      { type: 'text', speaker: '', text: '"그거예요. 그 이름이에요."' },
      { type: 'text', speaker: '', text: '웃었다.' },
      { type: 'text', speaker: '', text: '"그 이름으로 불려요. 누군가가 이름으로 안 불러줘도. 스스로 그 이름이에요."' },
      { type: 'text', speaker: '', text: '플레이어가 다가왔다.' },
      { type: 'text', speaker: '', text: '"팔."' },
      { type: 'text', speaker: '', text: '"조금이에요."' },
      { type: 'text', speaker: '', text: '"많이 났어."' },
      { type: 'text', speaker: '', text: '플레이어가 응급 처치를 했다.' },
      { type: 'text', speaker: '', text: '빠르게.' },
      { type: 'text', speaker: '', text: '당황한 손으로.' },
      { type: 'text', speaker: '', text: '주작이 그 손을 봤다.' },
      { type: 'text', speaker: '', text: '다친 게 싫은 손.' },
      { type: 'text', speaker: '', text: '"걱정해요?"' },
      { type: 'text', speaker: '', text: '"당연하지."' },
      { type: 'text', speaker: '', text: '"저 다쳐도 돼요. 저보다 저 사람들이—"' },
      { type: 'text', speaker: '', text: '"너도 다치면 안 돼."' },
      { type: 'text', speaker: '', text: '주작이 멈췄다.' },
      { type: 'text', speaker: '주작', text: '"당신한테도 저 중요해요?"' },
      { type: 'text', speaker: '', text: '"당연하지."' },
      { type: 'text', speaker: '', text: '주작의 눈이 흔들렸다.' },
      { type: 'text', speaker: '', text: '"그게 이상하게 당연하지 않아서요."' },
      { type: 'text', speaker: '', text: '플레이어가 처치를 마치고 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"고아원에서 네가 중요하다고 한 사람 없었지."' },
      { type: 'text', speaker: '', text: '"...응."' },
      { type: 'text', speaker: '', text: '"여기선 있어."' },
      { type: 'text', speaker: '', text: '주작이 잠시 말이 없었다.' },
      { type: 'text', speaker: '', text: '오래.' },
      { type: 'text', speaker: '', text: '아주 오래 말이 없었다.' },
      { type: 'text', speaker: '', text: '그러다가 조용히 말했다.' },
      { type: 'text', speaker: '', text: '"...당신 좋아요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '주작이 눈을 빠르게 깜박였다.' },
      { type: 'text', speaker: '', text: '뺨이 빨개졌다.' },
      { type: 'text', speaker: '', text: '불꽃이 반짝했다.' },
      { type: 'text', speaker: '', text: '손에서.' },
      { type: 'text', speaker: '', text: '아주 강하게.' },
      { type: 'text', speaker: '', text: '잠깐.' },
      { type: 'text', speaker: '', text: '그리고 조용해졌다.' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '잠시 후.' },
      { type: 'text', speaker: '', text: '"나도."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"너 중요해."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"...알아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 말해줘서 더 알아요."' },
      { type: 'text', speaker: '', text: '집으로 돌아오는 길.' },
      { type: 'text', speaker: '', text: '저녁 무렵이었다.' },
      { type: 'text', speaker: '', text: '하늘이 붉게 물들었다.' },
      { type: 'text', speaker: '', text: '주작이 걸으면서 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '붉었다.' },
      { type: 'text', speaker: '', text: '주작성처럼.' },
      { type: 'text', speaker: '', text: '"당신은요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"당신은 누구한테 감사한 사람 있어요?"' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '"있어."' },
      { type: 'text', speaker: '', text: '"누구요?"' },
      { type: 'text', speaker: '', text: '"...아직 잘 모르겠어."' },
      { type: 'text', speaker: '', text: '"그때 말해줘요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '왜소한 신이 뒤에서 따라왔다.' },
      { type: 'text', speaker: '', text: '주작의 발치 가까이.' },
      { type: 'text', speaker: '', text: '주작이 돌아봤다.' },
      { type: 'text', speaker: '주작', text: '"당신도요."' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"농담이에요."' },
      { type: 'text', speaker: '', text: '걸었다.' },
      { type: 'text', speaker: '', text: '셋이.' },
      { type: 'text', speaker: '', text: '저녁 하늘 아래.' },
      { type: 'text', speaker: '', text: '그날 밤.' },
      { type: 'text', speaker: '', text: '주작이 창문을 열었다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '주작성이 보였다.' },
      { type: 'text', speaker: '', text: '붉고 밝게.' },
      { type: 'text', speaker: '', text: '주작이 손을 들었다.' },
      { type: 'text', speaker: '', text: '손가락 끝에서 불꽃이 피었다.' },
      { type: 'text', speaker: '', text: '작고 붉은.' },
      { type: 'text', speaker: '', text: '별처럼.' },
      { type: 'text', speaker: '', text: '바람이 불었다.' },
      { type: 'text', speaker: '', text: '봄에서 여름으로 넘어가는 바람.' },
      { type: 'text', speaker: '', text: '따뜻하고 부드러운.' },
      { type: 'text', speaker: '', text: '주작은 그 바람을 맞으면서 오래 서 있었다.' },
      { type: 'text', speaker: '', text: '불꽃이 꺼지지 않았다.' },
      { type: 'text', speaker: '', text: '훈련이 석 달째가 됐다.' },
      { type: 'text', speaker: '', text: '어느 저녁.' },
      { type: 'text', speaker: '', text: '주작이 혼자 마당에서 연습하고 있었다.' },
      { type: 'text', speaker: '', text: '목검을 들고.' },
      { type: 'text', speaker: '', text: '플레이어가 옆에서 봤다.' },
      { type: 'text', speaker: '', text: '자세가 안정됐다. 발이 정확했다. 불꽃이 손에서 자연스럽게 흘렀다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"잠깐 쉬어."' },
      { type: 'text', speaker: '', text: '주작이 목검을 내렸다.' },
      { type: 'text', speaker: '', text: '마당에 앉았다.' },
      { type: 'text', speaker: '', text: '"물 마셔."' },
      { type: 'text', speaker: '', text: '플레이어가 물을 가져왔다.' },
      { type: 'text', speaker: '', text: '주작이 받아서 마셨다.' },
      { type: 'text', speaker: '주작', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신 피곤해요?"' },
      { type: 'text', speaker: '', text: '"아니."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"눈이 무거워요."' },
      { type: 'text', speaker: '', text: '"...들켰네."' },
      { type: 'text', speaker: '', text: '"왜 숨겨요?"' },
      { type: 'text', speaker: '', text: '"훈련 끊기게 하기 싫어서."' },
      { type: 'text', speaker: '', text: '주작이 고개를 저었다.' },
      { type: 'text', speaker: '주작', text: '"당신이 힘들면요. 저도 힘들어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"오늘은 일찍 자요."' },
      { type: 'text', speaker: '', text: '주작이 일어나면서 말했다.' },
      { type: 'text', speaker: '주작', text: '"잘 자요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 방으로 들어갔다.' },
      { type: 'text', speaker: '', text: '플레이어가 혼자 마당에 남았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 어느새 담장 위에 있었다.' },
      { type: 'text', speaker: '', text: '꼬리를 살짝 흔들었다.' },
      { type: 'text', speaker: '', text: '여름이 깊어졌을 무렵.' },
      { type: 'text', speaker: '', text: '밤에 주작이 방에서 나왔다.' },
      { type: 'text', speaker: '', text: '더워서.' },
      { type: 'text', speaker: '', text: '마당에 나왔다.' },
      { type: 'text', speaker: '', text: '밤바람이 불었다.' },
      { type: 'text', speaker: '', text: '주작이 마당에 앉았다.' },
      { type: 'text', speaker: '', text: '별이 보였다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
