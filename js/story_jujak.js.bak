      { type: 'text', speaker: '', text: '플레이어가 생각했다.' },
      { type: 'text', speaker: '', text: '"지금은 좋아."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"여기 있잖아."' },
      { type: 'text', speaker: '', text: '주작이 멈췄다.' },
      { type: 'text', speaker: '주작', text: '"당신이요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 다시 걸었다.' },
      { type: 'text', speaker: '', text: '뺨이 살짝 빨개졌다.' },
      { type: 'text', speaker: '', text: '"그거 이상한 말이에요."' },
      { type: 'text', speaker: '', text: '"이상해?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '주작이 걸으면서 말했다.' },
      { type: 'text', speaker: '주작', text: '"저도 같은 말 하고 싶었거든요."' },
      { type: 'text', speaker: '', text: '"뭐가."' },
      { type: 'text', speaker: '', text: '"이 세계가 좋은 이유가 당신이라고요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '주작이 앞을 봤다.' },
      { type: 'text', speaker: '주작', text: '"근데 당신이 먼저 말하면 이상하잖아요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"이상하잖아요. 그냥."' },
      { type: 'text', speaker: '', text: '플레이어가 웃었다.' },
      { type: 'text', speaker: '', text: '주작이 그 웃음 소리를 들었다.' },
      { type: 'text', speaker: '', text: '뺨이 더 빨개졌다.' },
      { type: 'text', speaker: '', text: '"웃지 말아요."' },
      { type: 'text', speaker: '', text: '"왜."' },
      { type: 'text', speaker: '', text: '"이상해서요."' },
      { type: 'text', speaker: '', text: '"이상하지 않아."' },
      { type: 'text', speaker: '', text: '"이상해요."' },
      { type: 'text', speaker: '', text: '두 사람이 걸었다.' },
      { type: 'text', speaker: '', text: '웃음 소리가 마당에 남았다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"저도 여름 좋아요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"당신이 여름이어서요."' },
      { type: 'text', speaker: '', text: '"그게 무슨 말이야."' },
      { type: 'text', speaker: '', text: '"처음 왔을 때가 여름이었잖아요. 여름에 당신이 왔잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그러니까 여름이 당신이에요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"봄은?"' },
      { type: 'text', speaker: '', text: '"봄은요."' },
      { type: 'text', speaker: '', text: '주작이 생각했다.' },
      { type: 'text', speaker: '주작', text: '"미나요. 처음 이름 불러준 사람이 봄 같으니까요."' },
      { type: 'text', speaker: '', text: '"가을은?"' },
      { type: 'text', speaker: '', text: '"가을은 아직 모르겠어요. 이제 오려는 계절이니까요."' },
      { type: 'text', speaker: '', text: '"겨울은?"' },
      { type: 'text', speaker: '', text: '"고아원이요."' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"추웠어?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"많이?"' },
      { type: 'text', speaker: '', text: '"많이요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"담요가 없는 날도 있었어요. 밥이 없는 날도 있었어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그런데 지금은."' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '주작', text: '"여름이에요."' },
