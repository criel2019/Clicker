      { type: 'text', speaker: '', text: '더 밝게.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '주작이 별에게 말했다.' },
      { type: 'text', speaker: '주작', text: '"여기 있어요."' },
      { type: 'text', speaker: '', text: '별이 빛났다.' },
      { type: 'text', speaker: '', text: '"잘 살고 있어요."' },
      { type: 'text', speaker: '', text: '별이 빛났다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 어느새 주작 옆에 와 있었다.' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '"당신도 별이 있어요?"' },
      { type: 'text', speaker: '', text: '신이 대답하지 않았다.' },
      { type: 'text', speaker: '', text: '"이름이 있으면 별도 있어요."' },
      { type: 'text', speaker: '', text: '주작이 신을 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신 이름을 찾으면요. 별도 찾게 될 거예요."' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '그러더니 슬쩍.' },
      { type: 'text', speaker: '', text: '주작 쪽으로 다가왔다.' },
      { type: 'text', speaker: '', text: '발치에 앉았다.' },
      { type: 'text', speaker: '', text: '"고마워요."' },
      { type: 'text', speaker: '', text: '별이 빛났다.' },
      { type: 'text', speaker: '', text: '밤이 깊어졌다.' },
      { type: 'text', speaker: '', text: '그래도.' },
      { type: 'text', speaker: '', text: '둘이.' },
      { type: 'text', speaker: '', text: '별을 봤다.' },
      { type: 'text', speaker: '', text: '어느 날 밤.' },
      { type: 'text', speaker: '', text: '주작이 방에서 나왔다.' },
      { type: 'text', speaker: '주작', text: '"잠이 안 와요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"아까 5층 그 사람들이요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름 없이 사는 것들요."' },
      { type: 'text', speaker: '', text: '플레이어가 들었다.' },
      { type: 'text', speaker: '', text: '"이름을 말하는 게 무서웠던 것 같아요. 그 사람들."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"이름을 말하면 그 이름이 가져가질 것 같아서요."' },
      { type: 'text', speaker: '', text: '"이름은 뺏길 수 없어."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '주작이 고개를 들었다.' },
      { type: 'text', speaker: '주작', text: '"당신이 불러줘서 알아요."' },
      { type: 'text', speaker: '', text: '불꽃이 손에서 일었다.' },
      { type: 'text', speaker: '', text: '"이름이 있다는 게 실감나요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '불꽃이 반짝했다.' },
      { type: 'text', speaker: '', text: '"고마워요."' },
      { type: 'text', speaker: '', text: '"또 감사해?"' },
      { type: 'text', speaker: '', text: '"이번엔 감사 말고요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"그냥 고마워요. 있어줘서요. 여기에."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '주작이 잠깐 눈을 피했다.' },
      { type: 'text', speaker: '주작', text: '"...이상한 소리 했죠?"' },
      { type: 'text', speaker: '', text: '"아니야."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"그것도 고마워요."' },
      { type: 'text', speaker: '', text: '5장이 끝나기 전의 마지막 밤.' },
      { type: 'text', speaker: '', text: '주작이 이불을 끌어안고 누웠다.' },
      { type: 'text', speaker: '', text: '창문 너머로 별이 보였다.' },
      { type: 'text', speaker: '', text: '주작성.' },
      { type: 'text', speaker: '', text: '붉고 밝은 별.' },
      { type: 'text', speaker: '', text: '주작이 손을 들었다.' },
      { type: 'text', speaker: '', text: '손바닥 위에 불꽃이 피었다. 별빛과 같은 색이었다.' },
      { type: 'text', speaker: '', text: '주작은 가슴 안에서 뭔가가 번지는 걸, 아직은 몰랐다.' },
      { type: 'text', speaker: '', text: '좋았다.' },
      { type: 'text', speaker: '', text: '그것만 알았다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '주작이 혼자 중얼거렸다.' },
      { type: 'text', speaker: '', text: '자기 이름을 불렀다.' },
      { type: 'text', speaker: '', text: '이번엔 쓸쓸하지 않았다.' },
      { type: 'text', speaker: '', text: '이름 뒤에.' },
      { type: 'text', speaker: '', text: '당신이 있었다.' },
      { type: 'text', speaker: '', text: '눈을 감았다.' },
      { type: 'text', speaker: '', text: '별이 빛났다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘에서.' },
      { type: 'text', speaker: '', text: '오늘도.' },
      { type: 'text', speaker: '', text: '내일도.' },
      { type: 'text', speaker: '', text: '당신이 부를 때까지.' },
      { type: 'text', speaker: '', text: '그 마지막 밤.' },
      { type: 'text', speaker: '', text: '왜소한 신이 마당 담장 위에 있었다.' },
      { type: 'text', speaker: '', text: '주작의 방을 봤다.' },
      { type: 'text', speaker: '', text: '불빛이 켜져 있었다.' },
      { type: 'text', speaker: '', text: '신이 담장 위에서 방 쪽을 봤다.' },
      { type: 'text', speaker: '', text: '오래 봤다.' },
      { type: 'text', speaker: '', text: '그러다가.' },
      { type: 'text', speaker: '', text: '내려왔다.' },
      { type: 'text', speaker: '', text: '마당으로.' },
      { type: 'text', speaker: '', text: '주작 방 앞으로.' },
      { type: 'text', speaker: '', text: '슬금슬금.' },
      { type: 'text', speaker: '', text: '방 앞에 앉았다.' },
      { type: 'text', speaker: '', text: '그냥 거기 있었다.' },
      { type: 'text', speaker: '', text: '한참 뒤.' },
      { type: 'text', speaker: '', text: '방 안의 불빛이 꺼졌다.' },
      { type: 'text', speaker: '', text: '신이 일어서려 했다.' },
      { type: 'text', speaker: '', text: '그때 방 안에서 소리가 들렸다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '잠꼬대였다.' },
      { type: 'text', speaker: '', text: '신이 멈췄다.' },
      { type: 'text', speaker: '', text: '"...응."' },
      { type: 'text', speaker: '', text: '작게.' },
      { type: 'text', speaker: '', text: '그냥 서 있었다.' },
      { type: 'text', speaker: '', text: '그리고 천천히.' },
      { type: 'text', speaker: '', text: '마당 한가운데로 갔다.' },
      { type: 'text', speaker: '', text: '별을 봤다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '주작성.' },
      { type: 'text', speaker: '', text: '밝게 빛났다.' },
      { type: 'text', speaker: '', text: '그리고.' },
      { type: 'text', speaker: '', text: '플레이어가 있는 방 쪽으로 걸어갔다.' },
      { type: 'text', speaker: '', text: '문 앞에 앉았다.' },
      { type: 'text', speaker: '', text: '거기서.' },
      { type: 'text', speaker: '', text: '밤을 보냈다.' },
      { type: 'text', speaker: '', text: '상권 끝.' },
      { type: 'text', speaker: '', text: '붉은 새.' },
      { type: 'text', speaker: '', text: '아직 날지 않은.' },
      { type: 'text', speaker: '', text: '하지만 날고자 하는.' },
      { type: 'text', speaker: '', text: '이름이 불려야 비로소 살아있는.' },
      { type: 'text', speaker: '', text: '그 새가.' },
      { type: 'text', speaker: '', text: '당신 곁에서 조금씩.' },
      { type: 'text', speaker: '', text: '날개를 펼치고 있었다.' },
      { type: 'text', speaker: '', text: '그리고 그 불꽃이 언젠가 당신을 삼킬 수도 있다는 걸, 아직은 아무도 몰랐다.' },
    ]
