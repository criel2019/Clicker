      { type: 'text', speaker: '', text: '그래도.' },
      { type: 'text', speaker: '', text: '기억할 거다.' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '마당으로 나왔다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 있었다.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '주작', text: '"봤죠?"' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"봤잖아요."' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"이름을 부르려 했잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"주—"' },
      { type: 'text', speaker: '', text: '주작이 입 모양을 따라 해봤다.' },
      { type: 'text', speaker: '주작', text: '"주작. 제 이름이잖아요."' },
      { type: 'text', speaker: '', text: '신이 조용히 있었다.' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '주작', text: '"이름 부르려다 못 불렀어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"못 불렀는데."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"괜찮아요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"찾아가면 불러줄 거니까요."' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"찾아가면."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"찾아가서 이름 불러달라고 하면."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"불러줄 거니까요."' },
      { type: 'text', speaker: '', text: '주작이 눈을 닦았다.' },
      { type: 'text', speaker: '', text: '눈물이 났는지 안 났는지.' },
      { type: 'text', speaker: '', text: '모르겠지만.' },
      { type: 'text', speaker: '', text: '어쨌든 닦았다.' },
      { type: 'text', speaker: '', text: '"그러니까 괜찮아요."' },
      { type: 'text', speaker: '', text: '주작이 신 앞에 섰다.' },
      { type: 'text', speaker: '주작', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이 말 안 하는 거 알아요."' },
      { type: 'text', speaker: '', text: '신이 봤다.' },
      { type: 'text', speaker: '', text: '"이유가 있는 거 알아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그래도 물어볼게요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신 이름이 뭐예요?"' },
      { type: 'text', speaker: '', text: '신이 입을 열지 않았다.' },
      { type: 'text', speaker: '', text: '"모르는 거잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"언젠가 알게 될 거예요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"이름은요. 잃어도 어딘가에 있어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"제가 고아원에서 야, 거기, 저거 이런 것들로 불렸어도. 주작은 항상 있었거든요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신 이름도 항상 어딘가에 있어요."' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '주작이 신을 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신은요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"항상 있었잖아요."' },
      { type: 'text', speaker: '', text: '신이 봤다.' },
      { type: 'text', speaker: '', text: '"처음부터."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"탑에서도. 집에서도. 마당에서도. 항상 거기 있었잖아요."' },
      { type: 'text', speaker: '', text: '신이 아무 말도 안 했다.' },
      { type: 'text', speaker: '', text: '"아무 말 안 해도요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"봐줬잖아요. 항상."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그게 감사해요."' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '뭔가 말하려는 것 같은 눈.' },
      { type: 'text', speaker: '', text: '하지만 입은 열리지 않았다.' },
      { type: 'text', speaker: '', text: '주작이 그걸 봤다.' },
      { type: 'text', speaker: '주작', text: '"말 안 해도 알아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"저도 말 못 할 때 있었거든요. 고아원에서요. 말해도 들어주는 사람이 없으면 말이 안 나와요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"근데 봐줄 때 있었어요. 딱 한 명이요. 미나요."' },
      { type: 'text', speaker: '', text: '신이 봤다.' },
      { type: 'text', speaker: '', text: '"봐주는 사람이 있으면."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"말할 수 있게 돼요. 언젠가."' },
      { type: 'text', speaker: '', text: '신이 그러더니 슬며시.' },
      { type: 'text', speaker: '', text: '주작 발치로 다가왔다.' },
      { type: 'text', speaker: '', text: '발 위에 앉았다.' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '무겁지 않게.' },
      { type: 'text', speaker: '', text: '그냥 거기 있었다.' },
      { type: 'text', speaker: '', text: '주작이 내려봤다.' },
      { type: 'text', speaker: '주작', text: '"어? 당신 여기 있어요?"' },
      { type: 'text', speaker: '', text: '신이 고개를 돌렸다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"고집이 세네요."' },
      { type: 'text', speaker: '', text: '주작이 마당 한가운데 섰다.' },
      { type: 'text', speaker: '', text: '눈을 감았다.' },
      { type: 'text', speaker: '', text: '기억이 쏟아졌다.' },
      { type: 'text', speaker: '', text: '밥 소리. 국자 소리. 숟가락이 그릇에 닿는 소리. 맛있다고 했던 당신 목소리. 훈련하면서 목검이 부딪치는 소리. 탑의 어둠 속에서 뒤에서 들리던 주작. 시장에서 리본을 고르던 손. 별을 보던 밤, 어깨가 닿던 거리.' },
      { type: 'text', speaker: '', text: '전부 당신이었다.' },
      { type: 'text', speaker: '', text: '그리고 이름.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '당신이 부르는 이름.' },
      { type: 'text', speaker: '', text: '불꽃이 쏟아졌다.' },
      { type: 'text', speaker: '', text: '전신에서.' },
      { type: 'text', speaker: '', text: '마당이 환해졌다. 붉은 빛이 마당 가득 찼다.' },
      { type: 'text', speaker: '', text: '주작이 눈을 떴다.' },
      { type: 'text', speaker: '', text: '눈물이 있었다. 닦지 않았다.' },
      { type: 'text', speaker: '', text: '불꽃 속에서 울었다.' },
      { type: 'text', speaker: '', text: '울어도 됐다. 기억이 끝나지 않을 거니까.' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 피웠다.' },
      { type: 'text', speaker: '', text: '손에서.' },
      { type: 'text', speaker: '', text: '뜨겁고 완전한 불꽃.' },
      { type: 'text', speaker: '', text: '각성한 불꽃.' },
      { type: 'text', speaker: '', text: '날개를 폈다.' },
      { type: 'text', speaker: '', text: '불꽃으로 된 날개.' },
      { type: 'text', speaker: '', text: '크고 붉은.' },
      { type: 'text', speaker: '', text: '"찾아갈게요."' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신이 날 찾아왔잖아요."' },
      { type: 'text', speaker: '', text: '불꽃이 강해졌다.' },
      { type: 'text', speaker: '', text: '"이번엔 제가 찾아갈게요."' },
      { type: 'text', speaker: '', text: '날개가 펼쳐졌다.' },
      { type: 'text', speaker: '', text: '"어디 있든."' },
      { type: 'text', speaker: '', text: '하늘로 오르려는 순간.' },
      { type: 'text', speaker: '', text: '멈췄다.' },
      { type: 'text', speaker: '', text: '"아."' },
      { type: 'text', speaker: '', text: '주작이 뒤를 봤다.' },
      { type: 'text', speaker: '', text: '빈 마당.' },
      { type: 'text', speaker: '', text: '밥그릇.' },
      { type: 'text', speaker: '', text: '수건.' },
      { type: 'text', speaker: '', text: '목검.' },
      { type: 'text', speaker: '', text: '리본.' },
      { type: 'text', speaker: '', text: '붉은 리본.' },
      { type: 'text', speaker: '', text: '주작이 가방을 봤다.' },
      { type: 'text', speaker: '', text: '리본이 달려 있었다.' },
      { type: 'text', speaker: '', text: '빼지 않았다.' },
      { type: 'text', speaker: '', text: '그냥 달고.' },
      { type: 'text', speaker: '', text: '"이거 당신이 사준 거잖아요."' },
      { type: 'text', speaker: '', text: '중얼거렸다.' },
      { type: 'text', speaker: '', text: '"가지고 갈게요."' },
      { type: 'text', speaker: '', text: '그리고 다시 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '"사과는."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"찾아왔을 때 받을게요."' },
      { type: 'text', speaker: '', text: '날아올랐다.' },
      { type: 'text', speaker: '', text: '날갯짓에 마당 흙이 원형으로 파였다. 지붕의 기와 세 장이 떨어졌다. 돌담 위에 붉은 발자국이 그을려 남았다. 주작이 서 있던 자리의 흙이 유리처럼 굳어 빛났다.' },
      { type: 'text', speaker: '', text: '붉은 불꽃이 하늘을 갈랐다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘에서 북쪽으로.' },
      { type: 'text', speaker: '', text: '동쪽으로.' },
      { type: 'text', speaker: '', text: '서쪽으로.' },
      { type: 'text', speaker: '', text: '어디든.' },
      { type: 'text', speaker: '', text: '당신이 있는 곳.' },
      { type: 'text', speaker: '', text: '당신이 내 이름을 불러줄 수 있는 곳.' },
      { type: 'text', speaker: '', text: '불꽃이 하늘에 긴 선을 그었다.' },
      { type: 'text', speaker: '', text: '붉게.' },
      { type: 'text', speaker: '', text: '찬란하게.' },
      { type: 'text', speaker: '', text: '남쪽 하늘에 주작성이 빛났다.' },
      { type: 'text', speaker: '', text: '오래간만에.' },
      { type: 'text', speaker: '', text: '가장 밝게.' },
      { type: 'text', speaker: '', text: '꺼지지 않고.' },
      { type: 'text', speaker: '', text: '고아원 뒷마당에서 하늘을 나는 새를 봤다. 부러웠다. 그 새가 이제 나였다. 하지만 자유롭지 않았다. 당신이 없으니까.' },
      { type: 'text', speaker: '', text: '미나가 기억났다. 고아원에서 유일하게 주작 언니라고 불러준 아이. 미나야. 잘 있어. 이름으로 살아.' },
      { type: 'text', speaker: '', text: '그리고 당신이 기억났다. 처음으로 이름을 불러줬을 때. 주작이요? 그게 저예요? 지금은 당연한 이름이었다. 당신이 불러줘서 익숙해진 이름.' },
      { type: 'text', speaker: '', text: '소매를 잡았다. 놓지 않겠다고 했다. 막을 수 없어도 잡겠다고 했다. 그런데도 잡지 못했다.' },
      { type: 'text', speaker: '', text: '주—' },
      { type: 'text', speaker: '', text: '그 입 모양. 당신이 마지막 순간에 부르려 했던 내 이름.' },
      { type: 'text', speaker: '', text: '눈물이 바람에 날렸다. 닦지 않았다. 그냥 날았다.' },
      { type: 'effect', effect: 'system', text: '【신수 주작. 귀환 비행 감지. 연결 대상 탐색 중. 대상 좌표: 미확정.】' },
      { type: 'text', speaker: '', text: '아무도 읽지 못하는 시스템 창이 하늘에 떠 있었다. 좌표가 깜빡거렸다.' },
      { type: 'text', speaker: '', text: '찾으면. 찾아서 당신을 보면.' },
      { type: 'text', speaker: '', text: '이름 불러줘요. 한 번만. 당신 목소리로. 주작이라고.' },
      { type: 'text', speaker: '', text: '그러면 다 됐다.' },
      { type: 'text', speaker: '', text: '바람이 강해졌다.' },
      { type: 'text', speaker: '', text: '날개가 찢어질 것처럼 흔들렸다. 깃 끝에서 불꽃이 떨어져 나갔다.' },
      { type: 'text', speaker: '', text: '구름 사이에서 벼락이 내렸다. 날개 옆을 스쳤다. 깃털 세 장이 타며 떨어졌다. 떨어지면서도 붉게 빛났다. 아래 구름이 불꽃의 열기에 찢겨 나갔다.' },
      { type: 'text', speaker: '', text: '버텼다.' },
      { type: 'text', speaker: '', text: '이를 악물었다. 바람이 뺨을 찢는 것 같았다. 왼쪽 날개 끝이 꺾이려 했다. 힘을 줬다. 불꽃을 밀어 올렸다. 날개 주변의 공기가 일그러지며 빛이 굴절됐다.' },
      { type: 'text', speaker: '', text: '폭풍이 방향을 바꿨다. 위에서 아래로 내리누르는 바람이었다. 몸이 떨어지려 했다. 날개를 접으면 끝이었다. 접지 않았다. 불꽃을 짜냈다. 뼈 안쪽에서 마지막 열기까지 끌어올려 날개에 밀어 넣었다. 날개 잔열이 폭풍의 습기를 증발시켜, 주작이 지나간 자리에 구름이 갈라지며 별이 드러났다.' },
      { type: 'text', speaker: '', text: '불꽃이 꺼지지 않았다.' },
      { type: 'text', speaker: '', text: '강한 바람 속에서도.' },
      { type: 'text', speaker: '', text: '오히려 불꽃이 강해졌다.' },
      { type: 'text', speaker: '', text: '이름이 있으니까.' },
      { type: 'text', speaker: '', text: '이름이 있는 불꽃이니까.' },
      { type: 'text', speaker: '', text: '마지막으로.' },
      { type: 'text', speaker: '', text: '남쪽 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '주작성.' },
      { type: 'text', speaker: '', text: '제일 밝은 별.' },
      { type: 'text', speaker: '', text: '"봐요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"찾아갈게요."' },
      { type: 'text', speaker: '', text: '"이름 불러줄 때까지."' },
      { type: 'text', speaker: '', text: '그날 밤.' },
      { type: 'text', speaker: '', text: '왜소한 신이 달빛 아래 앉아 있었다.' },
      { type: 'text', speaker: '', text: '플레이어 어깨에.' },
      { type: 'text', speaker: '', text: '밤하늘을 올려보면서.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '주작성.' },
      { type: 'text', speaker: '', text: '밝게 빛났다.' },
      { type: 'text', speaker: '', text: '신이 그 별을 봤다.' },
      { type: 'text', speaker: '', text: '오래 봤다.' },
      { type: 'text', speaker: '', text: '그러다.' },
      { type: 'text', speaker: '', text: '주작이 날아간 방향을 봤다.' },
      { type: 'text', speaker: '', text: '붉은 선이 사라진 하늘.' },
      { type: 'text', speaker: '', text: '신이 잠시 그쪽을 봤다.' },
      { type: 'text', speaker: '', text: '그리고 플레이어를 봤다.' },
      { type: 'text', speaker: '', text: '플레이어가 별을 보고 있었다.' },
      { type: 'text', speaker: '', text: '신이 살며시.' },
      { type: 'text', speaker: '', text: '플레이어 어깨에서 머리를 기댔다.' },
      { type: 'text', speaker: '', text: '아주 조금.' },
      { type: 'text', speaker: '', text: '거의 기대지 않은 것처럼.' },
      { type: 'text', speaker: '', text: '하지만 닿아 있었다.' },
      { type: 'text', speaker: '', text: '플레이어가 신을 내려봤다.' },
      { type: 'text', speaker: '', text: '신이 딴청을 피웠다.' },
      { type: 'text', speaker: '', text: '하지만 그 자리에 있었다.' },
      { type: 'text', speaker: '', text: '하늘에서.' },
      { type: 'text', speaker: '', text: '붉은 새가 날았다.' },
      { type: 'text', speaker: '', text: '이름을 가진 새가.' },
      { type: 'text', speaker: '', text: '이름을 부르는 사람을 찾아.' },
      { type: 'text', speaker: '', text: '날았다.' },
      { type: 'text', speaker: '', text: '불꽃이 하늘을 갈랐다.' },
      { type: 'text', speaker: '', text: '붉고.' },
      { type: 'text', speaker: '', text: '찬란하고.' },
      { type: 'text', speaker: '', text: '꺼지지 않고.' },
      { type: 'text', speaker: '', text: '주작성이 빛났다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘에서.' },
      { type: 'text', speaker: '', text: '오늘도.' },
      { type: 'text', speaker: '', text: '내일도.' },
      { type: 'text', speaker: '', text: '이름이 있는 한.' },
      { type: 'text', speaker: '', text: '불꽃이 꺼지지 않는 한.' },
      { type: 'text', speaker: '', text: '당신이 이름을 부르는 그날까지.' },
      { type: 'text', speaker: '', text: '반드시.' },
      { type: 'text', speaker: '', text: '— 끝 —' },
      { type: 'text', speaker: '', text: '이름이 불리면 있게 된다.' },
      { type: 'text', speaker: '', text: '이름이 불리면 불꽃이 켜진다.' },
      { type: 'text', speaker: '', text: '이름이 불리면 날 수 있다.' },
      { type: 'text', speaker: '', text: '고아원에서는 포기하는 법을 배웠다. 배고픔을. 따뜻함을. 이름을.' },
      { type: 'text', speaker: '', text: '하지만 당신은 포기하지 않았다.' },
      { type: 'text', speaker: '', text: '포기하지 않는 법을, 당신이 가르쳐줬다.' },
      { type: 'text', speaker: '', text: '주—. 그 입 모양을 기억하고 있을 거다. 찾아갔을 때 불러줄 거다. 주작이라고.' },
      { type: 'text', speaker: '', text: '불꽃이 하늘을 갈랐다. 꺼지지 않고.' },
      { type: 'text', speaker: '', text: '주작성이 빛났다. 남쪽 하늘에서. 가장 밝게.' },
      { type: 'text', speaker: '', text: '이름을 부르는 그날까지. 꺼지지 않을 거다.' },
      { type: 'text', speaker: '', text: '그리고 그 먼 하늘 어딘가에서, 시스템 창이 깜빡였다.' },
      { type: 'effect', effect: 'system', text: '【연결 대상 좌표: 수신 중... ██████ ... 신호 포착.】' },
    ]
  },
];
