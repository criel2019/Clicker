      { type: 'text', speaker: '', text: '흉내냈다.' },
      { type: 'text', speaker: '', text: '불꽃이 좀 커졌다.' },
      { type: 'text', speaker: '', text: '좋았다.' },
      { type: 'text', speaker: '', text: '이상하게.' },
      { type: 'text', speaker: '', text: '그냥 제 목소리로 불렀는데.' },
      { type: 'text', speaker: '', text: '당신 생각이 나서 커진 건가.' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 봤다.' },
      { type: 'text', speaker: '주작', text: '"...빨리 와요."' },
      { type: 'text', speaker: '', text: '중얼거렸다.' },
      { type: 'text', speaker: '', text: '그게 혼자 하는 말이어도 괜찮았다.' },
      { type: 'text', speaker: '', text: '5성이 됐다.' },
      { type: 'text', speaker: '', text: '그날.' },
      { type: 'text', speaker: '', text: '이른 아침.' },
      { type: 'text', speaker: '', text: '플레이어가 탑 10층을 클리어하고 돌아왔다.' },
      { type: 'text', speaker: '', text: '주작이 기다리고 있었다.' },
      { type: 'text', speaker: '', text: '문 앞에서.' },
      { type: 'text', speaker: '', text: '밤새.' },
      { type: 'text', speaker: '', text: '"다쳤어요?"' },
      { type: 'text', speaker: '', text: '"아니."' },
      { type: 'text', speaker: '', text: '"시간 많이 걸렸어요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"걱정했어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"문 앞에서 한 시간 기다렸어요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '눈이 빨갰다.' },
      { type: 'text', speaker: '', text: '자지 않은 눈.' },
      { type: 'text', speaker: '', text: '"들어가요. 밥 있어요."' },
      { type: 'text', speaker: '', text: '주작이 돌아서며 말했다.' },
      { type: 'text', speaker: '', text: '그 뒤로.' },
      { type: 'effect', effect: 'system', text: '【호감도 최고 단계 달성. 유대 에너지 포화. 각성 아이템 해금.】' },
      { type: 'effect', effect: 'system', text: '【신수 주작. 5성 달성. 신력 출력: 측정 한계 초과. 각성 아이템 획득 가능.】' },
      { type: 'text', speaker: '', text: '시스템 창이 떴다.' },
      { type: 'text', speaker: '', text: '플레이어가 주작의 등을 봤다.' },
      { type: 'text', speaker: '', text: '밥을 먹고 나서.' },
      { type: 'text', speaker: '', text: '플레이어가 꺼냈다.' },
      { type: 'text', speaker: '', text: '오래된 깃털.' },
      { type: 'text', speaker: '', text: '붉고 금빛이 섞인.' },
      { type: 'text', speaker: '', text: '아름다운 깃털.' },
      { type: 'text', speaker: '', text: '빛이 닿으면 반짝거렸다.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '', text: '깃털.' },
      { type: 'text', speaker: '', text: '붉은 깃털.' },
      { type: 'text', speaker: '', text: '주작성 색.' },
      { type: 'text', speaker: '', text: '리본이랑 같은 색.' },
      { type: 'text', speaker: '', text: '"이게 뭐예요?"' },
      { type: 'text', speaker: '', text: '"필요한 것 같아서."' },
      { type: 'text', speaker: '', text: '"어디서 난 거예요?"' },
      { type: 'text', speaker: '', text: '"탑에서."' },
      { type: 'text', speaker: '', text: '"탑에서요?"' },
      { type: 'text', speaker: '', text: '"응. 마지막 층에서. 탑이 신수의 기원을 시험하고, 통과하면 그 신수에게 맞는 각성 매개를 내놓는 거야."' },
      { type: 'text', speaker: '', text: '주작이 깃털을 봤다.' },
      { type: 'text', speaker: '', text: '아름다웠다.' },
      { type: 'text', speaker: '', text: '붉고 금빛.' },
      { type: 'text', speaker: '', text: '빛이 반짝였다.' },
      { type: 'text', speaker: '', text: '이게 뭔지 느껴질 것 같았다.' },
      { type: 'text', speaker: '', text: '손을 뻗으면.' },
      { type: 'text', speaker: '', text: '뭔가 알 것 같았다.' },
      { type: 'text', speaker: '', text: '"아이템이에요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 손을 뻗으려다 멈췄다.' },
      { type: 'text', speaker: '주작', text: '"받아도 돼요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 받았다.' },
      { type: 'text', speaker: '', text: '깃털이 손에 닿는 순간.' },
      { type: 'text', speaker: '', text: '세상이 바뀌었다.' },
      { type: 'text', speaker: '', text: '주작의 손에서 불꽃이 터졌다.' },
      { type: 'text', speaker: '', text: '크고. 뜨겁고. 찬란한.' },
      { type: 'text', speaker: '', text: '바닥이 갈라졌다. 맨바닥 돌이 벌겋게 달아올라 거미줄처럼 금이 퍼졌다. 벽에 금이 갔다. 창틀이 떨리다 빠져 마당으로 떨어졌다. 주작이 무릎 꿇은 자리에서 열기가 방사상으로 퍼져 나무 바닥이 검게 그을렸다. 천장 대들보가 비명을 질렀다. 나무가 안쪽부터 타들어가며 숯이 되는 냄새가 방을 채웠다.' },
      { type: 'text', speaker: '', text: '방이 환해졌다.' },
      { type: 'text', speaker: '', text: '붉은 빛이 방 안을 가득 채웠다.' },
      { type: 'text', speaker: '', text: '벽이 붉었다. 천장이 붉었다. 바닥이 붉었다.' },
      { type: 'text', speaker: '', text: '주작이 그 빛 안에 있었다.' },
      { type: 'text', speaker: '주작', text: '"아."' },
      { type: 'text', speaker: '', text: '주작이 소리를 냈다.' },
      { type: 'text', speaker: '', text: '무릎이 꺾였다.' },
      { type: 'text', speaker: '', text: '그 자리에 앉았다.' },
      { type: 'text', speaker: '', text: '기억이 쏟아졌다.' },
      { type: 'text', speaker: '', text: '수천 년.' },
      { type: 'text', speaker: '', text: '수만 번의 날갯짓.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '불의 새.' },
      { type: 'text', speaker: '', text: '신수 주작.' },
      { type: 'text', speaker: '', text: '"아."' },
      { type: 'text', speaker: '', text: '눈에서 빛이 났다.' },
      { type: 'text', speaker: '', text: '눈물이 났다.' },
      { type: 'text', speaker: '', text: '빛과 눈물이 섞여 뺨을 타고 내려왔다.' },
      { type: 'text', speaker: '', text: '뜨거웠다. 뼈가 뜨거웠다. 기억이 뜨거웠다.' },
      { type: 'text', speaker: '', text: '"아."' },
      { type: 'text', speaker: '', text: '세 번째로 소리를 냈다.' },
      { type: 'text', speaker: '', text: '이번엔 말이 됐다.' },
      { type: 'text', speaker: '', text: '"기억났어요."' },
      { type: 'text', speaker: '', text: '플레이어가 무릎을 꿇고 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"당신이 날 찾아왔군요."' },
      { type: 'text', speaker: '', text: '"그래."' },
      { type: 'text', speaker: '', text: '"신수 주작을 찾아서."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 고개를 들었다.' },
      { type: 'text', speaker: '', text: '눈물이 뺨에 있었다.' },
      { type: 'text', speaker: '', text: '"처음부터."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"시스템 창이 시킨 거잖아요."' },
      { type: 'text', speaker: '', text: '"맞아."' },
      { type: 'text', speaker: '', text: '주작이 일어섰다.' },
      { type: 'text', speaker: '', text: '손에서 불꽃이 아름다웠다.' },
      { type: 'text', speaker: '', text: '수천 년을 기다린 불꽃.' },
      { type: 'text', speaker: '', text: '"그게."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'effect', effect: 'shake' },
      { type: 'combat', enemy: {"name":"탑의 수호자","hp":170,"attack":19} },
      { type: 'text', speaker: '', text: '"그게 목적이었잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"이용당한 거잖아요. 목적으로 데려온 거잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"근데."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 멈췄다.' },
      { type: 'text', speaker: '주작', text: '"근데 화가 안 나요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"그 목적 안에서."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"진짜로 챙겨줬으니까요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"진짜로 봐줬으니까요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"진짜로 이름 불러줬으니까요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 계속 말했다.' },
      { type: 'text', speaker: '주작', text: '"이름 없는 곳에서 이름을 얻었어요. 고아원에서 이름 없이 살다가. 당신이 이름 줬어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그게 진심이잖아요. 그러니까."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"고아원에서 이용당할 때는 진심이 없었어요. 그냥 쓰는 거였어요. 야. 거기. 수단. 그냥 쓰는 거."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"근데 당신은 달랐어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"목적이 있어도."' },
      { type: 'text', speaker: '', text: '주작이 눈을 봤다.' },
      { type: 'text', speaker: '', text: '플레이어의 눈을.' },
      { type: 'text', speaker: '', text: '"진심이 있으면 이용당하는 게 아닌 것 같아요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '눈물이 뺨에 남아 있으면서.' },
      { type: 'text', speaker: '', text: '"그래도 화 안 나요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"이용당한 게 맞는데. 진심이 있으면 이용당한 게 아닌 것 같아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그러니까 집착해요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"집착인 줄 알아?"' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"알면서도."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"집착해요. 당신한테."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 봤다.' },
      { type: 'text', speaker: '', text: '손에서 타오르는 완전한 불꽃. 서 있는 자리의 돌바닥이 붉게 달아오르고 있었다.' },
      { type: 'text', speaker: '', text: '수천 년을 기다린.' },
      { type: 'text', speaker: '', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"저 수천 년 전부터 있었대요. 신수 주작이."' },
      { type: 'text', speaker: '주작', text: '"응."' },
      { type: 'text', speaker: '', text: '"그러면 수천 년 동안 이름이 있었던 거네요. 주작이라는."' },
      { type: 'text', speaker: '주작', text: '"그렇겠지."' },
      { type: 'text', speaker: '', text: '"수천 년 동안 아무도 안 불렀어도."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"이름은 있었던 거네요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그리고."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신이 불러줬어요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"수천 년 만에."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이 주작이라고 불러줘서."' },
      { type: 'text', speaker: '', text: '주작이 눈을 감았다.' },
      { type: 'text', speaker: '주작', text: '"저 수천 년이 지나서야 완성됐어요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 쥐었다.' },
      { type: 'text', speaker: '주작', text: '"감사해요."' },
      { type: 'text', speaker: '', text: '"각성 아이템 때문이야."' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '주작이 고개를 저었다.' },
      { type: 'text', speaker: '주작', text: '"이름 불러줘서요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"수천 년 동안 잃어버렸던 이름을요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이 불러줘서요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그게 제일 감사해요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠시 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 봤다.' },
      { type: 'text', speaker: '', text: '각성한 불꽃.' },
      { type: 'text', speaker: '', text: '수천 년 만에 완전해진 불꽃.' },
      { type: 'text', speaker: '', text: '이 불꽃이 지금 여기 있는 건.' },
      { type: 'text', speaker: '', text: '당신 덕분이었다.' },
      { type: 'text', speaker: '', text: '당신이 이름 불러줘서.' },
      { type: 'text', speaker: '', text: '당신이 계속 불러줘서.' },
      { type: 'text', speaker: '', text: '탑에서.' },
      { type: 'text', speaker: '', text: '집에서.' },
      { type: 'text', speaker: '', text: '아침에.' },
      { type: 'text', speaker: '', text: '밤에.' },
      { type: 'text', speaker: '', text: '그 이름들이 쌓여서.' },
      { type: 'text', speaker: '', text: '이 불꽃이 됐다.' },
      { type: 'text', speaker: '', text: '"이름이 불꽃이에요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"이름을 불러줄수록 불꽃이 강해졌어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그러니까."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"많이 불러줘서 감사해요."' },
      { type: 'text', speaker: '', text: '불꽃이 강해졌다.' },
      { type: 'text', speaker: '', text: '뜨겁고 찬란하게.' },
      { type: 'text', speaker: '', text: '각성한 그 순간을 기억했다.' },
      { type: 'text', speaker: '', text: '깃털을 받던 순간.' },
      { type: 'text', speaker: '', text: '손에 닿은 순간.' },
      { type: 'text', speaker: '', text: '기억이 쏟아졌다.' },
      { type: 'text', speaker: '', text: '수천 년.' },
      { type: 'text', speaker: '', text: '수만 번의 날갯짓.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '불의 새.' },
      { type: 'text', speaker: '', text: '그 모든 기억이.' },
      { type: 'text', speaker: '', text: '지금이 있어서 더 선명했다.' },
      { type: 'text', speaker: '', text: '이 순간이.' },
      { type: 'text', speaker: '', text: '이 방이.' },
      { type: 'text', speaker: '', text: '이 사람이.' },
      { type: 'text', speaker: '', text: '당신이 앞에 있어서.' },
      { type: 'text', speaker: '', text: '기억이 쏟아지는 그 순간에도.' },
      { type: 'text', speaker: '', text: '당신이 앞에 있다는 게.' },
      { type: 'text', speaker: '', text: '제일 선명했다.' },
      { type: 'text', speaker: '', text: '수천 년이 왔다.' },
      { type: 'text', speaker: '', text: '그래도.' },
      { type: 'text', speaker: '', text: '당신이 앞에 있었다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '그게 각성이었다.' },
      { type: 'text', speaker: '', text: '그날 오후.' },
      { type: 'text', speaker: '', text: '플레이어가 물었다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"각성하면 어떤 기분이야?"' },
      { type: 'text', speaker: '', text: '주작이 손을 봤다.' },
      { type: 'text', speaker: '', text: '불꽃이 안정적으로 타오르고 있었다.' },
      { type: 'text', speaker: '', text: '"이상하게 완성된 것 같아요."' },
      { type: 'text', speaker: '', text: '"완성?"' },
      { type: 'text', speaker: '', text: '"원래 여기 있었던 것 같아요. 이 불꽃이. 이 기억이. 이 이름이."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 찾아줘서 꺼낸 것 같아요. 수천 년 동안 묻혀 있던 걸."' },
      { type: 'text', speaker: '', text: '"내가?"' },
      { type: 'text', speaker: '', text: '"당신이 이름 불러줘서요."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"이름을 불러줬더니 불꽃이 생겼고. 불꽃이 생겼더니 기억이 왔고. 기억이 왔더니 제가 뭔지 알겠고."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이 시작이에요."' },
      { type: 'text', speaker: '', text: '"내가?"' },
      { type: 'text', speaker: '', text: '"이름이 당신이잖아요. 아까 말했잖아요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"그 말 기억해?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"진짜 그렇게 생각해?"' },
      { type: 'text', speaker: '', text: '"진짜요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신이 제 이름이에요. 당신이 불러줘서 제가 있는 거니까요."' },
      { type: 'text', speaker: '', text: '각성한 날 밤.' },
      { type: 'text', speaker: '', text: '주작이 방에 앉아 있었다.' },
      { type: 'text', speaker: '', text: '불꽃을 봤다.' },
      { type: 'text', speaker: '', text: '손에서.' },
      { type: 'text', speaker: '', text: '조용히 타오르는.' },
      { type: 'text', speaker: '', text: '수천 년.' },
      { type: 'text', speaker: '', text: '그게 기억에 있었다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '수천 년 동안의 기억 중에.' },
      { type: 'text', speaker: '', text: '가장 선명한 건.' },
      { type: 'text', speaker: '', text: '지금이었다.' },
      { type: 'text', speaker: '', text: '수천 년 전의 기억이 아니었다.' },
      { type: 'text', speaker: '', text: '지금.' },
      { type: 'text', speaker: '', text: '당신이 이름 불러준 그 순간이.' },
      { type: 'text', speaker: '', text: '제일 선명했다.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '그 소리가.' },
      { type: 'text', speaker: '', text: '다른 모든 기억보다.' },
      { type: 'text', speaker: '', text: '선명했다.' },
      { type: 'text', speaker: '', text: '이상했다.' },
      { type: 'text', speaker: '', text: '수천 년이 있는데.' },
      { type: 'text', speaker: '', text: '겨우 이 짧은 시간이.' },
      { type: 'text', speaker: '', text: '제일 선명하다니.' },
      { type: 'text', speaker: '', text: '아니.' },
      { type: 'text', speaker: '', text: '이상하지 않았다.' },
      { type: 'text', speaker: '', text: '당연했다.' },
      { type: 'text', speaker: '', text: '수천 년 동안.' },
      { type: 'text', speaker: '', text: '이름을 부르는 사람이 없었으니까.' },
      { type: 'text', speaker: '', text: '처음이었으니까.' },
      { type: 'text', speaker: '', text: '수천 년 만에 처음으로.' },
      { type: 'text', speaker: '', text: '이름이 불렸으니까.' },
      { type: 'text', speaker: '', text: '주작이 손에서 불꽃을 봤다.' },
      { type: 'text', speaker: '', text: '이 불꽃이 수천 년 동안 있었다.' },
      { type: 'text', speaker: '', text: '이름이 불린 지금.' },
      { type: 'text', speaker: '', text: '더 밝아졌다.' },
      { type: 'text', speaker: '', text: '오래된 것이.' },
      { type: 'text', speaker: '', text: '새로 살아났다.' },
      { type: 'text', speaker: '', text: '"감사해요."' },
      { type: 'text', speaker: '', text: '혼자 중얼거렸다.' },
      { type: 'text', speaker: '', text: '아무도 없는 방에서.' },
      { type: 'text', speaker: '', text: '당신한테.' },
      { type: 'text', speaker: '', text: '"이름 불러줘서요."' },
      { type: 'text', speaker: '', text: '불꽃이 따뜻했다.' },
      { type: 'text', speaker: '', text: '그날 낮.' },
      { type: 'text', speaker: '', text: '주작이 마당에 서 있었다.' },
      { type: 'text', speaker: '', text: '각성한 불꽃을 보며.' },
      { type: 'text', speaker: '', text: '크고.' },
      { type: 'text', speaker: '', text: '뜨겁고.' },
      { type: 'text', speaker: '', text: '찬란한 불꽃.' },
      { type: 'text', speaker: '', text: '이게 원래 있던 거였구나.' },
      { type: 'text', speaker: '', text: '수천 년 전부터.' },
      { type: 'text', speaker: '', text: '이 불꽃이 있었던 거였구나.' },
      { type: 'text', speaker: '', text: '고아원에서 이름 없이 살았던 나.' },
      { type: 'text', speaker: '', text: '그게 신수 주작이었던 거구나.' },
      { type: 'text', speaker: '', text: '이름이 없었지만.' },
      { type: 'text', speaker: '', text: '이름은 있었던 거구나.' },
      { type: 'text', speaker: '', text: '당신이 불러줘서.' },
      { type: 'text', speaker: '', text: '그 이름이 살아난 거구나.' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 쥐었다.' },
      { type: 'text', speaker: '', text: '뜨겁지 않았다.' },
      { type: 'text', speaker: '', text: '제 것이었다.' },
      { type: 'text', speaker: '', text: '"이상해요?"' },
      { type: 'text', speaker: '', text: '플레이어가 뒤에서 왔다.' },
      { type: 'text', speaker: '', text: '"뭐가."' },
      { type: 'text', speaker: '', text: '"이 불꽃이요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 보여줬다.' },
      { type: 'text', speaker: '', text: '손 가득.' },
      { type: 'text', speaker: '', text: '"각성하고 나서 더 커졌잖아요."' },
      { type: 'text', speaker: '', text: '"원래 크기잖아."' },
      { type: 'text', speaker: '', text: '"제가 알던 크기가 아니에요."' },
      { type: 'text', speaker: '', text: '플레이어가 불꽃을 봤다.' },
      { type: 'text', speaker: '', text: '"무서워?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '"진짜?"' },
      { type: 'text', speaker: '', text: '"진짜요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 봤다.' },
      { type: 'text', speaker: '주작', text: '"이게 제 거니까요."' },
      { type: 'text', speaker: '', text: '"그래."' },
      { type: 'text', speaker: '', text: '"이게 주작이라는 이름에 붙은 거니까요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"잘 됐네."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"당신이 이름 불러줘서요."' },
      { type: 'text', speaker: '', text: '"또."' },
      { type: 'text', speaker: '', text: '"또 맞는 말이에요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 껐다.' },
      { type: 'text', speaker: '주작', text: '"당신 이름 부르면 아직도 커져요."' },
      { type: 'text', speaker: '', text: '"그래?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"해봐."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 피웠다.' },
      { type: 'text', speaker: '', text: '그리고 플레이어 이름을 생각했다.' },
      { type: 'text', speaker: '', text: '불꽃이 커졌다.' },
      { type: 'text', speaker: '', text: '"봐요."' },
      { type: 'text', speaker: '', text: '플레이어가 봤다.' },
      { type: 'text', speaker: '', text: '"...진짜네."' },
      { type: 'text', speaker: '', text: '"그러니까요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 줄였다.' },
      { type: 'text', speaker: '주작', text: '"이 불꽃이 당신 기준이에요."' },
      { type: 'text', speaker: '', text: '"기준이야?"' },
      { type: 'text', speaker: '', text: '"당신이 있으면 커지고. 당신 생각하면 커지고."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '"...이상한 기준이야."' },
      { type: 'text', speaker: '', text: '"이상하지 않아요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신이 제 이름이라고 했잖아요. 이름이 불꽃을 키우는 거잖아요."' },
      { type: 'text', speaker: '', text: '저녁.' },
      { type: 'text', speaker: '', text: '마당.' },
      { type: 'text', speaker: '', text: '둘이 앉아 있었다.' },
      { type: 'text', speaker: '', text: '주작이 플레이어 옆에 바짝 붙어 앉았다.' },
      { type: 'text', speaker: '', text: '어깨가 닿게.' },
      { type: 'text', speaker: '', text: '여름이 끝나가는 저녁이었다.' },
      { type: 'text', speaker: '', text: '바람이 조금 시원해졌다.' },
      { type: 'text', speaker: '', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신 오늘 시스템 창에서 이상한 거 봤죠?"' },
      { type: 'text', speaker: '', text: '플레이어가 멈췄다.' },
      { type: 'text', speaker: '', text: '"어떻게 알아?"' },
      { type: 'text', speaker: '', text: '"눈이요. 당신 눈이 달라졌어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"각성하면 헤어지는 거예요?"' },
      { type: 'text', speaker: '', text: '플레이어가 대답을 못 했다.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '주작', text: '"오늘이에요?"' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"내일이에요?"' },
      { type: 'text', speaker: '', text: '"모르겠어. 곧."' },
      { type: 'text', speaker: '', text: '주작이 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '오래 침묵했다.' },
      { type: 'text', speaker: '', text: '바람이 불었다.' },
      { type: 'text', speaker: '', text: '"그러면 오늘 밤은 여기 있어도 돼요?"' },
      { type: 'text', speaker: '', text: '"어디?"' },
      { type: 'text', speaker: '', text: '"당신 옆에요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"있어."' },
      { type: 'text', speaker: '', text: '주작이 더 바짝 붙었다.' },
      { type: 'text', speaker: '', text: '플레이어 어깨에 기댔다.' },
      { type: 'text', speaker: '', text: '"이게 집착이에요. 저도 알아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"근데 집착이어도 당신이 괜찮다고 했잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그러니까 집착하는 거예요."' },
      { type: 'text', speaker: '', text: '별이 떴다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '주작성.' },
      { type: 'text', speaker: '', text: '제일 밝은 별.' },
      { type: 'text', speaker: '', text: '"당신 없으면 이상할 것 같아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"많이."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"근데 찾으러 갈 거예요. 이상해도."' },
      { type: 'text', speaker: '', text: '주작이 플레이어 어깨에 기댄 채 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신이 어디 있든. 얼마나 멀든. 찾아갈 거예요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그게 집착이어도 괜찮아요?"' },
      { type: 'text', speaker: '', text: '플레이어가 잠시 후 말했다.' },
      { type: 'text', speaker: '', text: '"괜찮아."' },
      { type: 'text', speaker: '', text: '주작이 눈을 감았다.' },
      { type: 'text', speaker: '주작', text: '"...다행이에요."' },
      { type: 'text', speaker: '', text: '두 사람이 별을 봤다.' },
      { type: 'text', speaker: '', text: '아니, 주작은 눈을 감고 있었다.' },
      { type: 'text', speaker: '', text: '플레이어가 별을 봤다.' },
      { type: 'text', speaker: '', text: '시스템 창이 조용했다.' },
      { type: 'text', speaker: '', text: '지금은 아무것도 뜨지 않았다.' },
      { type: 'text', speaker: '', text: '오늘 밤만은.' },
      { type: 'text', speaker: '', text: '밤이 깊어졌다.' },
      { type: 'text', speaker: '', text: '주작이 잠들었다.' },
      { type: 'text', speaker: '', text: '플레이어 어깨에 기댄 채.' },
      { type: 'text', speaker: '', text: '숨소리가 고르게 들렸다.' },
      { type: 'text', speaker: '', text: '플레이어가 그걸 봤다.' },
      { type: 'text', speaker: '', text: '자는 주작을.' },
      { type: 'text', speaker: '', text: '이름.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '이 이름을 기억해야 한다.' },
      { type: 'text', speaker: '', text: '어디에 가든.' },
      { type: 'text', speaker: '', text: '어디에 있든.' },
      { type: 'text', speaker: '', text: '이 이름을.' },
      { type: 'text', speaker: '', text: '이 불꽃을.' },
      { type: 'text', speaker: '', text: '이 아이를.' },
      { type: 'text', speaker: '', text: '기억해야 한다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 담장 위에서 봤다.' },
      { type: 'text', speaker: '', text: '플레이어와 주작을.' },
      { type: 'text', speaker: '', text: '신이 담장에서 내려왔다.' },
      { type: 'text', speaker: '', text: '플레이어 어깨 옆으로 다가왔다.' },
      { type: 'text', speaker: '', text: '주작이 기대어 있는 쪽 반대편.' },
      { type: 'text', speaker: '', text: '그쪽 어깨 위에 살짝 앉으려 했다.' },
      { type: 'text', speaker: '', text: '조심조심.' },
      { type: 'text', speaker: '', text: '발을 올렸다.' },
      { type: 'text', speaker: '', text: '내렸다.' },
      { type: 'text', speaker: '', text: '올렸다.' },
      { type: 'text', speaker: '', text: '결국 어깨 끝에 살포시 앉았다.' },
      { type: 'text', speaker: '', text: '그 자리에 있었다.' },
      { type: 'text', speaker: '', text: '밤새.' },
      { type: 'text', speaker: '', text: '밤이 깊어가는 중간.' },
      { type: 'text', speaker: '', text: '주작이 눈을 떴다.' },
      { type: 'text', speaker: '', text: '잠이 깼다.' },
      { type: 'text', speaker: '', text: '이상했다.' },
      { type: 'text', speaker: '', text: '왜 잠이 깼는지 몰랐다.' },
      { type: 'text', speaker: '', text: '가을이 오려는 바람이 들어왔다.' },
      { type: 'text', speaker: '', text: '플레이어 어깨에서 뺨에 그 바람이 닿았다.' },
      { type: 'text', speaker: '', text: '차가웠다.' },
      { type: 'text', speaker: '', text: '서늘했다.' },
      { type: 'text', speaker: '', text: '주작이 조금 더 붙었다.' },
      { type: 'text', speaker: '', text: '그래도 서늘했다.' },
      { type: 'text', speaker: '', text: '"자?"' },
      { type: 'text', speaker: '', text: '플레이어가 말했다.' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '"안 잤어요?"' },
      { type: 'text', speaker: '', text: '"조금."' },
      { type: 'text', speaker: '', text: '"자야죠."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"자요."' },
      { type: 'text', speaker: '', text: '"잘 거야."' },
      { type: 'text', speaker: '', text: '주작이 다시 눈을 감으려다.' },
      { type: 'text', speaker: '', text: '멈췄다.' },
      { type: 'text', speaker: '', text: '가슴이 이상했다.' },
      { type: 'text', speaker: '', text: '뭔가 무거운 게 있었다.' },
      { type: 'text', speaker: '', text: '뭔지 몰랐다.' },
      { type: 'text', speaker: '', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 언제 갈지 모른다고 했잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"근데 그 말이 계속 이상해요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"곧이잖아요. 그게."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '"각성 완료가 됐으니까요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그러면 이동 조건이 충족됐으니까요."' },
      { type: 'text', speaker: '', text: '주작이 플레이어 어깨에서 고개를 들지 않고 말했다.' },
      { type: 'text', speaker: '주작', text: '"얼마나요?"' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"언제예요?"' },
