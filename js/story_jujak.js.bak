// 주작 스토리 데이터 (메타데이터 자동 삽입)
// 총 11장, 5514개 노드

Story.chapters.jujak = [
  {
    title: '- 수정1: "아이는 몸으로 알았다." 뒤에 잔열 이미지 1줄 추가 → 서막에서부터 불의 물리적 존재감 부여 (+1줄)',
    nodes: [
      { type: 'text', speaker: '', text: '타겟 평가자: 버프(시스템/메카닉), 강철(잔열/물리적 긴장) 기대 효과: 서막에서부터 주작의 불이 단순 은유가 아닌 물리적 실체임을 암시. 본문 전투/시스템 장면과의 연결 고리 강화.' },
      { type: 'text', speaker: '', text: '서막. 불' },
      { type: 'text', speaker: '', text: '세상에 불이 있다.' },
      { type: 'text', speaker: '', text: '주작의 불.' },
      { type: 'text', speaker: '', text: '아직 자기가 불인 줄 모른다. 타오르는 줄도 모른다. 뜨거운 줄도 모른다.' },
      { type: 'text', speaker: '', text: '다만.' },
      { type: 'text', speaker: '', text: '이름이 없었다.' },
      { type: 'text', speaker: '', text: '이름이 없으면 불도 없다. 이름이 없으면 존재도 없다.' },
      { type: 'text', speaker: '', text: '그 애는 몸으로 알았다.' },
      { type: 'text', speaker: '', text: '손끝이 가끔 뜨거웠다. 이유를 몰랐다.' },
      { type: 'text', speaker: '', text: '불려야 비로소.' },
      { type: 'text', speaker: '', text: '타오를 수 있다는 걸.' },
      { type: 'text', speaker: '', text: '그래서.' },
      { type: 'text', speaker: '', text: '이름을 불러주는 사람이 왔을 때.' },
      { type: 'text', speaker: '', text: '그 불이 타오르기 시작했다.' },
      { type: 'text', speaker: '', text: '그 애가 잠든 자리에 풀이 마른 적이 있었다.' },
      { type: 'text', speaker: '', text: '아직은 불씨.' },
    ]
  },
  {
    title: '타겟 평가자: 버프(시스템 밀도), 강철(잔열), 1장 분량 긴축',
    nodes: [
      { type: 'text', speaker: '', text: '타겟 평가자: 버프(시스템 밀도), 강철(잔열), 1장 분량 긴축 기대 효과: 1장 분량 20줄 감소, 밥짓기/청소 중복 해소, 초반 시스템/잔열 밀도 보강' },
      { type: 'text', speaker: '', text: '1장. 이름 없는 아이' },
      { type: 'text', speaker: '', text: '봄이었다.' },
      { type: 'text', speaker: '', text: '아직 차가운 봄. 바람에 재 냄새가 섞여 오던 봄.' },
      { type: 'text', speaker: '', text: '전쟁 소식이 먼 곳에서 들려오던 봄.' },
      { type: 'text', speaker: '', text: '도시 외곽 고아원 뒷마당에 아이가 있었다.' },
      { type: 'text', speaker: '', text: '텃밭 흙을 손가락으로 파고 있었다. 이유는 없었다. 손이 심심해서. 그냥 아무도 없으니까.' },
      { type: 'text', speaker: '', text: '흙 냄새가 났다.' },
      { type: 'text', speaker: '', text: '습하고 서늘한 봄 흙 냄새.' },
      { type: 'text', speaker: '', text: '아이는 손가락을 더 깊이 박았다. 손톱 밑에 흙이 끼었다. 그래도 계속 팠다.' },
      { type: 'text', speaker: '', text: '무언가를 찾는 것처럼. 아무것도 없는 걸 알면서.' },
      { type: 'text', speaker: '', text: '아이는 혼자였다.' },
      { type: 'text', speaker: '', text: '혼자라는 게 무섭지는 않았다. 태어날 때부터 혼자였으니까. 무서운 건 혼자인 줄도 모르고 살다가, 어느 날 문득 혼자라는 걸 아는 순간이었다.' },
      { type: 'text', speaker: '', text: '"야."' },
      { type: 'text', speaker: '', text: '목소리가 들렸다.' },
      { type: 'text', speaker: '', text: '아이가 돌아봤다.' },
      { type: 'text', speaker: '', text: '상길이었다. 열두 살. 고아원에서 제일 큰 애. 두꺼운 팔뚝에 흙 묻은 신발을 신고 있었다. 눈이 작고 날카로웠다. 항상 뭔가를 계산하는 눈.' },
      { type: 'text', speaker: '', text: '"너 아침에 선생님한테 내가 어제 창문 깼다고 했어?"' },
      { type: 'text', speaker: '', text: '아이가 고개를 저었다.' },
      { type: 'text', speaker: '', text: '"안 했어."' },
      { type: 'text', speaker: '', text: '"거짓말하지 마. 내가 혼났잖아."' },
      { type: 'text', speaker: '', text: '"나 아니야."' },
      { type: 'text', speaker: '', text: '"그럼 누구야."' },
      { type: 'text', speaker: '', text: '상길이가 다가왔다. 머리 하나는 더 컸다. 그림자가 아이 위로 드리웠다.' },
      { type: 'text', speaker: '', text: '아이는 뒷걸음치지 않았다.' },
      { type: 'text', speaker: '', text: '뒷걸음치면 더 온다는 걸 알았다. 고아원에서 배운 것. 물러서면 끝까지 쫓아온다. 그냥 서 있으면 어느 순간 지나간다.' },
      { type: 'text', speaker: '', text: '"나 아니야."' },
      { type: 'text', speaker: '', text: '한 번 더 말했다.' },
      { type: 'text', speaker: '', text: '목소리가 떨리지 않았다.' },
      { type: 'text', speaker: '', text: '상길이가 콧방귀를 뀌었다.' },
      { type: 'text', speaker: '', text: '"야. 야, 거기."' },
      { type: 'text', speaker: '', text: '그게 이름이었다.' },
      { type: 'text', speaker: '', text: '야. 거기. 너. 쟤. 저거.' },
      { type: 'text', speaker: '', text: '이름이 다섯 개였다. 진짜 이름은 아무도 몰랐다.' },
      { type: 'text', speaker: '', text: '아니, 알고 있었다.' },
      { type: 'text', speaker: '', text: '선생님들은 알았다.' },
      { type: 'text', speaker: '', text: '그냥 부르지 않았다.' },
      { type: 'text', speaker: '', text: '귀찮아서. 기억 못 해서. 아니면.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '그냥 그랬다.' },
      { type: 'text', speaker: '', text: '"야. 오늘 텃밭 다 맸어?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"청소는?"' },
      { type: 'text', speaker: '', text: '"했어."' },
      { type: 'text', speaker: '', text: '"심부름은?"' },
      { type: 'text', speaker: '', text: '"어제 갔다 왔어."' },
      { type: 'text', speaker: '', text: '상길이가 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '"그래. 계속 해."' },
      { type: 'text', speaker: '', text: '가버렸다.' },
      { type: 'text', speaker: '', text: '신발 소리가 멀어졌다. 흙을 밟는 소리. 발을 끌지 않는 소리.' },
      { type: 'text', speaker: '', text: '아이가 다시 흙을 팠다.' },
      { type: 'text', speaker: '', text: '손이 더러워졌다.' },
      { type: 'text', speaker: '', text: '괜찮았다.' },
      { type: 'text', speaker: '', text: '원래 더러웠으니까.' },
      { type: 'text', speaker: '', text: '그게 아이의 하루였다.' },
      { type: 'text', speaker: '', text: '아침에 일어나면 밥을 만들었다. 다른 아이들이 먹을 밥을. 가마솥 앞에서 손이 빨개지도록 저었다.' },
      { type: 'text', speaker: '', text: '자기 몫은 항상 조금씩 부족했다. 먹을 만큼은 있었다. 충분하지는 않았지만.' },
      { type: 'text', speaker: '', text: '점심엔 청소를 했다. 방을 쓸고 닦고 정리했다. 창문을 닦았다.' },
      { type: 'text', speaker: '', text: '유리가 맑아지면 기분이 좋았다.' },
      { type: 'text', speaker: '', text: '맑은 창문 너머로 하늘이 보였다.' },
      { type: 'text', speaker: '', text: '봄 하늘. 파랗고 얕은. 어딘가 멀리 구름이 흘렀다.' },
      { type: 'text', speaker: '', text: '새가 날았다.' },
      { type: 'text', speaker: '', text: '아이는 오래 봤다.' },
      { type: 'text', speaker: '', text: '저 새는 이름이 있을까. 저 새는 누가 불러줄까.' },
      { type: 'text', speaker: '', text: '모르겠다.' },
      { type: 'text', speaker: '', text: '하지만 새는 날 수 있었다.' },
      { type: 'text', speaker: '', text: '그것만으로도 부러웠다.' },
      { type: 'text', speaker: '', text: '저렇게 날 수 있으면. 이름이 없어도. 저 하늘에서만큼은. 있는 것 같을 텐데.' },
      { type: 'text', speaker: '', text: '저녁엔 어린 애들 담요를 챙겼다.' },
      { type: 'text', speaker: '', text: '미나. 일곱 살. 잘 때 담요가 흘러내려서 항상 추워서 깨는 아이.' },
      { type: 'text', speaker: '', text: '미나의 담요는 낡았다. 모서리가 닳아서 실이 풀려 있었다.' },
      { type: 'text', speaker: '', text: '아이가 몰래 덮어줬다.' },
      { type: 'text', speaker: '', text: '미나가 자면서 중얼거렸다.' },
      { type: 'text', speaker: '', text: '"...따뜻해."' },
      { type: 'text', speaker: '', text: '아이가 웃었다.' },
      { type: 'text', speaker: '', text: '소리 없이.' },
      { type: 'text', speaker: '', text: '아무도 안 보는 밤에.' },
      { type: 'text', speaker: '', text: '그게 아이의 하루였다.' },
      { type: 'text', speaker: '', text: '아무도 그 이름을 부르지 않는 하루.' },
      { type: 'text', speaker: '', text: '밤이 됐다.' },
      { type: 'text', speaker: '', text: '아이가 이불에 누웠다.' },
      { type: 'text', speaker: '', text: '창문으로 달이 보였다.' },
      { type: 'text', speaker: '', text: '달빛이 방 안으로 들어왔다.' },
      { type: 'text', speaker: '', text: '차가운 달빛.' },
      { type: 'text', speaker: '', text: '아이는 그 빛을 봤다.' },
      { type: 'text', speaker: '', text: '손을 들어 봤다.' },
      { type: 'text', speaker: '', text: '손바닥이 달빛으로 환했다.' },
      { type: 'text', speaker: '', text: '손가락 사이로 빛이 새어나왔다.' },
      { type: 'text', speaker: '', text: '이 손이.' },
      { type: 'text', speaker: '', text: '내 손이다.' },
      { type: 'text', speaker: '', text: '이름은 없어도.' },
      { type: 'text', speaker: '', text: '손은 있다.' },
      { type: 'text', speaker: '', text: '아이가 그걸 생각했다.' },
      { type: 'text', speaker: '', text: '손이 있으면.' },
      { type: 'text', speaker: '', text: '있는 거잖아.' },
      { type: 'text', speaker: '', text: '어딘가에.' },
      { type: 'text', speaker: '', text: '있는 거잖아.' },
      { type: 'text', speaker: '', text: '손을 내렸다.' },
      { type: 'text', speaker: '', text: '눈을 감았다.' },
      { type: 'text', speaker: '', text: '밤이 깊어졌다.' },
      { type: 'text', speaker: '', text: '고아원에 아이들은 스물두 명이었다.' },
      { type: 'text', speaker: '', text: '전쟁 고아. 버려진 아이. 어디서 왔는지 모르는 아이.' },
      { type: 'text', speaker: '', text: '여기서도 아이들이 서로 이름을 가졌다. 부모가 지어준 이름. 선생님이 지어준 이름. 자기가 고른 이름.' },
      { type: 'text', speaker: '', text: '이름들이 넘쳐났다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '아이도 어디서 왔는지 몰랐다.' },
      { type: 'text', speaker: '', text: '이름만 알았다.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '어디서 온 이름인지 몰랐다.' },
      { type: 'text', speaker: '', text: '어느 날 스스로 그 이름을 말했다고 했다. 잠에서 깨자마자, 아직 눈도 다 뜨지 않은 채로. 아무도 가르쳐주지 않았는데. 잠에서 깨자마자 그 이름을 말했다고. 고아원에 처음 왔을 때. 아무것도 기억하지 못하는 상태로.' },
      { type: 'text', speaker: '', text: '그냥 그게 자기 이름인 것 같았다고 했다.' },
      { type: 'text', speaker: '', text: '선생님이 적었다.' },
      { type: 'text', speaker: '', text: '이름 : 주작.' },
      { type: 'text', speaker: '', text: '그게 전부였다.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '그게 이름인데.' },
      { type: 'text', speaker: '', text: '아무도 부르지 않았다.' },
      { type: 'text', speaker: '', text: '야. 거기. 너.' },
      { type: 'text', speaker: '', text: '그게 이름이었다.' },
      { type: 'text', speaker: '', text: '어느 날 상길이가 아이 밥그릇을 가져갔다.' },
      { type: 'text', speaker: '', text: '이유는 없었다.' },
      { type: 'text', speaker: '', text: '그냥 가져갔다.' },
      { type: 'text', speaker: '', text: '저녁 식사 시간. 아이가 밥을 받아서 자기 자리로 가려는데. 상길이가 그냥 가져갔다.' },
      { type: 'text', speaker: '', text: '아이가 봤다.' },
      { type: 'text', speaker: '', text: '말하지 않았다.' },
      { type: 'text', speaker: '', text: '상길이도 배가 고팠을 거다. 배가 고프면 뺏는 거니까.' },
      { type: 'text', speaker: '', text: '아이는 그렇게 생각했다.' },
      { type: 'text', speaker: '', text: '배려인지 체념인지.' },
      { type: 'text', speaker: '', text: '구분이 안 됐다.' },
      { type: 'text', speaker: '', text: '부엌으로 가서 남은 밥을 긁어 먹었다. 눌은밥이었다. 딱딱했다.' },
      { type: 'text', speaker: '', text: '씹었다.' },
      { type: 'text', speaker: '', text: '괜찮았다.' },
      { type: 'text', speaker: '', text: '저녁에 원장 선생님이 불렀다.' },
      { type: 'text', speaker: '', text: '"야, 거기. 이리 와봐."' },
      { type: 'text', speaker: '', text: '아이가 갔다.' },
      { type: 'text', speaker: '', text: '원장실은 늘 담배 냄새가 났다. 낡은 가죽 의자. 서류들이 쌓인 책상.' },
      { type: 'text', speaker: '주작', text: '"내일 시장 심부름 갈 수 있지?"' },
      { type: 'text', speaker: '', text: '"네."' },
      { type: 'text', speaker: '', text: '"일찍 나가야 해. 늦으면 안 돼."' },
      { type: 'text', speaker: '', text: '"알겠어요."' },
      { type: 'text', speaker: '', text: '"그래. 가봐."' },
      { type: 'text', speaker: '', text: '아이가 돌아섰다.' },
      { type: 'text', speaker: '', text: '"아, 그리고."' },
      { type: 'text', speaker: '', text: '선생님이 말했다.' },
      { type: 'text', speaker: '', text: '"뭔가 필요한 거 있어?"' },
      { type: 'text', speaker: '', text: '아이가 멈췄다.' },
      { type: 'text', speaker: '', text: '생각했다.' },
      { type: 'text', speaker: '', text: '필요한 거.' },
      { type: 'text', speaker: '', text: '담요가 더 있으면 좋겠다. 미나 것 말고 자기 것도.' },
      { type: 'text', speaker: '', text: '밥이 조금 더 있으면 좋겠다.' },
      { type: 'text', speaker: '', text: '이름을 불러주는 사람이 있으면 좋겠다.' },
      { type: 'text', speaker: '', text: '아이가 말했다.' },
      { type: 'text', speaker: '', text: '"없어요."' },
      { type: 'text', speaker: '', text: '선생님이 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '아이가 방으로 돌아갔다.' },
      { type: 'text', speaker: '', text: '밤이었다.' },
      { type: 'text', speaker: '', text: '창문 너머로 별이 보였다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘에 붉은 별 하나.' },
      { type: 'text', speaker: '', text: '별빛이 붉고 또렷했다. 다른 별들과 달랐다.' },
      { type: 'text', speaker: '', text: '아이는 그 별을 봤다.' },
      { type: 'text', speaker: '', text: '왠지 저 별이 자기 것 같은 느낌이 들었다.' },
      { type: 'text', speaker: '', text: '어디서 오는 느낌인지 몰랐다.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '저 별이 자기를 알고 있는 것 같았다.' },
      { type: 'text', speaker: '', text: '이름도 없는 자기를.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '알고 있는 것 같았다.' },
      { type: 'text', speaker: '', text: '그날 밤 상길이가 왔다.' },
      { type: 'text', speaker: '', text: '"야."' },
      { type: 'text', speaker: '', text: '아이가 눈을 떴다.' },
      { type: 'text', speaker: '', text: '"뭐야."' },
      { type: 'text', speaker: '', text: '"미나가 울어. 가봐."' },
      { type: 'text', speaker: '', text: '"왜 나한테."' },
      { type: 'text', speaker: '', text: '"네가 잘 달래잖아."' },
      { type: 'text', speaker: '', text: '상길이가 그렇게 말하고 가버렸다.' },
      { type: 'text', speaker: '', text: '뒤통수를 보며 생각했다. 상길이도 알고 있구나. 미나가 누구한테 달려가는지. 그리고 누가 달려가야 하는지.' },
      { type: 'text', speaker: '', text: '그걸 알면서.' },
      { type: 'text', speaker: '', text: '나한테 말한다.' },
      { type: 'text', speaker: '', text: '아이가 일어났다.' },
      { type: 'text', speaker: '', text: '방이 차가웠다. 봄인데도 밤은 차가웠다. 맨발로 마루를 밟으면 시렸다.' },
      { type: 'text', speaker: '', text: '미나가 자는 방으로 갔다.' },
      { type: 'text', speaker: '', text: '미나가 작게 울고 있었다.' },
      { type: 'text', speaker: '', text: '이불 속에서. 얼굴을 묻고.' },
      { type: 'text', speaker: '', text: '"미나야."' },
      { type: 'text', speaker: '', text: '아이가 불렀다.' },
      { type: 'text', speaker: '', text: '미나가 눈을 떴다.' },
      { type: 'text', speaker: '', text: '"언니."' },
      { type: 'text', speaker: '', text: '미나는 아이를 언니라고 불렀다.' },
      { type: 'text', speaker: '', text: '이름 대신.' },
      { type: 'text', speaker: '', text: '그래도 괜찮았다.' },
      { type: 'text', speaker: '', text: '아무도 이름을 안 불러주는 것보다.' },
      { type: 'text', speaker: '', text: '뭔가로 불리는 게 나았다.' },
      { type: 'text', speaker: '', text: '아이가 미나 옆에 앉았다.' },
      { type: 'text', speaker: '', text: '"뭐가 무서워?"' },
      { type: 'text', speaker: '', text: '"꿈에서 무서운 거 나왔어."' },
      { type: 'text', speaker: '', text: '"뭐가."' },
      { type: 'text', speaker: '', text: '"불이요. 엄청 큰 불."' },
      { type: 'text', speaker: '', text: '아이가 잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '"불이?"' },
      { type: 'text', speaker: '', text: '"응. 근데 무서운 불이 아니었어. 근데 무서웠어."' },
      { type: 'text', speaker: '', text: '"그게 무슨 말이야."' },
      { type: 'text', speaker: '', text: '미나가 코를 훌쩍였다.' },
      { type: 'text', speaker: '', text: '"뜨거운데 안 태워. 밝은데 눈도 안 아파. 근데 무서웠어."' },
      { type: 'text', speaker: '', text: '무섭지 않은 불. 그런데 무서운 불.' },
      { type: 'text', speaker: '', text: '아이는 그 말이 이상하게 걸렸다.' },
      { type: 'text', speaker: '', text: '무섭지 않은 불.' },
      { type: 'text', speaker: '', text: '그게 뭔지 알 것 같기도 했다.' },
      { type: 'text', speaker: '', text: '손이 잠깐 따뜻해지는 것 같았다. 손끝에서 아주 희미하게 뭔가가 빛난 것도 같았다. 착각일 수도 있었다.' },
      { type: 'text', speaker: '', text: '하지만 열기는 분명했다. 손바닥 한가운데에서, 아주 작고 낮은 열이 올라왔다.' },
      { type: 'text', speaker: '', text: '아이가 미나의 머리를 쓰다듬었다.' },
      { type: 'text', speaker: '', text: '작고 얇은 머리카락. 부드럽고 보드라운.' },
      { type: 'text', speaker: '', text: '미나가 쓰다듬은 자리에서 이불이 살짝 따뜻해졌다. 마른 풀 냄새가 희미하게 났다.' },
      { type: 'text', speaker: '주작', text: '"꿈이야. 괜찮아."' },
      { type: 'text', speaker: '', text: '"언니는 무서운 꿈 안 꿔?"' },
      { type: 'text', speaker: '', text: '아이가 생각했다.' },
      { type: 'text', speaker: '', text: '"꿔."' },
      { type: 'text', speaker: '', text: '"뭐가 나와?"' },
      { type: 'text', speaker: '', text: '"이름 없는 꿈."' },
      { type: 'text', speaker: '', text: '"이름이요?"' },
      { type: 'text', speaker: '', text: '"아무도 나를 부르지 않는 꿈."' },
      { type: 'text', speaker: '', text: '미나가 고개를 들었다.' },
      { type: 'text', speaker: '', text: '"언니 이름이 뭐야?"' },
      { type: 'text', speaker: '', text: '아이가 잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"주작이라고?"' },
      { type: 'text', speaker: '주작', text: '"응."' },
      { type: 'text', speaker: '', text: '"주작 언니."' },
      { type: 'text', speaker: '', text: '아이가 멈췄다.' },
      { type: 'text', speaker: '', text: '숨이 살짝 멎는 것 같았다.' },
      { type: 'text', speaker: '', text: '"그렇게 부르면 되는 거야?"' },
      { type: 'text', speaker: '', text: '미나가 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '"주작 언니."' },
      { type: 'text', speaker: '', text: '이름을 불러줬다.' },
      { type: 'text', speaker: '', text: '이름을.' },
      { type: 'text', speaker: '', text: '아이의 눈이 잠깐 흔들렸다.' },
      { type: 'text', speaker: '', text: '코끝이 이상하게 따가웠다.' },
      { type: 'text', speaker: '', text: '"...응."' },
      { type: 'text', speaker: '', text: '대답했다.' },
      { type: 'text', speaker: '', text: '그게 전부였다.' },
      { type: 'text', speaker: '', text: '미나는 금방 잠들었다.' },
      { type: 'text', speaker: '', text: '아이는 한참 미나 옆에 있다가 방으로 돌아왔다.' },
      { type: 'text', speaker: '', text: '이불을 끌어안고 누웠다.' },
      { type: 'text', speaker: '', text: '차가운 이불이 천천히 따뜻해졌다.' },
      { type: 'text', speaker: '', text: '주작 언니.' },
      { type: 'text', speaker: '', text: '그 말이 귀에 남았다.' },
      { type: 'text', speaker: '', text: '이름을 불러줬다.' },
      { type: 'text', speaker: '', text: '이름을.' },
      { type: 'text', speaker: '', text: '심장이 이상하게 뛰었다.' },
      { type: 'text', speaker: '', text: '아이는 그게 뭔지 몰랐다.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '따뜻했다.' },
      { type: 'text', speaker: '', text: '태어나서 처음으로, 이름이 불린 밤이었다.' },
      { type: 'text', speaker: '', text: '밖에서 바람이 불었다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘의 붉은 별이 빛났다.' },
      { type: 'text', speaker: '', text: '아이는 눈을 감았다.' },
      { type: 'text', speaker: '', text: '다음 날 아침이었다.' },
      { type: 'text', speaker: '', text: '아이가 밥을 지었다.' },
      { type: 'text', speaker: '', text: '스물두 명 분량.' },
      { type: 'text', speaker: '', text: '가마솥 앞에서 혼자 저었다.' },
      { type: 'text', speaker: '', text: '불이 뜨거웠다. 연기가 올라왔다. 눈이 매웠다.' },
      { type: 'text', speaker: '', text: '"야, 빨리 안 해?"' },
      { type: 'text', speaker: '', text: '상길이가 와서 뚜껑을 열어봤다.' },
      { type: 'text', speaker: '', text: '"다 됐어."' },
      { type: 'text', speaker: '', text: '"뭐야 이게. 좀 더 끓여."' },
      { type: 'text', speaker: '', text: '"더 끓이면 타."' },
      { type: 'text', speaker: '', text: '"그럼 밥이 딱딱하잖아."' },
      { type: 'text', speaker: '', text: '"딱딱한 게 낫지 탄 것보다."' },
      { type: 'text', speaker: '', text: '상길이가 코웃음을 쳤다.' },
      { type: 'text', speaker: '', text: '"어쨌든 해. 야."' },
      { type: 'text', speaker: '', text: '아이가 국자를 잡았다.' },
      { type: 'text', speaker: '', text: '야.' },
      { type: 'text', speaker: '', text: '또 야였다.' },
      { type: 'text', speaker: '', text: '아이는 국자를 저었다.' },
      { type: 'text', speaker: '', text: '저으면서 생각했다.' },
      { type: 'text', speaker: '', text: '오늘도 이름이 불리지 않았다.' },
      { type: 'text', speaker: '', text: '어제 미나가 불러줬다.' },
      { type: 'text', speaker: '', text: '주작 언니.' },
      { type: 'text', speaker: '', text: '그게 오늘 하루를 버티게 해줄 것 같았다.' },
      { type: 'text', speaker: '', text: '그걸로 됐다.' },
      { type: 'text', speaker: '', text: '오전에 심부름을 갔다.' },
      { type: 'text', speaker: '', text: '시장 골목.' },
      { type: 'text', speaker: '', text: '아침부터 소란스러웠다. 노점들이 물건을 늘어놓고 있었다. 생선 냄새. 채소 냄새. 사람 냄새.' },
      { type: 'text', speaker: '', text: '사람들이 많았다.' },
      { type: 'text', speaker: '', text: '아이는 사람들 사이를 걸었다.' },
      { type: 'text', speaker: '', text: '아무도 아이를 보지 않았다.' },
      { type: 'text', speaker: '', text: '당연했다.' },
      { type: 'text', speaker: '', text: '이름 없는 사람은 보이지 않는다.' },
      { type: 'text', speaker: '', text: '보이지 않는 사람이 되면. 부딪혀도 아무도 미안하다고 하지 않는다. 그냥 지나간다.' },
      { type: 'text', speaker: '', text: '아이는 어깨를 좁혔다. 부딪힌 사람이 혀를 찼다. 미안하다는 말은 없었다.' },
      { type: 'text', speaker: '', text: '더 작아졌다.' },
      { type: 'text', speaker: '', text: '시장에서 필요한 것들을 샀다.' },
      { type: 'text', speaker: '', text: '채소. 소금. 간장.' },
      { type: 'text', speaker: '', text: '무거웠다.' },
      { type: 'text', speaker: '', text: '둘이 들어야 할 것들을 혼자 들었다.' },
      { type: 'text', speaker: '', text: '어깨가 빠질 것 같았다. 손바닥에 자국이 생겼다. 끈이 파고들어서.' },
      { type: 'text', speaker: '', text: '아이는 그냥 들었다.' },
      { type: 'text', speaker: '', text: '도와달라고 말하지 않았다.' },
      { type: 'text', speaker: '', text: '말해도 아무도 안 도와줄 것 같아서가 아니었다. 말하는 게 익숙하지 않았다.' },
      { type: 'text', speaker: '', text: '돌아오는 길에 골목에서 소리가 들렸다.' },
      { type: 'text', speaker: '', text: '"야, 이 꼬마 좀 봐."' },
      { type: 'text', speaker: '', text: '아이가 멈췄다.' },
      { type: 'text', speaker: '', text: '골목 안쪽에 아이들이 있었다.' },
      { type: 'text', speaker: '', text: '고아원 아이들이 아니었다.' },
      { type: 'text', speaker: '', text: '동네 아이들. 옷이 깨끗했다. 신발이 새 것이었다.' },
      { type: 'text', speaker: '', text: '가운데 작은 아이가 웅크리고 있었다.' },
      { type: 'text', speaker: '', text: '울고 있었다.' },
      { type: 'text', speaker: '', text: '무릎을 껴안고. 머리를 숙이고.' },
      { type: 'text', speaker: '', text: '"야, 울지 마. 더 맞고 싶어?"' },
      { type: 'text', speaker: '', text: '아이가 짐을 내려놓았다.' },
      { type: 'text', speaker: '', text: '골목으로 들어갔다.' },
      { type: 'text', speaker: '', text: '"잠깐."' },
      { type: 'text', speaker: '', text: '자기 목소리였다.' },
      { type: 'text', speaker: '', text: '동네 아이들이 돌아봤다.' },
      { type: 'text', speaker: '', text: '"뭐야."' },
      { type: 'text', speaker: '', text: '"그 애 놔줘."' },
      { type: 'text', speaker: '', text: '"왜? 네가 뭔데?"' },
      { type: 'text', speaker: '', text: '아이가 멈췄다.' },
      { type: 'text', speaker: '', text: '뭔데.' },
      { type: 'text', speaker: '', text: '이름이 없으면 대답할 수가 없었다.' },
      { type: 'text', speaker: '', text: '뭔데.' },
      { type: 'text', speaker: '', text: '뭔지 말하려면 이름이 있어야 했다.' },
      { type: 'text', speaker: '', text: '이름 없는 사람은 뭔데에 대답을 못 했다.' },
      { type: 'text', speaker: '', text: '"그냥."' },
      { type: 'text', speaker: '', text: '아이가 말했다.' },
      { type: 'text', speaker: '', text: '"무섭게 하지 마. 작잖아."' },
      { type: 'text', speaker: '', text: '"네가 뭔데 참견이야. 너도 맞을래?"' },
      { type: 'text', speaker: '', text: '아이가 가운데 아이 앞으로 나갔다.' },
      { type: 'text', speaker: '', text: '막았다.' },
      { type: 'text', speaker: '', text: '그 아이 앞을.' },
      { type: 'text', speaker: '', text: '손바닥이 뜨거워졌다. 주먹을 쥐자 공기가 일그러지는 것 같았다. 착각일 수도 있었다.' },
      { type: 'text', speaker: '', text: '뒤에서 아이의 울음소리가 들렸다. 작고 참은. 더 울지 못하고.' },
      { type: 'text', speaker: '', text: '동네 아이들이 웃었다.' },
      { type: 'text', speaker: '', text: '"진짜 맞고 싶어?"' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"야, 고아원 애잖아. 쟤도."' },
      { type: 'text', speaker: '', text: '아이가 눈을 들었다.' },
      { type: 'text', speaker: '', text: '"맞아."' },
      { type: 'text', speaker: '', text: '"그러면 더 건드려도 되겠다."' },
      { type: 'text', speaker: '', text: '"아니."' },
      { type: 'text', speaker: '', text: '아이가 말했다.' },
      { type: 'text', speaker: '', text: '이상하게 단단한 목소리로.' },
      { type: 'text', speaker: '', text: '"우리 고아원 애라도 이름은 있어. 이름 있는 사람한테 그러는 거 아니야."' },
      { type: 'text', speaker: '', text: '동네 아이들이 멈췄다.' },
      { type: 'text', speaker: '', text: '잠깐 눈치를 봤다.' },
      { type: 'text', speaker: '', text: '그러다가 그냥 가버렸다.' },
      { type: 'text', speaker: '', text: '재미없다는 듯이. 못 이길 것 같다는 듯이. 아이의 주먹 가까이에 있던 풀잎이 끝부터 말라 있었다. 아무도 알아차리지 못했다.' },
      { type: 'text', speaker: '', text: '아이가 뒤를 돌았다.' },
      { type: 'text', speaker: '', text: '웅크린 아이가 고개를 들었다.' },
      { type: 'text', speaker: '', text: '눈이 빨갰다.' },
      { type: 'text', speaker: '', text: '코가 흘렀다.' },
      { type: 'text', speaker: '', text: '"...이름이 뭐야?"' },
      { type: 'text', speaker: '', text: '아이가 물었다.' },
      { type: 'text', speaker: '', text: '작은 아이가 조용히 이름을 말했다.' },
      { type: 'text', speaker: '', text: '아이가 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '"그거야. 그 이름이야. 잊지 마."' },
      { type: 'text', speaker: '', text: '집으로 돌아갔다.' },
      { type: 'text', speaker: '', text: '무거운 짐을 들고.' },
      { type: 'text', speaker: '', text: '어깨가 아팠다.' },
      { type: 'text', speaker: '', text: '괜찮았다. 이름을 지켜주는 게 이렇게 무거운 건지 처음 알았다.' },
      { type: 'text', speaker: '', text: '그날 오후.' },
      { type: 'text', speaker: '', text: '원장이 아이를 불렀다.' },
      { type: 'text', speaker: '', text: '"야, 거기."' },
      { type: 'text', speaker: '', text: '아이가 갔다.' },
      { type: 'text', speaker: '', text: '"손님이 올 거야. 내일."' },
      { type: 'text', speaker: '', text: '"무슨 손님이요?"' },
      { type: 'text', speaker: '', text: '"입양 문의."' },
      { type: 'text', speaker: '', text: '아이가 멈췄다.' },
      { type: 'text', speaker: '', text: '입양.' },
      { type: 'text', speaker: '', text: '"누구를요?"' },
      { type: 'text', speaker: '', text: '"모르겠어. 아직."' },
      { type: 'text', speaker: '', text: '원장이 서류를 봤다.' },
      { type: 'text', speaker: '', text: '안경 너머로. 두꺼운 서류 더미.' },
      { type: 'text', speaker: '', text: '"아마 너한테 올 것 같아."' },
      { type: 'text', speaker: '', text: '"저한테요?"' },
      { type: 'text', speaker: '', text: '"이상하게 네 나이대를 원하더라고. 이름도 물어보더라. 주작이 맞냐고."' },
      { type: 'text', speaker: '', text: '아이가 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '"알겠어요."' },
      { type: 'text', speaker: '', text: '방으로 돌아갔다.' },
      { type: 'text', speaker: '', text: '입양.' },
      { type: 'text', speaker: '', text: '그 말을 씹었다.' },
      { type: 'text', speaker: '', text: '입양이 되면 달라질까.' },
      { type: 'text', speaker: '', text: '이름을 불러줄까.' },
      { type: 'text', speaker: '', text: '아이가 창문을 봤다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '붉은 별이 아직 보이지 않았다.' },
      { type: 'text', speaker: '', text: '해가 지지 않았으니까.' },
      { type: 'text', speaker: '', text: '아이는 해가 지기를 기다렸다.' },
      { type: 'text', speaker: '', text: '별이 보이면.' },
      { type: 'text', speaker: '', text: '그 별이 자기를 알아볼 것 같아서.' },
      { type: 'text', speaker: '', text: '이름도 없이.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '알아볼 것 같아서.' },
      { type: 'text', speaker: '', text: '밤에 상길이가 왔다.' },
      { type: 'text', speaker: '', text: '또 뭔가를 가져갔다.' },
      { type: 'text', speaker: '', text: '아이의 담요를.' },
      { type: 'text', speaker: '', text: '"추워."' },
      { type: 'text', speaker: '', text: '상길이가 말했다.' },
      { type: 'text', speaker: '', text: '방에 들어와서. 담요를 잡아당겼다.' },
      { type: 'text', speaker: '', text: '"나도 추워."' },
      { type: 'text', speaker: '', text: '"나 먼저야."' },
      { type: 'text', speaker: '', text: '아이가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '상길이가 맞았다.' },
      { type: 'text', speaker: '', text: '추워 보였다.' },
      { type: 'text', speaker: '', text: '웃옷 하나만 입고 있었다. 입술이 파래져 있었다.' },
      { type: 'text', speaker: '', text: '아이가 담요를 줬다.' },
      { type: 'text', speaker: '', text: '상길이가 가져갔다.' },
      { type: 'text', speaker: '', text: '아이는 이불 끝을 당겨 덮었다.' },
      { type: 'text', speaker: '', text: '부족했다.' },
      { type: 'text', speaker: '', text: '괜찮았다.' },
      { type: 'text', speaker: '', text: '내일이면 어차피 돌려받을 테니까.' },
      { type: 'text', speaker: '', text: '돌려받을 수 있을지 몰랐지만.' },
      { type: 'text', speaker: '', text: '어쨌든.' },
      { type: 'text', speaker: '', text: '괜찮았다.' },
      { type: 'text', speaker: '', text: '창문 너머로 별이 보였다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '붉고 작은 별.' },
      { type: 'text', speaker: '', text: '아이가 그걸 봤다.' },
      { type: 'text', speaker: '', text: '손바닥이 다시 뜨거워졌다. 낮에 느꼈던 그 열기. 별빛을 보는데 손이 반응했다. 태어날 때부터 손 안에 잠들어 있던 것이 눈을 뜨는 것 같았다.' },
      { type: 'effect', effect: 'system', text: '【남방주작성 감응. 신수 미각성 상태. 잠재력 측정 불가.】' },
      { type: 'effect', effect: 'system', text: '【잔열 감지. 유대 에너지 미발현. 각성 조건: 이름의 호명.】' },
      { type: 'effect', effect: 'system', text: '【잠재 등급: ???. 화속성 친화도: 극상.】' },
      { type: 'text', speaker: '', text: '저 별에서 이름이 온 것 같은 느낌.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '어디서 온 이름인지. 왜 이름인지.' },
      { type: 'text', speaker: '', text: '모르지만.' },
      { type: 'text', speaker: '', text: '저 별이 알고 있을 것 같은 느낌.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '아이가 혼자 중얼거렸다.' },
      { type: 'text', speaker: '', text: '자기 이름을.' },
      { type: 'text', speaker: '', text: '자기가 자기 이름을 불렀다.' },
      { type: 'text', speaker: '', text: '이상하게 쓸쓸했다.' },
      { type: 'text', speaker: '', text: '이상하게 따뜻했다.' },
      { type: 'text', speaker: '', text: '둘 다였다.' },
      { type: 'text', speaker: '', text: '아이는 눈을 감았다.' },
      { type: 'text', speaker: '', text: '내일.' },
      { type: 'text', speaker: '', text: '손님이 온다고 했다.' },
      { type: 'text', speaker: '', text: '입양 문의.' },
      { type: 'text', speaker: '', text: '달라질까.' },
      { type: 'text', speaker: '', text: '달라질지도.' },
      { type: 'text', speaker: '', text: '아이는 그 생각을 하면서 잠들었다.' },
      { type: 'text', speaker: '', text: '그리고 다음 날 아침.' },
      { type: 'text', speaker: '', text: '해가 떴다.' },
      { type: 'text', speaker: '', text: '창문으로 봄 햇살이 들어왔다.' },
      { type: 'text', speaker: '', text: '주작이 눈을 떴다.' },
      { type: 'text', speaker: '', text: '오늘이다.' },
      { type: 'text', speaker: '', text: '손님이 오는 날.' },
      { type: 'text', speaker: '', text: '잠에서 깬 지 얼마 안 됐는데.' },
      { type: 'text', speaker: '', text: '이상하게 가슴이 두근거렸다.' },
      { type: 'text', speaker: '', text: '무서운 건 아니었다.' },
      { type: 'text', speaker: '', text: '기대인 건지.' },
      { type: 'text', speaker: '', text: '불안인 건지.' },
      { type: 'text', speaker: '', text: '구분이 안 됐다.' },
      { type: 'text', speaker: '', text: '일어나서 세수를 했다.' },
      { type: 'text', speaker: '', text: '찬물로.' },
      { type: 'text', speaker: '', text: '얼굴이 차가워졌다.' },
      { type: 'text', speaker: '', text: '맑아졌다.' },
      { type: 'text', speaker: '', text: '거울이 없었다.' },
      { type: 'text', speaker: '', text: '그냥 물을 닦으면서 생각했다.' },
      { type: 'text', speaker: '', text: '어떤 사람이 올까.' },
      { type: 'text', speaker: '', text: '이름을 불러줄 사람이면 좋겠다.' },
      { type: 'text', speaker: '', text: '그냥 이름으로.' },
      { type: 'text', speaker: '', text: '야. 거기. 그런 거 말고.' },
      { type: 'text', speaker: '', text: '주작이라고.' },
      { type: 'text', speaker: '', text: '그냥.' },
      { type: 'text', speaker: '', text: '불러줄 사람이면.' },
      { type: 'text', speaker: '', text: '그것만으로 됐다.' },
      { type: 'text', speaker: '', text: '가마솥 앞에 섰다. 스물두 명 분량. 오늘이 마지막일 수도 있었다.' },
      { type: 'text', speaker: '', text: '그렇게 생각하니.' },
      { type: 'text', speaker: '', text: '손이 더 꼼꼼하게 움직였다.' },
      { type: 'text', speaker: '', text: '마지막이라면.' },
      { type: 'text', speaker: '', text: '잘 해주고 싶었다.' },
      { type: 'text', speaker: '', text: '스물두 명을 위한 마지막 밥.' },
      { type: 'text', speaker: '', text: '문이 두드려졌다.' },
      { type: 'effect', effect: 'system', text: '【대상 탐지. 고아원 내부. 신수 주작. 구출 권장.】' },
      { type: 'text', speaker: '', text: '플레이어가 고아원 문을 열고 들어갔다.' },
      { type: 'text', speaker: '', text: '그 옆에 왜소한 신이 있었다.' },
      { type: 'text', speaker: '', text: '조용하고 작은 무언가.' },
      { type: 'text', speaker: '', text: '아무 말도 하지 않는.' },
      { type: 'text', speaker: '', text: '그 존재가 뒷마당 창문 너머를 봤다.' },
      { type: 'text', speaker: '', text: '주작이 그걸 봤다.' },
      { type: 'text', speaker: '', text: '작고 동그란 것이.' },
      { type: 'text', speaker: '', text: '자기를 보고 있었다.' },
      { type: 'text', speaker: '', text: '심장이 뛰었다.' },
      { type: 'text', speaker: '', text: '손 안의 잔열이 한 번 크게 뛰었다.' },
      { type: 'text', speaker: '', text: '저게.' },
      { type: 'text', speaker: '', text: '뭐지.' },
      { type: 'text', speaker: '', text: '귀엽다.' },
      { type: 'text', speaker: '', text: '"주작아."' },
      { type: 'text', speaker: '', text: '원장이 불렀다.' },
      { type: 'text', speaker: '', text: '주작이 일어섰다.' },
      { type: 'text', speaker: '', text: '가는 길에 생각했다.' },
      { type: 'text', speaker: '', text: '달라진다.' },
      { type: 'text', speaker: '', text: '이번엔 달라진다.' },
      { type: 'text', speaker: '', text: '확신이었다.' },
      { type: 'text', speaker: '', text: '어디서 오는 확신인지.' },
      { type: 'text', speaker: '', text: '몰랐다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '불씨가 한 번 붙으면 꺼지지 않는 것처럼. 이 만남도 그런 것 같았다.' },
      { type: 'text', speaker: '', text: '달라질 것 같았다.' },
      { type: 'text', speaker: '', text: '아니. 달라진다.' },
    ]
  },
  {
    title: '- 수정3: "고아원에서는요~고개를 끄덕여주니까요" 중간 해설 삭제 → 2장 내 "당신은 그냥~" 패턴 변주 (-6줄)',
    nodes: [
      { type: 'text', speaker: '', text: '타겟 평가자: 버프(시스템 밀도), 감사 표현 패턴 변주 기대 효과: 2장 전반부 시스템 밀도 보강, 중반부 대화 호흡 개선' },
      { type: 'text', speaker: '', text: '2장. 입양' },
      { type: 'text', speaker: '', text: '원장 방에 들어섰을 때.' },
      { type: 'text', speaker: '', text: '원장실 문을 여는 손이 떨렸다. 입양이라는 말이 아직 귀에 남아 있었다.' },
      { type: 'text', speaker: '', text: '낯선 어른이 있었다.' },
      { type: 'text', speaker: '', text: '플레이어였다.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '', text: '그냥 사람.' },
      { type: 'text', speaker: '', text: '특별한 게 없어 보이는 사람.' },
      { type: 'text', speaker: '', text: '근데.' },
      { type: 'text', speaker: '', text: '이상하게.' },
      { type: 'text', speaker: '', text: '옆에 작고 조용한 존재가 서 있었다.' },
      { type: 'text', speaker: '', text: '왜소한 신.' },
      { type: 'text', speaker: '', text: '그 존재가 다시 주작을 봤다.' },
      { type: 'text', speaker: '', text: '주작도 봤다.' },
      { type: 'text', speaker: '', text: '이상한 편안함이 들었다.' },
      { type: 'text', speaker: '', text: '편안하다는 게 이상했다.' },
      { type: 'text', speaker: '', text: '낯선 사람인데. 낯선 곳인데. 낯선 눈인데.' },
      { type: 'text', speaker: '', text: '그래도 편안했다.' },
      { type: 'text', speaker: '', text: '눈이 부드러웠다. 위협적이지 않았다. 그냥 보는 눈.' },
      { type: 'text', speaker: '', text: '"주작아."' },
      { type: 'text', speaker: '', text: '원장이 말했다.' },
      { type: 'text', speaker: '', text: '"이분이 너랑 같이 살고 싶다고 하셨어."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'effect', effect: 'system', text: '【신수 주작을 구출하십시오. 훈련을 통해 각성을 이끄십시오.】' },
      { type: 'text', speaker: '', text: '시스템 창 메시지가 플레이어에게만 보였다.' },
      { type: 'text', speaker: '', text: '주작은 몰랐다.' },
      { type: 'text', speaker: '', text: '그냥 플레이어를 봤다.' },
      { type: 'text', speaker: '', text: '"같이 갈래?"' },
      { type: 'text', speaker: '', text: '플레이어가 물었다.' },
      { type: 'text', speaker: '', text: '주작이 생각했다.' },
      { type: 'text', speaker: '', text: '고아원.' },
      { type: 'text', speaker: '', text: '스물두 명.' },
      { type: 'text', speaker: '', text: '야. 거기. 너.' },
      { type: 'text', speaker: '', text: '상길이. 미나. 텃밭. 담요. 심부름.' },
      { type: 'text', speaker: '', text: '이름 없는 하루.' },
      { type: 'text', speaker: '', text: '"갈게요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '', text: '이유를 굳이 따지지 않았다.' },
      { type: 'text', speaker: '', text: '그냥 가야 할 것 같았다.' },
      { type: 'text', speaker: '', text: '처음 보는 사람인데.' },
      { type: 'text', speaker: '', text: '이상하게.' },
      { type: 'text', speaker: '', text: '믿어도 될 것 같은 눈이었다.' },
      { type: 'text', speaker: '', text: '짐이 많지 않았다.' },
      { type: 'text', speaker: '', text: '주작의 짐은 작은 보따리 하나였다.' },
      { type: 'text', speaker: '', text: '옷 두 벌. 낡은 빗.' },
      { type: 'text', speaker: '', text: '별것 없었다.' },
      { type: 'text', speaker: '', text: '고아원에서 사 년을 살면서.' },
      { type: 'text', speaker: '', text: '이게 전부였다.' },
      { type: 'text', speaker: '', text: '방을 한 번 돌아봤다.' },
      { type: 'text', speaker: '', text: '침대. 창문. 벽.' },
      { type: 'text', speaker: '', text: '아무것도 없는 방.' },
      { type: 'text', speaker: '', text: '뭔가 있었으면 하는 생각이 있었지만.' },
      { type: 'text', speaker: '', text: '남겨두고 갈 게 없었다.' },
      { type: 'text', speaker: '', text: '대신.' },
      { type: 'text', speaker: '', text: '미나한테 뭔가 줄 수 있으면 좋겠다는 생각을 했다.' },
      { type: 'text', speaker: '', text: '아무것도 없었다.' },
      { type: 'text', speaker: '', text: '그래서.' },
      { type: 'text', speaker: '', text: '"미나야."' },
      { type: 'text', speaker: '', text: '방을 나가기 전에.' },
      { type: 'text', speaker: '', text: '미나를 찾아갔다.' },
      { type: 'text', speaker: '', text: '미나가 아직 자고 있었다.' },
      { type: 'text', speaker: '', text: '작은 몸.' },
      { type: 'text', speaker: '', text: '이불이 반쯤 내려가 있었다.' },
      { type: 'text', speaker: '', text: '주작이 이불을 올려줬다.' },
      { type: 'text', speaker: '', text: '마지막으로.' },
      { type: 'text', speaker: '', text: '"잘 자."' },
      { type: 'text', speaker: '', text: '조용히 말했다.' },
      { type: 'text', speaker: '', text: '미나가 잠꼬대를 했다.' },
      { type: 'text', speaker: '', text: '"...주작 언니."' },
      { type: 'text', speaker: '', text: '잠꼬대로.' },
      { type: 'text', speaker: '', text: '이름을 불렀다.' },
      { type: 'text', speaker: '', text: '주작이 멈췄다.' },
      { type: 'text', speaker: '', text: '자면서도.' },
      { type: 'text', speaker: '', text: '이름을 불렀다.' },
      { type: 'text', speaker: '', text: '"...응. 여기 있어."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '', text: '마지막으로.' },
      { type: 'text', speaker: '', text: '그리고 나왔다.' },
      { type: 'text', speaker: '', text: '보따리를 묶으면서 생각했다.' },
      { type: 'text', speaker: '', text: '그래도 미나가 있었다.' },
      { type: 'text', speaker: '', text: '상길이도 있었다.' },
      { type: 'text', speaker: '', text: '이름이 있었다.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '무언가이긴 했다.' },
      { type: 'text', speaker: '', text: '원장이 서류에 도장을 찍었다.' },
      { type: 'text', speaker: '', text: '딱딱딱.' },
      { type: 'text', speaker: '', text: '소리가 났다.' },
      { type: 'text', speaker: '', text: '아이들이 나와서 봤다.' },
      { type: 'text', speaker: '', text: '상길이가 있었다.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '', text: '상길이가 고개를 돌렸다.' },
      { type: 'text', speaker: '', text: '안 봤다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '손을 올렸다가 내렸다.' },
      { type: 'text', speaker: '', text: '거의 보이지 않게.' },
      { type: 'text', speaker: '', text: '그게.' },
      { type: 'text', speaker: '', text: '작별인사였을 수도 있었다.' },
      { type: 'text', speaker: '', text: '미나가 있었다.' },
      { type: 'text', speaker: '', text: '"주작 언니."' },
      { type: 'text', speaker: '', text: '미나가 달려왔다.' },
      { type: 'text', speaker: '', text: '주작이 무릎을 꿇었다.' },
      { type: 'text', speaker: '주작', text: '"미나야."' },
      { type: 'text', speaker: '', text: '"가요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '미나의 눈이 빨개졌다.' },
      { type: 'text', speaker: '', text: '"또 와요?"' },
      { type: 'text', speaker: '', text: '주작이 잠깐 멈췄다.' },
      { type: 'text', speaker: '주작', text: '"...올게."' },
      { type: 'text', speaker: '', text: '"약속해요?"' },
      { type: 'text', speaker: '', text: '주작이 미나의 머리를 쓰다듬었다.' },
      { type: 'text', speaker: '', text: '미나의 머리카락이 이마에 달라붙어 있었다. 달려오면서 땀이 난 것 같았다.' },
      { type: 'text', speaker: '', text: '"약속."' },
      { type: 'text', speaker: '', text: '미나가 코를 훌쩍였다.' },
      { type: 'text', speaker: '', text: '"주작 언니. 주작. 이름. 잊지 마."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"알아."' },
      { type: 'text', speaker: '', text: '일어섰다.' },
      { type: 'text', speaker: '', text: '플레이어가 기다리고 있었다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 옆에 있었다.' },
      { type: 'text', speaker: '', text: '셋이 고아원 문을 나왔다.' },
      { type: 'text', speaker: '', text: '봄 바람이 불었다.' },
      { type: 'text', speaker: '', text: '주작이 한 번 돌아봤다.' },
      { type: 'text', speaker: '', text: '미나가 손을 흔들고 있었다.' },
      { type: 'text', speaker: '', text: '상길이는 없었다.' },
      { type: 'text', speaker: '', text: '이미 안으로 들어간 것 같았다.' },
      { type: 'text', speaker: '', text: '주작이 다시 앞을 봤다.' },
      { type: 'text', speaker: '', text: '새 길.' },
      { type: 'text', speaker: '', text: '플레이어의 집은 도시 안쪽에 있었다.' },
      { type: 'text', speaker: '', text: '고아원에서 걸어서 삼십 분.' },
      { type: 'text', speaker: '', text: '시장 골목을 지나. 작은 골목을 지나. 담장 위에 들고양이가 앉아 있는 골목을 지나.' },
      { type: 'text', speaker: '', text: '걸으면서 한 번 뒤를 돌아봤다. 쫓아오는 사람이 없다는 걸 확인하는 습관이었다.' },
      { type: 'text', speaker: '', text: '그렇게 크지 않았다.' },
      { type: 'text', speaker: '', text: '작은 마당. 방 두 개. 부엌.' },
      { type: 'text', speaker: '', text: '그게 전부였다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '마당에 풀이 났다.' },
      { type: 'text', speaker: '', text: '담장 밑에. 작고 연한 봄 풀.' },
      { type: 'text', speaker: '', text: '주작이 그걸 봤다.' },
      { type: 'text', speaker: '', text: '풀이 있었다.' },
      { type: 'text', speaker: '', text: '고아원 텃밭에도 풀은 있었지만.' },
      { type: 'text', speaker: '', text: '여기 풀은 아무도 뽑으라고 하지 않는 풀이었다.' },
      { type: 'text', speaker: '', text: '그냥 있는 풀.' },
      { type: 'text', speaker: '', text: '주작이 손끝으로 풀잎을 건드렸다. 풀잎 끝이 살짝 시들었다. 손에서 열기가 빠져나가는 것 같았다.' },
      { type: 'text', speaker: '주작', text: '"여기야."' },
      { type: 'text', speaker: '', text: '플레이어가 말했다.' },
      { type: 'text', speaker: '', text: '주작이 둘러봤다.' },
      { type: 'text', speaker: '주작', text: '"어."' },
      { type: 'text', speaker: '', text: '"불편해?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '주작이 고개를 저었다.' },
      { type: 'text', speaker: '주작', text: '"충분해요."' },
      { type: 'text', speaker: '', text: '플레이어가 방 하나를 가리켰다.' },
      { type: 'text', speaker: '', text: '"이 방 써."' },
      { type: 'text', speaker: '', text: '주작이 들어갔다.' },
      { type: 'text', speaker: '', text: '방 안에 침대가 있었다.' },
      { type: 'text', speaker: '', text: '담요가 있었다.' },
      { type: 'text', speaker: '', text: '아무도 뺏어가지 않을 담요가.' },
      { type: 'text', speaker: '', text: '주작이 담요를 만졌다.' },
      { type: 'text', speaker: '', text: '두꺼웠다.' },
      { type: 'text', speaker: '', text: '따뜻했다.' },
      { type: 'text', speaker: '', text: '아직 아무도 눕지 않은 깨끗한 담요.' },
      { type: 'text', speaker: '', text: '"필요한 거 있으면 말해."' },
      { type: 'text', speaker: '', text: '플레이어가 문 앞에서 말했다.' },
      { type: 'text', speaker: '', text: '주작이 돌아봤다.' },
      { type: 'text', speaker: '주작', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"없어요."' },
      { type: 'text', speaker: '', text: '그게 처음으로 하는 거짓말이었다.' },
      { type: 'text', speaker: '', text: '담요가 없어지지 않았으면 좋겠다는 것. 밥이 충분했으면 좋겠다는 것. 이름을 불러줬으면 좋겠다는 것.' },
      { type: 'text', speaker: '', text: '다 있었다.' },
      { type: 'text', speaker: '', text: '하지만 말하지 않았다.' },
      { type: 'text', speaker: '', text: '말하는 게 익숙하지 않았다.' },
      { type: 'text', speaker: '', text: '말했다가 힘들다는 소리를 들으면. 말하지 않은 게 낫다는 기분이 드니까.' },
      { type: 'text', speaker: '', text: '"그래."' },
      { type: 'text', speaker: '', text: '플레이어가 들어갔다.' },
      { type: 'text', speaker: '', text: '주작이 혼자 방에 남았다.' },
      { type: 'text', speaker: '', text: '창문이 있었다.' },
      { type: 'text', speaker: '', text: '열었다.' },
      { type: 'text', speaker: '', text: '바깥 공기가 들어왔다.' },
      { type: 'text', speaker: '', text: '봄 냄새.' },
      { type: 'text', speaker: '', text: '고아원과 다른 봄 냄새.' },
      { type: 'text', speaker: '', text: '더 조용하고. 더 가벼운.' },
      { type: 'text', speaker: '', text: '남쪽 하늘이 보였다.' },
      { type: 'text', speaker: '', text: '아직 낮이라 별은 없었다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '그 자리에 있을 것 같았다.' },
      { type: 'text', speaker: '', text: '주작의 별이.' },
      { type: 'text', speaker: '', text: '저기 있을 것 같았다.' },
      { type: 'text', speaker: '', text: '손바닥이 또 따뜻해졌다. 고아원에서부터 따라온 그 열기. 이 집에서도 사라지지 않았다.' },
      { type: 'effect', effect: 'system', text: '【잔열 반응 지속. 환경 변화에도 소멸하지 않음. 유대 대상 근접 시 출력 미세 증가.】' },
      { type: 'text', speaker: '', text: '첫날 밤.' },
      { type: 'text', speaker: '', text: '잠이 안 왔다.' },
      { type: 'text', speaker: '', text: '불을 껐다.' },
      { type: 'text', speaker: '', text: '어둠이 왔다.' },
      { type: 'text', speaker: '', text: '눈을 감았다.' },
      { type: 'text', speaker: '', text: '눈을 떴다.' },
      { type: 'text', speaker: '', text: '또 감았다.' },
      { type: 'text', speaker: '', text: '또 떴다.' },
      { type: 'text', speaker: '', text: '조용했다.' },
      { type: 'text', speaker: '', text: '고아원은 항상 소리가 났다. 아이들 소리. 울음소리. 뒤척이는 소리. 복도에서 발소리.' },
      { type: 'text', speaker: '', text: '여기는 조용했다.' },
      { type: 'text', speaker: '', text: '바람 소리만.' },
      { type: 'text', speaker: '', text: '조용한 게 이상했다.' },
      { type: 'text', speaker: '', text: '이상하게 불안했다.' },
      { type: 'text', speaker: '', text: '이 조용함이 좋아야 하는데.' },
      { type: 'text', speaker: '', text: '왜 이상한 걸까.' },
      { type: 'text', speaker: '', text: '주작이 앉아 있었다.' },
      { type: 'text', speaker: '', text: '이불을 끌어안고.' },
      { type: 'text', speaker: '', text: '그때 문을 두드리는 소리가 났다. 작게. 조심스럽게. 잠든 사람을 깨우는 소리가 아니라, 깨어 있는 사람을 확인하는 소리였다.' },
      { type: 'text', speaker: '', text: '"자냐?"' },
      { type: 'text', speaker: '', text: '플레이어였다.' },
      { type: 'text', speaker: '', text: '주작이 문을 열었다.' },
      { type: 'text', speaker: '주작', text: '"못 잤어요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"조용해서."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 생각했다.' },
      { type: 'text', speaker: '', text: '"뭔가 마실래?"' },
      { type: 'text', speaker: '', text: '"...따뜻한 거."' },
      { type: 'text', speaker: '', text: '주작이 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '부엌으로 갔다.' },
      { type: 'text', speaker: '', text: '플레이어가 차를 만들었다.' },
      { type: 'text', speaker: '', text: '주작이 맞은편에 앉았다.' },
      { type: 'text', speaker: '', text: '조용했다.' },
      { type: 'text', speaker: '', text: '불편하지 않은 조용함이었다.' },
      { type: 'text', speaker: '', text: '이상했다.' },
      { type: 'text', speaker: '', text: '조용한 게 이상한데.' },
      { type: 'text', speaker: '', text: '이 조용함은 이상하지 않았다.' },
      { type: 'text', speaker: '', text: '같이 있는 조용함.' },
      { type: 'text', speaker: '', text: '혼자 있는 조용함과 달랐다.' },
      { type: 'text', speaker: '', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '주작이 먼저 말했다.' },
      { type: 'text', speaker: '주작', text: '"응."' },
      { type: 'text', speaker: '', text: '"제 이름을 그냥 부르잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"고아원에서는요."' },
      { type: 'text', speaker: '', text: '주작이 찻잔을 봤다.' },
      { type: 'text', speaker: '주작', text: '"야. 거기. 너. 쟤. 그렇게 불렀어요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"이름 아는 사람이 별로 없었어요. 아니, 알아도 안 불러줬어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그래서요."' },
      { type: 'text', speaker: '', text: '주작이 찻잔을 손가락으로 감쌌다.' },
      { type: 'text', speaker: '', text: '따뜻한 도자기.' },
      { type: 'text', speaker: '', text: '손가락이 따뜻해졌다.' },
      { type: 'text', speaker: '', text: '"이름으로 불리는 게 좀 어색해요."' },
      { type: 'text', speaker: '', text: '플레이어가 고개를 끄덕였다.' },
      { type: 'text', speaker: '', text: '그러더니.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '불렀다.' },
      { type: 'text', speaker: '', text: '주작이 멈췄다.' },
      { type: 'text', speaker: '', text: '찻잔을 쥔 손가락이 하얘질 만큼 힘이 들어갔다.' },
      { type: 'text', speaker: '', text: '이름이 공기를 가로질러 왔다.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '부드럽게.' },
      { type: 'text', speaker: '', text: '"...응."' },
      { type: 'text', speaker: '', text: '"그게 이름이야."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"내가 부를 거야. 계속."' },
      { type: 'text', speaker: '', text: '주작이 찻잔을 봤다.' },
      { type: 'text', speaker: '', text: '목이 뭔가로 막힌 것 같았다.' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"이상해?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '"그래?"' },
      { type: 'text', speaker: '', text: '"그냥."' },
      { type: 'text', speaker: '', text: '주작이 차를 한 모금 마셨다.' },
      { type: 'text', speaker: '', text: '뜨겁고 달콤했다.' },
      { type: 'text', speaker: '', text: '"그냥 그 말이 좀 무거워서요."' },
      { type: 'text', speaker: '', text: '"계속 부를 거라는 말이?"' },
      { type: 'text', speaker: '', text: '"응. 계속이라는 말이."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"계속 부를 거야."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"싫어?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '주작이 고개를 저었다.' },
      { type: 'text', speaker: '주작', text: '"좋아요."' },
      { type: 'text', speaker: '', text: '조용히.' },
      { type: 'text', speaker: '', text: '목소리가 갈라졌다. 울음도 아니고 웃음도 아닌, 오래 참아온 것이 풀리는 소리였다.' },
      { type: 'text', speaker: '', text: '처음으로 좋다고 말했다.' },
      { type: 'text', speaker: '', text: '차를 다 마셨다.' },
      { type: 'text', speaker: '', text: '잔을 내려놓았다.' },
      { type: 'text', speaker: '', text: '"자러 갈게요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 일어섰다.' },
      { type: 'text', speaker: '', text: '문 쪽으로 가다가 멈췄다.' },
      { type: 'text', speaker: '', text: '"저기요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름을 계속 불러주면요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신한테 감사할 것 같아요. 계속."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"감사까지 할 거야?"' },
      { type: 'text', speaker: '', text: '"그럼요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"이름 불러주는 사람한테 감사 안 하면 이상하잖아요."' },
      { type: 'text', speaker: '', text: '"이름이 그렇게 중요해?"' },
      { type: 'text', speaker: '', text: '"당연하죠."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '', text: '조용하게. 하지만 확실하게.' },
      { type: 'text', speaker: '', text: '"이름이 없으면 저 없는 거예요. 이름이 있어야 제가 있어요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"당신이 불러줘서 오늘 제가 있어요."' },
      { type: 'text', speaker: '', text: '그 말을 하는 동안, 주작의 눈에 물기가 번졌다. 울지는 않았다. 대신 웃었다. 태어나서 처음으로, 감사해서 웃는 법을 알았다.' },
      { type: 'effect', effect: 'system', text: '【신수 주작의 신력 안정화 시작. 유대 수치 기준선 돌파. 잔열이 유대 에너지로 전환 중.】' },
      { type: 'text', speaker: '', text: '그 말을 하고.' },
      { type: 'text', speaker: '', text: '방으로 들어갔다.' },
      { type: 'text', speaker: '', text: '문이 닫혔다.' },
      { type: 'text', speaker: '', text: '플레이어가 혼자 앉아 있었다.' },
      { type: 'text', speaker: '', text: '이름이 없으면 저 없는 거예요.' },
      { type: 'text', speaker: '', text: '그 말이 오래 남았다.' },
      { type: 'text', speaker: '', text: '아주 오래.' },
      { type: 'text', speaker: '', text: '왜소한 신이 마당에서 그걸 보고 있었다.' },
      { type: 'text', speaker: '', text: '부엌 창문 너머로.' },
      { type: 'text', speaker: '', text: '조용히.' },
      { type: 'text', speaker: '', text: '살짝 고개를 기울이면서. 마치 저 안의 대화가 중요한 것처럼. 놓치고 싶지 않은 것처럼.' },
      { type: 'text', speaker: '', text: '첫 주가 지나는 동안.' },
      { type: 'text', speaker: '', text: '이불이 없어지지 않았다. 아침마다 확인했다. 그대로였다. 자기 밥도 충분히 있었다. 아무도 가져가지 않았다.' },
      { type: 'text', speaker: '', text: '플레이어가 이름을 물었을 때는 셋째 날이었다. 주작이 그 이름을 조심스럽게 불러봤다. 아직 익숙하지 않았다. "제가 부르는 건 아직 어색해요." "왜?" "처음이라서요."' },
      { type: 'text', speaker: '', text: '나흘째. 주작이 물었다. "저한테 원하는 게 있으면 말해줘요." "없어." "그러면 왜 데려온 거예요?"' },
      { type: 'text', speaker: '', text: '플레이어가 시스템 창을 봤다.' },
      { type: 'effect', effect: 'system', text: '【신수 주작을 훈련시켜 각성을 이끄십시오.】' },
      { type: 'text', speaker: '', text: '"강해져야 할 이유가 있어서."' },
      { type: 'text', speaker: '', text: '"저요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 생각했다.' },
      { type: 'text', speaker: '주작', text: '"그러면 같이 알아가는 거네요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그것도 좋아요."' },
      { type: 'text', speaker: '', text: '주작이 부엌으로 들어갔다.' },
      { type: 'text', speaker: '', text: '밥을 짓기 시작했다.' },
      { type: 'text', speaker: '', text: '자기 방식대로.' },
      { type: 'text', speaker: '', text: '플레이어가 보고 있었다.' },
      { type: 'text', speaker: '', text: '"이거 내가 할 수 있어."' },
      { type: 'text', speaker: '', text: '"저도 할 수 있어요."' },
      { type: 'text', speaker: '', text: '"너한테 이거 시키려고 데려온 게 아니야."' },
      { type: 'text', speaker: '', text: '주작이 국자를 저으면서 말했다.' },
      { type: 'text', speaker: '주작', text: '"알아요. 그냥 하고 싶어서 해요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"고아원에서는 시키면 해야 하는 게 싫었어요. 시키니까 하는 거잖아요. 제가 하고 싶을 때 하는 건 달라요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"그렇구나."' },
      { type: 'text', speaker: '', text: '어느 아침이었다.' },
      { type: 'text', speaker: '', text: '주작이 혼자 부엌에서 밥을 지었다.' },
      { type: 'text', speaker: '', text: '플레이어가 들어왔다.' },
      { type: 'text', speaker: '', text: '"뭐 해?"' },
      { type: 'text', speaker: '', text: '"밥 지어요."' },
      { type: 'text', speaker: '', text: '"내가 해도 되는데."' },
      { type: 'text', speaker: '', text: '"하고 싶어서요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '주작이 생각했다.' },
      { type: 'text', speaker: '주작', text: '"밥을 지으면서 생각해요."' },
      { type: 'text', speaker: '', text: '"뭘?"' },
      { type: 'text', speaker: '', text: '"이 밥이 누구한테 갈 건지."' },
      { type: 'text', speaker: '', text: '"나한테 가겠지."' },
      { type: 'text', speaker: '', text: '"응. 당신한테 가요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신한테 가는 밥이라는 걸 알면요. 더 맛있게 만들고 싶어요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"그게 이상해요?"' },
      { type: 'text', speaker: '', text: '"아니야."' },
      { type: 'text', speaker: '', text: '"당신은 그냥 들어주네요."' },
      { type: 'text', speaker: '', text: '주작이 채소를 얹으면서 중얼거렸다.' },
      { type: 'text', speaker: '주작', text: '"그래서 말하게 돼요. 이상한 것들도."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 불을 줄였다.' },
      { type: 'text', speaker: '주작', text: '"다 됐어요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"먹어요."' },
      { type: 'text', speaker: '', text: '둘이 밥을 먹었다.' },
      { type: 'text', speaker: '', text: '주작이 처음으로 자기가 만든 밥이 맛있다고 생각했다.' },
      { type: 'text', speaker: '', text: '당신이 먹어서. 그래서 맛있었다.' },
      { type: 'text', speaker: '', text: '며칠 뒤.' },
      { type: 'text', speaker: '', text: '비가 왔다.' },
      { type: 'text', speaker: '', text: '아침부터.' },
      { type: 'text', speaker: '', text: '빗소리가 지붕을 두드렸다.' },
      { type: 'text', speaker: '', text: '낮고 규칙적인 소리.' },
      { type: 'text', speaker: '', text: '주작이 창문을 봤다.' },
      { type: 'text', speaker: '', text: '빗물이 유리를 타고 흘렀다.' },
      { type: 'text', speaker: '', text: '플레이어가 방으로 왔다.' },
      { type: 'text', speaker: '', text: '"창문 닫아."' },
