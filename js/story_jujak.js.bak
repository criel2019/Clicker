      { type: 'text', speaker: '', text: '보는 눈.' },
      { type: 'text', speaker: '', text: '"...당신 이름이 뭐예요?"' },
      { type: 'text', speaker: '', text: '신이 대답하지 않았다.' },
      { type: 'text', speaker: '', text: '주작이 기다렸다.' },
      { type: 'text', speaker: '주작', text: '"모르는 거예요?"' },
      { type: 'text', speaker: '', text: '신이 눈을 깜박였다.' },
      { type: 'text', speaker: '', text: '그게 대답인 것 같았다.' },
      { type: 'text', speaker: '', text: '"그래요."' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '주작', text: '"나도 내 이름이 어디서 왔는지 몰라요."' },
