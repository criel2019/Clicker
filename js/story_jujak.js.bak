      { type: 'text', speaker: '', text: '"그래서 당신이 좋아요."' },
      { type: 'text', speaker: '', text: '그 말을 하고 나서 뺨이 빨개졌다.' },
      { type: 'text', speaker: '', text: '"...이상한 소리 했죠?"' },
      { type: 'text', speaker: '', text: '"아니야."' },
