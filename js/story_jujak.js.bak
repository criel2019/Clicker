      { type: 'text', speaker: '', text: '주작이 눈물을 닦았다.' },
      { type: 'text', speaker: '', text: '어느새 또 났다.' },
      { type: 'text', speaker: '', text: '참지 않았다.' },
      { type: 'text', speaker: '', text: '울었다.' },
      { type: 'text', speaker: '', text: '또 울었다.' },
      { type: 'text', speaker: '', text: '그리고 멈췄다.' },
      { type: 'text', speaker: '', text: '"주—"' },
      { type: 'text', speaker: '', text: '"그 입 모양이요."' },
      { type: 'text', speaker: '', text: '"주—"' },
      { type: 'text', speaker: '', text: '"주작이잖아요."' },
      { type: 'text', speaker: '', text: '눈물이 났다.' },
      { type: 'text', speaker: '', text: '이번엔 참지 않았다.' },
      { type: 'text', speaker: '', text: '한참 울었다.' },
      { type: 'text', speaker: '', text: '마당에.' },
      { type: 'text', speaker: '', text: '혼자.' },
      { type: 'text', speaker: '', text: '왜소한 신이 그 옆에 왔다.' },
      { type: 'text', speaker: '', text: '아무 말도 안 했다.' },
      { type: 'text', speaker: '', text: '그냥 옆에 앉았다.' },
      { type: 'text', speaker: '', text: '주작이 느꼈다.' },
      { type: 'text', speaker: '주작', text: '"...저 잠깐 울어도 돼요?"' },
      { type: 'text', speaker: '', text: '신이 아무 말도 안 했다.' },
      { type: 'text', speaker: '', text: '하지만 그 자리에 있었다.' },
      { type: 'text', speaker: '', text: '주작이 무릎에 얼굴을 묻었다.' },
      { type: 'text', speaker: '', text: '울었다.' },
      { type: 'text', speaker: '', text: '한참.' },
      { type: 'text', speaker: '', text: '그리고 멈췄다.' },
      { type: 'text', speaker: '', text: '고개를 들었다.' },
      { type: 'text', speaker: '', text: '눈이 달랐다.' },
      { type: 'text', speaker: '', text: '착한 눈이었다. 그대로.' },
      { type: 'text', speaker: '', text: '하지만 다른 것도 있었다.' },
      { type: 'text', speaker: '', text: '집착.' },
      { type: 'text', speaker: '', text: '단단한.' },
      { type: 'text', speaker: '', text: '포기하지 않는.' },
      { type: 'text', speaker: '', text: '고아원에서.' },
      { type: 'text', speaker: '', text: '포기하는 법을 배웠다.' },
      { type: 'text', speaker: '', text: '배고픔을 포기하고.' },
      { type: 'text', speaker: '', text: '따뜻함을 포기하고.' },
      { type: 'text', speaker: '', text: '이름을 포기하고.' },
      { type: 'text', speaker: '', text: '그냥 살았다.' },
      { type: 'text', speaker: '', text: '지금은.' },
      { type: 'text', speaker: '', text: '포기하지 않았다.' },
      { type: 'text', speaker: '', text: '당신을.' },
      { type: 'text', speaker: '', text: '포기하지 않을 거였다.' },
      { type: 'text', speaker: '', text: '이름 부르는 사람을.' },
      { type: 'text', speaker: '', text: '포기하지 않을 거였다.' },
      { type: 'text', speaker: '', text: '"주—"' },
      { type: 'text', speaker: '', text: '주작이 중얼거렸다.' },
      { type: 'text', speaker: '', text: '플레이어의 입 모양을 따라.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '자기 이름을 불렀다.' },
      { type: 'text', speaker: '', text: '"이름을 부르려 했잖아요."' },
      { type: 'text', speaker: '', text: '뺨의 눈물을 닦았다.' },
      { type: 'text', speaker: '', text: '"그러면."' },
      { type: 'text', speaker: '', text: '일어섰다.' },
      { type: 'text', speaker: '', text: '"찾아가면 되잖아요."' },
      { type: 'text', speaker: '', text: '조용했다.' },
      { type: 'text', speaker: '', text: '"찾아가서. 이름 불러달라고 하면 되잖아요."' },
      { type: 'text', speaker: '', text: '주작이 마당을 봤다.' },
      { type: 'text', speaker: '', text: '빈 마당.' },
      { type: 'text', speaker: '', text: '당신이 없는 마당.' },
      { type: 'text', speaker: '', text: '이름이 불리지 않는 마당.' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '이상했다.' },
      { type: 'text', speaker: '', text: '이 이상함을 알고 있었다.' },
      { type: 'text', speaker: '', text: '고아원에서 알던 그 이상함.' },
      { type: 'text', speaker: '', text: '아무도 이름을 부르지 않는 이상함.' },
      { type: 'text', speaker: '', text: '아무도 없는 이상함.' },
      { type: 'text', speaker: '', text: '하지만 달랐다.' },
      { type: 'text', speaker: '', text: '고아원의 그 이상함은.' },
      { type: 'text', speaker: '', text: '끝이 보이지 않는 이상함이었다.' },
      { type: 'text', speaker: '', text: '지금의 이상함은.' },
      { type: 'text', speaker: '', text: '끝이 있는 이상함이었다.' },
      { type: 'text', speaker: '', text: '찾아가면 됐다.' },
      { type: 'text', speaker: '', text: '찾아가서 이름 불러달라고 하면 됐다.' },
      { type: 'text', speaker: '', text: '그러면 이 이상함이 끝났다.' },
      { type: 'text', speaker: '', text: '"괜찮아."' },
      { type: 'text', speaker: '', text: '주작이 중얼거렸다.' },
      { type: 'text', speaker: '', text: '자기 자신에게.' },
      { type: 'text', speaker: '', text: '"찾을 거니까."' },
      { type: 'text', speaker: '', text: '주작이 신을 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신은요?"' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"당신도 따라가요?"' },
      { type: 'text', speaker: '', text: '신이 아주 조금 고개를 끄덕이는 것 같았다.' },
      { type: 'text', speaker: '', text: '"그래요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"같이 가요."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 피웠다.' },
      { type: 'text', speaker: '', text: '손에서.' },
      { type: 'text', speaker: '', text: '팔에서.' },
      { type: 'text', speaker: '', text: '전신에서.' },
      { type: 'text', speaker: '', text: '각성한 불꽃.' },
      { type: 'text', speaker: '', text: '완전한 불꽃.' },
      { type: 'text', speaker: '', text: '뜨겁고 찬란한 붉은 불꽃.' },
      { type: 'effect', effect: 'system', text: '【신수 주작. 완전각성 상태. 비행 능력 해금. 신력 출력: 측정 불가.】' },
      { type: 'effect', effect: 'system', text: '【유대 에너지 역류 감지. 연결 대상 부재 시 자력 출력으로 전환. 귀환 비행 가능.】' },
      { type: 'text', speaker: '', text: '마음이 남긴 열기가 몸속에서 거꾸로 타올랐다. 당신에게 흘러가야 할 온기가 갈 곳을 잃고 제 몸 안에서 불꽃이 됐다.' },
      { type: 'text', speaker: '', text: '날개가 돋았다.' },
      { type: 'text', speaker: '', text: '등이 찢어졌다. 뼈가 아닌 것이 돋았다. 불꽃이었다.' },
      { type: 'text', speaker: '', text: '크고 붉고 아름다운. 펼치는 순간 열기가 폭풍처럼 밀려나가 마당의 풀이 뿌리째 눌려 납작해졌다.' },
      { type: 'text', speaker: '', text: '주작이 날개를 폈다.' },
      { type: 'text', speaker: '', text: '고아원에서 봤던 새처럼.' },
      { type: 'text', speaker: '', text: '저 새는 저렇게 날 수 있구나 하고 부러워했던.' },
      { type: 'text', speaker: '', text: '이제 날 수 있었다.' },
      { type: 'text', speaker: '', text: '하지만 자유롭지 않았다.' },
      { type: 'text', speaker: '', text: '당신이 없으니까.' },
      { type: 'text', speaker: '', text: '자유가 뭔지 알게 해준 사람이 없으니까.' },
      { type: 'text', speaker: '', text: '"찾아갈게요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"어디든."' },
      { type: 'text', speaker: '', text: '날개를 펼쳤다.' },
      { type: 'text', speaker: '', text: '"얼마나 걸리든."' },
      { type: 'text', speaker: '', text: '불꽃이 일었다.' },
      { type: 'text', speaker: '', text: '"반드시."' },
      { type: 'text', speaker: '', text: '하늘로 올랐다.' },
      { type: 'text', speaker: '', text: '날갯짓 한 번에 마당의 흙이 원형으로 파이고 돌담 위 먼지가 날았다. 두 번째 날갯짓에 처마의 기와 세 장이 떨어져 깨졌다.' },
      { type: 'text', speaker: '', text: '붉은 불꽃이 하늘을 갈랐다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘에 주작성이 빛났다.' },
      { type: 'text', speaker: '', text: '오래간만에.' },
      { type: 'text', speaker: '', text: '가장 밝게.' },
      { type: 'text', speaker: '', text: '왜소한 신이 주작이 날아간 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '붉은 불꽃이 하늘에 긴 선을 그었다.' },
      { type: 'text', speaker: '', text: '신이 그 선을 봤다.' },
      { type: 'text', speaker: '', text: '오래 봤다.' },
      { type: 'text', speaker: '', text: '신은 플레이어의 좌표에 묶여 있었다. 시스템이 정한 연결. 플레이어가 이동하면 신도 끌려간다. 그게 규칙이었다.' },
      { type: 'text', speaker: '', text: '그런데 멈췄다.' },
      { type: 'text', speaker: '', text: '다시 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '불꽃이 그은 붉은 선.' },
      { type: 'text', speaker: '', text: '신이 그쪽으로 한 걸음 내딛었다.' },
      { type: 'text', speaker: '', text: '멈췄다.' },
      { type: 'text', speaker: '', text: '뿔루퉁하게 고개를 돌렸다. 주작이 갈 곳과 플레이어가 갈 곳이 다르다는 걸 아는 것처럼.' },
      { type: 'text', speaker: '', text: '그리고 플레이어 쪽으로 달려갔다. 좌표가 당기는 대로.' },
      { type: 'text', speaker: '', text: '사라졌다.' },
    ]
  },
  {
