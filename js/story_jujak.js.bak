      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"덥지 않아. 더우면 힘드니까."' },
      { type: 'text', speaker: '', text: '"아. 이세계라 더위 다르게 느껴요?"' },
      { type: 'text', speaker: '', text: '"어떻게 알아?"' },
      { type: 'text', speaker: '', text: '"그냥요. 이세계 온 사람이니까. 뭔가 다를 것 같아서요."' },
      { type: 'text', speaker: '', text: '"더위가 좀 달라. 이 세계 여름이 그나마 나아."' },
