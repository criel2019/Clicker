      { type: 'text', speaker: '', text: '가볍게.' },
      { type: 'text', speaker: '', text: '마지막이 될 것 같아서.' },
      { type: 'text', speaker: '', text: '마지막이 되면 안 된다고 생각하면서.' },
      { type: 'text', speaker: '', text: '그러면서도.' },
      { type: 'text', speaker: '', text: '목검을 들고.' },
      { type: 'text', speaker: '', text: '자세를 잡고.' },
      { type: 'text', speaker: '', text: '움직였다.' },
      { type: 'text', speaker: '', text: '주작이 목검을 내렸다.' },
      { type: 'text', speaker: '주작', text: '"있잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"각성하면 날개가 돋아요?"' },
      { type: 'text', speaker: '', text: '"신수 주작이면 그래."' },
      { type: 'text', speaker: '주작', text: '"날 수 있어요?"' },
      { type: 'text', speaker: '', text: '"아마도."' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '주작', text: '"고아원에서요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"저 새 보면 부러웠어요."' },
      { type: 'text', speaker: '', text: '"하늘 날 수 있는 거?"' },
      { type: 'text', speaker: '', text: '"응. 저기 날면 자유로울 것 같아서요."' },
      { type: 'text', speaker: '', text: '"지금은?"' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"지금은요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"날 수 있어도 가고 싶은 곳이 여기예요."' },
      { type: 'text', speaker: '', text: '"여기?"' },
      { type: 'text', speaker: '', text: '"당신 옆이요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '"날아도 당신 옆에 있을 거예요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"어디 가든."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신 옆이요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '"그게."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"집착이야."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"집착이 나쁜 건 아니잖아요."' },
      { type: 'text', speaker: '', text: '"그래?"' },
      { type: 'text', speaker: '', text: '"응. 집착이 있으면 찾아가잖아요. 포기 안 하잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"고아원에서 포기하는 법을 배웠어요. 배고픔을. 따뜻함을. 이름을. 다 포기했어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"근데 당신은 포기 못 해요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '"그러니까 집착이에요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
