  {
    title: '6장. 애정',
    nodes: [
      { type: 'text', speaker: '', text: '탑 7층을 클리어한 다음 날 아침.' },
      { type: 'text', speaker: '', text: '주작이 먼저 일어났다.' },
      { type: 'text', speaker: '', text: '부엌에서 소리가 났다.' },
      { type: 'text', speaker: '', text: '밥 짓는 소리.' },
      { type: 'text', speaker: '', text: '물 끓는 소리.' },
      { type: 'text', speaker: '', text: '솥뚜껑을 열면 피어오르는 김.' },
      { type: 'text', speaker: '', text: '따뜻한 냄새.' },
      { type: 'text', speaker: '', text: '아침 냄새.' },
      { type: 'text', speaker: '', text: '주작이 혼자 서 있었다.' },
      { type: 'text', speaker: '', text: '아침이 왔다.' },
      { type: 'text', speaker: '', text: '또 아침이 왔다.' },
      { type: 'text', speaker: '', text: '당신이 있는 아침이.' },
      { type: 'text', speaker: '', text: '당신이 오기 전에, 당신을 위해 이 아침을 준비하는 시간이.' },
      { type: 'text', speaker: '', text: '고아원에서는 아침이 왜 오는지 몰랐다. 그냥 왔다. 지금은 알았다.' },
      { type: 'text', speaker: '', text: '플레이어가 부엌으로 왔다.' },
      { type: 'text', speaker: '', text: '"먼저 일어났네."' },
      { type: 'text', speaker: '', text: '"응. 당신이 오기 전에 다 하려고요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '주작이 채소를 썰면서 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신 피곤해 보였어요. 어제."' },
      { type: 'text', speaker: '', text: '"봤어?"' },
      { type: 'text', speaker: '', text: '"응. 눈이 좀 무거웠어요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"잘 봐네."' },
      { type: 'text', speaker: '', text: '"당신 보는 건 잘 알아요."' },
      { type: 'text', speaker: '', text: '그 말을 아무렇지 않게 했다.' },
      { type: 'text', speaker: '', text: '아무렇지 않게.' },
      { type: 'text', speaker: '', text: '하지만 뺨이 살짝 빨개졌다.' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 채소를 얹었다.' },
      { type: 'text', speaker: '주작', text: '"앉아요. 곧 돼요."' },
      { type: 'text', speaker: '', text: '탑 7층을 클리어한 다음 날.' },
      { type: 'text', speaker: '', text: '비가 오지 않는 날.' },
      { type: 'text', speaker: '', text: '주작이 마당에서 혼자 훈련했다.' },
      { type: 'text', speaker: '', text: '불꽃을 피웠다.' },
      { type: 'text', speaker: '', text: '크게.' },
      { type: 'text', speaker: '', text: '작게.' },
      { type: 'text', speaker: '', text: '다시 크게.' },
      { type: 'text', speaker: '', text: '조절했다.' },
      { type: 'text', speaker: '', text: '당신 목소리를 생각하면 커졌다.' },
      { type: 'text', speaker: '', text: '주작.' },
      { type: 'text', speaker: '', text: '그 소리를.' },
      { type: 'text', speaker: '', text: '기억하면.' },
      { type: 'text', speaker: '', text: '커졌다.' },
      { type: 'text', speaker: '', text: '이상한 연결.' },
      { type: 'text', speaker: '', text: '이름이 불꽃을 키운다.' },
      { type: 'text', speaker: '', text: '이름이 이름을 부르는 사람을 기억해서, 손끝이 벌겋게 달아오르고, 손바닥 안쪽에서 심장처럼 뛰는 무언가가 불꽃을 밀어 올린다.' },
      { type: 'text', speaker: '', text: '불꽃이 커진다.' },
      { type: 'effect', effect: 'system', text: '【신수 주작. 신력 반응 감지. 호감도 연동 확인. 현재 호감도: 5단계→6단계 전환 중.】' },
      { type: 'text', speaker: '', text: '가슴팍이 울렸다. 심장이 뛴 게 아니었다. 심장보다 깊은 곳에서, 뭔가 자물쇠가 풀리는 것처럼 딸깍 했다.' },
      { type: 'text', speaker: '', text: '주작이 그걸 봤다.' },
      { type: 'text', speaker: '', text: '손 안에서.' },
      { type: 'text', speaker: '', text: '뜨겁지 않게.' },
      { type: 'text', speaker: '', text: '따뜻하게.' },
      { type: 'text', speaker: '', text: '이 불꽃이.' },
      { type: 'text', speaker: '', text: '당신이랑 연결됐다.' },
      { type: 'text', speaker: '', text: '그게 이상하지 않았다.' },
      { type: 'text', speaker: '', text: '자연스러웠다.' },
      { type: 'text', speaker: '', text: '당신이 이름 불러줘서.' },
      { type: 'text', speaker: '', text: '이 불꽃이 있는 거니까.' },
      { type: 'text', speaker: '', text: '밥을 먹으면서.' },
      { type: 'text', speaker: '', text: '주작이 먼저 물었다.' },
      { type: 'text', speaker: '주작', text: '"당신 오늘 어땠어요?"' },
      { type: 'text', speaker: '', text: '"뭐가."' },
      { type: 'text', speaker: '', text: '"그냥요. 오늘 하루요."' },
      { type: 'text', speaker: '', text: '"평범했어. 왜?"' },
      { type: 'text', speaker: '', text: '"그냥 물어보고 싶어서요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"평범한 게 좋아."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"평범하면 탈이 없으니까."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"그렇겠다."' },
      { type: 'text', speaker: '', text: '"주작은요?"' },
      { type: 'text', speaker: '', text: '"저요?"' },
      { type: 'text', speaker: '', text: '"오늘 어땠어."' },
      { type: 'text', speaker: '', text: '주작이 생각했다.' },
      { type: 'text', speaker: '주작', text: '"평범했어요."' },
      { type: 'text', speaker: '', text: '"뭐가 평범해."' },
      { type: 'text', speaker: '', text: '"당신이랑 밥 먹고요. 훈련하고요. 지금 밥 먹고요."' },
      { type: 'text', speaker: '', text: '"그게 평범해?"' },
      { type: 'text', speaker: '', text: '"당신이랑 있으면 평범해요."' },
      { type: 'text', speaker: '', text: '그 말을 하는데, 멀리서 탑이 한 번 울렸다. 둘 다 잠깐 멈췄다. 탑은 금방 조용해졌다. 아무것도 아니었다. 그래도 주작은 플레이어 쪽을 한 번 더 봤다.' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이랑 있으면 뭐든 평범해져요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '주작이 국을 더 떴다.' },
      { type: 'text', speaker: '주작', text: '"더 먹어요."' },
      { type: 'text', speaker: '', text: '플레이어가 물었다.' },
      { type: 'text', speaker: '', text: '"탑 올라가면서 어땠어?"' },
      { type: 'text', speaker: '', text: '주작이 생각했다.' },
      { type: 'text', speaker: '주작', text: '"이상한 느낌이 있었어요."' },
      { type: 'text', speaker: '', text: '"뭐가?"' },
      { type: 'text', speaker: '', text: '"제가 강해질수록요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 걱정되는 게 커졌어요."' },
      { type: 'text', speaker: '', text: '플레이어가 멈췄다.' },
      { type: 'text', speaker: '', text: '"강해질수록?"' },
      { type: 'text', speaker: '', text: '"응. 강해지면 덜 걱정해야 할 것 같은데. 오히려 더 걱정돼요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '주작이 밥을 먹으면서 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신이 소중해질수록 잃는 게 무서운 것 같아요."' },
      { type: 'text', speaker: '', text: '숟가락이 그릇에 닿는 소리가 멈췄다.' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"처음엔 고마운 사람이었는데."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"지금은."' },
      { type: 'text', speaker: '', text: '주작이 말을 멈췄다.' },
      { type: 'text', speaker: '', text: '국자를 들었다.' },
      { type: 'text', speaker: '', text: '"국 더 먹어요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"아까 하던 말."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '주작이 국을 더 떴다.' },
      { type: 'text', speaker: '주작', text: '"지금은 없으면 안 되는 사람이에요."' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '아무렇지 않은 듯.' },
      { type: 'text', speaker: '', text: '하지만 뺨이 조금 빨개졌다.' },
      { type: 'text', speaker: '', text: '플레이어가 국을 받았다.' },
      { type: 'text', speaker: '', text: '말이 없었다.' },
      { type: 'text', speaker: '', text: '두 사람이 밥을 먹었다.' },
      { type: 'text', speaker: '', text: '조용하게.' },
      { type: 'text', speaker: '', text: '그게 애정이었다.' },
      { type: 'text', speaker: '', text: '말하지 않아도 알고 있는.' },
      { type: 'text', speaker: '', text: '탑 7층을 클리어하고 돌아오는 길.' },
      { type: 'text', speaker: '', text: '주작이 걸으면서 팔을 봤다.' },
      { type: 'text', speaker: '', text: '긁힌 자국이 있었다.' },
      { type: 'text', speaker: '', text: '얕게.' },
      { type: 'text', speaker: '', text: '피는 안 났다.' },
      { type: 'text', speaker: '', text: '괜찮았다.' },
      { type: 'text', speaker: '', text: '플레이어가 봤다.' },
      { type: 'text', speaker: '', text: '"괜찮아?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"진짜?"' },
      { type: 'text', speaker: '', text: '"진짜요."' },
      { type: 'text', speaker: '', text: '"상처 있잖아."' },
      { type: 'text', speaker: '', text: '"긁힌 거예요. 베인 게 아니에요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작의 팔을 봤다.' },
      { type: 'text', speaker: '', text: '직접.' },
      { type: 'text', speaker: '', text: '손으로 팔을 잡고.' },
      { type: 'text', speaker: '', text: '확인했다.' },
      { type: 'text', speaker: '', text: '주작이 멈췄다.' },
      { type: 'text', speaker: '', text: '손이 차가웠다.' },
      { type: 'text', speaker: '', text: '플레이어의 손이.' },
      { type: 'text', speaker: '', text: '"...차가워요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"손이요."' },
      { type: 'text', speaker: '', text: '"원래 차가워."' },
      { type: 'text', speaker: '', text: '"그래요?"' },
      { type: 'text', speaker: '', text: '주작이 플레이어의 손을 봤다.' },
      { type: 'text', speaker: '', text: '양손으로.' },
      { type: 'text', speaker: '', text: '감쌌다.' },
      { type: 'text', speaker: '', text: '불꽃이 일었다.' },
      { type: 'text', speaker: '', text: '아주 약하게.' },
      { type: 'text', speaker: '', text: '손이 따뜻해졌다.' },
      { type: 'text', speaker: '', text: '"이러면 돼요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"저 불꽃이 따뜻하잖아요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 손을 놓았다.' },
      { type: 'text', speaker: '주작', text: '"됐어요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그럼 됐어요."' },
      { type: 'text', speaker: '', text: '주작이 걸었다.' },
      { type: 'text', speaker: '', text: '손이 따뜻했다.' },
      { type: 'text', speaker: '', text: '그게 좋았다.' },
      { type: 'text', speaker: '', text: '자기 불꽃으로.' },
      { type: 'text', speaker: '', text: '당신 손을 따뜻하게 할 수 있다는 게.' },
      { type: 'text', speaker: '', text: '그날 오후.' },
      { type: 'text', speaker: '', text: '주작이 탑 근처를 혼자 걸었다.' },
      { type: 'text', speaker: '', text: '탑을 봤다.' },
      { type: 'text', speaker: '', text: '탑이 높았다.' },
      { type: 'text', speaker: '', text: '저 탑의 끝에.' },
      { type: 'text', speaker: '', text: '마지막 층이 있었다.' },
      { type: 'text', speaker: '', text: '아직 올라가지 않은 층.' },
      { type: 'text', speaker: '', text: '저 층을 올라가면.' },
      { type: 'text', speaker: '', text: '뭔가 달라진다는 걸 알았다.' },
      { type: 'text', speaker: '', text: '당신의 눈이 달랐다.' },
      { type: 'text', speaker: '', text: '탑 앞에서. 밥 먹다 멈출 때. 웃다가 갑자기 입을 다물 때.' },
      { type: 'text', speaker: '', text: '죄책감 같은 것.' },
      { type: 'text', speaker: '', text: '뭔가 알고 있는데 말하지 못하는 눈. 시스템 창에서 뭔가 본 것 같은 눈.' },
      { type: 'text', speaker: '', text: '주작이 탑을 봤다.' },
      { type: 'text', speaker: '', text: '물어볼 수 있었다.' },
      { type: 'text', speaker: '', text: '하지만 안 물었다.' },
      { type: 'text', speaker: '', text: '나중에 말해요.' },
      { type: 'text', speaker: '', text: '지금 말하기 싫으면.' },
      { type: 'text', speaker: '', text: '그렇게 말했다.' },
      { type: 'text', speaker: '', text: '당신이 말하고 싶을 때 말해주길 기다렸다.' },
      { type: 'text', speaker: '', text: '그게 맞았다.' },
      { type: 'text', speaker: '', text: '탑이 높았다.' },
      { type: 'text', speaker: '', text: '저 탑의 끝.' },
      { type: 'text', speaker: '', text: '아직 몰랐다.' },
      { type: 'text', speaker: '', text: '하지만.' },
      { type: 'text', speaker: '', text: '같이 알아가면 됐다.' },
      { type: 'text', speaker: '', text: '당신이랑.' },
      { type: 'text', speaker: '', text: '같이.' },
      { type: 'effect', effect: 'system', text: '【호감도 상승. 현재 단계: 6단계.】' },
      { type: 'text', speaker: '', text: '시스템 창 메시지는 플레이어에게 떴다.' },
      { type: 'text', speaker: '', text: '주작은 몰랐다.' },
      { type: 'text', speaker: '', text: '주작은 그냥 걸었다.' },
      { type: 'text', speaker: '', text: '길을 걸으면서 생각했다.' },
      { type: 'text', speaker: '', text: '이름.' },
      { type: 'text', speaker: '', text: '당신이 내 이름을 부르는 것.' },
      { type: 'text', speaker: '', text: '그 소리가 들리면 내가 여기 있다는 게 확인되니까.' },
      { type: 'text', speaker: '', text: '당신 눈에 내가 비친다는 뜻이니까.' },
      { type: 'text', speaker: '', text: '길가에 붉은 꽃이 피어 있었다. 주작이 봤다. 이름처럼 붉었다.' },
      { type: 'text', speaker: '', text: '밤에 플레이어가 물었다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"제일 좋은 게 뭐야."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 생각했다.' },
      { type: 'text', speaker: '', text: '긴 침묵.' },
      { type: 'text', speaker: '', text: '별이 보이는 밤.' },
      { type: 'text', speaker: '', text: '창문으로 바람이 들어왔다.' },
      { type: 'text', speaker: '', text: '"이름이요."' },
      { type: 'text', speaker: '', text: '"이름?"' },
      { type: 'text', speaker: '', text: '"당신이 제 이름 부르는 거요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"그게 제일 좋아요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"음식도 좋고. 별도 좋고. 훈련도 좋고. 탑도 재밌어요. 근데요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 주작이라고 부를 때가 제일 좋아요."' },
      { type: 'text', speaker: '주작', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"그 이름이요."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"당신이 저를 본다는 뜻이잖아요. 당신이 저한테 집중한다는 뜻이잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"고아원에서는 이름으로 안 불렀잖아요. 야. 거기. 그건요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그건 저를 보는 게 아니에요. 그냥 대상이에요. 물건이에요. 야. 거기. 뭔가."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이 주작이라고 부르는 건. 저예요. 저를 보는 거예요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 말이 없었다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '불렀다.' },
      { type: 'text', speaker: '', text: '주작이 눈을 감았다.' },
      { type: 'text', speaker: '', text: '이름이 들렸다.' },
      { type: 'text', speaker: '', text: '귀에서.' },
      { type: 'text', speaker: '', text: '가슴으로.' },
      { type: 'text', speaker: '', text: '뜨겁게.' },
      { type: 'text', speaker: '', text: '"...응."' },
      { type: 'text', speaker: '', text: '"그게 들려?"' },
      { type: 'text', speaker: '', text: '"들려요."' },
      { type: 'text', speaker: '', text: '"다르게 들려?"' },
      { type: 'text', speaker: '', text: '주작이 눈을 떴다.' },
      { type: 'text', speaker: '주작', text: '"달라요. 당신이 부르는 건."' },
      { type: 'text', speaker: '', text: '"어떻게?"' },
      { type: 'text', speaker: '', text: '주작이 잠깐 생각했다.' },
      { type: 'text', speaker: '주작', text: '"따뜻해요."' },
      { type: 'text', speaker: '', text: '"따뜻해?"' },
      { type: 'text', speaker: '', text: '"응. 당신 목소리가요. 제 이름 부를 때요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"따뜻하게 들려요."' },
      { type: 'text', speaker: '', text: '그 말을 하고 나서 주작이 얼굴을 숙였다.' },
      { type: 'text', speaker: '', text: '뺨이 빨개졌다.' },
      { type: 'text', speaker: '', text: '"...이상한 소리 했죠?"' },
      { type: 'text', speaker: '', text: '"아니야."' },
      { type: 'text', speaker: '', text: '"진짜요?"' },
      { type: 'text', speaker: '', text: '"진짜."' },
      { type: 'text', speaker: '', text: '"그럼."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"계속 불러줘요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"많이요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"오래오래요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 멈췄다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"...응."' },
      { type: 'text', speaker: '', text: '그날 오후.' },
      { type: 'text', speaker: '', text: '플레이어가 짧은 낮잠을 잤다.' },
      { type: 'text', speaker: '', text: '주작이 방 앞에 앉아 있었다.' },
      { type: 'text', speaker: '', text: '문이 열려 있었다.' },
      { type: 'text', speaker: '', text: '주작이 들여다봤다.' },
      { type: 'text', speaker: '', text: '플레이어가 자고 있었다.' },
      { type: 'text', speaker: '', text: '눈을 감고.' },
      { type: 'text', speaker: '', text: '조용히.' },
      { type: 'text', speaker: '', text: '숨이 고르게.' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '', text: '오래 봤다.' },
      { type: 'text', speaker: '', text: '눈이 감긴 얼굴.' },
      { type: 'text', speaker: '', text: '눈이 뜨여 있을 때보다 더 조용한 얼굴.' },
      { type: 'text', speaker: '', text: '피곤해 보였다.' },
      { type: 'text', speaker: '', text: '그래도.' },
      { type: 'text', speaker: '', text: '편안해 보였다.' },
      { type: 'text', speaker: '', text: '여기서.' },
      { type: 'text', speaker: '', text: '주작이 몸을 당겼다.' },
      { type: 'text', speaker: '', text: '방 안에 들어가지 않았다.' },
      { type: 'text', speaker: '', text: '그냥 문틈에서.' },
      { type: 'text', speaker: '', text: '봤다.' },
      { type: 'text', speaker: '', text: '주작이 자는 거 보는 걸 좋아한다는 걸 알았다.' },
      { type: 'text', speaker: '', text: '당신이 자는 거 보는 것도 좋았다.' },
      { type: 'text', speaker: '', text: '보호받아야 한다는 기분.' },
      { type: 'text', speaker: '', text: '내가 지켜야 한다는 기분.' },
      { type: 'text', speaker: '', text: '당신이 자는 동안 내가 깨어 있으면.' },
      { type: 'text', speaker: '', text: '당신이 안전하다는 기분.' },
      { type: 'text', speaker: '', text: '이상한 기분이었다.' },
      { type: 'text', speaker: '', text: '좋은 기분이었다.' },
      { type: 'text', speaker: '', text: '플레이어가 뒤척였다.' },
      { type: 'text', speaker: '', text: '주작이 뒤로 물러났다.' },
      { type: 'text', speaker: '', text: '깰까봐.' },
      { type: 'text', speaker: '', text: '깨지 않았다.' },
      { type: 'text', speaker: '', text: '다시 고요해졌다.' },
      { type: 'text', speaker: '', text: '주작이 무릎을 품고 앉았다.' },
      { type: 'text', speaker: '', text: '문 앞에서.' },
      { type: 'text', speaker: '', text: '불꽃을 손에 아주 조금 피웠다.' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '따뜻하게.' },
      { type: 'text', speaker: '', text: '"...당신이 잘 자면 되지요."' },
      { type: 'text', speaker: '', text: '중얼거렸다.' },
      { type: 'text', speaker: '', text: '아무도 못 들었다.' },
      { type: 'text', speaker: '', text: '그게 좋았다.' },
      { type: 'text', speaker: '', text: '이 말은 혼자 하는 말이어도 됐다.' },
      { type: 'text', speaker: '', text: '시장을 같이 다녔다.' },
      { type: 'text', speaker: '', text: '주작이 시장을 좋아했다.' },
      { type: 'text', speaker: '', text: '볼 것이 많아서.' },
      { type: 'text', speaker: '', text: '소리도 많고. 냄새도 많고. 색도 많고.' },
      { type: 'text', speaker: '', text: '사람들이 살아있는 것 같았다.' },
      { type: 'text', speaker: '', text: '"저거 봐요."' },
      { type: 'text', speaker: '', text: '"뭐?"' },
      { type: 'text', speaker: '', text: '"저 색이요. 붉잖아요."' },
      { type: 'text', speaker: '', text: '노점에서 붉은 천을 팔고 있었다. 천막 아래 향신료 냄새가 섞이고, 저쪽에서 국 끓이는 연기가 올라왔다. 아이가 빈 깡통을 발로 차며 뛰어가고, 누군가 목소리 높여 흥정을 했다.' },
      { type: 'text', speaker: '주작', text: '"예쁘죠?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"주작성 색이에요."' },
      { type: 'text', speaker: '', text: '플레이어가 봤다.' },
      { type: 'text', speaker: '', text: '"주작성이 저 색이야?"' },
      { type: 'text', speaker: '', text: '"응. 붉은색이요. 남쪽 하늘에서 제일 밝게."' },
      { type: 'text', speaker: '', text: '주작이 천을 만졌다.' },
      { type: 'text', speaker: '', text: '손가락으로.' },
      { type: 'text', speaker: '', text: '살살.' },
      { type: 'text', speaker: '', text: '부드럽고 차가웠다.' },
      { type: 'text', speaker: '', text: '"좋다."' },
      { type: 'text', speaker: '', text: '"사줄까?"' },
      { type: 'text', speaker: '', text: '"아니요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"그냥 보는 거예요."' },
      { type: 'text', speaker: '', text: '주작이 손을 뗐다.' },
      { type: 'text', speaker: '주작', text: '"사달라고 하면 이상해요."' },
      { type: 'text', speaker: '', text: '"이상하지 않아."' },
      { type: 'text', speaker: '', text: '"아니요. 이상해요."' },
      { type: 'text', speaker: '', text: '주작이 걸으면서 말했다.' },
      { type: 'text', speaker: '주작', text: '"필요한 것도 아닌데 사달라고 하는 건 이상해요."' },
      { type: 'text', speaker: '', text: '플레이어가 멈췄다.' },
      { type: 'text', speaker: '', text: '"고아원에서 그런 말 많이 들었어?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"필요한 것만 달라고 해, 이런 거요?"' },
      { type: 'text', speaker: '', text: '"응. 아니면 그걸 꼭 가져야 해? 이런 거요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"갖고 싶으면 갖고 싶은 거야."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"필요한 거 아니어도."' },
      { type: 'text', speaker: '', text: '주작이 멈췄다.' },
      { type: 'text', speaker: '주작', text: '"그래요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그러면."' },
      { type: 'text', speaker: '', text: '주작이 노점 쪽을 봤다.' },
      { type: 'text', speaker: '', text: '다시 걸어갔다.' },
      { type: 'text', speaker: '', text: '붉은 리본을 골랐다.' },
      { type: 'text', speaker: '', text: '작은 것.' },
      { type: 'text', speaker: '', text: '가방에 달 수 있는.' },
      { type: 'text', speaker: '', text: '"이거요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '플레이어가 샀다.' },
      { type: 'text', speaker: '', text: '주작이 받았다.' },
      { type: 'text', speaker: '', text: '가방에 달았다.' },
      { type: 'text', speaker: '', text: '리본을 매는 손가락이 살짝 떨렸다. 매듭이 한 번에 안 됐다. 다시 묶었다.' },
      { type: 'text', speaker: '', text: '"어때요?"' },
      { type: 'text', speaker: '', text: '"잘 어울려."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"감사해요."' },
      { type: 'text', speaker: '', text: '"그냥 리본인데."' },
      { type: 'text', speaker: '', text: '"그냥이 아니에요."' },
      { type: 'text', speaker: '', text: '주작이 리본을 만졌다.' },
      { type: 'text', speaker: '주작', text: '"당신이 사준 거잖아요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 걸으면서 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신이 사준 건 다 소중해요."' },
      { type: 'text', speaker: '', text: '"다?"' },
      { type: 'text', speaker: '', text: '"다요."' },
      { type: 'text', speaker: '', text: '"고구마도?"' },
      { type: 'text', speaker: '', text: '"고구마도요."' },
      { type: 'text', speaker: '', text: '"우산도?"' },
      { type: 'text', speaker: '', text: '"우산도요."' },
      { type: 'text', speaker: '', text: '"리본도?"' },
      { type: 'text', speaker: '', text: '"리본도요."' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"다 소중해요."' },
      { type: 'text', speaker: '', text: '리본을 한 번 더 만졌다.' },
      { type: 'text', speaker: '', text: '붉은 리본.' },
      { type: 'text', speaker: '', text: '주작성 색.' },
      { type: 'text', speaker: '', text: '내 이름의 색.' },
      { type: 'text', speaker: '', text: '당신이 사준.' },
      { type: 'text', speaker: '', text: '내 이름 색 리본.' },
      { type: 'text', speaker: '', text: '어느 아침. 해가 뜨기 전.' },
      { type: 'text', speaker: '', text: '마당에 나갔다. 서늘했다. 손에서 불꽃을 피웠다. 아주 작게.' },
      { type: 'text', speaker: '', text: '고아원에서 이름 없이 살았던 시절. 이런 거 없었다. 이름도 없고. 불꽃도 없고. 그냥 있었다.' },
      { type: 'text', speaker: '', text: '지금은. 이름이 있고. 불꽃이 있고. 당신이 있었다.' },
      { type: 'text', speaker: '', text: '불꽃을 조금 키웠다. 어두운 마당이 밝아졌다. 당신이 일어나기 전에. 내 불꽃이 이 마당을 밝히고 있었다.' },
      { type: 'text', speaker: '', text: '3성에서 4성으로.' },
      { type: 'text', speaker: '', text: '탑 7층을 클리어한 날. 몸 안에서 뭔가 넘쳤다. 그릇에 물을 너무 많이 부은 것처럼, 안에서 찰랑거리다가 한꺼번에 쏟아졌다.' },
      { type: 'text', speaker: '', text: '그날 시스템 창이 떴다.' },
      { type: 'effect', effect: 'system', text: '【신수 주작. 4성 달성. 유대 에너지 임계 돌파. 전투력 대폭 상승. 신력 출력 187% 증가.】' },
      { type: 'text', speaker: '', text: '주작은 그 창을 볼 수 없었지만 몸이 달랐다.' },
      { type: 'text', speaker: '', text: '손끝이 뜨거웠다. 뼈 안쪽에서 무언가 돌아가는 것 같았다. 이가 달그락 울렸다. 무릎이 잠깐 꺾였다가 다시 섰다. 핏줄을 따라 열기가 올라오는 게 느껴졌다. 손바닥을 펴자 바닥의 먼지가 둥글게 밀려났다.' },
      { type: 'effect', effect: 'shake' },
      { type: 'combat', enemy: {"name":"바람의 시련","hp":130,"attack":15} },
      { type: 'text', speaker: '', text: '주작이 마당 한가운데 섰다. 불꽃을 피웠다. 이전과 다른 불꽃이었다. 발 아래 흙이 벌겋게 달아올랐다. 마른 풀잎 끝이 오그라들며 연기가 피어올랐다. 주작이 발을 뗐는데 발자국이 바닥에 그을려 남았다. 마당 가장자리 돌담에 손을 짚었는데 돌이 벌겋게 달아오르며 손가락 자국대로 갈라졌다. 나중에 부엌에 들어갔을 때도 맨발이 닿는 나무 바닥에 희미한 그을림이 남았다. 4성의 잔열은 전투가 끝나도 몸에서 빠져나가지 않았다.' },
      { type: 'effect', effect: 'system', text: '【4성 전투력 반영. 신력 잔열: 주변 환경 반응 시작. 비전투 시에도 신력 방출 감지.】' },
      { type: 'text', speaker: '', text: '훈련하는데 불꽃이 달랐다.' },
      { type: 'text', speaker: '', text: '이전보다 크고. 이전보다 안정적이고. 이전보다 강했다.' },
      { type: 'text', speaker: '', text: '불꽃이 팔까지 올라왔다. 손을 내려뜨리자 공기가 아지랑이처럼 일그러졌다.' },
      { type: 'text', speaker: '', text: '피부 위에 불이 타는데, 뜨거운데.' },
      { type: 'text', speaker: '', text: '뜨겁지 않았다.' },
      { type: 'text', speaker: '', text: '제 것이어서. 제 이름에 붙은 것이어서.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"잘하고 있어."' },
      { type: 'text', speaker: '', text: '"그래요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 봤다.' },
      { type: 'text', speaker: '', text: '손 전체에서.' },
      { type: 'text', speaker: '', text: '팔 전체에서.' },
      { type: 'text', speaker: '', text: '뜨겁고 안정적인 불꽃.' },
      { type: 'text', speaker: '', text: '"당신 때문인 것 같아요."' },
      { type: 'text', speaker: '', text: '"내가 뭘 했다고."' },
      { type: 'text', speaker: '', text: '"이름 불러줘서요."' },
      { type: 'text', speaker: '', text: '플레이어가 웃었다.' },
      { type: 'text', speaker: '', text: '주작이 그 웃음을 봤다.' },
      { type: 'text', speaker: '', text: '가슴이 뛰었다.' },
      { type: 'text', speaker: '', text: '이상한 느낌.' },
      { type: 'text', speaker: '', text: '의존이 다른 것으로 변하려는 것 같은.' },
      { type: 'text', speaker: '', text: '가슴 안쪽이 따뜻해지면서 동시에 아린, 이름 모를 감정.' },
      { type: 'text', speaker: '', text: '애정.' },
      { type: 'text', speaker: '', text: '그게 애정이었다.' },
      { type: 'text', speaker: '', text: '없으면 이상한 것에서, 있으면 행복한 것으로.' },
      { type: 'text', speaker: '', text: '왜소한 신이 뒤에서 그걸 봤다.' },
      { type: 'text', speaker: '', text: '둘 사이로 살금살금 다가오려다.' },
      { type: 'text', speaker: '', text: '플레이어가 웃는 걸 보고.' },
      { type: 'text', speaker: '', text: '멈췄다.' },
      { type: 'text', speaker: '', text: '그냥 거기 서서 봤다.' },
      { type: 'text', speaker: '', text: '꼬리를 말고.' },
      { type: 'text', speaker: '', text: '뭔가 방해하기 싫은 것처럼.' },
      { type: 'text', speaker: '', text: '그런데 끼고 싶은 것처럼.' },
      { type: 'text', speaker: '', text: '꼬리를 풀었다.' },
      { type: 'text', speaker: '', text: '다시 말았다.' },
      { type: 'text', speaker: '', text: '저녁.' },
      { type: 'text', speaker: '', text: '별을 보는 시간.' },
      { type: 'text', speaker: '', text: '주작이 플레이어 옆에 앉았다.' },
      { type: 'text', speaker: '', text: '예전보다 더 가까이.' },
      { type: 'text', speaker: '', text: '어깨가 닿을 정도.' },
      { type: 'text', speaker: '', text: '"당신 별이 있어요?"' },
      { type: 'text', speaker: '', text: '"내 별?"' },
      { type: 'text', speaker: '', text: '"응. 신수마다 별이 있잖아요. 주작성처럼. 당신 별도 있을 것 같아서요."' },
      { type: 'text', speaker: '', text: '"이세계 환생자한테도 별이 있을까?"' },
      { type: 'text', speaker: '', text: '"있을 것 같아요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '여름 밤하늘.' },
      { type: 'text', speaker: '', text: '별이 많았다.' },
      { type: 'text', speaker: '', text: '크고 밝은 것. 작고 희미한 것.' },
      { type: 'text', speaker: '', text: '"당신이 없으면 제 별이 빛나지 않을 것 같아서요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이 있으니까 제가 타오르는 거니까요. 당신이 있으니까 불꽃이 있는 거니까요."' },
      { type: 'text', speaker: '', text: '"그건 과장이야."' },
      { type: 'text', speaker: '', text: '"과장 아니에요."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"진짜예요."' },
      { type: 'text', speaker: '', text: '진심으로.' },
      { type: 'text', speaker: '', text: '부끄럽지 않게.' },
      { type: 'text', speaker: '', text: '"당신이 불러주니까 제 별이 빛나는 거예요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '주작이 눈을 감았다.' },
      { type: 'text', speaker: '', text: '그 두 글자가 가슴 안쪽까지 울렸다.' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"있어."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '"옆에."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '주작이 눈을 뜨지 않고 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신이 옆에 있는 게 제일 좋아요."' },
      { type: 'text', speaker: '', text: '아침.' },
      { type: 'text', speaker: '', text: '주작이 밥을 짓다가 문 쪽을 봤다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 서 있었다.' },
      { type: 'text', speaker: '', text: '문 앞에.' },
      { type: 'text', speaker: '', text: '플레이어가 아직 안 나왔는데.' },
      { type: 'text', speaker: '', text: '기다리는 것 같았다.' },
      { type: 'text', speaker: '', text: '"어? 들어와요."' },
      { type: 'text', speaker: '', text: '신이 들어오지 않았다.' },
      { type: 'text', speaker: '', text: '주작이 나갔다.' },
      { type: 'text', speaker: '주작', text: '"플레이어 기다려요?"' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '갸웃.' },
      { type: 'text', speaker: '', text: '"그냥 같이 먹어요. 안에서."' },
      { type: 'text', speaker: '', text: '주작이 신을 데려왔다.' },
      { type: 'text', speaker: '', text: '밥을 한 그릇 더 떴다.' },
      { type: 'text', speaker: '', text: '셋이 먹었다.' },
      { type: 'text', speaker: '', text: '플레이어. 주작. 왜소한 신.' },
      { type: 'text', speaker: '', text: '신이 먹었다.' },
      { type: 'text', speaker: '', text: '먹는지 안 먹는지 모르겠지만.' },
      { type: 'text', speaker: '', text: '그냥 거기 있었다.' },
      { type: 'text', speaker: '', text: '플레이어 옆 자리.' },
      { type: 'text', speaker: '', text: '그 쪽에.' },
      { type: 'text', speaker: '', text: '주작이 신을 봤다.' },
      { type: 'text', speaker: '주작', text: '"맛있어요?"' },
      { type: 'text', speaker: '', text: '신이 고개를 아주 살짝 끄덕였다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"잘됐다."' },
      { type: 'text', speaker: '', text: '플레이어가 신을 봤다.' },
      { type: 'text', speaker: '', text: '신이 플레이어를 봤다.' },
      { type: 'text', speaker: '', text: '그러더니 슬쩍.' },
      { type: 'text', speaker: '', text: '플레이어 팔에 살짝 기댔다.' },
      { type: 'text', speaker: '', text: '아주 살짝.' },
      { type: 'text', speaker: '', text: '거의 기대지 않은 것처럼.' },
      { type: 'text', speaker: '', text: '하지만 붙어 있었다.' },
      { type: 'text', speaker: '', text: '주작이 그걸 봤다.' },
      { type: 'text', speaker: '주작', text: '"귀엽죠?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신한테 기대네요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이 좋은가봐요."' },
      { type: 'text', speaker: '', text: '플레이어가 신을 봤다.' },
      { type: 'text', speaker: '', text: '신이 딴청을 피웠다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '어느 날.' },
      { type: 'text', speaker: '', text: '플레이어가 혼자 나갔다가 늦게 돌아왔다.' },
      { type: 'text', speaker: '', text: '주작이 기다렸다.' },
      { type: 'text', speaker: '', text: '밥이 식었다.' },
      { type: 'text', speaker: '', text: '다시 데웠다.' },
      { type: 'text', speaker: '', text: '또 식었다.' },
      { type: 'text', speaker: '', text: '또 데웠다. 세 번째 데울 때 손이 멈췄다. 이러다 타겠다 싶었다. 그래도 데웠다. 손끝에서 불꽃이 새어 나와 솥 손잡이가 살짝 그을렸다.' },
      { type: 'text', speaker: '', text: '플레이어가 돌아왔다.' },
      { type: 'text', speaker: '', text: '"늦었네요."' },
      { type: 'text', speaker: '', text: '"응. 미안."' },
      { type: 'text', speaker: '', text: '"괜찮아요. 밥은요?"' },
      { type: 'text', speaker: '', text: '"배고파."' },
      { type: 'text', speaker: '', text: '"잠깐만요."' },
      { type: 'text', speaker: '', text: '주작이 밥을 데웠다.' },
      { type: 'text', speaker: '주작', text: '"얼마 걸렸어요?"' },
      { type: 'text', speaker: '', text: '"두 시간?"' },
      { type: 'text', speaker: '', text: '"그거요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"더 늦게 올 줄 알았어요."' },
      { type: 'text', speaker: '', text: '"걱정했어?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"두 시간이 걱정돼?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 밥을 건넸다.' },
      { type: 'text', speaker: '주작', text: '"당신이 없으면 이상해요. 두 시간이든 한 시간이든."' },
      { type: 'text', speaker: '', text: '"집착이야."' },
      { type: 'text', speaker: '', text: '"알아요."' },
      { type: 'text', speaker: '', text: '주작이 맞은편에 앉았다.' },
      { type: 'text', speaker: '주작', text: '"집착이어도 당신 없으면 이상해요."' },
      { type: 'text', speaker: '', text: '플레이어가 밥을 먹었다.' },
      { type: 'text', speaker: '', text: '"맛있어."' },
      { type: 'text', speaker: '', text: '"다행이에요."' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
      { type: 'text', speaker: '', text: '밥 먹는 당신을.' },
      { type: 'text', speaker: '', text: '두 시간 만에 돌아온 당신을.' },
      { type: 'text', speaker: '', text: '돌아와서 밥을 먹는 당신을.' },
      { type: 'text', speaker: '', text: '좋았다.' },
      { type: 'text', speaker: '', text: '이게 좋았다.' },
      { type: 'text', speaker: '', text: '비가 왔다.' },
      { type: 'text', speaker: '', text: '훈련하던 날.' },
      { type: 'text', speaker: '', text: '갑자기 소나기가 내렸다.' },
      { type: 'text', speaker: '', text: '마당이 순식간에 젖었다.' },
      { type: 'text', speaker: '', text: '"들어가요."' },
      { type: 'text', speaker: '', text: '플레이어가 먼저 처마 밑으로 왔다.' },
      { type: 'text', speaker: '', text: '주작이 잠깐 밖에 서 있었다.' },
      { type: 'text', speaker: '', text: '빗속에.' },
      { type: 'text', speaker: '', text: '얼굴에 빗물이 닿았다.' },
      { type: 'text', speaker: '', text: '차가웠다.' },
      { type: 'text', speaker: '', text: '그래도 섰다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"들어와."' },
      { type: 'text', speaker: '', text: '"잠깐요."' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '회색.' },
      { type: 'text', speaker: '', text: '빗속.' },
      { type: 'text', speaker: '', text: '고아원에서 비 오는 날.' },
      { type: 'text', speaker: '', text: '마당에 서 있던 적이 있었다.' },
      { type: 'text', speaker: '', text: '젖어도 괜찮았다. 밥이 없는 날보다 나았고, 맞는 날보다 나았다.' },
      { type: 'text', speaker: '', text: '비는 아프지 않았다. 차갑기만 했다.' },
      { type: 'text', speaker: '', text: '그날엔 그게 다였다.' },
      { type: 'text', speaker: '', text: '지금은.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '플레이어가 또 불렀다.' },
      { type: 'text', speaker: '', text: '뒤에서.' },
      { type: 'text', speaker: '', text: '주작이 돌아봤다.' },
      { type: 'text', speaker: '주작', text: '"추워."' },
      { type: 'text', speaker: '', text: '"아직 여름이에요."' },
      { type: 'text', speaker: '', text: '"빗속에 서 있으면 추워."' },
      { type: 'text', speaker: '', text: '주작이 처마 밑으로 들어왔다.' },
      { type: 'text', speaker: '', text: '두 사람이 나란히 비를 봤다.' },
      { type: 'text', speaker: '', text: '비가 마당을 두드렸다. 주작 머리카락에서 물이 떨어져 어깨에 닿았다.' },
      { type: 'text', speaker: '', text: '"방금요."' },
      { type: 'text', speaker: '', text: '갑자기.' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"비 맞으면서 당신이 불렀잖아요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그게 이상하게 울렸어요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"뭐가."' },
      { type: 'text', speaker: '', text: '주작이 빗소리를 들었다.' },
      { type: 'text', speaker: '주작', text: '"빗소리 사이로 제 이름이 들렸는데요. 다른 소리보다 먼저 들렸어요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이 걱정해서 부른 거잖아요. 그 마음이 소리에 실려서 먼저 온 것 같아요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 뺨에서 빗물을 닦았다.' },
      { type: 'text', speaker: '주작', text: '"그게 좋았어요."' },
      { type: 'text', speaker: '', text: '비가 그쳤다. 물이 처마에서 떨어졌다. 톡. 톡.' },
      { type: 'text', speaker: '', text: '주작이 공기를 들이마셨다. "가을 냄새 같아요." 플레이어가 들이마셨다. "...모르겠어."' },
      { type: 'text', speaker: '', text: '주작이 마당을 봤다. "빗물이 마르면 훈련 더 해요."' },
      { type: 'text', speaker: '주작', text: '"그래도 무리하지 마."' },
      { type: 'text', speaker: '', text: '"무리 안 해요. 당신 옆에 있어야 하니까."' },
      { type: 'text', speaker: '', text: '4성 이후로 플레이어가 말했다.' },
      { type: 'text', speaker: '', text: '"탑 더 올라가야 해."' },
      { type: 'text', speaker: '', text: '"어디까지요?"' },
      { type: 'text', speaker: '', text: '"아직 몰라."' },
      { type: 'text', speaker: '', text: '"얼마나 강해져야 해요?"' },
      { type: 'text', speaker: '', text: '"모르겠어."' },
      { type: 'text', speaker: '', text: '"그럼 올라가면서 알아가는 거네요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 만들었다.' },
      { type: 'text', speaker: '', text: '안정적인 불꽃.' },
      { type: 'text', speaker: '', text: '손에서.' },
      { type: 'text', speaker: '', text: '뜨겁고.' },
      { type: 'text', speaker: '', text: '안정적이고.' },
      { type: 'text', speaker: '', text: '당신 이름을 생각하면 커지는.' },
      { type: 'text', speaker: '', text: '"당신이 옆에 있으면 올라갈 수 있어요."' },
      { type: 'text', speaker: '', text: '"왜?"' },
      { type: 'text', speaker: '', text: '"당신 목소리 들으면 불꽃이 반응하니까요."' },
      { type: 'text', speaker: '', text: '플레이어가 웃었다.' },
      { type: 'text', speaker: '', text: '"증명해봐."' },
      { type: 'text', speaker: '', text: '"주작이라고 불러봐요."' },
      { type: 'text', speaker: '주작', text: '"주작."' },
      { type: 'text', speaker: '', text: '불꽃이 커졌다.' },
      { type: 'text', speaker: '', text: '"봤죠?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이러니까 당신이 필요해요."' },
      { type: 'text', speaker: '', text: '플레이어가 고개를 저었다.' },
      { type: 'text', speaker: '', text: '"불꽃은 네 거야."' },
      { type: 'text', speaker: '', text: '"당신 부를 때 커지는 건요?"' },
      { type: 'text', speaker: '', text: '"그것도 네 거야."' },
      { type: 'text', speaker: '', text: '"이상한 말이에요."' },
      { type: 'text', speaker: '', text: '"이상하지 않아."' },
      { type: 'text', speaker: '', text: '주작이 고개를 기울였다.' },
      { type: 'text', speaker: '주작', text: '"내 거라서 당신한테 커진다고요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"당신이 기준이라서요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 잠깐 생각했다.' },
      { type: 'text', speaker: '주작', text: '"그럼 당신이 제 이름이에요."' },
      { type: 'text', speaker: '', text: '플레이어가 멈췄다.' },
      { type: 'text', speaker: '', text: '"이름이요. 당신이요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신이 부를 때 제가 살아나는 것 같으니까요."' },
      { type: 'text', speaker: '', text: '바람이 멈춘 것처럼 조용해졌다.' },
      { type: 'text', speaker: '', text: '플레이어가 아무 말도 못 했다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '', text: '그냥 웃었다.' },
      { type: 'text', speaker: '', text: '애정이 차올라서.' },
      { type: 'text', speaker: '', text: '그날 밤.' },
      { type: 'text', speaker: '', text: '주작이 플레이어 방 앞에 앉아 있었다.' },
      { type: 'text', speaker: '', text: '불꽃을 아주 작게 켰다.' },
      { type: 'text', speaker: '', text: '손가락 끝에.' },
      { type: 'text', speaker: '', text: '별처럼.' },
      { type: 'text', speaker: '', text: '복도가 조금 밝아졌다.' },
      { type: 'text', speaker: '', text: '당신이 문 열면.' },
      { type: 'text', speaker: '', text: '이 빛이 보일 거다.' },
      { type: 'text', speaker: '', text: '이 빛이 보이면.' },
      { type: 'text', speaker: '', text: '주작이 여기 있다는 걸 알 거다.' },
      { type: 'text', speaker: '', text: '내가 여기 있다는 걸.' },
      { type: 'text', speaker: '', text: '당신 방 앞에.' },
      { type: 'text', speaker: '', text: '기다리고 있다는 걸.' },
      { type: 'text', speaker: '', text: '알 거다.' },
      { type: 'text', speaker: '', text: '문이 열렸다.' },
      { type: 'text', speaker: '', text: '플레이어가 발견했다.' },
      { type: 'text', speaker: '', text: '"왜 여기 있어?"' },
      { type: 'text', speaker: '', text: '"자고 싶어서요."' },
      { type: 'text', speaker: '', text: '"방 있잖아."' },
      { type: 'text', speaker: '', text: '"혼자 있으면 이상해요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"들어와."' },
      { type: 'text', speaker: '', text: '주작이 들어갔다.' },
      { type: 'text', speaker: '', text: '바닥에 이불을 깔고 누웠다.' },
      { type: 'text', speaker: '', text: '조용해졌다.' },
      { type: 'text', speaker: '', text: '밤이 조용했다.' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"왜 여기서 자고 싶어?"' },
      { type: 'text', speaker: '', text: '"당신이 있으니까요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"방에 당신이 없잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신이 없으면 이상한 것 같아요. 자리가 있어도."' },
      { type: 'text', speaker: '', text: '플레이어가 잠시 말이 없었다.' },
      { type: 'text', speaker: '', text: '"언제부터?"' },
      { type: 'text', speaker: '', text: '"...모르겠어요. 어느 순간부터."' },
      { type: 'text', speaker: '', text: '주작이 천장을 봤다.' },
      { type: 'text', speaker: '주작', text: '"이상한 거 알아요. 근데 당신이랑 있는 게 좋아서. 당신이 없으면 이상해서."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"그냥 솔직하게 말하는 게 좋을 것 같아서요."' },
      { type: 'text', speaker: '', text: '플레이어가 천장을 봤다.' },
      { type: 'text', speaker: '', text: '"솔직하게 말해줘서 고마워."' },
      { type: 'text', speaker: '', text: '"화 안 나요?"' },
      { type: 'text', speaker: '', text: '"왜 화 나."' },
      { type: 'text', speaker: '', text: '"이상한 거잖아요."' },
      { type: 'text', speaker: '', text: '"이상하지 않아."' },
      { type: 'text', speaker: '', text: '주작이 옆으로 돌아누웠다.' },
      { type: 'text', speaker: '주작', text: '"당신이 이상하다고 하면 이상한 거고. 안 이상하다고 하면 안 이상한 거예요. 그냥 당신 기준으로."' },
      { type: 'text', speaker: '', text: '"기준이 나야?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '조용해졌다.' },
      { type: 'text', speaker: '', text: '주작이 잠들었다.' },
      { type: 'text', speaker: '', text: '플레이어가 그걸 지켜봤다.' },
      { type: 'text', speaker: '', text: '기준이 나야.' },
      { type: 'text', speaker: '', text: '그 말이 오래 남았다.' },
      { type: 'text', speaker: '', text: '왜소한 신이 문틈으로 봤다.' },
      { type: 'text', speaker: '', text: '자는 주작을.' },
      { type: 'text', speaker: '', text: '지켜보는 플레이어를.' },
      { type: 'text', speaker: '', text: '신이 문틈에서 조금 더 들어오려 했다.' },
      { type: 'text', speaker: '', text: '문이 좁았다.' },
      { type: 'text', speaker: '', text: '비집었다.' },
      { type: 'text', speaker: '', text: '조금 들어왔다.' },
      { type: 'text', speaker: '', text: '플레이어 발치 근처까지.' },
      { type: 'text', speaker: '', text: '거기서 멈췄다.' },
      { type: 'text', speaker: '', text: '그 자리에 쪼그려 앉았다.' },
      { type: 'text', speaker: '', text: '플레이어를 올려봤다.' },
      { type: 'text', speaker: '', text: '플레이어가 내려봤다.' },
      { type: 'text', speaker: '', text: '신이 시선을 피했다.' },
      { type: 'text', speaker: '', text: '그래도 그 자리에 있었다.' },
      { type: 'text', speaker: '', text: '그렇게 며칠이 지났다.' },
      { type: 'text', speaker: '', text: '주작이 플레이어 방 근처에서 자는 날이 늘었다.' },
      { type: 'text', speaker: '', text: '플레이어가 늦게 들어오면 기다렸다.' },
      { type: 'text', speaker: '', text: '훈련 중에 다치면 먼저 들여다봤다.' },
      { type: 'text', speaker: '', text: '이름이 불릴 때마다 웃었다.' },
      { type: 'text', speaker: '', text: '진짜 웃음으로.' },
      { type: 'text', speaker: '', text: '한번은.' },
      { type: 'text', speaker: '', text: '왜소한 신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '주작이 마당에서 불꽃 연습을 하는데.' },
      { type: 'text', speaker: '', text: '신이 구석에서 봤다.' },
      { type: 'text', speaker: '', text: '조용히.' },
      { type: 'text', speaker: '', text: '말없이.' },
      { type: 'text', speaker: '', text: '주작이 뒤를 봤다.' },
      { type: 'text', speaker: '주작', text: '"거기 있었어요?"' },
      { type: 'text', speaker: '', text: '신이 고개를 기울였다.' },
      { type: 'text', speaker: '', text: '"봤어요?"' },
      { type: 'text', speaker: '', text: '신이 아무 말도 안 했다.' },
      { type: 'text', speaker: '', text: '"잘했어요? 제가요?"' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '그러더니.' },
      { type: 'text', speaker: '', text: '아주 조금.' },
      { type: 'text', speaker: '', text: '끄덕이는 것 같았다.' },
      { type: 'text', speaker: '', text: '주작이 웃었다.' },
      { type: 'text', speaker: '주작', text: '"당신한테 잘했다는 소리 들으니까 좋아요."' },
      { type: 'text', speaker: '', text: '신이 딴청을 피웠다.' },
      { type: 'text', speaker: '', text: '주작이 계속 웃었다.' },
      { type: 'text', speaker: '주작', text: '"항상 봐주잖아요. 당신이. 그러면 잘한 거 맞는 거잖아요?"' },
      { type: 'text', speaker: '', text: '신이 슬금슬금 뒤로 물러났다.' },
      { type: 'text', speaker: '', text: '"어디 가요?"' },
      { type: 'text', speaker: '', text: '물러났다.' },
      { type: 'text', speaker: '', text: '"그냥 있어요."' },
      { type: 'text', speaker: '', text: '멈췄다.' },
      { type: 'text', speaker: '', text: '거기 있었다.' },
      { type: 'text', speaker: '', text: '주작이 다시 연습을 시작했다.' },
      { type: 'text', speaker: '', text: '신이 구석에서 봤다.' },
      { type: 'text', speaker: '', text: '그게 기분 좋았다.' },
      { type: 'text', speaker: '', text: '혼자가 아닌 것 같아서.' },
      { type: 'text', speaker: '', text: '당신은 탑에 갔지만.' },
      { type: 'text', speaker: '', text: '신이 여기서 봐줬다.' },
      { type: 'text', speaker: '', text: '그게 좋았다.' },
      { type: 'text', speaker: '', text: '밤.' },
      { type: 'text', speaker: '', text: '주작이 불꽃을 껐다.' },
      { type: 'text', speaker: '', text: '신이 마당에 있었다.' },
      { type: 'text', speaker: '', text: '같이 별을 봤다.' },
      { type: 'text', speaker: '', text: '신은 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '주작도 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '남쪽 하늘.' },
      { type: 'text', speaker: '', text: '주작성.' },
      { type: 'text', speaker: '', text: '"저게 제 별이에요."' },
      { type: 'text', speaker: '', text: '신이 봤다.' },
      { type: 'text', speaker: '', text: '"예쁘죠?"' },
      { type: 'text', speaker: '', text: '신이 봤다.' },
      { type: 'text', speaker: '', text: '"저 별이 제 이름이에요. 주작이라는 이름이요."' },
      { type: 'text', speaker: '주작', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신은 별이 있어요?"' },
      { type: 'text', speaker: '', text: '신이 고개를 기울였다.' },
      { type: 'text', speaker: '', text: '대답이 없었다.' },
      { type: 'text', speaker: '', text: '"있겠죠. 분명히."' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '주작', text: '"이름이 있으면 별이 있는 거잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"당신 이름 아직 모르지만."' },
      { type: 'text', speaker: '', text: '주작이 신을 봤다.' },
      { type: 'text', speaker: '주작', text: '"별은 있을 거예요."' },
      { type: 'text', speaker: '', text: '신이 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '어떤 별인지.' },
      { type: 'text', speaker: '', text: '모르는 것처럼.' },
      { type: 'text', speaker: '', text: '아니.' },
      { type: 'text', speaker: '', text: '알지만.' },
      { type: 'text', speaker: '', text: '지금은 말할 수 없는 것처럼.' },
      { type: 'text', speaker: '', text: '그냥 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '주작이 그 옆에서.' },
      { type: 'text', speaker: '', text: '같이 봤다.' },
      { type: 'text', speaker: '', text: '애정이 그렇게 쌓였다.' },
      { type: 'text', speaker: '', text: '감사에서 믿음. 믿음에서 의존. 의존에서 애정.' },
      { type: 'text', speaker: '', text: '애정이 됐다.' },
      { type: 'text', speaker: '', text: '주작은 그날 밤 잠들기 전에도 플레이어 방 쪽을 한 번 더 봤다. 문이 닫혀 있어도 봤다. 숨소리가 들리는지 귀를 기울였다. 들리지 않으면 가슴이 조여왔다.' },
      { type: 'text', speaker: '', text: '아직은 몰랐다. 그게 뭔지.' },
