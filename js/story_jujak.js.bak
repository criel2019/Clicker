      { type: 'text', speaker: '', text: '"진짜."' },
      { type: 'text', speaker: '', text: '주작이 고개를 숙였다.' },
      { type: 'text', speaker: '주작', text: '"당신은 그냥 받아주는 게 습관이에요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"그것도 좋아요."' },
