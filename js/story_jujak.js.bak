      { type: 'text', speaker: '', text: '"비가 들어."' },
      { type: 'text', speaker: '', text: '"조금요."' },
      { type: 'text', speaker: '', text: '"주작."' },
      { type: 'text', speaker: '', text: '플레이어가 불렀다.' },
      { type: 'text', speaker: '', text: '주작이 창문 쪽에서 눈을 뗐다.' },
      { type: 'text', speaker: '주작', text: '"응."' },
      { type: 'text', speaker: '', text: '"닫아."' },
      { type: 'text', speaker: '', text: '"네."' },
      { type: 'text', speaker: '', text: '창문을 닫았다.' },
      { type: 'text', speaker: '', text: '비가 안 보였다.' },
      { type: 'text', speaker: '', text: '소리만 들렸다.' },
      { type: 'text', speaker: '', text: '"아까 제 이름 불렀잖아요."' },
      { type: 'text', speaker: '', text: '"응?"' },
      { type: 'text', speaker: '', text: '"창문 닫으라고요."' },
      { type: 'text', speaker: '', text: '"불렀지."' },
      { type: 'text', speaker: '', text: '"그래서 닫았어요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"이름 불러야 말 들어?"' },
      { type: 'text', speaker: '', text: '"아니요. 그냥요."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"이름 불러주는 거 좋아서요."' },
      { type: 'text', speaker: '', text: '플레이어가 말이 없었다.' },
      { type: 'text', speaker: '', text: '주작이 창문에서 물방울이 흘러내리는 걸 봤다.' },
      { type: 'text', speaker: '', text: '유리 안쪽에서.' },
      { type: 'text', speaker: '', text: '"하나만 물어봐도 돼요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름을 불러주는 거랑요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름으로 부르는 건 달라요."' },
      { type: 'text', speaker: '', text: '"어떻게?"' },
      { type: 'text', speaker: '', text: '주작이 유리를 손가락으로 짚었다.' },
      { type: 'text', speaker: '', text: '차가운 유리.' },
      { type: 'text', speaker: '', text: '물방울이 손가락 밑에서 갈라졌다.' },
      { type: 'text', speaker: '', text: '"야. 거기. 그런 건 부르는 거예요. 그냥 소리예요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"주작이라고 부르는 건요."' },
      { type: 'text', speaker: '주작', text: '"응."' },
      { type: 'text', speaker: '', text: '"이름이에요. 저를 보고 저한테 말하는 거예요."' },
      { type: 'effect', effect: 'system', text: '【신수 주작의 유대 지수 미세 상승 감지.】' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"그게 달라."' },
      { type: 'text', speaker: '', text: '"달라요."' },
      { type: 'text', speaker: '', text: '주작이 유리에서 손가락을 뗐다.' },
