      { type: 'text', speaker: '', text: '하지만 이름 없이.' },
      { type: 'text', speaker: '', text: '그냥 별.' },
      { type: 'text', speaker: '', text: '이름 없이 있던 별.' },
      { type: 'text', speaker: '', text: '지금은 이름이 있는 별.' },
      { type: 'text', speaker: '', text: '주작이라는.' },
      { type: 'text', speaker: '', text: '주작이 하늘을 봤다.' },
      { type: 'text', speaker: '', text: '별이 빛났다.' },
      { type: 'text', speaker: '', text: '내 이름이 빛난다.' },
      { type: 'text', speaker: '', text: '당신이 불러줘서.' },
      { type: 'text', speaker: '', text: '내 이름이 빛난다.' },
      { type: 'text', speaker: '', text: '주작이 손에서 불꽃을 피웠다.' },
      { type: 'text', speaker: '', text: '아주 작게.' },
      { type: 'text', speaker: '', text: '별처럼.' },
      { type: 'text', speaker: '', text: '작고 뜨겁게.' },
      { type: 'text', speaker: '', text: '저 별이 나고.' },
      { type: 'text', speaker: '', text: '이 불꽃도 나다.' },
      { type: 'text', speaker: '', text: '같은 이름이.' },
      { type: 'text', speaker: '', text: '하늘에서도 빛나고.' },
      { type: 'text', speaker: '', text: '손에서도 빛난다.' },
      { type: 'text', speaker: '', text: '당신 덕분에.' },
      { type: 'text', speaker: '', text: '탑 10층을 앞두고.' },
      { type: 'text', speaker: '', text: '주작이 플레이어에게 말했다.' },
      { type: 'text', speaker: '주작', text: '"혼자 가요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"저도 갈 수 있어요."' },
      { type: 'text', speaker: '', text: '"알아."' },
      { type: 'text', speaker: '', text: '"그런데 혼자요?"' },
      { type: 'text', speaker: '', text: '"이 층은 내가 혼자 가야 해."' },
      { type: 'text', speaker: '', text: '주작이 플레이어를 봤다.' },
      { type: 'text', speaker: '주작', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 생각했다.' },
      { type: 'text', speaker: '', text: '"시스템이 그래."' },
      { type: 'text', speaker: '', text: '"시스템 창이요?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 고개를 끄덕였다.' },
      { type: 'text', speaker: '주작', text: '"그러면."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"금방 돌아와요."' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"혼자 가는 거잖아요. 더 조심해요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"걱정돼?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '주작이 말했다.' },
      { type: 'text', speaker: '주작', text: '"당신이 혼자 가면 걱정돼요. 당신은 저를 걱정하는 것처럼 당신도 다칠 수 있잖아요."' },
      { type: 'text', speaker: '', text: '"..."' },
      { type: 'text', speaker: '', text: '"다치면 제가 처치해줄 수도 없잖아요."' },
      { type: 'text', speaker: '', text: '플레이어가 웃었다.' },
      { type: 'text', speaker: '', text: '"그게 걱정이야?"' },
      { type: 'text', speaker: '', text: '"그게 제일 걱정이에요."' },
      { type: 'text', speaker: '', text: '"처치."' },
      { type: 'text', speaker: '', text: '"응. 당신이 다치면 바로 봐줘야 하는데. 혼자 가면 제가 바로 못 봐주잖아요."' },
      { type: 'text', speaker: '', text: '플레이어가 잠깐 봤다.' },
      { type: 'text', speaker: '', text: '"금방 돌아올게."' },
      { type: 'text', speaker: '', text: '"얼마나요?"' },
      { type: 'text', speaker: '', text: '"모르겠어. 빠르면 밤 안에."' },
      { type: 'text', speaker: '', text: '"밤 안에요?"' },
      { type: 'text', speaker: '', text: '"빠르면."' },
      { type: 'text', speaker: '', text: '주작이 팔짱을 꼈다.' },
      { type: 'text', speaker: '주작', text: '"알겠어요. 그럼 기다릴게요."' },
      { type: 'text', speaker: '', text: '"문 앞에서 기다리지 마."' },
      { type: 'text', speaker: '', text: '"왜요?"' },
      { type: 'text', speaker: '', text: '"추워."' },
      { type: 'text', speaker: '', text: '"안 추워요."' },
      { type: 'text', speaker: '', text: '"밤에 추워."' },
      { type: 'text', speaker: '', text: '"당신이 없으면 더 이상해요."' },
      { type: 'text', speaker: '', text: '플레이어가 주작을 봤다.' },
      { type: 'text', speaker: '', text: '"방에서 기다려."' },
      { type: 'text', speaker: '', text: '"...알겠어요."' },
      { type: 'text', speaker: '', text: '주작이 고개를 끄덕였다.' },
      { type: 'text', speaker: '주작', text: '"하지만 밤 지나서 안 오면 찾으러 갈게요."' },
      { type: 'text', speaker: '', text: '"탑 안까지?"' },
      { type: 'text', speaker: '', text: '"응."' },
      { type: 'text', speaker: '', text: '"거기 못 들어가."' },
      { type: 'text', speaker: '', text: '"그럼 문 앞에서 기다릴게요."' },
      { type: 'text', speaker: '', text: '플레이어가 웃었다.' },
      { type: 'text', speaker: '', text: '"빨리 올게."' },
      { type: 'text', speaker: '', text: '"그래요."' },
      { type: 'text', speaker: '', text: '주작이 봤다.' },
