      { type: 'text', speaker: '', text: '왜소한 신이 마당에 있었다.' },
      { type: 'text', speaker: '', text: '저물녘. 하늘이 붉게 물들던 시간.' },
      { type: 'text', speaker: '', text: '주작이 마당에 나왔다가 봤다.' },
      { type: 'text', speaker: '주작', text: '"어."' },
      { type: 'text', speaker: '', text: '신이 주작을 봤다.' },
      { type: 'text', speaker: '', text: '조용했다.' },
      { type: 'text', speaker: '', text: '작고 동그랬다.' },
      { type: 'text', speaker: '', text: '주작이 신 쪽으로 걸어갔다.' },
      { type: 'text', speaker: '', text: '신이 뒷걸음치지 않았다.' },
      { type: 'text', speaker: '', text: '주작이 앞에 섰다.' },
      { type: 'text', speaker: '', text: '신과 눈이 마주쳤다.' },
      { type: 'text', speaker: '', text: '이상하게 눈이 깊었다.' },
      { type: 'text', speaker: '', text: '깊은 눈인데.' },
      { type: 'text', speaker: '', text: '위협적이지 않았다.' },
