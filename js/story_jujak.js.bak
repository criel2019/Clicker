      { type: 'text', speaker: '', text: '없었다.' },
      { type: 'text', speaker: '', text: '그냥 날았다. 가슴 안쪽이 끌렸다. 그쪽이었다.' },
      { type: 'text', speaker: '', text: '당신이 있는 곳으로.' },
